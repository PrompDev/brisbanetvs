---
/**
 * CustomBlogPost.astro
 * -----------------------------------------------------------------
 * Magazine-style blog layout. Design references:
 *   - NYT Magazine long-form (drop cap, figure captions, pull quotes)
 *   - The Atlantic (full-bleed hero, narrow column, sans pull quotes)
 *   - Stripe Press (generous whitespace, elegant figures)
 *   - Substack / Medium (reading-progress bar, author card, subscribe CTA)
 *
 * This is the ONE layout to iterate on.
 * -----------------------------------------------------------------
 */
import BaseLayout from "~/layouts/BaseLayout.astro";
import { getCollection } from "astro:content";

interface Props {
  frontmatter: {
    title: string;
    description: string;
    heroImage: string;
    heroAlt: string;
    publishDate: Date;
    updatedDate?: Date;
    author: string;
    tags: string[];
    readTime?: number;
    suburb?: string;
    service?: string;
  };
}

const { frontmatter } = Astro.props;
const currentSlug = Astro.url.pathname.replace(/\/$/, "").split("/").pop();

const published = new Date(frontmatter.publishDate).toLocaleDateString(
  "en-AU",
  { day: "numeric", month: "long", year: "numeric" }
);
const updated = frontmatter.updatedDate
  ? new Date(frontmatter.updatedDate).toLocaleDateString("en-AU", {
      day: "numeric",
      month: "long",
      year: "numeric",
    })
  : null;

// Eyebrow: prefer service > suburb > "Feature"
const eyebrow = frontmatter.service ?? frontmatter.suburb ?? "Feature";
const category = frontmatter.service
  ? "Services"
  : frontmatter.suburb
  ? "Locations"
  : "Articles";

// Related posts — same layout, shared tag, exclude current
const all = await getCollection("blog", ({ data }) => !data.draft);
const related = all
  .filter((p) => p.slug !== currentSlug)
  .map((p) => ({
    post: p,
    overlap: p.data.tags.filter((t) => frontmatter.tags.includes(t)).length,
  }))
  .sort((a, b) => b.overlap - a.overlap || b.post.data.publishDate.valueOf() - a.post.data.publishDate.valueOf())
  .slice(0, 3)
  .map((x) => x.post);

// Author initials for avatar
const initials = frontmatter.author
  .split(" ")
  .map((n) => n[0])
  .slice(0, 2)
  .join("");
---
<BaseLayout
  title={frontmatter.title}
  description={frontmatter.description}
  image={frontmatter.heroImage}
>
  {/* Reading progress bar — fills as the user scrolls the article */}
  <div class="cp-progress" aria-hidden="true">
    <div class="cp-progress-fill" id="cp-progress-fill"></div>
  </div>

  <article class="custom-post">
    {/* === HERO === */}
    <header class="cp-hero">
      <img
        class="cp-hero-img"
        src={frontmatter.heroImage}
        alt={frontmatter.heroAlt}
        loading="eager"
        fetchpriority="high"
      />
      <div class="cp-hero-veil"></div>
      <div class="cp-hero-inner">
        <nav class="cp-crumbs" aria-label="Breadcrumb">
          <a href="/">Home</a>
          <span aria-hidden="true">›</span>
          <a href="/blog/">Blog</a>
          <span aria-hidden="true">›</span>
          <span class="cp-crumb-current">{category}</span>
        </nav>
        <p class="cp-eyebrow">{eyebrow}</p>
        <h1 class="cp-title">{frontmatter.title}</h1>
        <p class="cp-dek">{frontmatter.description}</p>
        <div class="cp-byline">
          <span class="cp-avatar" aria-hidden="true">{initials}</span>
          <div class="cp-byline-text">
            <span class="cp-byline-name">{frontmatter.author}</span>
            <span class="cp-byline-meta">
              <time datetime={frontmatter.publishDate.toISOString?.() ?? String(frontmatter.publishDate)}>
                {published}
              </time>
              {frontmatter.readTime && (
                <>
                  <span class="cp-dot">·</span>
                  <span>{frontmatter.readTime} min read</span>
                </>
              )}
            </span>
          </div>
        </div>
      </div>
    </header>

    {/* === BODY === */}
    <div class="cp-body">
      {/* Sticky sidebar: TOC, share, CTA.
          Sidebar stays visible on every post (short or long) so the design
          is consistent. The TOC section inside it hides only when the post
          has no ## headings — Share + CTA always show. */}
      <aside class="cp-toc" aria-label="Article sidebar">
        <div class="cp-toc-section" id="cp-toc-section">
          <p class="cp-toc-label">On this page</p>
          <nav id="cp-toc-nav"></nav>
        </div>

        <div class="cp-share">
          <p class="cp-toc-label">Share</p>
          <div class="cp-share-row">
            <a href="#" data-share="twitter" aria-label="Share on Twitter / X">
              <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M18.244 2H21l-6.52 7.446L22 22h-6.828l-4.49-5.87L5.44 22H2.68l6.987-7.98L2 2h6.98l4.06 5.378L18.244 2zm-1.197 18.188h1.88L7.05 3.72H5.04l12.007 16.468z"/></svg>
            </a>
            <a href="#" data-share="facebook" aria-label="Share on Facebook">
              <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M22 12c0-5.52-4.48-10-10-10S2 6.48 2 12c0 4.84 3.44 8.87 8 9.8V15H8v-3h2V9.5C10 7.57 11.57 6 13.5 6H16v3h-2c-.55 0-1 .45-1 1v2h3v3h-3v6.95c5.05-.5 9-4.76 9-9.95z"/></svg>
            </a>
            <a href="#" data-share="linkedin" aria-label="Share on LinkedIn">
              <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M20.45 20.45h-3.55v-5.57c0-1.33-.02-3.04-1.85-3.04-1.85 0-2.14 1.45-2.14 2.94v5.67H9.36V9h3.41v1.56h.05c.48-.9 1.64-1.85 3.37-1.85 3.6 0 4.27 2.37 4.27 5.46v6.28zM5.34 7.43c-1.14 0-2.06-.93-2.06-2.07 0-1.14.92-2.06 2.06-2.06 1.14 0 2.07.92 2.07 2.06 0 1.14-.93 2.07-2.07 2.07zM7.12 20.45H3.56V9h3.56v11.45zM22.22 0H1.77C.8 0 0 .77 0 1.73v20.54C0 23.23.8 24 1.77 24h20.45c.98 0 1.78-.77 1.78-1.73V1.73C24 .77 23.2 0 22.22 0z"/></svg>
            </a>
            <a href="#" data-share="copy" aria-label="Copy link">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/></svg>
            </a>
          </div>
        </div>

        <a class="cp-cta-card" href="/book/">
          <p class="cp-cta-eyebrow">Need this done?</p>
          <p class="cp-cta-title">Book a same-day Brisbane TV install</p>
          <span class="cp-cta-arrow">→</span>
        </a>
      </aside>

      <div class="cp-article" id="cp-article">
        {/* Hero caption — sits visually over the hero border */}
        <figcaption class="cp-hero-caption">
          <strong>Above:</strong> {frontmatter.heroAlt} · Photo: Brisbane&nbsp;TVs
        </figcaption>

        {/* Post content — markdown renders here */}
        <slot />

        {/* === POST FOOTER === */}
        <footer class="cp-post-foot">
          {frontmatter.tags.length > 0 && (
            <div class="cp-tags" aria-label="Tags">
              {frontmatter.tags.map((t) => (
                <a class="cp-tag" href={`/blog/?tag=${encodeURIComponent(t)}`}>#{t}</a>
              ))}
            </div>
          )}
          {updated && (
            <p class="cp-updated">Last updated {updated}</p>
          )}

          {/* Author card — bio + social */}
          <section class="cp-author-card">
            <p class="cp-author-label">Written by</p>
            <div class="cp-author-main">
              <span class="cp-author-avatar" aria-hidden="true">{initials}</span>
              <div class="cp-author-body">
                <p class="cp-author-name">{frontmatter.author}</p>
                <p class="cp-author-bio">
                  The Brisbane TVs field team installs TVs, soundbars, and home theatres across 109 Brisbane suburbs. If you've got a question about your space, call <a href="tel:1300312271">1300 312 271</a> — the installers answer the phone.
                </p>
              </div>
            </div>
          </section>

          {/* Newsletter card */}
          <section class="cp-newsletter">
            <div class="cp-newsletter-text">
              <p class="cp-newsletter-eyebrow">Brisbane-only TV install tips</p>
              <p class="cp-newsletter-title">One short email a month.</p>
              <p class="cp-newsletter-copy">New install guides, pricing updates and mount-compatibility breakdowns. No spam — unsubscribe any time.</p>
            </div>
            <form class="cp-newsletter-form" onsubmit="event.preventDefault(); this.querySelector('button').textContent='Subscribed ✓';" aria-label="Newsletter signup">
              <input type="email" placeholder="you@email.com" aria-label="Email address" required />
              <button type="submit">Subscribe</button>
            </form>
          </section>

          {/* Final CTA */}
          <div class="cp-endcard">
            <div>
              <p class="cp-endcard-eyebrow">Ready to book?</p>
              <p class="cp-endcard-title">Same-day TV mounting from $179</p>
              <p class="cp-endcard-copy">
                Brisbane's highest-rated installers. 5-year warranty. Covering 109 suburbs across Greater Brisbane.
              </p>
            </div>
            <a class="cp-endcard-btn" href="/book/">Book now →</a>
          </div>
        </footer>
      </div>
    </div>

    {/* === RELATED POSTS === */}
    {related.length > 0 && (
      <section class="cp-related">
        <div class="cp-related-inner">
          <header class="cp-related-head">
            <p class="cp-related-eyebrow">Keep reading</p>
            <h2 class="cp-related-title">More from the Brisbane TVs blog</h2>
          </header>
          <div class="cp-related-grid">
            {related.map((p) => (
              <a class="cp-related-card" href={`/blog/${p.slug}/`}>
                <div class="cp-related-img-wrap">
                  <img src={p.data.heroImage} alt={p.data.heroAlt} loading="lazy" />
                </div>
                <div class="cp-related-body">
                  <p class="cp-related-eyebrow-sm">
                    {p.data.service ?? p.data.suburb ?? "Article"}
                  </p>
                  <h3 class="cp-related-h3">{p.data.title}</h3>
                  <p class="cp-related-dek">{p.data.description}</p>
                  <p class="cp-related-meta">
                    {new Date(p.data.publishDate).toLocaleDateString("en-AU", { day: "numeric", month: "short", year: "numeric" })}
                    {p.data.readTime && <> · {p.data.readTime} min read</>}
                  </p>
                </div>
              </a>
            ))}
          </div>
        </div>
      </section>
    )}
  </article>

  {/* Interactive wiring: progress bar, TOC, share, copy-link */}
  <script>
    (function () {
      const article = document.getElementById("cp-article");
      const nav = document.getElementById("cp-toc-nav");
      const progressFill = document.getElementById("cp-progress-fill");
      if (!article) return;

      // --- Reading progress bar ---
      if (progressFill) {
        const onScroll = () => {
          const rect = article.getBoundingClientRect();
          const scrolled = Math.max(0, -rect.top);
          const total = Math.max(1, rect.height - window.innerHeight);
          const pct = Math.min(100, (scrolled / total) * 100);
          (progressFill as HTMLElement).style.width = pct + "%";
        };
        window.addEventListener("scroll", onScroll, { passive: true });
        window.addEventListener("resize", onScroll);
        onScroll();
      }

      // --- Auto-wrap first-paragraph drop cap ---
      // Only apply the oversized drop cap when the first paragraph has enough
      // text to carry it. A 4-char body like "test" turns into a huge "t"
      // with 3 orphan letters wrapping awkwardly around it, which looks
      // broken rather than editorial.
      const firstP = article.querySelector<HTMLElement>("p");
      if (firstP && (firstP.textContent || "").trim().length >= 40) {
        firstP.classList.add("cp-lede");
      }

      // --- Wrap markdown images as figures with captions from alt text ---
      article.querySelectorAll<HTMLImageElement>("p > img:only-child").forEach((img) => {
        const p = img.parentElement;
        if (!p) return;
        const fig = document.createElement("figure");
        fig.className = "cp-figure";
        const imgClone = img.cloneNode(true) as HTMLImageElement;
        fig.appendChild(imgClone);
        if (img.alt) {
          const cap = document.createElement("figcaption");
          cap.textContent = img.alt;
          fig.appendChild(cap);
        }
        p.replaceWith(fig);
      });

      // --- Build TOC from h2s ---
      if (nav) {
        const headings = article.querySelectorAll<HTMLElement>("h2");
        if (headings.length === 0) {
          // No headings → hide only the TOC section. Share + CTA stay visible
          // so the sidebar still anchors the layout and every post looks
          // consistent, short or long.
          const tocSection = document.getElementById("cp-toc-section");
          if (tocSection) tocSection.style.display = "none";
        } else {
          const ul = document.createElement("ul");
          ul.className = "cp-toc-list";
          headings.forEach((h, i) => {
            if (!h.id) {
              h.id =
                "s-" +
                (h.textContent || "section-" + i)
                  .toLowerCase()
                  .replace(/[^a-z0-9]+/g, "-")
                  .replace(/^-+|-+$/g, "");
            }
            const li = document.createElement("li");
            const a = document.createElement("a");
            a.href = "#" + h.id;
            a.textContent = h.textContent || "";
            li.appendChild(a);
            ul.appendChild(li);
          });
          nav.appendChild(ul);

          const links = nav.querySelectorAll<HTMLAnchorElement>("a");
          const obs = new IntersectionObserver(
            (entries) => {
              entries.forEach((e) => {
                if (e.isIntersecting) {
                  links.forEach((l) => l.classList.remove("is-active"));
                  const active = nav.querySelector<HTMLAnchorElement>(
                    `a[href="#${e.target.id}"]`
                  );
                  if (active) active.classList.add("is-active");
                }
              });
            },
            { rootMargin: "-20% 0px -70% 0px" }
          );
          headings.forEach((h) => obs.observe(h));
        }
      }

      // --- Share buttons ---
      document.querySelectorAll<HTMLAnchorElement>("[data-share]").forEach((btn) => {
        btn.addEventListener("click", (e) => {
          e.preventDefault();
          const kind = btn.dataset.share;
          const url = encodeURIComponent(location.href);
          const title = encodeURIComponent(document.title);
          if (kind === "twitter") {
            window.open(`https://twitter.com/intent/tweet?url=${url}&text=${title}`, "_blank", "noopener");
          } else if (kind === "facebook") {
            window.open(`https://www.facebook.com/sharer/sharer.php?u=${url}`, "_blank", "noopener");
          } else if (kind === "linkedin") {
            window.open(`https://www.linkedin.com/sharing/share-offsite/?url=${url}`, "_blank", "noopener");
          } else if (kind === "copy") {
            navigator.clipboard?.writeText(location.href);
            const orig = btn.getAttribute("aria-label");
            btn.setAttribute("aria-label", "Link copied!");
            setTimeout(() => btn.setAttribute("aria-label", orig || ""), 1500);
          }
        });
      });
    })();
  </script>

  <style is:global>
    /* ============================================================
       CustomBlogPost — magazine-style blog article
       Tokens follow the Brisbane TVs palette.
       ============================================================ */
    .custom-post {
      --cp-ink: #131619;
      --cp-ink-soft: #4a5056;
      --cp-muted: #7c848c;
      --cp-line: #e5e7ea;
      --cp-bg-soft: #f7f7f5;
      --cp-accent: #d4a44a;
      --cp-accent-deep: #b8872f;
      --cp-highlight: #fff7e1;
      --cp-serif: "Noto Serif", Georgia, "Times New Roman", serif;
      --cp-sans: "Inter", -apple-system, BlinkMacSystemFont, sans-serif;
      color: var(--cp-ink);
      font-family: var(--cp-sans);
      background: #fff;
    }

    /* ---- Reading progress bar ---- */
    .cp-progress {
      position: fixed;
      top: 0;
      left: 0;
      right: 0;
      height: 3px;
      background: transparent;
      z-index: 100;
      pointer-events: none;
    }
    .cp-progress-fill {
      height: 100%;
      width: 0%;
      background: var(--cp-accent, #d4a44a);
      transition: width 0.08s linear;
    }

    /* ---- HERO ---- */
    .custom-post .cp-hero {
      position: relative;
      min-height: clamp(480px, 70vh, 720px);
      color: #fff;
      display: flex;
      align-items: flex-end;
      overflow: hidden;
    }
    .custom-post .cp-hero-img {
      position: absolute;
      inset: 0;
      width: 100%;
      height: 100%;
      object-fit: cover;
      z-index: 0;
    }
    .custom-post .cp-hero-veil {
      position: absolute;
      inset: 0;
      background: linear-gradient(180deg, rgba(0,0,0,0.55) 0%, rgba(0,0,0,0.25) 45%, rgba(0,0,0,0.85) 100%);
      z-index: 1;
    }
    .custom-post .cp-hero-inner {
      position: relative;
      z-index: 2;
      max-width: 880px;
      margin: 0 auto;
      padding: 8rem 1.5rem 3.5rem;
      width: 100%;
    }
    .custom-post .cp-crumbs {
      display: flex;
      align-items: center;
      gap: 0.5rem;
      font-size: 0.78rem;
      color: rgba(255, 255, 255, 0.75);
      margin-bottom: 1.25rem;
      letter-spacing: 0.04em;
    }
    .custom-post .cp-crumbs a {
      color: rgba(255, 255, 255, 0.85);
      transition: color 0.15s;
    }
    .custom-post .cp-crumbs a:hover {
      color: #fff;
    }
    .custom-post .cp-crumb-current {
      color: #fff;
      font-weight: 500;
    }
    .custom-post .cp-eyebrow {
      font-family: var(--cp-sans);
      font-size: 0.78rem;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: var(--cp-accent);
      margin: 0 0 1rem;
      font-weight: 600;
    }
    .custom-post .cp-title {
      font-family: var(--cp-serif);
      font-weight: 600;
      font-size: clamp(2rem, 5vw, 3.8rem);
      line-height: 1.08;
      letter-spacing: -0.015em;
      margin: 0 0 1.25rem;
      color: #fff;
      max-width: 900px;
    }
    .custom-post .cp-dek {
      font-family: var(--cp-serif);
      font-size: clamp(1.05rem, 1.6vw, 1.3rem);
      line-height: 1.55;
      color: rgba(255, 255, 255, 0.92);
      max-width: 680px;
      margin: 0 0 2rem;
      font-style: italic;
    }
    .custom-post .cp-byline {
      display: flex;
      align-items: center;
      gap: 0.75rem;
    }
    .custom-post .cp-avatar {
      width: 40px;
      height: 40px;
      border-radius: 50%;
      background: var(--cp-accent);
      color: #131619;
      display: inline-grid;
      place-items: center;
      font-size: 0.78rem;
      font-weight: 700;
      letter-spacing: 0.04em;
    }
    .custom-post .cp-byline-text {
      display: flex;
      flex-direction: column;
      gap: 0.1rem;
    }
    .custom-post .cp-byline-name {
      color: #fff;
      font-weight: 600;
      font-size: 0.92rem;
    }
    .custom-post .cp-byline-meta {
      color: rgba(255, 255, 255, 0.72);
      font-size: 0.82rem;
    }
    .custom-post .cp-dot {
      margin: 0 0.4rem;
      opacity: 0.5;
    }

    /* ---- BODY 2-col grid ---- */
    .custom-post .cp-body {
      max-width: 1180px;
      margin: 0 auto;
      padding: 4rem 1.5rem 5rem;
      display: grid;
      grid-template-columns: 240px 1fr;
      gap: 4rem;
      align-items: start;
    }

    /* ---- TOC rail ---- */
    .custom-post .cp-toc {
      position: sticky;
      top: 5.5rem;
      font-size: 0.88rem;
    }
    .custom-post .cp-toc-label {
      font-family: var(--cp-sans);
      font-size: 0.68rem;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: var(--cp-muted);
      margin: 0 0 0.9rem;
      font-weight: 600;
    }
    .custom-post .cp-toc-list {
      list-style: none;
      padding: 0;
      margin: 0 0 2rem;
      border-left: 1px solid var(--cp-line);
    }
    .custom-post .cp-toc-list li { margin: 0; }
    .custom-post .cp-toc-list a {
      display: block;
      padding: 0.4rem 0 0.4rem 0.9rem;
      color: var(--cp-ink-soft);
      font-size: 0.85rem;
      border-left: 2px solid transparent;
      margin-left: -1px;
      line-height: 1.4;
      transition: color 0.15s, border-color 0.15s;
    }
    .custom-post .cp-toc-list a:hover { color: var(--cp-ink); }
    .custom-post .cp-toc-list a.is-active {
      color: var(--cp-ink);
      border-left-color: var(--cp-accent);
      font-weight: 500;
    }

    .custom-post .cp-share { margin: 0 0 2rem; }
    .custom-post .cp-share-row {
      display: flex;
      gap: 0.5rem;
      flex-wrap: wrap;
    }
    .custom-post .cp-share-row a {
      width: 34px;
      height: 34px;
      border: 1px solid var(--cp-line);
      border-radius: 50%;
      display: inline-grid;
      place-items: center;
      color: var(--cp-ink-soft);
      transition: background 0.15s, color 0.15s, border-color 0.15s;
    }
    .custom-post .cp-share-row a:hover {
      background: var(--cp-ink);
      color: #fff;
      border-color: var(--cp-ink);
    }
    .custom-post .cp-share-row svg { width: 15px; height: 15px; }

    .custom-post .cp-cta-card {
      display: block;
      position: relative;
      background: var(--cp-bg-soft);
      border: 1px solid var(--cp-line);
      padding: 1rem 2.25rem 1rem 1rem;
      border-radius: 8px;
      color: var(--cp-ink);
      transition: border-color 0.15s, background 0.15s, transform 0.15s;
    }
    .custom-post .cp-cta-card:hover {
      border-color: var(--cp-accent);
      background: #fff;
      transform: translateY(-1px);
    }
    .custom-post .cp-cta-eyebrow {
      font-size: 0.68rem;
      letter-spacing: 0.16em;
      text-transform: uppercase;
      color: var(--cp-accent-deep);
      margin: 0 0 0.3rem;
      font-weight: 700;
    }
    .custom-post .cp-cta-title {
      margin: 0;
      font-size: 0.9rem;
      font-weight: 500;
      line-height: 1.35;
    }
    .custom-post .cp-cta-arrow {
      position: absolute;
      right: 0.95rem;
      top: 50%;
      transform: translateY(-50%);
      color: var(--cp-accent);
      font-size: 1.15rem;
    }

    /* ---- ARTICLE body typography ---- */
    .custom-post .cp-article {
      font-family: var(--cp-serif);
      font-size: 1.14rem;

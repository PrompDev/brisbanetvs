---
import BaseLayout from "~/layouts/BaseLayout.astro";
import { getCollection } from "astro:content";

/**
 * Only render TV cross-links whose slugs have actual product-collection
 * entries — stops the "Compatible TVs" list from 404-ing.
 */
const __existingProducts = new Set(
  (await getCollection("products", ({ data }) => !data.draft)).map((e) => e.slug),
);

/**
 * MountPage — TV wall-mount detail page for the `mounts` collection.
 *
 * Layout pattern (mirrors LocationPage/New Farm — the canonical design):
 *   1. Full-bleed banner strip with the brand + model overlay
 *   2. 1720px container with a split hero (left: breadcrumbs + copy +
 *      price card; right: mount image stretched to the left's height)
 *   3. Full-width horizontal rule separator
 *   4. 70% / 380px article grid with a sticky "Request a quote" sidebar
 *   5. Dark foot-CTA strip
 *
 * Shares the schema.org/Product backbone with ProductPage but leans on
 * mount-specific additionalProperty fields (VESA range, weight rating,
 * motion specs) — the dimensions installers actually compare on.
 *
 * SEO payload:
 *   - schema.org/Product JSON-LD with Offer
 *   - additionalProperty entries for every populated mount spec
 *   - aggregateRating when present
 *   - BreadcrumbList JSON-LD
 */

interface Props {
  frontmatter: {
    title: string;
    description: string;
    heroImage: string;
    heroAlt: string;
    publishDate: Date;
    updatedDate?: Date;
    brand: string;
    model: string;
    sku?: string;
    mountType: "fixed" | "tilt" | "full-motion" | "ceiling" | "outdoor";
    priceAud: number;
    priceWas?: number;
    availability: "InStock" | "OutOfStock" | "PreOrder";
    minScreenInches: number;
    maxScreenInches: number;
    maxWeightKg: number;
    vesaMin?: string;
    vesaMax?: string;
    tiltDegrees?: number;
    swivelDegrees?: number;
    extensionMm?: number;
    profileMm?: number;
    finish?: string;
    pros: string[];
    cons: string[];
    rating?: number;
    reviewCount?: number;
    affiliateUrl?: string;
    compatibleTvs: string[];
    tags: string[];
  };
}

const { frontmatter } = Astro.props;
const pageUrl = new URL(Astro.url.pathname, Astro.site).toString();
const businessUrl = new URL("/", Astro.site).toString();

const filteredCompatibleTvs = frontmatter.compatibleTvs.filter((t) => __existingProducts.has(t));

type Spec = { name: string; value: string };
const compat: Spec[] = [];
compat.push({
  name: "Screen size range",
  value: `${frontmatter.minScreenInches}" – ${frontmatter.maxScreenInches}"`,
});
compat.push({ name: "Max TV weight", value: `${frontmatter.maxWeightKg} kg` });
if (frontmatter.vesaMin || frontmatter.vesaMax) {
  const vesaRange = [frontmatter.vesaMin, frontmatter.vesaMax].filter(Boolean).join(" – ");
  compat.push({ name: "VESA pattern", value: vesaRange });
}

const motion: Spec[] = [];
if (typeof frontmatter.tiltDegrees === "number") motion.push({ name: "Tilt", value: `±${frontmatter.tiltDegrees}°` });
if (typeof frontmatter.swivelDegrees === "number") motion.push({ name: "Swivel", value: `±${frontmatter.swivelDegrees}°` });
if (typeof frontmatter.extensionMm === "number") motion.push({ name: "Extension", value: `${frontmatter.extensionMm} mm` });
if (typeof frontmatter.profileMm === "number") motion.push({ name: "Profile (folded)", value: `${frontmatter.profileMm} mm` });
if (frontmatter.finish) motion.push({ name: "Finish", value: frontmatter.finish });

const allSpecs = [...compat, ...motion];

const discountPct =
  frontmatter.priceWas && frontmatter.priceWas > frontmatter.priceAud
    ? Math.round((1 - frontmatter.priceAud / frontmatter.priceWas) * 100)
    : null;

const mountTypeLabel = {
  fixed: "Fixed mount",
  tilt: "Tilt mount",
  "full-motion": "Full-motion mount",
  ceiling: "Ceiling mount",
  outdoor: "Outdoor mount",
}[frontmatter.mountType];

const productLd: Record<string, any> = {
  "@context": "https://schema.org",
  "@type": "Product",
  name: frontmatter.title,
  description: frontmatter.description,
  image: new URL(frontmatter.heroImage, Astro.site).toString(),
  brand: { "@type": "Brand", name: frontmatter.brand },
  model: frontmatter.model,
  ...(frontmatter.sku ? { sku: frontmatter.sku, mpn: frontmatter.sku } : {}),
  category: `TV Wall Mount / ${mountTypeLabel}`,
  offers: {
    "@type": "Offer",
    price: frontmatter.priceAud,
    priceCurrency: "AUD",
    availability: `https://schema.org/${frontmatter.availability}`,
    url: frontmatter.affiliateUrl ?? pageUrl,
    seller: { "@type": "Organization", name: "Brisbane TVs" },
  },
  ...(typeof frontmatter.rating === "number" && typeof frontmatter.reviewCount === "number" && frontmatter.reviewCount > 0
    ? {
        aggregateRating: {
          "@type": "AggregateRating",
          ratingValue: frontmatter.rating,
          reviewCount: frontmatter.reviewCount,
          bestRating: 5,
          worstRating: 0,
        },
      }
    : {}),
  additionalProperty: allSpecs.map((s) => ({
    "@type": "PropertyValue",
    name: s.name,
    value: s.value,
  })),
};

const breadcrumbLd = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    { "@type": "ListItem", position: 1, name: "Home", item: businessUrl },
    {
      "@type": "ListItem",
      position: 2,
      name: "Wall mounts",
      item: new URL("/mounts/", Astro.site).toString(),
    },
    { "@type": "ListItem", position: 3, name: frontmatter.title, item: pageUrl },
  ],
};

const availLabel = {
  InStock: "In stock",
  OutOfStock: "Out of stock",
  PreOrder: "Pre-order",
}[frontmatter.availability];

// Banner title — short & punchy.
const bannerLabel = `${frontmatter.brand} ${frontmatter.model}`;
---
<BaseLayout
  title={frontmatter.title}
  description={frontmatter.description}
  image={frontmatter.heroImage}
  canonical={pageUrl}
>
  <script type="application/ld+json" set:html={JSON.stringify(productLd)} />
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbLd)} />

  {/* Full-bleed banner — brand + model overlay. Same chrome as the other
      detail-page layouts (Locations / Services / Products). */}
  <section class="mnt-banner">
    <img class="mnt-banner-img" src={frontmatter.heroImage} alt="" aria-hidden="true" />
    <div class="mnt-banner-inner">
      <p class="mnt-banner-title">{bannerLabel}</p>
    </div>
  </section>

  <article class="mnt">
    {/* Split hero: breadcrumbs + copy + price card on the left;
        mount image stretched to match on the right. */}
    <div class="mnt-split">
      <div class="mnt-split-left">
        <nav class="mnt-crumbs" aria-label="Breadcrumb">
          <a href="/">Home</a>
          <span aria-hidden="true">›</span>
          <a href="/mounts/">Wall mounts</a>
          <span aria-hidden="true">›</span>
          <span class="mnt-crumbs-current">{frontmatter.brand} {frontmatter.model}</span>
        </nav>
        <header class="mnt-hero-copy">
          <p class="mnt-brand">{frontmatter.brand} · {mountTypeLabel}</p>
          <h1>{frontmatter.title}</h1>
          <p class="mnt-model">Model: {frontmatter.model}{frontmatter.sku && ` · SKU ${frontmatter.sku}`}</p>

          {typeof frontmatter.rating === "number" && typeof frontmatter.reviewCount === "number" && frontmatter.reviewCount > 0 && (
            <div class="mnt-rating" aria-label={`Rated ${frontmatter.rating} out of 5 based on ${frontmatter.reviewCount} reviews`}>
              <span class="mnt-stars" aria-hidden="true">
                {"★".repeat(Math.round(frontmatter.rating))}{"☆".repeat(5 - Math.round(frontmatter.rating))}
              </span>
              <span class="mnt-rating-n">{frontmatter.rating.toFixed(1)} ({frontmatter.reviewCount} reviews)</span>
            </div>
          )}

          <div class="mnt-price-card">
            <div class="mnt-price-row">
              <span class="mnt-price">${frontmatter.priceAud.toLocaleString("en-AU")}</span>
              {frontmatter.priceWas && frontmatter.priceWas > frontmatter.priceAud && (
                <span class="mnt-price-was">${frontmatter.priceWas.toLocaleString("en-AU")}</span>
              )}
              {discountPct && <span class="mnt-price-save">Save {discountPct}%</span>}
            </div>
            <div class={`mnt-avail mnt-avail-${frontmatter.availability.toLowerCase()}`}>
              <span class="mnt-avail-dot" aria-hidden="true"></span>
              {availLabel}
            </div>
            <div class="mnt-buy-cta">
              {frontmatter.affiliateUrl ? (
                <a class="mnt-btn mnt-btn-primary" href={frontmatter.affiliateUrl} rel="sponsored noopener" target="_blank">
                  Check latest price
                </a>
              ) : (
                <a class="mnt-btn mnt-btn-primary" href="tel:0432145101">Enquire now</a>
              )}
              <a class="mnt-btn mnt-btn-ghost" href="/services/tv-wall-mounting/">Get it installed</a>
            </div>
          </div>

          <p class="mnt-lede">{frontmatter.description}</p>
        </header>
      </div>
      {/* Wrapper owns the grid cell so the mount image (absolutely-positioned
          inside it) can't push the row taller than the left column. */}
      <div class="mnt-split-img-wrap">
        <img class="mnt-split-img" src={frontmatter.heroImage} alt={frontmatter.heroAlt} loading="eager" />
      </div>
    </div>

    {/* Full-width divider between split hero and article grid. */}
    <hr class="mnt-section-divider" />

    {/* 70% main / 380px sticky-sidebar article grid. */}
    <div class="mnt-article-grid">
      <div class="mnt-article-main">
        <section class="mnt-compat" aria-labelledby="mnt-compat-h">
          <h2 id="mnt-compat-h">Will it fit your TV?</h2>
          <table class="mnt-spec-table">
            <tbody>
              {compat.map((s) => (
                <tr><th scope="row">{s.name}</th><td>{s.value}</td></tr>
              ))}
            </tbody>
          </table>
        </section>

        {motion.length > 0 && (
          <section class="mnt-motion" aria-labelledby="mnt-motion-h">
            <h2 id="mnt-motion-h">Motion &amp; geometry</h2>
            <table class="mnt-spec-table">
              <tbody>
                {motion.map((s) => (
                  <tr><th scope="row">{s.name}</th><td>{s.value}</td></tr>
                ))}
              </tbody>
            </table>
          </section>
        )}

        {(frontmatter.pros.length > 0 || frontmatter.cons.length > 0) && (
          <section class="mnt-review" aria-labelledby="mnt-review-h">
            <h2 id="mnt-review-h">Our installer verdict</h2>
            <div class="mnt-proscons">
              {frontmatter.pros.length > 0 && (
                <div class="mnt-pros">
                  <h3>Pros</h3>
                  <ul>{frontmatter.pros.map((p) => (<li>{p}</li>))}</ul>
                </div>
              )}
              {frontmatter.cons.length > 0 && (
                <div class="mnt-cons">
                  <h3>Cons</h3>
                  <ul>{frontmatter.cons.map((c) => (<li>{c}</li>))}</ul>
                </div>
              )}
            </div>
          </section>
        )}

        <section class="mnt-body prose">
          <slot />
        </section>

        {filteredCompatibleTvs.length > 0 && (
          <section class="mnt-tvs" aria-labelledby="mnt-tvs-h">
            <h2 id="mnt-tvs-h">Compatible TVs in our catalogue</h2>
            <ul class="mnt-tv-grid">
              {filteredCompatibleTvs.map((t) => (
                <li>
                  <a class="mnt-tv-card" href={`/products/${t}/`}>
                    <span>{t.replace(/-/g, " ")}</span>
                    <span aria-hidden="true">→</span>
                  </a>
                </li>
              ))}
            </ul>
          </section>
        )}
      </div>

      <aside class="mnt-sidebar" aria-label="Quote sidebar">
        <div class="mnt-book-card">
          <p class="mnt-book-eyebrow">Brisbane TVs · Wall mount</p>
          <h3 class="mnt-book-title">Request a quote on this {mountTypeLabel.toLowerCase()}</h3>
          <p class="mnt-book-desc">We supply, fit, and warrant every mount we install. Tell us your TV model and wall type — we'll confirm fit.</p>
          <ul class="mnt-book-list">
            <li><span class="mnt-book-k">Price</span><span>${frontmatter.priceAud.toLocaleString("en-AU")}</span></li>
            <li><span class="mnt-book-k">Availability</span><span>{availLabel}</span></li>
            <li><span class="mnt-book-k">Fits</span><span>{frontmatter.minScreenInches}"–{frontmatter.maxScreenInches}"</span></li>
            <li><span class="mnt-book-k">Max weight</span><span>{frontmatter.maxWeightKg} kg</span></li>
          </ul>
          <a class="mnt-book-btn" href="tel:0432145101">Request a quote →</a>
          <a class="mnt-book-link" href="tel:+61700000000">or call our dispatch line</a>
        </div>
      </aside>
    </div>

    <aside class="mnt-foot-cta">
      <div>
        <h2>Not sure if it fits?</h2>
        <p>Send us your TV model and we'll confirm compatibility + install it for you.</p>
      </div>
      <a class="mnt-btn mnt-btn-primary" href="tel:0432145101">Ask an installer</a>
    </aside>
  </article>
</BaseLayout>

<style is:global>
  /* Full-bleed banner — escapes any parent container via the 100vw margin
     trick, same pattern as the other detail-page layouts. */
  .mnt-banner { position: relative; margin-left: calc(50% - 50vw); margin-right: calc(50% - 50vw); width: 100vw; height: clamp(240px, 32vh, 420px); overflow: hidden; background: #131619; }
  .mnt-banner-img { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; object-position: center; }
  .mnt-banner::after { content: ""; position: absolute; inset: 0; background: linear-gradient(90deg, rgba(0,0,0,0.55) 0%, rgba(0,0,0,0.35) 35%, rgba(0,0,0,0) 70%); pointer-events: none; }
  .mnt-banner-inner { position: relative; z-index: 1; width: 100%; max-width: 1200px; height: 100%; margin: 0 auto; padding: 0 24px; display: flex; align-items: center; }
  @media (min-width: 1201px) {
    .mnt-banner-inner { width: 90%; max-width: 1720px; padding: 0; }
  }
  .mnt-banner-title { margin: 0; color: #fff; font-weight: 400; font-size: clamp(2.5rem, 6vw, 5rem); letter-spacing: 0.02em; text-transform: uppercase; line-height: 1; text-shadow: 0 2px 18px rgba(0,0,0,0.35); }

  /* Outer container mirrors site header (90% / 1720px cap). */
  .mnt { width: 100%; max-width: 1200px; margin: 0 auto; padding: 2rem 24px 4rem; }
  @media (min-width: 1201px) {
    .mnt { width: 90%; max-width: 1720px; padding: 2rem 0 4rem; }
  }
  .mnt-crumbs { font-size: 0.85rem; color: #5a6271; display: flex; gap: 0.4rem; flex-wrap: wrap; margin-bottom: 3.5rem; }
  .mnt-crumbs a { color: #5a6271; text-decoration: none; }
  .mnt-crumbs a:hover { color: #131619; text-decoration: underline; }
  .mnt-crumbs-current { color: #131619; font-weight: 500; }

  /* Split hero: left = copy + price card; right = image stretched. */
  .mnt-split { display: grid; grid-template-columns: minmax(0, 1.1fr) minmax(0, 1fr); gap: 2.5rem; align-items: stretch; margin-bottom: 2rem; }
  .mnt-split-left { display: flex; flex-direction: column; min-width: 0; }
  .mnt-split-img-wrap { position: relative; width: 100%; height: 100%; min-height: 0; border-radius: 10px; overflow: hidden; background: #fafbfc; }
  .mnt-split-img { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; display: block; }
  @media (max-width: 820px) {
    .mnt-split { grid-template-columns: 1fr; }
    .mnt-split-img-wrap { position: relative; height: auto; aspect-ratio: 1/1; }
  }
  .mnt-hero-copy { display: flex; flex-direction: column; justify-content: flex-start; margin-bottom: 4rem; }
  .mnt-brand { text-transform: uppercase; letter-spacing: 0.08em; font-size: 0.8rem; color: #8a94a6; margin: 0 0 0.5rem; font-weight: 600; }
  /* H1 scale aligned with the rest of the site family (.idx-hero-copy,
     .svc-hero-copy, .loc-hero-copy) so mount detail pages don't read
     visually smaller than their sibling silos. */
  .mnt-hero-copy h1 { font-size: clamp(1.8rem, 3.2vw, 2.6rem); line-height: 1.15; margin: 0 0 0.35rem; }
  .mnt-model { color: #5a6271; font-size: 0.85rem; margin: 0 0 1rem; }

  .mnt-rating { display: flex; align-items: center; gap: 0.5rem; margin-bottom: 1rem; }
  .mnt-stars { color: #f59e0b; letter-spacing: 0.08em; }
  .mnt-rating-n { color: #5a6271; font-size: 0.85rem; }

  .mnt-price-card { background: #fafbfc; border: 1px solid #eef0f3; border-radius: 10px; padding: 1.25rem; margin-bottom: 1.25rem; }
  .mnt-price-row { display: flex; align-items: baseline; gap: 0.75rem; flex-wrap: wrap; margin-bottom: 0.5rem; }
  .mnt-price { font-size: 1.8rem; font-weight: 700; color: #131619; }
  .mnt-price-was { color: #8a94a6; text-decoration: line-through; font-size: 1rem; }
  .mnt-price-save { background: #16a34a; color: #fff; padding: 0.2rem 0.55rem; border-radius: 999px; font-size: 0.75rem; font-weight: 600; }
  .mnt-avail { display: inline-flex; align-items: center; gap: 0.4rem; font-size: 0.85rem; margin-bottom: 1rem; font-weight: 500; }
  .mnt-avail-dot { width: 0.5rem; height: 0.5rem; border-radius: 50%; background: #8a94a6; }
  .mnt-avail-instock .mnt-avail-dot { background: #16a34a; }
  .mnt-avail-instock { color: #16a34a; }
  .mnt-avail-outofstock .mnt-avail-dot { background: #c62828; }
  .mnt-avail-outofstock { color: #c62828; }
  .mnt-avail-preorder .mnt-avail-dot { background: #f59e0b; }
  .mnt-avail-preorder { color: #c07a00; }
  .mnt-buy-cta { display: flex; gap: 0.6rem; flex-wrap: wrap; }
  .mnt-btn { display: inline-flex; align-items: center; padding: 0.7rem 1.3rem; border-radius: 6px; font-weight: 600; text-decoration: none; font-size: 0.95rem; }
  .mnt-btn-primary { background: #131619; color: #fff; }
  .mnt-btn-primary:hover { background: #2a2f35; }
  .mnt-btn-ghost { background: transparent; color: #131619; border: 1px solid #d7dbe2; }
  .mnt-btn-ghost:hover { border-color: #131619; }

  .mnt-lede { color: #3d4656; line-height: 1.55; font-size: 1rem; margin: 0; }

  /* Full-width divider between split hero and article grid. */
  .mnt-section-divider { width: 100%; border: 0; border-top: 1px solid #e5e7eb; margin: 3.5rem 0 0; }

  /* Article grid — flexible main column + fixed 380px sticky sidebar. */
  .mnt-article-grid { display: grid; grid-template-columns: minmax(0, 1fr) 380px; column-gap: 4rem; row-gap: 2rem; align-items: start; margin: 3.5rem 0; }
  .mnt-article-main { min-width: 0; }
  .mnt-article-main > section { margin: 0 0 3.5rem; }
  .mnt-article-main > section:last-child { margin-bottom: 0; }

  .mnt-sidebar { position: sticky; top: 6rem; align-self: start; }
  .mnt-book-card { background: #131619; color: #fff; padding: 1.75rem; border-radius: 12px; display: flex; flex-direction: column; gap: 0.85rem; }
  .mnt-book-eyebrow { margin: 0; font-size: 0.7rem; letter-spacing: 0.12em; text-transform: uppercase; color: #8a94a6; font-weight: 600; }
  .mnt-book-title { margin: 0; font-size: 1.25rem; line-height: 1.25; color: #fff; font-family: 'Noto Serif', serif; font-weight: 400; }
  .mnt-book-desc { margin: 0; color: #c5ccd6; font-size: 0.92rem; line-height: 1.55; }
  .mnt-book-list { list-style: none; padding: 0; margin: 0.25rem 0 0; display: flex; flex-direction: column; gap: 0.5rem; border-top: 1px solid #2a2f35; padding-top: 0.9rem; }
  .mnt-book-list li { display: flex; justify-content: space-between; font-size: 0.88rem; color: #eef0f3; }
  .mnt-book-k { color: #8a94a6; }
  .mnt-book-btn { display: inline-flex; justify-content: center; margin-top: 0.6rem; padding: 0.75rem 1rem; background: #fff; color: #131619; font-weight: 600; border-radius: 8px; text-decoration: none; transition: background 0.15s; }
  .mnt-book-btn:hover { background: #eef0f3; }
  .mnt-book-link { color: #8a94a6; font-size: 0.85rem; text-decoration: underline; text-align: center; }
  .mnt-book-link:hover { color: #fff; }

  @media (max-width: 900px) {
    .mnt-article-grid { grid-template-columns: 1fr; gap: 2rem; }
    .mnt-sidebar { position: static; }
  }

  .mnt-compat h2, .mnt-motion h2, .mnt-review h2, .mnt-tvs h2 { font-size: 1.4rem; margin: 0 0 1rem; }
  .mnt-spec-table { width: 100%; border-collapse: collapse; }
  .mnt-spec-table th, .mnt-spec-table td { text-align: left; padding: 0.65rem 0.9rem; border-bottom: 1px solid #eef0f3; font-size: 0.95rem; }
  .mnt-spec-table th { color: #5a6271; font-weight: 500; width: 35%; }
  .mnt-spec-table td { color: #131619; }

  .mnt-proscons { display: grid; grid-template-columns: 1fr 1fr; gap: 1.5rem; }
  @media (max-width: 640px) { .mnt-proscons { grid-template-columns: 1fr; } }
  .mnt-proscons h3 { font-size: 1rem; margin: 0 0 0.5rem; font-weight: 600; }
  .mnt-pros h3 { color: #16a34a; }
  .mnt-cons h3 { color: #c62828; }
  .mnt-proscons ul { padding-left: 1.1rem; margin: 0; line-height: 1.6; color: #3d4656; }

  .mnt-tv-grid { list-style: none; padding: 0; margin: 0; display: grid; grid-template-columns: repeat(auto-fill, minmax(260px, 1fr)); gap: 0.6rem; }
  .mnt-tv-card { display: flex; justify-content: space-between; align-items: center; padding: 0.9rem 1rem; background: #fafbfc; border: 1px solid #eef0f3; border-radius: 8px; text-decoration: none; color: #131619; text-transform: capitalize; transition: border-color 0.15s; }
  .mnt-tv-card:hover { border-color: #131619; }

  .mnt-foot-cta { margin-top: 3rem; padding: 1.75rem; background: #131619; color: #fff; border-radius: 10px; display: flex; justify-content: space-between; align-items: center; gap: 1.5rem; flex-wrap: wrap; }
  .mnt-foot-cta h2 { margin: 0 0 0.35rem; font-size: 1.3rem; color: #fff; }
  .mnt-foot-cta p { margin: 0; color: #c5ccd6; }
  .mnt-foot-cta .mnt-btn-primary { background: #fff; color: #131619; }
  .mnt-foot-cta .mnt-btn-primary:hover { background: #eef0f3; }
</style>

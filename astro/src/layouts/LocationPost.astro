---
import BaseLayout from "~/layouts/BaseLayout.astro";

interface Props {
  frontmatter: {
    title: string;
    description: string;
    heroImage: string;
    heroAlt: string;
    publishDate: Date;
    suburb?: string;
    author: string;
    tags: string[];
    readTime?: number;
  };
}

const { frontmatter } = Astro.props;
const published = new Date(frontmatter.publishDate).toLocaleDateString("en-AU", { day: "numeric", month: "long", year: "numeric" });
---
<BaseLayout title={frontmatter.title} description={frontmatter.description} image={frontmatter.heroImage}>
  <article class="prose">
    <header class="post-header">
      <p class="u-muted">Location guide · {frontmatter.suburb ?? "Brisbane"}</p>
      <h1>{frontmatter.title}</h1>
      <div class="post-meta">
        <span>{frontmatter.author}</span>
        <span>{published}</span>
        {frontmatter.readTime && <span>{frontmatter.readTime} min read</span>}
      </div>
      <img class="post-hero" src={frontmatter.heroImage} alt={frontmatter.heroAlt} loading="eager" />
    </header>
    <slot />
    <hr />
    <p><a class="btn" href="/contact/">Get a quote in {frontmatter.suburb ?? "your suburb"}</a></p>
  </article>
</BaseLayout>

<script is:inline>
    // ===== Mega Menu — hover with open/close delay =====
    (function () {
        const OPEN_DELAY = 150;
        const CLOSE_DELAY = 200;

        const siteHeader = document.querySelector('.site-header');
        const backdrop = document.querySelector('.mega-backdrop');
        const navItems = document.querySelectorAll('.nav-item[data-menu]');
        const panels = document.querySelectorAll('.mega-menu[data-menu]');
        if (!siteHeader || navItems.length === 0) return;

        let openTimer = null;
        let closeTimer = null;
        let currentMenu = null;

        const panelFor = (key) => document.querySelector(`.mega-menu[data-menu="${key}"]`);
        const itemFor = (key) => document.querySelector(`.nav-item[data-menu="${key}"]`);

        function openMenu(key) {
            if (currentMenu === key) return;

            panels.forEach(p => p.classList.remove('is-active'));
            navItems.forEach(n => {
                n.classList.remove('is-active');
                const btn = n.querySelector('.nav-dropdown-trigger');
                if (btn) btn.setAttribute('aria-expanded', 'false');
            });

            const panel = panelFor(key);
            const item = itemFor(key);
            if (panel) panel.classList.add('is-active');
            if (item) {
                item.classList.add('is-active');
                const btn = item.querySelector('.nav-dropdown-trigger');
                if (btn) btn.setAttribute('aria-expanded', 'true');
            }

            siteHeader.classList.add('is-menu-open');
            if (backdrop) backdrop.classList.add('is-active');
            currentMenu = key;
        }

        function closeMenu() {
            panels.forEach(p => p.classList.remove('is-active'));
            navItems.forEach(n => {
                n.classList.remove('is-active');
                const btn = n.querySelector('.nav-dropdown-trigger');
                if (btn) btn.setAttribute('aria-expanded', 'false');
            });
            siteHeader.classList.remove('is-menu-open');
            if (backdrop) backdrop.classList.remove('is-active');
            currentMenu = null;
        }

        function scheduleOpen(key) {
            clearTimeout(closeTimer);
            closeTimer = null;
            if (currentMenu === key) return;
            clearTimeout(openTimer);
            openTimer = setTimeout(() => openMenu(key), OPEN_DELAY);
        }

        function scheduleClose() {
            clearTimeout(openTimer);
            openTimer = null;
            clearTimeout(closeTimer);
            closeTimer = setTimeout(closeMenu, CLOSE_DELAY);
        }

        // Hover on triggers
        navItems.forEach(item => {
            const key = item.getAttribute('data-menu');
            item.addEventListener('mouseenter', () => scheduleOpen(key));
            item.addEventListener('mouseleave', scheduleClose);
            // Click toggles (keyboard / tap fallback)
            const btn = item.querySelector('.nav-dropdown-trigger');
            if (btn) {
                btn.addEventListener('click', (e) => {
                    e.preventDefault();
                    if (currentMenu === key) closeMenu();
                    else openMenu(key);
                });
            }
        });

        // Hover on panels keeps them open
        panels.forEach(panel => {
            panel.addEventListener('mouseenter', () => {
                clearTimeout(closeTimer);
                closeTimer = null;
            });
            panel.addEventListener('mouseleave', scheduleClose);
        });

        // Close when mouse leaves header area entirely
        siteHeader.addEventListener('mouseleave', scheduleClose);

        // Close on backdrop click / Escape
        if (backdrop) backdrop.addEventListener('click', closeMenu);
        document.addEventListener('keydown', (e) => {
            if (e.key === 'Escape' && currentMenu) closeMenu();
        });
    })();
</script>

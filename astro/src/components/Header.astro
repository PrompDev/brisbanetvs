---
/**
 * Real Brisbane TVs site header — wired to the Astro content collections
 * so every nav link resolves to a real built page. No more href="#" stubs.
 *
 * Behaviour:
 *   - Logo → `/` (homepage)
 *   - Top-level nav items (Services / Locations / Products / Mounts / Blog)
 *     are anchor tags (not buttons) so they navigate to their hub on click
 *     AND open the mega-menu on hover. Hover-to-open is handled by the
 *     inline script below.
 *   - Mega-menu sub-links: the left column ("Browse by…") is curated
 *     category copy that all points to the parent hub; the middle column
 *     ("Popular…") is populated from the real content collections so it
 *     auto-fills as more entries are published.
 *   - BOOK NOW / View All / Featured CTAs all route to the corresponding hub.
 */

import { getCollection } from "astro:content";

// Pull real entries for the "Popular" column of each mega-menu. Limited
// to 8 each so the mega-menu doesn't overflow vertically. As the
// collections grow, these auto-populate.
const services = (await getCollection("services", ({ data }) => !data.draft))
  .sort((a, b) => a.data.priceFrom - b.data.priceFrom)
  .slice(0, 8);

const locations = (await getCollection("locations", ({ data }) => !data.draft))
  .sort((a, b) => a.data.suburb.localeCompare(b.data.suburb))
  .slice(0, 8);

const products = (await getCollection("products", ({ data }) => !data.draft))
  .sort((a, b) => b.data.priceAud - a.data.priceAud)
  .slice(0, 8);

const mounts = (await getCollection("mounts", ({ data }) => !data.draft))
  .sort((a, b) => b.data.maxWeightKg - a.data.maxWeightKg)
  .slice(0, 8);
---
<div class="page-header-wrapper">

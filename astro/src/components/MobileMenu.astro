<script is:inline>
    (function () {
        const hamburger = document.getElementById('hamburgerBtn');
        const menu      = document.getElementById('mobileMenu');
        const backdrop  = document.getElementById('mobileBackdrop');
        const closeBtn  = document.getElementById('mobileMenuClose');
        if (!hamburger || !menu || !backdrop) return;

        const body = document.body;
        let isOpen = false;

        function openMenu() {
            if (isOpen) return;
            isOpen = true;
            menu.classList.add('active');
            backdrop.classList.add('active');
            hamburger.classList.add('is-open');
            hamburger.setAttribute('aria-expanded', 'true');
            hamburger.setAttribute('aria-label', 'Close menu');
            menu.setAttribute('aria-hidden', 'false');
            backdrop.setAttribute('aria-hidden', 'false');
            body.classList.add('menu-open');
        }

        function closeMenu() {
            if (!isOpen) return;
            isOpen = false;
            menu.classList.remove('active');
            backdrop.classList.remove('active');
            hamburger.classList.remove('is-open');
            hamburger.setAttribute('aria-expanded', 'false');
            hamburger.setAttribute('aria-label', 'Open menu');
            menu.setAttribute('aria-hidden', 'true');
            backdrop.setAttribute('aria-hidden', 'true');
            body.classList.remove('menu-open');
        }

        function toggleMenu() { isOpen ? closeMenu() : openMenu(); }

        hamburger.addEventListener('click', toggleMenu);
        if (closeBtn) closeBtn.addEventListener('click', closeMenu);
        backdrop.addEventListener('click', closeMenu);

        // Close when a link inside the drawer is clicked
        menu.querySelectorAll('a').forEach(a => {
            a.addEventListener('click', () => {
                // Only close if it's navigating somewhere real OR a hash on this page
                closeMenu();
            });
        });

        // Escape key
        document.addEventListener('keydown', e => {
            if (e.key === 'Escape' && isOpen) closeMenu();
        });

        // If the viewport grows past the mobile breakpoint while the drawer is
        // open (e.g. rotate tablet landscape), close it cleanly.
        const mq = window.matchMedia('(min-width: 1201px)');
        const handleMQ = (ev) => { if (ev.matches && isOpen) closeMenu(); };
        if (mq.addEventListener) mq.addEventListener('change', handleMQ);
        else if (mq.addListener) mq.addListener(handleMQ);
    })();
</script>

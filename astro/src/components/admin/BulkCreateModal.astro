---
/**
 * BulkCreateModal.astro — shared bulk-upload modal used by the four
 * "content" admin pages (services, locations, products, mounts).
 *
 * The blog admin has its own copy of this UX (src/pages/admin-nav/blogs/
 * index.astro) because it predates this shared component and carries a
 * chunk of blog-only UI (author/style fields). If you change behaviour
 * here, mirror it there — or eventually replace that copy with this one.
 *
 * Usage:
 *   <BulkCreateModal collection="services" />
 *
 * What it does, end-to-end:
 *   1. Drop up to 50 .md files onto the drop zone.
 *   2. Parses each file's YAML frontmatter and scans for IMAGE:xxx
 *      placeholders (heroImage or anywhere in the body). Each unique
 *      placeholder becomes a "slot" the user must fill with an image.
 *   3. Per-collection validator checks required schema fields.
 *   4. Saves each ready file:
 *        - preferred path: Decap local proxy (no folder pick needed)
 *        - fallback     : File System Access folder picker, writing
 *                         directly to astro/src/content/<collection>/
 *                         and astro/public/media/.
 *      Images are WebP-converted client-side before either path.
 *
 * Everything collection-specific (save paths, template URL, validation
 * rules) is derived from the `collection` prop + CONFIGS map at the
 * bottom of this file's inline script — no per-collection JS duplication.
 */
export interface Props {
  /** Which content collection this modal saves to. */
  collection: "services" | "locations" | "products" | "mounts";
}

const { collection } = Astro.props;

/**
 * Collection-specific wiring (server-side). Gets passed to the inline
 * script via `define:vars` below so the same code handles all four
 * collections with zero branching in the client.
 */
const COLLECTION_LABELS: Record<Props["collection"], { singular: string; plural: string; }> = {
  services: { singular: "service",  plural: "services"  },
  locations: { singular: "location", plural: "locations" },
  products: { singular: "product",  plural: "products"  },
  mounts:   { singular: "mount",    plural: "mounts"    },
};
const label = COLLECTION_LABELS[collection];
---

{/* === BULK UPLOAD MODAL === */}
<div class="bulk-overlay" data-bulk-overlay hidden>
  <div class="bulk-modal" role="dialog" aria-labelledby={`bulk-title-${collection}`} aria-modal="true">
    <header class="bulk-head">
      <div>
        <h3 id={`bulk-title-${collection}`}>Bulk upload {label.plural}</h3>
        <p>Drop <code>.md</code> files, then click through each {label.singular} and pick an image for every <code>IMAGE:</code> slot.</p>
      </div>
      <button type="button" class="bulk-close" data-bulk-close aria-label="Close">×</button>
    </header>

    {/* Connection banner — shows whether we can talk to the CMS proxy */}
    <div class="bulk-conn" data-bulk-conn>
      <span class="bulk-conn-dot" data-bulk-conn-dot></span>
      <span data-bulk-conn-label>Checking CMS connection…</span>
      <button type="button" class="bulk-conn-btn" data-bulk-root hidden>Pick folder manually…</button>
    </div>

    <div class="bulk-drop" data-bulk-drop tabindex="0">
      <p class="bulk-drop-main">Drag <strong>.md</strong> files here or <button type="button" class="bulk-browse" data-bulk-browse>browse…</button></p>
      <input type="file" accept=".md,text/markdown" multiple hidden data-bulk-input />
    </div>

    {/* Dot rail + prev/next stepper — only shows once files are added */}
    <nav class="bulk-strip" data-bulk-strip hidden aria-label={label.plural}>
      <button type="button" class="bulk-nav" data-bulk-prev aria-label="Previous entry (left arrow)">‹</button>
      <span class="bulk-strip-count" data-bulk-strip-count>1 / 1</span>
      <div class="bulk-dots" data-bulk-dots role="tablist"></div>
      <span class="bulk-strip-error" data-bulk-strip-error hidden title="">Invalid template</span>
      <button type="button" class="bulk-nav" data-bulk-next aria-label="Next entry (right arrow)">›</button>
    </nav>

    {/* Single-entry focus view */}
    <section class="bulk-focus" data-bulk-focus hidden aria-live="polite"></section>

    <footer class="bulk-foot">
      <div class="bulk-summary" data-bulk-summary>No files yet.</div>
      <div class="bulk-actions">
        <button type="button" class="btn" data-bulk-clear disabled>Clear</button>
        <button type="button" class="btn btn-primary" data-bulk-save disabled>Save all</button>
      </div>
    </footer>

    <p class="bulk-hint">
      Tip: use <kbd>←</kbd> <kbd>→</kbd> to jump between entries, <kbd>Enter</kbd> to open the picker on the focused slot.
    </p>
  </div>
</div>

<style is:global>
  /* Everything below is the same visual system the blogs admin page uses —
     sharing it here keeps the two modals visually identical. The selectors
     are global so this component's single <style> block styles the modal
     regardless of where it's embedded. */

  /* ===== Dropdown (sibling — not in this component, but styled here so
     the parent page's "+ New X ▾" button matches without duplicating CSS) ===== */
  .np-dropdown { position: relative; display: inline-block; }
  .np-caret { font-size: 0.75rem; margin-left: 0.1rem; transition: transform 0.15s; }
  .np-dropdown[data-open="true"] .np-caret { transform: rotate(180deg); }
  .np-menu {
    position: absolute; top: calc(100% + 6px); right: 0;
    min-width: 240px;
    background: #fff;
    border: 1px solid var(--panel-line, #e5e7eb);
    border-radius: 8px;
    box-shadow: 0 12px 28px rgba(15, 22, 36, 0.12);
    padding: 0.35rem;
    z-index: 40;
    display: flex; flex-direction: column;
  }
  .np-menu[hidden] { display: none; }
  .np-item {
    all: unset;
    display: flex; flex-direction: column;
    gap: 0.15rem;
    padding: 0.6rem 0.75rem;
    border-radius: 6px;
    cursor: pointer;
    font-family: inherit;
    color: var(--ink, #131619);
  }
  .np-item:hover, .np-item:focus-visible { background: #f1f3f7; outline: none; }
  .np-item-title { font-size: 0.88rem; font-weight: 600; }
  .np-item-sub { font-size: 0.76rem; color: var(--ink-soft, #5a6271); }

  /* ===== Bulk upload modal ===== */
  .bulk-overlay {
    position: fixed; inset: 0;
    background: rgba(15, 22, 36, 0.55);
    display: flex; align-items: center; justify-content: center;
    padding: 1.5rem;
    z-index: 80;
  }
  .bulk-overlay[hidden] { display: none; }
  .bulk-strip[hidden], .bulk-focus[hidden], .bulk-strip-error[hidden] { display: none !important; }

  .bulk-modal {
    width: min(640px, 100%);
    max-height: calc(100vh - 3rem);
    background: #fff;
    border-radius: 12px;
    box-shadow: 0 24px 60px rgba(0, 0, 0, 0.25);
    display: flex; flex-direction: column;
    overflow: hidden;
  }

  .bulk-head {
    display: flex; justify-content: space-between; align-items: flex-start;
    gap: 1rem;
    padding: 1.1rem 1.25rem 0.9rem;
    border-bottom: 1px solid var(--panel-line, #e5e7eb);
  }
  .bulk-head h3 { margin: 0 0 0.25rem; font-size: 1.02rem; font-weight: 600; }
  .bulk-head p { margin: 0; font-size: 0.82rem; color: var(--ink-soft, #5a6271); line-height: 1.4; }
  .bulk-head code { font-size: 0.78rem; background: #f1f3f7; padding: 0.05rem 0.3rem; border-radius: 4px; }

  .bulk-close {
    border: 0; background: transparent;
    color: var(--ink-soft, #5a6271);
    font-size: 1.5rem; line-height: 1;
    cursor: pointer;
    padding: 0.1rem 0.35rem;
    border-radius: 4px;
    flex-shrink: 0;
  }
  .bulk-close:hover { background: #f1f3f7; color: var(--ink, #131619); }

  .bulk-drop {
    margin: 1rem 1.25rem;
    padding: 2rem 1rem;
    border: 2px dashed var(--panel-line, #d7dae1);
    border-radius: 10px;
    text-align: center;
    color: var(--ink-soft, #5a6271);
    transition: background 0.12s, border-color 0.12s;
    cursor: pointer;
  }
  .bulk-drop.is-dragover { background: #f5f3eb; border-color: #c5a14a; color: var(--ink, #131619); }
  .bulk-drop-main { margin: 0 0 0.25rem; font-size: 0.95rem; color: var(--ink, #131619); }

  .bulk-browse {
    border: 0; background: transparent; padding: 0;
    color: var(--sidebar-accent, #4f46e5);
    text-decoration: underline;
    font: inherit; cursor: pointer;
  }

  .bulk-conn {
    display: flex; align-items: center; gap: 0.55rem;
    padding: 0.55rem 1.25rem;
    background: #f6f7fa;
    border-bottom: 1px solid var(--panel-line, #e5e7eb);
    font-size: 0.8rem;
    color: var(--ink-soft, #5a6271);
  }
  .bulk-conn.is-online  { background: #ecfaf1; border-bottom-color: #b9e6ce; color: #17633a; }
  .bulk-conn.is-offline { background: #fff7e8; border-bottom-color: #f1d99b; color: #7a5507; }
  .bulk-conn.is-folder  { background: #edf1fd; border-bottom-color: #c2cef0; color: #1e40af; }
  .bulk-conn-dot { width: 0.5rem; height: 0.5rem; border-radius: 50%; background: #b6bdc9; flex-shrink: 0; }
  .bulk-conn.is-online  .bulk-conn-dot { background: #1e9a58; box-shadow: 0 0 0 3px #1e9a5830; }
  .bulk-conn.is-offline .bulk-conn-dot { background: #c88b22; }
  .bulk-conn.is-folder  .bulk-conn-dot { background: #1e40af; }
  .bulk-conn-btn {
    margin-left: auto;
    border: 1px solid currentColor;
    background: transparent;
    color: inherit;
    font: inherit; font-size: 0.74rem;
    padding: 0.2rem 0.55rem;
    border-radius: 4px;
    cursor: pointer;
    opacity: 0.85;
  }
  .bulk-conn-btn:hover { opacity: 1; background: rgba(0,0,0,0.05); }

  .bulk-strip {
    display: flex; align-items: center; gap: 0.5rem;
    margin: 1rem 1.25rem 0;
    padding: 0.45rem 0.55rem;
    background: #fafbfc;
    border: 1px solid var(--panel-line, #e5e7eb);
    border-radius: 8px;
  }
  .bulk-strip-count {
    flex-shrink: 0;
    font-size: 0.74rem; font-weight: 600;
    color: var(--ink-soft, #5a6271);
    padding: 0 0.4rem;
    min-width: 3.5rem;
    text-align: center;
  }
  .bulk-nav {
    border: 1px solid var(--panel-line, #d7dae1);
    background: #fff;
    width: 2rem; height: 2rem;
    border-radius: 50%;
    font-size: 1.1rem; line-height: 1;
    cursor: pointer;
    color: var(--ink, #131619);
    flex-shrink: 0;
    display: flex; align-items: center; justify-content: center;
  }
  .bulk-nav:hover:not(:disabled) { background: #f5f3eb; border-color: #c5a14a; }
  .bulk-nav:disabled { opacity: 0.35; cursor: not-allowed; }
  .bulk-dots {
    flex: 1;
    display: flex; align-items: center;
    gap: 6px;
    overflow-x: auto;
    padding: 0.15rem 0.25rem;
    min-height: 1.5rem;
  }
  .bulk-dots::-webkit-scrollbar { height: 4px; }
  .bulk-dots::-webkit-scrollbar-thumb { background: #d7dae1; border-radius: 2px; }
  .bulk-dot {
    width: 0.85rem; height: 0.85rem;
    border-radius: 50%;
    border: 2px solid #fff;
    padding: 0;
    cursor: pointer;
    background: #c9cdd4;
    flex-shrink: 0;
    box-shadow: 0 0 0 1px #c9cdd4;
    transition: transform 0.12s, box-shadow 0.12s;
  }
  .bulk-dot:hover { transform: scale(1.2); }
  .bulk-dot.is-current { transform: scale(1.25); box-shadow: 0 0 0 2px var(--ink, #131619); }
  .bulk-dot.is-ready { background: #1e9a58; box-shadow: 0 0 0 1px #1e9a58; }
  .bulk-dot.is-needs { background: #d4a94a; box-shadow: 0 0 0 1px #d4a94a; }
  .bulk-dot.is-error { background: #c62828; box-shadow: 0 0 0 1px #c62828; position: relative; }
  .bulk-dot.is-error::before {
    content: "!";
    position: absolute; inset: 0;
    display: flex; align-items: center; justify-content: center;
    color: #fff; font-size: 0.6rem; font-weight: 900; line-height: 1;
    font-family: ui-sans-serif, system-ui, sans-serif;
  }
  .bulk-dot.is-saved { background: #1e40af; box-shadow: 0 0 0 1px #1e40af; }
  .bulk-dot.is-current.is-ready,
  .bulk-dot.is-current.is-needs,
  .bulk-dot.is-current.is-saved { box-shadow: 0 0 0 2px var(--ink, #131619); }
  .bulk-dot.is-current.is-error { box-shadow: 0 0 0 2px #c62828; animation: bulk-dot-pulse 1.4s ease-in-out infinite; }
  @keyframes bulk-dot-pulse {
    0%, 100% { box-shadow: 0 0 0 2px #c62828, 0 0 0 4px #c6282800; }
    50%      { box-shadow: 0 0 0 2px #c62828, 0 0 0 5px #c6282855; }
  }

  .bulk-strip-error {
    display: inline-flex; align-items: center; gap: 0.3rem;
    flex-shrink: 0;
    font-size: 0.7rem; font-weight: 700;
    color: #fff;
    background: #c62828;
    padding: 0.2rem 0.55rem 0.22rem;
    border-radius: 999px;
    line-height: 1;
    white-space: nowrap;
  }
  .bulk-strip-error::before {
    content: "!";
    display: inline-flex; align-items: center; justify-content: center;
    width: 0.85rem; height: 0.85rem;
    border-radius: 50%;
    background: #fff;
    color: #c62828;
    font-weight: 900;
    font-size: 0.65rem;
  }

  .bulk-focus {
    margin: 0.75rem 1.25rem 0;
    padding: 0;
    background: transparent;
    max-height: 54vh;
    overflow-y: auto;
    display: flex; flex-direction: column;
    gap: 0.65rem;
  }

  .bf-meta-card {
    background: #fff;
    border: 1px solid var(--panel-line, #e5e7eb);
    border-radius: 10px;
    padding: 0.85rem 1rem;
    box-shadow: 0 1px 2px rgba(15, 22, 36, 0.03);
  }
  .bf-meta-top {
    display: flex; align-items: flex-start; gap: 0.65rem;
    margin-bottom: 0.1rem;
  }
  .bf-meta-main { flex: 1; min-width: 0; }
  .bf-pos {
    font-size: 0.7rem;
    color: var(--ink-soft, #5a6271);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    font-weight: 600;
    margin-bottom: 0.2rem;
  }
  .bf-title {
    font-size: 1rem; font-weight: 600;
    color: var(--ink, #131619);
    line-height: 1.3;
    margin: 0 0 0.25rem;
    word-break: break-word;
  }
  .bf-slug-row {
    display: inline-flex; align-items: center; gap: 0.35rem;
    font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
    font-size: 0.75rem;
    background: #f5f3eb;
    border: 1px solid #eadfb8;
    color: #5e4a15;
    padding: 0.15rem 0.45rem;
    border-radius: 4px;
    max-width: 100%;
    overflow: hidden; text-overflow: ellipsis; white-space: nowrap;
  }
  .bf-slug-row .bf-slug-prefix { opacity: 0.6; }
  .bf-file {
    display: block;
    margin-top: 0.35rem;
    font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
    font-size: 0.7rem;
    color: var(--ink-soft, #5a6271);
  }
  .bf-status {
    font-size: 0.72rem; padding: 0.15rem 0.55rem;
    border-radius: 999px; font-weight: 600;
    flex-shrink: 0; align-self: center;
  }
  .bf-status.ready { background: #dcf5e5; color: #17633a; }
  .bf-status.needs { background: #fff1cf; color: #7a5507; }
  .bf-status.error { background: #fde1e1; color: #8a1c1c; }
  .bf-status.saved { background: #d6e2ff; color: #1e40af; }
  .bf-remove {
    border: 0; background: transparent; cursor: pointer;
    color: var(--ink-soft, #5a6271);
    font-size: 1.1rem; line-height: 1;
    padding: 0.15rem 0.35rem; border-radius: 4px;
    flex-shrink: 0; align-self: flex-start;
  }
  .bf-remove:hover { background: #f1f3f7; color: #b33; }

  .bf-errors {
    margin: 0;
    padding: 0.55rem 0.7rem;
    background: #fdf4f4;
    border: 1px solid #f3c8c8;
    border-left: 3px solid #b33;
    border-radius: 6px;
    font-size: 0.78rem;
    color: #8a1c1c;
  }

  .bf-images-card {
    background: #fff;
    border: 1px solid var(--panel-line, #e5e7eb);
    border-radius: 10px;
    padding: 0.75rem 0.85rem 0.85rem;
    box-shadow: 0 1px 2px rgba(15, 22, 36, 0.03);
  }
  .bf-images-head {
    display: flex; align-items: center; justify-content: space-between;
    gap: 0.5rem;
    margin-bottom: 0.6rem;
    padding-bottom: 0.55rem;
    border-bottom: 1px solid var(--panel-line, #eef0f4);
  }
  .bf-images-title { font-size: 0.82rem; font-weight: 600; color: var(--ink, #131619); }
  .bf-images-count { font-size: 0.72rem; color: var(--ink-soft, #5a6271); font-weight: 500; }

  .bf-empty-state {
    padding: 1rem; text-align: center;
    color: var(--ink-soft, #5a6271);
    font-size: 0.85rem;
    background: #fff;
    border: 1px dashed var(--panel-line, #d7dae1);
    border-radius: 8px;
  }

  .bf-slots { display: flex; flex-direction: column; gap: 0.45rem; }
  .bf-slot {
    border: 1px solid var(--panel-line, #e5e7eb);
    border-left: 3px solid #d4a94a;
    border-radius: 6px;
    padding: 0.55rem 0.7rem;
    outline: none;
    background: #fff;
    transition: border-color 0.1s, box-shadow 0.1s;
  }
  .bf-slot.is-filled  { border-left-color: #1e9a58; background: #fafefb; }
  .bf-slot.is-focused { box-shadow: 0 0 0 2px #c5a14a80; border-color: #c5a14a; }
  .bf-slot-head { display: flex; align-items: baseline; gap: 0.5rem; justify-content: space-between; }
  .bf-slot-tag {
    font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
    font-size: 0.76rem;
    background: #f5f3eb;
    padding: 0.08rem 0.4rem;
    border-radius: 4px;
    color: #5e4a15;
    font-weight: 600;
  }
  .bf-slot.is-filled .bf-slot-tag { background: #e1f3e8; color: #17633a; }
  .bf-slot-flag { font-size: 0.72rem; color: #b33; font-weight: 700; }
  .bf-slot.is-filled .bf-slot-flag { color: #17633a; font-weight: 600; }
  .bf-slot-desc { margin: 0.25rem 0 0; font-size: 0.8rem; color: var(--ink, #131619); line-height: 1.4; }
  .bf-slot-alt  { margin: 0.2rem 0 0; font-size: 0.74rem; color: var(--ink, #131619); font-weight: 700; }
  .bf-slot-picker { display: flex; align-items: center; gap: 0.5rem; margin-top: 0.55rem; flex-wrap: wrap; }
  .btn-slot {
    background: var(--ink, #131619);
    color: #fff;
    border: 0;
    padding: 0.4rem 0.9rem;
    border-radius: 6px;
    cursor: pointer;
    font-size: 0.82rem;
    font-family: inherit;
    font-weight: 600;
  }
  .btn-slot:hover { background: #2a2f3a; }
  .bf-slot.is-filled .btn-slot {
    background: #fff;
    color: var(--ink, #131619);
    border: 1px solid var(--panel-line, #d7dae1);
    font-weight: 500;
  }
  .bf-slot.is-filled .btn-slot:hover { background: #f5f3eb; border-color: #c5a14a; }
  .bf-filename {
    font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
    font-size: 0.74rem;
    color: #1e633a;
    flex: 1; min-width: 0;
    white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
  }
  .bf-slot-clear {
    border: 0; background: transparent;
    color: var(--ink-soft, #5a6271);
    cursor: pointer;
    font-size: 1rem; line-height: 1;
    padding: 0.1rem 0.3rem;
    border-radius: 3px;
  }
  .bf-slot-clear:hover { background: #f1f3f7; color: var(--ink, #131619); }

  .bulk-hint kbd {
    font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
    font-size: 0.72rem;
    background: #fff;
    border: 1px solid var(--panel-line, #d7dae1);
    border-bottom-width: 2px;
    border-radius: 3px;
    padding: 0.05rem 0.35rem;
    color: var(--ink, #131619);
    margin: 0 0.1rem;
  }

  .bulk-foot {
    display: flex; justify-content: space-between; align-items: center;
    gap: 1rem;
    padding: 1rem 1.25rem;
    border-top: 1px solid var(--panel-line, #e5e7eb);
    flex-wrap: wrap;
  }
  .bulk-summary { font-size: 0.82rem; color: var(--ink-soft, #5a6271); }
  .bulk-actions { display: flex; gap: 0.5rem; }

  .bulk-hint {
    margin: 0;
    padding: 0.75rem 1.25rem 1rem;
    font-size: 0.76rem;
    color: var(--ink-soft, #5a6271);
    background: #fafbfc;
    border-top: 1px solid var(--panel-line, #eef0f4);
  }
  .bulk-hint code {
    font-size: 0.74rem;
    background: #fff; padding: 0.05rem 0.3rem;
    border-radius: 3px;
    border: 1px solid var(--panel-line, #e5e7eb);
  }
</style>

<script is:inline define:vars={{ collection, collectionLabel: label }}>
  /* eslint-disable */
  (function () {
    // ---------- Dropdown wiring (reused across pages) ----------
    // The parent page renders the "+ New X ▾" dropdown; we hook it here so the
    // same code handles the open/close on every admin page that embeds this
    // modal. If the parent didn't render a dropdown, all this is a no-op.
    const dropdown = document.querySelector("[data-np-root]");
    const toggle   = dropdown ? dropdown.querySelector("[data-np-toggle]") : null;
    const menu     = dropdown ? dropdown.querySelector("[data-np-menu]")   : null;

    function openMenu()  { if (!menu) return; menu.hidden = false; dropdown.setAttribute("data-open", "true"); toggle.setAttribute("aria-expanded", "true"); }
    function closeMenu() { if (!menu) return; menu.hidden = true;  dropdown.removeAttribute("data-open");       toggle.setAttribute("aria-expanded", "false"); }
    if (toggle) {
      toggle.addEventListener("click", (e) => { e.stopPropagation(); if (menu.hidden) openMenu(); else closeMenu(); });
      document.addEventListener("click", (e) => { if (!dropdown.contains(e.target)) closeMenu(); });
      document.addEventListener("keydown", (e) => { if (e.key === "Escape") closeMenu(); });
    }

    // ---------- Collection config ----------
    // Single source of truth for collection-specific behaviour. Add entries
    // here if we ever spin up new collections (e.g. a "guides" or "case
    // studies" collection) — the rest of this file stays untouched.
    const CFG = (function () {
      const base = {
        services: {
          contentDir: ["astro", "src", "content", "services"],
          indexPath: "/services/",
          slugPrefix: "/services/",
          requireFields: ["title", "description", "heroImage", "heroAlt", "priceFrom"],
        },
        locations: {
          contentDir: ["astro", "src", "content", "locations"],
          indexPath: "/locations/",
          slugPrefix: "/locations/",
          requireFields: ["title", "description", "heroImage", "heroAlt", "suburb", "postcode", "latitude", "longitude"],
        },
        products: {
          contentDir: ["astro", "src", "content", "products"],
          indexPath: "/products/",
          slugPrefix: "/products/",
          requireFields: ["title", "description", "heroImage", "heroAlt", "brand", "model", "category", "priceAud"],
        },
        mounts: {
          contentDir: ["astro", "src", "content", "mounts"],
          indexPath: "/mounts/",
          slugPrefix: "/mounts/",
          requireFields: ["title", "description", "heroImage", "heroAlt", "brand", "model", "mountType", "priceAud"],
        },
      };
      return base[collection];
    })();

    // Decap persistEntry needs a collection name that matches /admin/config.yml.
    // Our Decap config names each collection identically to the content folder.
    const DECAP_COLLECTION = collection;

    const DECAP_URL = "http://localhost:8081/api/v1";
    const DECAP_BRANCH = "main";
    const MAX_FILES = 50;

    // ---------- DOM references (scoped to this overlay) ----------
    const overlay     = document.querySelector("[data-bulk-overlay]");
    if (!overlay) return; // defensive — component not rendered on this page
    const openers     = document.querySelectorAll("[data-bulk-open]");
    const closers     = overlay.querySelectorAll("[data-bulk-close]");
    const drop        = overlay.querySelector("[data-bulk-drop]");
    const browse      = overlay.querySelector("[data-bulk-browse]");
    const input       = overlay.querySelector("[data-bulk-input]");
    const focusEl     = overlay.querySelector("[data-bulk-focus]");
    const stripEl     = overlay.querySelector("[data-bulk-strip]");
    const dotsEl      = overlay.querySelector("[data-bulk-dots]");
    const stripCountEl = overlay.querySelector("[data-bulk-strip-count]");
    const stripErrEl   = overlay.querySelector("[data-bulk-strip-error]");
    const prevBtn     = overlay.querySelector("[data-bulk-prev]");
    const nextBtn     = overlay.querySelector("[data-bulk-next]");
    const summary     = overlay.querySelector("[data-bulk-summary]");
    const saveBtn     = overlay.querySelector("[data-bulk-save]");
    const clearBtn    = overlay.querySelector("[data-bulk-clear]");
    const rootBtn     = overlay.querySelector("[data-bulk-root]");
    const connEl      = overlay.querySelector("[data-bulk-conn]");
    const connLabelEl = overlay.querySelector("[data-bulk-conn-label]");

    // ---------- State ----------
    /**
     * entries[i] shape:
     *   { file, text, raw, body, fm, slug,
     *     slots: [{name, description, alt, imageFile, imageName}],
     *     status: "needs"|"ready"|"error"|"saved", msg, _errs }
     */
    let entries = [];
    let currentIndex = 0;
    let focusedSlot = null;
    let rootHandle = null;
    let decapOnline = false;

    // ---------- IndexedDB (persist picked root folder across sessions) ----------
    const IDB_NAME = "btv-admin";
    const IDB_STORE = "handles";
    const IDB_ROOT_KEY = "brisbaneTvsRoot";

    function idb() {
      return new Promise((resolve, reject) => {
        const req = indexedDB.open(IDB_NAME, 1);
        req.onupgradeneeded = () => req.result.createObjectStore(IDB_STORE);
        req.onsuccess = () => resolve(req.result);
        req.onerror = () => reject(req.error);
      });
    }
    async function idbGet(key) {
      const db = await idb();
      return new Promise((resolve, reject) => {
        const tx = db.transaction(IDB_STORE, "readonly");
        const req = tx.objectStore(IDB_STORE).get(key);
        req.onsuccess = () => resolve(req.result);
        req.onerror = () => reject(req.error);
      });
    }
    async function idbSet(key, value) {
      const db = await idb();
      return new Promise((resolve, reject) => {
        const tx = db.transaction(IDB_STORE, "readwrite");
        tx.objectStore(IDB_STORE).put(value, key);
        tx.oncomplete = () => resolve();
        tx.onerror = () => reject(tx.error);
      });
    }
    async function verifyHandle(h) {
      if (!h || !h.queryPermission) return false;
      if ((await h.queryPermission({ mode: "readwrite" })) === "granted") return true;
      return (await h.requestPermission({ mode: "readwrite" })) === "granted";
    }
    async function loadSavedRoot() {
      try { const h = await idbGet(IDB_ROOT_KEY); if (h) rootHandle = h; } catch (_) {}
    }
    async function pickRoot() {
      if (!window.showDirectoryPicker) { alert("Your browser can't pick folders directly. Use Chrome or Edge."); return; }
      try {
        const h = await window.showDirectoryPicker({ mode: "readwrite" });
        if (await verifyHandle(h)) {
          rootHandle = h;
          try { await idbSet(IDB_ROOT_KEY, h); } catch (_) {}
          updateConnectionBanner();
        }
      } catch (err) { if (err && err.name === "AbortError") return; console.error(err); alert("Could not open folder."); }
    }
    if (rootBtn) rootBtn.addEventListener("click", pickRoot);

    // ---------- Decap local proxy detection ----------
    async function detectDecap() {
      try {
        const r = await fetch(DECAP_URL, {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({ action: "info", params: {} }),
        });
        if (!r.ok) return false;
        await r.json();
        return true;
      } catch (_) { return false; }
    }
    async function updateConnectionBanner() {
      decapOnline = await detectDecap();
      connEl.classList.remove("is-online", "is-offline", "is-folder");
      if (decapOnline) {
        connEl.classList.add("is-online");
        connLabelEl.innerHTML = `Connected to CMS — saves go straight to <code>src/content/${collection}/</code> and <code>public/media/</code>. No folder pick needed.`;
        rootBtn.hidden = true;
      } else if (rootHandle && rootHandle.name) {
        connEl.classList.add("is-folder");
        connLabelEl.innerHTML = `Using local folder <strong>${rootHandle.name}</strong> (CMS proxy not running).`;
        rootBtn.hidden = false;
        rootBtn.textContent = "Change folder…";
      } else {
        connEl.classList.add("is-offline");
        connLabelEl.innerHTML = "CMS proxy not running. Start <code>npx decap-server</code> or pick the project folder manually.";
        rootBtn.hidden = false;
        rootBtn.textContent = "Pick folder…";
      }
    }
    loadSavedRoot().then(updateConnectionBanner);

    // ---------- Overlay open/close ----------
    function openOverlay() {
      overlay.hidden = false;
      closeMenu();
      document.body.style.overflow = "hidden";
      updateConnectionBanner();
    }
    function closeOverlay() { overlay.hidden = true; document.body.style.overflow = ""; }
    openers.forEach((b) => b.addEventListener("click", openOverlay));
    closers.forEach((b) => b.addEventListener("click", closeOverlay));
    overlay.addEventListener("click", (e) => { if (e.target === overlay) closeOverlay(); });

    // Keyboard: Escape closes; arrows navigate entries; Enter opens picker.
    document.addEventListener("keydown", (e) => {
      if (overlay.hidden) return;
      if (e.key === "Escape") { closeOverlay(); return; }
      const t = e.target;
      if (t && (t.tagName === "INPUT" || t.tagName === "TEXTAREA")) return;
      if (entries.length === 0) return;
      if (e.key === "ArrowLeft")       { e.preventDefault(); goToIndex(currentIndex - 1); }
      else if (e.key === "ArrowRight") { e.preventDefault(); goToIndex(currentIndex + 1); }
      else if (e.key === "ArrowUp")    { e.preventDefault(); moveSlotFocus(-1); }
      else if (e.key === "ArrowDown")  { e.preventDefault(); moveSlotFocus(1); }
      else if (e.key === "Enter" || e.key === " ") {
        const cur = entries[currentIndex];
        if (cur && focusedSlot) {
          const s = cur.slots.find((x) => x.name === focusedSlot);
          if (s) { e.preventDefault(); pickImageForSlot(cur, s); }
        }
      }
    });

    prevBtn.addEventListener("click", () => goToIndex(currentIndex - 1));
    nextBtn.addEventListener("click", () => goToIndex(currentIndex + 1));

    function goToIndex(n) {
      if (entries.length === 0) return;
      currentIndex = Math.max(0, Math.min(entries.length - 1, n));
      const e = entries[currentIndex];
      const empty = e.slots.find((s) => !s.imageFile);
      focusedSlot = empty ? empty.name : (e.slots[0] ? e.slots[0].name : null);
      render();
    }
    function moveSlotFocus(dir) {
      const e = entries[currentIndex];
      if (!e || e.slots.length === 0) return;
      const i = e.slots.findIndex((s) => s.name === focusedSlot);
      const j = Math.max(0, Math.min(e.slots.length - 1, (i < 0 ? 0 : i) + dir));
      focusedSlot = e.slots[j].name;
      render();
    }
    function advanceAfterPick() {
      const e = entries[currentIndex];
      if (!e) return;
      const nextEmpty = e.slots.find((s) => !s.imageFile);
      if (nextEmpty) { focusedSlot = nextEmpty.name; render(); return; }
      for (let i = currentIndex + 1; i < entries.length; i++) {
        const ne = entries[i].slots.find((s) => !s.imageFile);
        if (ne) { currentIndex = i; focusedSlot = ne.name; render(); return; }
      }
      for (let i = 0; i < currentIndex; i++) {
        const ne = entries[i].slots.find((s) => !s.imageFile);
        if (ne) { currentIndex = i; focusedSlot = ne.name; render(); return; }
      }
      render();
      if (!saveBtn.disabled) saveBtn.focus();
    }

    // ---------- Drag & drop ----------
    ["dragenter", "dragover"].forEach((ev) =>
      drop.addEventListener(ev, (e) => { e.preventDefault(); e.stopPropagation(); drop.classList.add("is-dragover"); })
    );
    ["dragleave", "drop"].forEach((ev) =>
      drop.addEventListener(ev, (e) => { e.preventDefault(); e.stopPropagation(); drop.classList.remove("is-dragover"); })
    );
    drop.addEventListener("drop", (e) => {
      const files = e.dataTransfer ? Array.from(e.dataTransfer.files) : [];
      addFiles(files);
    });
    drop.addEventListener("click", () => input.click());
    drop.addEventListener("keydown", (e) => { if (e.key === "Enter" || e.key === " ") input.click(); });
    browse.addEventListener("click", (e) => { e.stopPropagation(); input.click(); });
    input.addEventListener("change", () => addFiles(Array.from(input.files || [])));

    clearBtn.addEventListener("click", () => {
      entries = [];
      currentIndex = 0;
      focusedSlot = null;
      if (input) input.value = "";
      render();
    });
    saveBtn.addEventListener("click", saveAll);

    // ---------- Frontmatter parser ----------
    // Handles scalar keys, boolean, numeric, inline-array, and quoted strings.
    // Nested list-of-objects blocks (imageBriefs, faq) are intentionally
    // skipped here — imageBriefs is parsed separately, everything else is
    // passed through as raw text and re-emitted untouched on save.
    function parseFrontmatter(text) {
      const m = /^---\r?\n([\s\S]*?)\r?\n---/.exec(text);
      if (!m) return { raw: "", fm: null, body: text };
      const raw = m[1];
      const fm = {};
      const lines = raw.split(/\r?\n/);
      let i = 0;
      while (i < lines.length) {
        const line = lines[i];
        if (/^\s*#/.test(line) || !line.trim()) { i++; continue; }
        const keyOnly = /^([A-Za-z_][\w]*)\s*:\s*$/.exec(line);
        if (keyOnly) { i++; while (i < lines.length && /^\s+/.test(lines[i])) i++; continue; }
        const kv = /^([A-Za-z_][\w]*)\s*:\s*(.*)$/.exec(line);
        if (!kv) { i++; continue; }
        const key = kv[1];
        let val = kv[2].trim().replace(/\s+#.*$/, "");
        if ((val.startsWith('"') && val.endsWith('"')) || (val.startsWith("'") && val.endsWith("'"))) {
          val = val.slice(1, -1);
        }
        if (val === "true")  { fm[key] = true;  i++; continue; }
        if (val === "false") { fm[key] = false; i++; continue; }
        if (/^-?\d+(\.\d+)?$/.test(val)) { fm[key] = Number(val); i++; continue; }
        if (val.startsWith("[") && val.endsWith("]")) {
          const inner = val.slice(1, -1).trim();
          fm[key] = inner ? inner.split(",").map((s) => s.trim().replace(/^["']|["']$/g, "")) : [];
          i++; continue;
        }
        fm[key] = val;
        i++;
      }
      return { raw, fm, body: text.slice(m[0].length).replace(/^\r?\n/, "") };
    }

    function parseImageBriefs(raw) {
      const lines = raw.split(/\r?\n/);
      const briefs = [];
      let inList = false;
      let cur = null;
      for (const line of lines) {
        if (/^imageBriefs\s*:/.test(line)) { inList = true; continue; }
        if (!inList) continue;
        if (/^[A-Za-z_]/.test(line)) break;
        const item = /^\s*-\s+(\w+)\s*:\s*(.*)$/.exec(line);
        const more = /^\s+(\w+)\s*:\s*(.*)$/.exec(line);
        if (item) {
          if (cur) briefs.push(cur);
          cur = {};
          cur[item[1]] = item[2].trim().replace(/^["']|["']$/g, "");
        } else if (more && cur) {
          cur[more[1]] = more[2].trim().replace(/^["']|["']$/g, "");
        }
      }
      if (cur) briefs.push(cur);
      return briefs;
    }

    function extractImageTokens(text) {
      const fmMatch = /^---\r?\n([\s\S]*?)\r?\n---/.exec(text);
      let scannable;
      if (fmMatch) {
        const fmStripped = fmMatch[1].split(/\r?\n/).filter((ln) => !/^\s*#/.test(ln)).join("\n");
        scannable = fmStripped + "\n" + text.slice(fmMatch[0].length);
      } else {
        scannable = text;
      }
      const found = [];
      const seen = new Set();
      const re = /IMAGE:([\w-]+)/g;
      let m;
      while ((m = re.exec(scannable))) { if (!seen.has(m[1])) { seen.add(m[1]); found.push(m[1]); } }
      return found;
    }
    function buildSlots(rawFm, fullText) {
      const briefs = parseImageBriefs(rawFm || "");
      const briefMap = new Map(briefs.map((b) => [b.slot, b]));
      const tokens = extractImageTokens(fullText);
      const seen = new Set();
      const order = [];
      for (const b of briefs) { if (b.slot && !seen.has(b.slot)) { order.push(b.slot); seen.add(b.slot); } }
      for (const t of tokens) { if (!seen.has(t)) { order.push(t); seen.add(t); } }
      return order.map((name) => {
        const b = briefMap.get(name) || {};
        return {
          name,
          description: b.description || "",
          alt: b.alt || "",
          imageFile: null,
          imageName: "",
        };
      });
    }

    // ---------- Validation ----------
    // The validator's job is to surface obvious problems BEFORE the user
    // hits Save — it's not a full Zod re-implementation. If a tricky
    // constraint slips through, Astro's build will catch it and print the
    // exact schema violation. Tuned to the templates we ship.
    function validate(fm) {
      const errs = [];
      if (!fm) { errs.push("missing or invalid frontmatter block"); return errs; }
      // Common fields first — same rules as the blog validator.
      if (typeof fm.title !== "string" || fm.title.length < 8 || fm.title.length > 120)
        errs.push("title must be 8–120 chars");
      if (typeof fm.description !== "string" || fm.description.length < 40 || fm.description.length > 200)
        errs.push("description must be 40–200 chars");
      if (typeof fm.heroImage !== "string" || !fm.heroImage)
        errs.push("heroImage required");
      if (typeof fm.heroAlt !== "string" || fm.heroAlt.length < 8)
        errs.push("heroAlt must be at least 8 chars");
      if (fm.publishDate && isNaN(Date.parse(fm.publishDate)))
        errs.push("publishDate invalid");

      // Per-collection extras. Every required field below maps to the Zod
      // schema in src/content/config.ts — if you add a schema field, add the
      // check here so broken templates fail in the modal, not at build.
      if (collection === "services") {
        if (fm.priceFrom === undefined || typeof fm.priceFrom !== "number" || fm.priceFrom < 0)
          errs.push("priceFrom required (number)");
      } else if (collection === "locations") {
        if (typeof fm.suburb !== "string" || !fm.suburb) errs.push("suburb required");
        if (typeof fm.postcode !== "string" || !/^\d{4}$/.test(fm.postcode)) errs.push("postcode must be 4 digits");
        if (typeof fm.latitude !== "number")  errs.push("latitude must be a number");
        if (typeof fm.longitude !== "number") errs.push("longitude must be a number");
      } else if (collection === "products") {
        if (typeof fm.brand !== "string" || !fm.brand) errs.push("brand required");
        if (typeof fm.model !== "string" || !fm.model) errs.push("model required");
        const PRODUCT_CATS = ["tv", "soundbar", "media-box", "cable", "accessory"];
        if (!PRODUCT_CATS.includes(fm.category))
          errs.push(`category must be one of: ${PRODUCT_CATS.join(", ")}`);
        if (fm.priceAud === undefined || typeof fm.priceAud !== "number" || fm.priceAud < 0)
          errs.push("priceAud required (number)");
      } else if (collection === "mounts") {
        if (typeof fm.brand !== "string" || !fm.brand) errs.push("brand required");
        if (typeof fm.model !== "string" || !fm.model) errs.push("model required");
        const MOUNT_TYPES = ["fixed", "tilt", "full-motion", "ceiling", "outdoor"];
        if (!MOUNT_TYPES.includes(fm.mountType))
          errs.push(`mountType must be one of: ${MOUNT_TYPES.join(", ")}`);
        if (fm.priceAud === undefined || typeof fm.priceAud !== "number" || fm.priceAud < 0)
          errs.push("priceAud required (number)");
      }
      return errs;
    }

    // ---------- Slug + extension helpers ----------
    function slugFromFilename(name) {
      return name.replace(/\.md$/i, "").toLowerCase()
        .replace(/[^a-z0-9-_]+/g, "-").replace(/^-+|-+$/g, "");
    }
    function extOf(name) {
      const m = /\.([A-Za-z0-9]+)$/.exec(name || "");
      return m ? m[1].toLowerCase() : "jpg";
    }

    /**
     * Re-encode a picked image as WebP via a <canvas>. All-browser. See the
     * blogs admin page for the full rationale — short version: quality 0.85,
     * max edge 2400px, skips files already encoded as webp, falls back to
     * the original if decoding fails. Preserves basename, swaps extension.
     */
    async function toWebp(file, { quality = 0.85, maxEdge = 2400 } = {}) {
      if (!file || file.type === "image/webp") return file;
      let bitmap;
      try { bitmap = await createImageBitmap(file); }
      catch (err) { console.warn("WebP: couldn't decode, keeping original:", file.name, err); return file; }
      const scale = Math.min(1, maxEdge / Math.max(bitmap.width, bitmap.height));
      const w = Math.max(1, Math.round(bitmap.width * scale));
      const h = Math.max(1, Math.round(bitmap.height * scale));
      const canvas = document.createElement("canvas");
      canvas.width = w; canvas.height = h;
      const ctx = canvas.getContext("2d");
      ctx.drawImage(bitmap, 0, 0, w, h);
      const blob = await new Promise((res) => canvas.toBlob(res, "image/webp", quality));
      if (typeof bitmap.close === "function") bitmap.close();
      if (!blob) { console.warn("WebP: toBlob returned null, keeping original:", file.name); return file; }
      const base = (file.name || "image").replace(/\.[^.]+$/, "");
      return new File([blob], `${base}.webp`, { type: "image/webp" });
    }

    // ---------- Adding files ----------
    async function addFiles(files) {
      const mdFiles = files.filter((f) => /\.md$/i.test(f.name));
      if (mdFiles.length === 0) { summary.textContent = "No .md files in that selection."; return; }
      const remaining = MAX_FILES - entries.length;
      const accept = mdFiles.slice(0, remaining);
      const rejected = mdFiles.length - accept.length;

      for (const f of accept) {
        if (entries.some((e) => e.file.name === f.name)) continue;
        const text = await f.text();
        const { raw, fm, body } = parseFrontmatter(text);
        const errs = validate(fm);
        const slug = (fm && typeof fm.slug === "string" && fm.slug) ? fm.slug : slugFromFilename(f.name);
        const slots = buildSlots(raw, text);
        entries.push({
          file: f, text, raw, body,
          fm: fm || {}, slug, slots,
          status: "needs", msg: "",
          _errs: errs,
        });
      }
      if (rejected > 0) summary.textContent = `Added ${accept.length}. Skipped ${rejected} — 50-file limit.`;
      input.value = "";
      if (entries.length > 0) {
        const firstNeedy = entries.findIndex((e) => e.slots.some((s) => !s.imageFile));
        currentIndex = firstNeedy >= 0 ? firstNeedy : 0;
        const e = entries[currentIndex];
        const empty = e.slots.find((s) => !s.imageFile);
        focusedSlot = empty ? empty.name : (e.slots[0] ? e.slots[0].name : null);
      }
      render();
    }

    function updateEntryStatus(e) {
      if (e.status === "saved") return;
      if (e._errs && e._errs.length) { e.status = "error"; e.msg = e._errs.join(" · "); return; }
      if (e.slots.length === 0) { e.status = "ready"; e.msg = "No images needed — ready to save."; return; }
      const filled = e.slots.filter((s) => s.imageFile).length;
      const missing = e.slots.length - filled;
      if (missing === 0) { e.status = "ready"; e.msg = `All ${e.slots.length} image${e.slots.length === 1 ? "" : "s"} picked.`; }
      else { e.status = "needs"; e.msg = `${missing} image${missing === 1 ? "" : "s"} still to pick.`; }
    }

    async function pickImageForSlot(entry, slot) {
      if (!window.showOpenFilePicker) { alert("Your browser can't open file pickers. Use Chrome or Edge."); return; }
      try {
        const [h] = await window.showOpenFilePicker({
          multiple: false,
          types: [{
            description: "Images",
            accept: { "image/*": [".jpg", ".jpeg", ".png", ".webp", ".gif", ".avif"] },
          }],
        });
        const raw = await h.getFile();
        const f = await toWebp(raw);
        slot.imageFile = f;
        slot.imageName = f.name;
        focusedSlot = slot.name;
        advanceAfterPick();
      } catch (err) {
        if (err && err.name === "AbortError") return;
        console.error(err);
        alert("Could not open image.");
      }
    }

    // ---------- Render ----------
    function render() {
      if (entries.length === 0) {
        stripEl.hidden = true; focusEl.hidden = true;
        summary.textContent = "No files yet.";
        saveBtn.disabled = true; clearBtn.disabled = true;
        return;
      }
      stripEl.hidden = entries.length <= 1;
      focusEl.hidden = false;

      for (const e of entries) updateEntryStatus(e);
      const ready = entries.filter((e) => e.status === "ready").length;
      const needs = entries.filter((e) => e.status === "needs").length;
      const errs  = entries.filter((e) => e.status === "error").length;
      const saved = entries.filter((e) => e.status === "saved").length;
      const parts = [`${entries.length} file${entries.length === 1 ? "" : "s"}`];
      parts.push(`${ready} ready`);
      if (needs) parts.push(`${needs} need images`);
      if (errs)  parts.push(`${errs} with errors`);
      if (saved) parts.push(`${saved} saved`);
      summary.textContent = parts.join(" · ");
      saveBtn.disabled = (ready - saved) <= 0;
      clearBtn.disabled = false;

      // Dot rail
      dotsEl.innerHTML = "";
      entries.forEach((e, i) => {
        const dot = document.createElement("button");
        dot.type = "button";
        dot.className = `bulk-dot is-${e.status}` + (i === currentIndex ? " is-current" : "");
        const titleHead = `${i + 1}. ${e.fm.title || e.file.name}`;
        if (e.status === "error") {
          const why = (e._errs && e._errs.length) ? e._errs.join(" · ") : "validation failed";
          dot.setAttribute("aria-label", `${titleHead} — INVALID TEMPLATE: ${why}`);
          dot.title = `${titleHead} — Invalid template\n${why}`;
        } else {
          dot.setAttribute("aria-label", `${titleHead} (${e.status})`);
          dot.title = `${titleHead} — ${e.status}`;
        }
        dot.addEventListener("click", () => goToIndex(i));
        dotsEl.appendChild(dot);
      });
      if (stripCountEl) stripCountEl.textContent = `${currentIndex + 1} / ${entries.length}`;

      if (stripErrEl) {
        const bad = entries.map((e, i) => ({ e, i })).filter(({ e }) => e.status === "error");
        if (bad.length === 0) {
          stripErrEl.hidden = true; stripErrEl.onclick = null;
          stripErrEl.title = ""; stripErrEl.textContent = "Invalid template";
        } else {
          stripErrEl.hidden = false;
          stripErrEl.textContent = bad.length === 1 ? "Invalid template" : `${bad.length} invalid`;
          stripErrEl.title = bad.map(({ e, i }) => `#${i + 1} ${e.fm.title || e.file.name}: ${(e._errs || []).join(" · ")}`).join("\n");
          stripErrEl.style.cursor = "pointer";
          stripErrEl.onclick = () => goToIndex(bad[0].i);
        }
      }
      prevBtn.disabled = currentIndex <= 0;
      nextBtn.disabled = currentIndex >= entries.length - 1;

      // Focus view
      const e = entries[currentIndex];
      if (!e) { focusEl.innerHTML = ""; return; }
      focusEl.innerHTML = "";

      // Metadata card (read-only — unlike blogs we don't expose editable
      // author/date/style fields; these collections have too many schema
      // variations for an inline form. User edits frontmatter in-file or
      // via Decap after save.)
      const meta = document.createElement("div");
      meta.className = "bf-meta-card";
      const metaTop = document.createElement("div");
      metaTop.className = "bf-meta-top";
      const metaMain = document.createElement("div");
      metaMain.className = "bf-meta-main";

      const pos = document.createElement("div");
      pos.className = "bf-pos";
      const filled = e.slots.filter((s) => s.imageFile).length;
      pos.textContent = e.slots.length > 0
        ? `${collectionLabel.singular[0].toUpperCase() + collectionLabel.singular.slice(1)} ${currentIndex + 1} of ${entries.length} · ${filled}/${e.slots.length} images`
        : `${collectionLabel.singular[0].toUpperCase() + collectionLabel.singular.slice(1)} ${currentIndex + 1} of ${entries.length}`;
      metaMain.appendChild(pos);

      const title = document.createElement("div");
      title.className = "bf-title";
      title.textContent = e.fm.title || e.file.name;
      metaMain.appendChild(title);

      const slugRow = document.createElement("div");
      slugRow.className = "bf-slug-row";
      slugRow.title = `Will save to src/content/${collection}/${e.slug}.md`;
      const slugPrefix = document.createElement("span");
      slugPrefix.className = "bf-slug-prefix";
      slugPrefix.textContent = CFG.slugPrefix;
      const slugText = document.createElement("span");
      slugText.textContent = e.slug;
      slugRow.appendChild(slugPrefix);
      slugRow.appendChild(slugText);
      metaMain.appendChild(slugRow);

      const fileLine = document.createElement("span");
      fileLine.className = "bf-file";
      fileLine.textContent = `source: ${e.file.name}`;
      metaMain.appendChild(fileLine);
      metaTop.appendChild(metaMain);

      const status = document.createElement("span");
      status.className = `bf-status ${e.status}`;
      status.textContent =
        e.status === "ready" ? "Ready" :
        e.status === "needs" ? "Needs images" :
        e.status === "error" ? "Error" :
        e.status === "saved" ? "Saved" : "";
      metaTop.appendChild(status);

      const remove = document.createElement("button");
      remove.type = "button";
      remove.className = "bf-remove";
      remove.setAttribute("aria-label", `Remove ${e.file.name}`);
      remove.textContent = "×";
      remove.addEventListener("click", () => {
        entries = entries.filter((x) => x !== e);
        if (currentIndex >= entries.length) currentIndex = Math.max(0, entries.length - 1);
        focusedSlot = null;
        render();
      });
      metaTop.appendChild(remove);
      meta.appendChild(metaTop);
      focusEl.appendChild(meta);

      if (e._errs && e._errs.length) {
        const errBox = document.createElement("div");
        errBox.className = "bf-errors";
        errBox.innerHTML = "<strong>Won't save until fixed:</strong> " + e._errs.join(" · ");
        focusEl.appendChild(errBox);
      }

      // Images card
      if (e.slots.length === 0) {
        const empty = document.createElement("div");
        empty.className = "bf-empty-state";
        empty.textContent = "No images needed for this entry. Press → to move on, or Save all.";
        focusEl.appendChild(empty);
      } else {
        const imgCard = document.createElement("div");
        imgCard.className = "bf-images-card";
        const imgHead = document.createElement("div");
        imgHead.className = "bf-images-head";
        const imgTitle = document.createElement("div");
        imgTitle.className = "bf-images-title";
        imgTitle.textContent = "Images";
        const imgCount = document.createElement("div");
        imgCount.className = "bf-images-count";
        imgCount.textContent = `${filled} of ${e.slots.length} picked`;
        imgHead.appendChild(imgTitle);
        imgHead.appendChild(imgCount);
        imgCard.appendChild(imgHead);

        const slotsBox = document.createElement("div");
        slotsBox.className = "bf-slots";
        for (const s of e.slots) {
          const card = document.createElement("div");
          card.className = "bf-slot" + (s.imageFile ? " is-filled" : "") + (s.name === focusedSlot ? " is-focused" : "");
          card.tabIndex = -1;
          card.dataset.slot = s.name;
          card.addEventListener("click", (ev) => {
            if (ev.target.closest("button")) return;
            focusedSlot = s.name; render();
          });

          const ch = document.createElement("div");
          ch.className = "bf-slot-head";
          const tag = document.createElement("span");
          tag.className = "bf-slot-tag";
          tag.textContent = `IMAGE:${s.name}`;
          ch.appendChild(tag);
          const flag = document.createElement("span");
          flag.className = "bf-slot-flag";
          flag.textContent = s.imageFile ? "✓ picked" : "required";
          ch.appendChild(flag);
          card.appendChild(ch);

          if (s.description) {
            const desc = document.createElement("p"); desc.className = "bf-slot-desc"; desc.textContent = s.description;
            card.appendChild(desc);
          }
          if (s.alt) {
            const alt = document.createElement("p"); alt.className = "bf-slot-alt"; alt.textContent = `alt: ${s.alt}`;
            card.appendChild(alt);
          }

          const picker = document.createElement("div");
          picker.className = "bf-slot-picker";
          const btn = document.createElement("button");
          btn.type = "button";
          btn.className = "btn-slot";
          btn.textContent = s.imageFile ? "Change image…" : "Pick image…";
          btn.addEventListener("click", () => pickImageForSlot(e, s));
          picker.appendChild(btn);

          if (s.imageFile) {
            const name = document.createElement("span");
            name.className = "bf-filename";
            const willSaveAs = `${e.slug}-${s.name}.${extOf(s.imageName)}`;
            name.textContent = `${s.imageName} → ${willSaveAs}`;
            name.title = `Will be saved to /media/${willSaveAs}`;
            picker.appendChild(name);

            const clear = document.createElement("button");
            clear.type = "button";
            clear.className = "bf-slot-clear";
            clear.textContent = "×";
            clear.setAttribute("aria-label", "Clear image");
            clear.addEventListener("click", () => { s.imageFile = null; s.imageName = ""; focusedSlot = s.name; render(); });
            picker.appendChild(clear);
          }
          card.appendChild(picker);
          slotsBox.appendChild(card);
        }
        imgCard.appendChild(slotsBox);
        focusEl.appendChild(imgCard);

        requestAnimationFrame(() => {
          const node = focusEl.querySelector(".bf-slot.is-focused");
          if (node) node.scrollIntoView({ block: "nearest", behavior: "smooth" });
        });
      }
    }

    // ---------- Save ----------
    async function ensureRoot() {
      if (rootHandle && await verifyHandle(rootHandle)) return rootHandle;
      if (!window.showDirectoryPicker) { alert("Your browser can't pick folders. Use Chrome or Edge."); return null; }
      try {
        const h = await window.showDirectoryPicker({ mode: "readwrite" });
        if (!(await verifyHandle(h))) return null;
        rootHandle = h;
        try { await idbSet(IDB_ROOT_KEY, h); } catch (_) {}
        return rootHandle;
      } catch (err) { if (err && err.name !== "AbortError") { console.error(err); alert("Could not open folder."); } return null; }
    }
    async function getSubdir(root, parts) {
      let d = root;
      for (const p of parts) d = await d.getDirectoryHandle(p, { create: true });
      return d;
    }

    // Build final .md text: replace IMAGE:xxx with /media/<slug>-<slot>.<ext>,
    // then strip the imageBriefs block (it's an authoring aid, not content).
    function buildSavedText(entry) {
      const pathMap = new Map();
      for (const s of entry.slots) {
        const filename = `${entry.slug}-${s.name}.${extOf(s.imageName)}`;
        pathMap.set(s.name, `/media/${filename}`);
      }
      let text = entry.text.replace(/IMAGE:([\w-]+)/g, (m, slot) => pathMap.get(slot) || m);
      text = text.replace(/\n[ \t]*imageBriefs\s*:[^\n]*(?:\n[ \t]+[^\n]*)*/g, "");
      return text;
    }

    async function saveOne(entry, mediaDir, contentDir) {
      for (const s of entry.slots) {
        if (!s.imageFile) continue;
        const filename = `${entry.slug}-${s.name}.${extOf(s.imageName)}`;
        const fh = await mediaDir.getFileHandle(filename, { create: true });
        const w = await fh.createWritable();
        await w.write(await s.imageFile.arrayBuffer());
        await w.close();
      }
      const mdName = `${entry.slug}.md`;
      const fh = await contentDir.getFileHandle(mdName, { create: true });
      const w = await fh.createWritable();
      await w.write(buildSavedText(entry));
      await w.close();
      return mdName;
    }

    function fileToBase64(file) {
      return new Promise((resolve, reject) => {
        const r = new FileReader();
        r.onload = () => {
          const s = r.result || "";
          const comma = s.indexOf(",");
          resolve(comma >= 0 ? s.slice(comma + 1) : s);
        };
        r.onerror = () => reject(r.error);
        r.readAsDataURL(file);
      });
    }
    async function decapCall(action, params) {
      const r = await fetch(DECAP_URL, {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ action, params }),
      });
      if (!r.ok) {
        let body = "";
        try { body = await r.text(); } catch (_) {}
        throw new Error(`Decap ${action} ${r.status}: ${body || r.statusText}`);
      }
      return await r.json();
    }
    async function saveOneViaDecap(entry) {
      for (const s of entry.slots) {
        if (!s.imageFile) continue;
        const filename = `${entry.slug}-${s.name}.${extOf(s.imageName)}`;
        const content = await fileToBase64(s.imageFile);
        await decapCall("persistMedia", {
          branch: DECAP_BRANCH,
          asset: { path: `public/media/${filename}`, content, encoding: "base64" },
          options: { commitMessage: `Upload ${filename}` },
        });
      }
      const raw = buildSavedText(entry);
      const collectionTitle = DECAP_COLLECTION[0].toUpperCase() + DECAP_COLLECTION.slice(1);
      await decapCall("persistEntry", {
        branch: DECAP_BRANCH,
        entry: {
          slug: entry.slug,
          path: `src/content/${collection}/${entry.slug}.md`,
          raw,
        },
        assets: [],
        options: {
          commitMessage: `Create ${collectionTitle} "${(entry.fm && entry.fm.title) || entry.slug}"`,
          useWorkflow: false,
          status: "draft",
        },
        cmsLabelPrefix: undefined,
      });
      return `${entry.slug}.md`;
    }

    async function saveAll() {
      const savable = entries.filter((e) => e.status === "ready");
      if (savable.length === 0) return;
      if (!decapOnline) await updateConnectionBanner();

      let useDecap = decapOnline;
      let contentDir, mediaDir;

      if (!useDecap) {
        const root = await ensureRoot();
        if (!root) return;
        try {
          contentDir = await getSubdir(root, CFG.contentDir);
          mediaDir   = await getSubdir(root, ["astro", "public", "media"]);
        } catch (err) {
          console.error(err);
          alert(`Couldn't find astro/src/content/${collection} or astro/public/media inside the folder you picked. Make sure you pick the Brisbane TVs project root (the folder that has astro/ inside it).`);
          return;
        }
      }

      let saved = 0, failed = 0;
      for (const e of savable) {
        try {
          let mdName;
          if (useDecap) mdName = await saveOneViaDecap(e);
          else          mdName = await saveOne(e, mediaDir, contentDir);
          e.status = "saved";
          const imgCount = e.slots.filter((s) => s.imageFile).length;
          e.msg = imgCount > 0
            ? `Saved ${mdName} + ${imgCount} image${imgCount === 1 ? "" : "s"}.`
            : `Saved ${mdName}.`;
          saved++;
        } catch (err) {
          console.error(err);
          e.status = "error";
          e._errs = [`Write failed: ${err && err.message ? err.message : err}`];
          e.msg = e._errs[0];
          failed++;
        }
        render();
      }
      if (saved > 0) {
        const via = useDecap ? "via CMS" : "to folder";
        summary.textContent = `Saved ${saved} ${collectionLabel.singular}${saved === 1 ? "" : "s"} ${via}${failed ? ` · ${failed} failed` : ""}. Refresh the page to see them.`;
      }
    }
  })();
</script>

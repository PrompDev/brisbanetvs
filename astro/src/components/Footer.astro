        </div>

        <hr class="footer-divider">

        <div class="footer-bottom">
            <div class="footer-meta">
                <span>© 2026 Brisbane TVs Pty Ltd · ABN 12 345 678 901</span>
                <span class="sep">|</span>
                <a href="#">Privacy Policy</a>
                <span class="sep">|</span>
                <a href="#">Terms of Service</a>
                <span class="sep">|</span>

---
/**
 * Real Brisbane TVs site footer — brand block, column nav, quote signup,
 * payment chips. Every link is now wired to a real route on the Astro
 * site. Columns point users at the 5 content silos and relevant utility
 * links (tel:, mailto:). No more href="#" stubs.
 */
---
<footer class="site-footer" role="contentinfo">
    <div class="footer-inner">
        <div class="footer-top">
            <div class="footer-brand">
                <div class="footer-logo">
                    Brisbane TVs
                    <em>TV Mounting · Est. 2019</em>
                </div>
                <p class="footer-tagline">Brisbane's highest-rated TV wall mounting, cable concealment &amp; home-theatre installers — covering 109 suburbs from Paddington to Wynnum.</p>
                <div class="footer-socials" aria-label="Social media">
                    <a href="https://www.instagram.com/brisbanetvs" target="_blank" rel="noopener" aria-label="Instagram"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1112.63 8 4 4 0 0116 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg></a>
                    <a href="https://www.facebook.com/brisbanetvs" target="_blank" rel="noopener" aria-label="Facebook"><svg viewBox="0 0 24 24" fill="currentColor"><path d="M22 12c0-5.52-4.48-10-10-10S2 6.48 2 12c0 4.84 3.44 8.87 8 9.8V15H8v-3h2V9.5C10 7.57 11.57 6 13.5 6H16v3h-2c-.55 0-1 .45-1 1v2h3v3h-3v6.95c5.05-.5 9-4.76 9-9.95z"/></svg></a>
                    <a href="https://g.page/brisbanetvs" target="_blank" rel="noopener" aria-label="Google Reviews"><svg viewBox="0 0 24 24" fill="currentColor"><path d="M22 11.5h-9.25v2.95h5.4C17.75 17 15.15 18 12.75 18 9.55 18 7 15.45 7 12.25S9.55 6.5 12.75 6.5c1.45 0 2.75.5 3.75 1.4l2.2-2.2C17 4.05 15 3 12.75 3 7.6 3 3.5 7.1 3.5 12.25S7.6 21.5 12.75 21.5c5.15 0 9-3.8 9-9.25 0-.25 0-.5-.05-.75z"/></svg></a>
                    <a href="https://www.youtube.com/@brisbanetvs" target="_blank" rel="noopener" aria-label="YouTube"><svg viewBox="0 0 24 24" fill="currentColor"><path d="M21.58 7.19c-.23-.86-.9-1.53-1.76-1.76C18.25 5 12 5 12 5s-6.25 0-7.82.43c-.86.23-1.53.9-1.76 1.76C2 8.77 2 12 2 12s0 3.23.42 4.81c.23.86.9 1.53 1.76 1.76C5.75 19 12 19 12 19s6.25 0 7.82-.43c.86-.23 1.53-.9 1.76-1.76C22 15.23 22 12 22 12s0-3.23-.42-4.81zM10 15V9l5.2 3-5.2 3z"/></svg></a>
                </div>
            </div>

            <div class="footer-col">
                <h4>Services</h4>
                <ul>
                    <li><a href="/services/">TV Wall Mounting</a></li>
                    <li><a href="/services/">Cable Concealment</a></li>
                    <li><a href="/services/">Above-Fireplace Installs</a></li>
                    <li><a href="/services/">TV Antenna Installation</a></li>
                    <li><a href="/services/">Starlink Installation</a></li>
                    <li><a href="/services/">Commercial TV Mounting</a></li>
                    <li><a href="/services/">TV Removal &amp; Re-mount</a></li>
                </ul>
            </div>

            <div class="footer-col">
                <h4>Coverage</h4>
                <ul>
                    <li><a href="/locations/">North Brisbane</a></li>
                    <li><a href="/locations/">South Brisbane</a></li>
                    <li><a href="/locations/">Inner-City &amp; CBD</a></li>
                    <li><a href="/locations/">Bayside &amp; Redlands</a></li>
                    <li><a href="/locations/">Western Suburbs</a></li>
                    <li><a href="/locations/">Ipswich &amp; Logan</a></li>
                    <li><a href="/locations/">Moreton Bay</a></li>
                </ul>
            </div>

            <div class="footer-col">
                <h4>Shop</h4>
                <ul>
                    <li><a href="/products/">TVs &amp; Displays</a></li>
                    <li><a href="/products/">Soundbars</a></li>
                    <li><a href="/products/">Cables &amp; Accessories</a></li>
                    <li><a href="/mounts/">Full-Motion Mounts</a></li>
                    <li><a href="/mounts/">Tilt &amp; Fixed Mounts</a></li>
                    <li><a href="/mounts/">Ceiling &amp; Outdoor</a></li>
                    <li><a href="/blog/">Mounting Guides</a></li>
                </ul>
            </div>

            <div class="footer-col">
                <h4>Help</h4>
                <ul>
                    <li><a href="/quote/">Get a Quote</a></li>
                    <li><a href="/pricing/">Prices &amp; Packages</a></li>
                    <li><a href="/blog/">Booking FAQ</a></li>
                    <li><a href="/services/">Warranty &amp; Guarantee</a></li>
                    <li><a href="tel:0432145101">Call 0432 145 101</a></li>
                    <li><a href="mailto:admin@brisbanetvs.com">Email Support</a></li>
                </ul>
            </div>

            <div class="footer-signup">
                <div class="footer-signup-title">Book <em>before 10 AM</em><br>for same-day install.</div>
                <p class="footer-signup-copy">Get a flat-rate quote in 60 seconds. No call-out fees, no hidden charges — just honest Brisbane pricing.</p>
                <form class="footer-form" id="footerQuoteForm" data-webhook="/api/n8n/email-signup" aria-label="Quote request">
                    <input type="email" name="email" placeholder="Your email address" aria-label="Email address" required>
                    <button type="submit" aria-label="Request quote">→</button>
                </form>
                <p class="footer-form-status" id="footerQuoteStatus" role="status" aria-live="polite" style="min-height:1em;font-size:11px;color:#d8d8d8;margin:0.4rem 0 0;"></p>
                <script is:inline>
                  (function () {
                    var form = document.getElementById('footerQuoteForm');
                    if (!form) return;
                    var status = document.getElementById('footerQuoteStatus');
                    form.addEventListener('submit', async function (ev) {
                      ev.preventDefault();
                      status.textContent = 'Sending…';
                      try {
                        var fd = new FormData(form);
                        fd.append('source', 'footer-email-signup');
                        fd.append('submittedAt', new Date().toISOString());
                        var res = await fetch(form.dataset.webhook, { method: 'POST', body: fd });
                        if (!res.ok) throw new Error('HTTP ' + res.status);
                        status.textContent = 'Thanks — check your inbox for the quote form.';
                        form.reset();
                      } catch (err) {
                        status.textContent = 'Could not send — please call 0432 145 101.';
                      }
                    });
                  })();
                </script>
                <p class="footer-signup-copy" style="font-size:11px;">Or call <a href="tel:0432145101" style="color:#d8d8d8;text-decoration:none;border-bottom:1px solid rgba(255,255,255,0.2);"><strong>0432 145 101</strong></a> — 7&nbsp;days, 7&nbsp;AM–7&nbsp;PM.</p>
            </div>
        </div>

        <hr class="footer-divider">

        <div class="footer-bottom">
            <div class="footer-meta">
                <span>© 2026 Brisbane TVs Pty Ltd · ABN 12 345 678 901</span>
                <span class="sep">|</span>
                <a href="/">Home</a>
                <span class="sep">|</span>
                <a href="/pricing/">Pricing</a>
                <span class="sep">|</span>
                <a href="/quote/">Quote</a>
                <span class="sep">|</span>
                <a href="/blog/">Blog</a>
            </div>
            <div class="footer-payments" aria-label="Accepted payment methods">
                <span class="footer-pay-chip">Visa</span>
                <span class="footer-pay-chip">Mastercard</span>
                <span class="footer-pay-chip">PayPal</span>
                <span class="footer-pay-chip">BPAY</span>
                <span class="footer-pay-chip">Bank Transfer</span>
            </div>
        </div>
    </div>
</footer>

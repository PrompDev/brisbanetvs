---
import BaseLayout from "~/layouts/BaseLayout.astro";
import { BUSINESS, PACKAGES } from "~/data/business";

/**
 * /quote/ — the "deep" quote form.
 *
 * The pricing page (/pricing/) package cards link here with ?package=<id>,
 * so this page needs to (a) preselect that package on load, and (b) let
 * the visitor upload a photo of the wall + attach any extra context Tom
 * might need to lock in the final number.
 *
 * It's intentionally more form, more copy, more trust — this is where
 * visitors who hesitated at /pricing/ come to commit. Photo upload is
 * the "bait" (Tom's word) that converts custom-quote cases which would
 * otherwise never phone.
 *
 * Submits to BUSINESS.webhooks.photoQuote (separate from quickQuote so
 * the n8n workflow can branch on lead quality / file upload presence).
 */

const pageUrl = new URL("/quote/", Astro.site).toString();
const businessUrl = new URL("/", Astro.site).toString();

const breadcrumbLd = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    { "@type": "ListItem", position: 1, name: "Home", item: businessUrl },
    { "@type": "ListItem", position: 2, name: "Get a quote", item: pageUrl },
  ],
};

// Contact point JSON-LD — helps Google show our phone on the SERP.
const contactLd = {
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  name: BUSINESS.name,
  telephone: BUSINESS.phoneDisplay,
  email: BUSINESS.email,
  url: businessUrl,
  priceRange: "$$",
  areaServed: "Greater Brisbane",
};
---
<BaseLayout
  title="Get a TV Mounting Quote — Brisbane TVs"
  description="Send a photo of your wall and we'll lock in a flat-rate TV mounting quote within the hour. Same-day bookings, $20M insured, 12-month workmanship warranty."
  canonical={pageUrl}
>
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbLd)} />
  <script type="application/ld+json" set:html={JSON.stringify(contactLd)} />

  <section class="qt-banner">
    <img class="qt-banner-img" src="https://cdn.brisbanetvs.com/install-toowong1200x1200.webp" alt="" aria-hidden="true" />
    <div class="qt-banner-inner">
      <p class="qt-banner-title">Get a Quote</p>
    </div>
  </section>

  <article class="qt">
    <div class="qt-hero">
      <nav class="qt-crumbs" aria-label="Breadcrumb">
        <a href="/">Home</a>
        <span aria-hidden="true">›</span>
        <a href="/pricing/">Pricing</a>
        <span aria-hidden="true">›</span>
        <span class="qt-crumbs-current">Get a quote</span>
      </nav>
      <p class="qt-eyebrow">Brisbane TVs · Free, no-commitment quote</p>
      <h1>Send a photo. Get a locked-in price.</h1>
      <p class="qt-lede">
        Snap the wall you want the TV on, tell us the size, and we'll reply within
        the hour with a flat-rate quote, the matching package, and the next
        available install slot. No call-out fees. No hourly clocks.
      </p>
      <div class="qt-hero-cta-row">
        <a class="qt-btn qt-btn-ghost" href={BUSINESS.phoneTel}>Or call {BUSINESS.phoneDisplay}</a>
        <a class="qt-btn qt-btn-link" href="/pricing/">See all package prices →</a>
      </div>
    </div>

    <hr class="qt-divider" />

    <div class="qt-grid">
      <form
        class="qt-form"
        id="quote-form"
        data-webhook={BUSINESS.webhooks.photoQuote}
        enctype="multipart/form-data"
        aria-label="Photo quote form"
      >
        <fieldset class="qt-fieldset">
          <legend class="qt-legend">1. Your TV</legend>

          <div class="qt-field">
            <label for="q-package">Package</label>
            <select id="q-package" name="package" required>
              <option value="">Pick the package that fits your TV</option>
              {PACKAGES.map((p) => (
                <option value={p.id}>
                  {p.name} — {p.sizeLabel}
                  {p.priceAud !== null ? ` (from $${p.priceAud})` : " (custom quote)"}
                </option>
              ))}
              <option value="unsure">Not sure — help me pick</option>
            </select>
            <p class="qt-hint">Pre-selected from /pricing/ if you came from a package card.</p>
          </div>

          <div class="qt-field qt-field-pair">
            <div>
              <label for="q-size">TV size (inches)</label>
              <input
                type="number"
                id="q-size"
                name="tvSize"
                min="30"
                max="130"
                step="1"
                placeholder="e.g. 75"
                autocomplete="off"
              />
            </div>
            <div>
              <label for="q-brand">Brand & model <span class="qt-muted">(optional)</span></label>
              <input
                type="text"
                id="q-brand"
                name="tvBrand"
                placeholder="e.g. Samsung S95D"
                autocomplete="off"
              />
            </div>
          </div>

          <div class="qt-field">
            <label for="q-wall">Wall type</label>
            <select id="q-wall" name="wallType" required>
              <option value="">Select wall type…</option>
              <option value="plasterboard">Plasterboard (timber stud)</option>
              <option value="plasterboard-steel">Plasterboard (steel stud)</option>
              <option value="brick">Exposed / rendered brick</option>
              <option value="concrete">Concrete / cement block</option>
              <option value="fibro">Fibro / weatherboard</option>
              <option value="tile">Tiled / feature wall</option>
              <option value="not-sure">Not sure — you'll tell me</option>
            </select>
          </div>

          <div class="qt-field">
            <label>Install extras <span class="qt-muted">(tick all that apply)</span></label>
            <div class="qt-checks">
              <label class="qt-check"><input type="checkbox" name="extras" value="cable-concealment" /> In-wall cable concealment</label>
              <label class="qt-check"><input type="checkbox" name="extras" value="soundbar" /> Soundbar mount</label>
              <label class="qt-check"><input type="checkbox" name="extras" value="above-fireplace" /> Above-fireplace lift</label>
              <label class="qt-check"><input type="checkbox" name="extras" value="power-relocation" /> New power point behind TV</label>
              <label class="qt-check"><input type="checkbox" name="extras" value="outdoor" /> Outdoor / alfresco install</label>
              <label class="qt-check"><input type="checkbox" name="extras" value="remove-old" /> Remove or relocate existing TV</label>
            </div>
          </div>
        </fieldset>

        <fieldset class="qt-fieldset">
          <legend class="qt-legend">2. Photo of the wall</legend>
          <p class="qt-hint">
            Upload a photo (or two) so we can see the wall, skirting, power points,
            and any obstacles. This is the fastest way to lock in a real price.
            Max 10 MB each, JPG / PNG / HEIC.
          </p>
          <div class="qt-field">
            <label for="q-photo" class="qt-file-label">
              <span class="qt-file-btn">Choose photo(s)</span>
              <span class="qt-file-name" id="q-photo-name">No file chosen</span>
            </label>
            <input
              type="file"
              id="q-photo"
              name="photo"
              accept="image/*"
              multiple
              class="qt-file-input"
            />
          </div>
        </fieldset>

        <fieldset class="qt-fieldset">
          <legend class="qt-legend">3. Where & when</legend>

          <div class="qt-field">
            <label for="q-suburb">Suburb</label>
            <input
              type="text"
              id="q-suburb"
              name="suburb"
              required
              placeholder="e.g. New Farm"
              autocomplete="address-level2"
            />
          </div>

          <div class="qt-field qt-field-pair">
            <div>
              <label for="q-postcode">Postcode <span class="qt-muted">(optional)</span></label>
              <input
                type="text"
                id="q-postcode"
                name="postcode"
                pattern="[0-9]{4}"
                placeholder="4000"
                autocomplete="postal-code"
              />
            </div>
            <div>
              <label for="q-preferred-day">Preferred day</label>
              <select id="q-preferred-day" name="preferredDay">
                <option value="">Any day this week</option>
                <option value="asap">ASAP — same day if possible</option>
                <option value="weekday-morning">Weekday mornings</option>
                <option value="weekday-afternoon">Weekday afternoons</option>
                <option value="saturday">Saturday</option>
                <option value="next-week">Next week</option>
                <option value="flexible">Flexible — whenever fits you</option>
              </select>
            </div>
          </div>
        </fieldset>

        <fieldset class="qt-fieldset">
          <legend class="qt-legend">4. Your details</legend>

          <div class="qt-field qt-field-pair">
            <div>
              <label for="q-name">Full name</label>
              <input
                type="text"
                id="q-name"
                name="name"
                required
                autocomplete="name"
              />
            </div>
            <div>
              <label for="q-phone">Phone</label>
              <input
                type="tel"
                id="q-phone"
                name="phone"
                required
                placeholder="0412 345 678"
                autocomplete="tel"
              />
            </div>
          </div>

          <div class="qt-field">
            <label for="q-email">Email</label>
            <input
              type="email"
              id="q-email"
              name="email"
              required
              autocomplete="email"
            />
          </div>

          <div class="qt-field">
            <label for="q-notes">Anything else we should know? <span class="qt-muted">(optional)</span></label>
            <textarea
              id="q-notes"
              name="notes"
              rows="4"
              placeholder="Double-stud timber frame, need cable conceal, TV is arriving Thursday, etc."
            ></textarea>
          </div>

          <div class="qt-field">
            <label class="qt-check qt-check-bold">
              <input type="checkbox" name="consent" value="yes" required />
              I'm happy for Brisbane TVs to contact me about this quote.
            </label>
          </div>
        </fieldset>

        <button type="submit" class="qt-submit" id="q-submit">
          Send my quote request →
        </button>

        <p class="qt-form-status" id="q-status" role="status" aria-live="polite"></p>
        <p class="qt-form-fineprint">
          Typical reply within the hour during business hours (7 AM – 7 PM, 7 days).
          No spam, no follow-up calls unless you ask for them. Your details are only
          used to write your quote.
        </p>
      </form>

      <aside class="qt-aside" aria-label="What happens next">
        <div class="qt-aside-card">
          <h3 class="qt-aside-title">What happens after you submit</h3>
          <ol class="qt-steps">
            <li>
              <span class="qt-step-k">1. We look at your photo</span>
              <span class="qt-step-v">Tom or the lead installer reads every quote — we don't farm this out.</span>
            </li>
            <li>
              <span class="qt-step-k">2. You get a flat-rate quote</span>
              <span class="qt-step-v">Emailed (and SMS'd if you give us a mobile) — usually inside the hour.</span>
            </li>
            <li>
              <span class="qt-step-k">3. You pick a time</span>
              <span class="qt-step-v">Same-day if it's before 10 AM, otherwise usually next business day.</span>
            </li>
            <li>
              <span class="qt-step-k">4. We install. You pay on the day.</span>
              <span class="qt-step-v">Card, bank transfer, or BPAY after the TV is up and working.</span>
            </li>
          </ol>
        </div>

        <div class="qt-aside-card qt-aside-card-trust">
          <p class="qt-aside-eyebrow">Why Brisbane homes pick us</p>
          <ul class="qt-trust-list">
            <li><strong>4.9★</strong> across 2,000+ Google reviews</li>
            <li><strong>$20M</strong> public-liability insurance</li>
            <li><strong>12-month</strong> workmanship warranty on every install</li>
            <li><strong>109 suburbs</strong> covered across Greater Brisbane</li>
            <li><strong>Locally owned</strong> — not a national franchise</li>
          </ul>
        </div>

        <div class="qt-aside-card qt-aside-card-cta">
          <p class="qt-aside-eyebrow">Prefer to talk?</p>
          <p class="qt-aside-copy">Tom answers the phone 7 days, 7 AM – 7 PM.</p>
          <a class="qt-btn qt-btn-primary qt-btn-block" href={BUSINESS.phoneTel}>
            Call {BUSINESS.phoneDisplay}
          </a>
          <a class="qt-aside-link" href={BUSINESS.mailto}>
            or email {BUSINESS.email}
          </a>
        </div>
      </aside>
    </div>
  </article>
</BaseLayout>

{/* ===== JS: preselect package, show filename, POST to n8n ===== */}
<script is:inline define:vars={{ webhook: BUSINESS.webhooks.photoQuote }}>
  (function () {
    const form = document.getElementById("quote-form");
    if (!form) return;

    // ---- Preselect package from ?package= query string ----
    try {
      const params = new URLSearchParams(window.location.search);
      const pkg = params.get("package");
      if (pkg) {
        const sel = document.getElementById("q-package");
        if (sel) {
          for (const opt of sel.options) {
            if (opt.value === pkg) {
              opt.selected = true;
              break;
            }
          }
        }
      }
    } catch (err) {
      // non-fatal — form still works without preselection
      console.warn("Could not preselect package:", err);
    }

    // ---- Filename display for the file input ----
    const fileInput = document.getElementById("q-photo");
    const fileName = document.getElementById("q-photo-name");
    if (fileInput && fileName) {
      fileInput.addEventListener("change", () => {
        const files = fileInput.files;
        if (!files || files.length === 0) {
          fileName.textContent = "No file chosen";
        } else if (files.length === 1) {
          fileName.textContent = files[0].name;
        } else {
          fileName.textContent = files.length + " files selected";
        }
      });
    }

    // ---- Submit handler: POST to n8n webhook ----
    const submitEl = document.getElementById("q-submit");
    const statusEl = document.getElementById("q-status");

    form.addEventListener("submit", async (ev) => {
      ev.preventDefault();
      submitEl.disabled = true;
      submitEl.textContent = "Sending…";
      statusEl.textContent = "";
      statusEl.className = "qt-form-status";

      try {
        const fd = new FormData(form);
        // Collect extras[] checkboxes as a comma-list (n8n unpacks cleaner).
        const extras = fd.getAll("extras");
        fd.delete("extras");
        fd.append("extras", extras.join(","));
        fd.append("source", "quote-page");
        fd.append("submittedAt", new Date().toISOString());

        const res = await fetch(webhook, {
          method: "POST",
          body: fd,
        });

        if (!res.ok) throw new Error("Webhook returned " + res.status);

        statusEl.textContent =
          "Thanks — your quote request is in. We'll be in touch inside the hour.";
        statusEl.classList.add("qt-form-status-ok");
        form.reset();
        if (fileName) fileName.textContent = "No file chosen";
        submitEl.textContent = "Sent ✓";
      } catch (err) {
        console.error(err);
        statusEl.textContent =
          "Hmm, that didn't send. Please call 0432 145 101 or email admin@brisbanetvs.com and we'll sort it manually.";
        statusEl.classList.add("qt-form-status-err");
        submitEl.disabled = false;
        submitEl.textContent = "Send my quote request →";
      }
    });
  })();
</script>

<style is:global>
  /* ===== /quote/ page styles — mirrors the pr-* system from /pricing/ =====
     Kept in an is:global block so the photo upload form renders identically
     whether the visitor lands here cold or deep-linked from a package card. */
  .qt-banner { position: relative; height: 220px; overflow: hidden; background: #0f1113; }
  .qt-banner-img { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; opacity: 0.35; }
  .qt-banner-inner { position: absolute; inset: 0; display: flex; align-items: center; justify-content: center; }
  .qt-banner-title { color: #fff; font-size: 3rem; font-weight: 700; letter-spacing: -0.02em; margin: 0; }

  .qt { max-width: 1200px; margin: 0 auto; padding: 3rem 1.5rem 4rem; }

  .qt-hero { max-width: 780px; }
  .qt-crumbs { font-size: 0.85rem; color: #6a7482; margin-bottom: 1rem; }
  .qt-crumbs a { color: #6a7482; text-decoration: none; }
  .qt-crumbs a:hover { color: #131619; text-decoration: underline; }
  .qt-crumbs-current { color: #131619; }

  .qt-eyebrow { font-size: 0.8rem; font-weight: 600; letter-spacing: 0.08em; text-transform: uppercase; color: #6a7482; margin: 0 0 0.75rem; }
  /* H1 aligned with the shared .idx-hero-copy / .svc-hero-copy scale
     so the quote page doesn't tower over the rest of the subpages. */
  .qt-hero h1 { font-size: clamp(1.8rem, 3.2vw, 2.6rem); line-height: 1.15; margin: 0 0 1rem; color: #131619; letter-spacing: -0.02em; }
  .qt-lede { font-size: 1.1rem; line-height: 1.55; color: #404954; margin: 0 0 1.5rem; }

  .qt-hero-cta-row { display: flex; gap: 0.75rem; flex-wrap: wrap; align-items: center; }
  .qt-btn { display: inline-flex; align-items: center; justify-content: center; padding: 0.75rem 1.25rem; border-radius: 6px; font-size: 0.95rem; font-weight: 600; text-decoration: none; border: 1px solid transparent; transition: transform 0.1s, background 0.15s; }
  .qt-btn-primary { background: #c5332e; color: #fff; }
  .qt-btn-primary:hover { background: #a72824; }
  .qt-btn-ghost { background: transparent; color: #131619; border-color: #d2d8e0; }
  .qt-btn-ghost:hover { background: #f6f7f9; }
  .qt-btn-link { background: transparent; color: #c5332e; padding: 0.75rem 0; border: 0; }
  .qt-btn-link:hover { text-decoration: underline; }
  .qt-btn-block { width: 100%; }

  .qt-divider { border: 0; border-top: 1px solid #eef0f3; margin: 2.5rem 0; }

  /* ===== FORM GRID — form + aside side-by-side on desktop ===== */
  .qt-grid { display: grid; grid-template-columns: minmax(0, 1fr) 320px; gap: 2.5rem; align-items: start; }

  /* ===== FORM ===== */
  .qt-form { background: #fff; border: 1px solid #eef0f3; border-radius: 8px; padding: 2rem; }
  .qt-fieldset { border: 0; padding: 0; margin: 0 0 2rem; }
  .qt-fieldset:last-of-type { margin-bottom: 1rem; }
  .qt-legend { font-size: 1.1rem; font-weight: 700; color: #131619; letter-spacing: -0.01em; padding: 0 0 0.75rem; margin: 0 0 1rem; border-bottom: 1px solid #eef0f3; width: 100%; }

  .qt-field { margin-bottom: 1rem; }
  .qt-field label { display: block; font-size: 0.88rem; font-weight: 600; color: #131619; margin-bottom: 0.4rem; }
  .qt-field input[type="text"],
  .qt-field input[type="email"],
  .qt-field input[type="tel"],
  .qt-field input[type="number"],
  .qt-field select,
  .qt-field textarea { width: 100%; padding: 0.65rem 0.85rem; border: 1px solid #d2d8e0; border-radius: 6px; font-size: 0.95rem; font-family: inherit; color: #131619; background: #fff; box-sizing: border-box; }
  .qt-field input:focus, .qt-field select:focus, .qt-field textarea:focus { outline: 2px solid #c5332e; outline-offset: 1px; border-color: #c5332e; }
  .qt-field-pair { display: grid; grid-template-columns: 1fr 1fr; gap: 0.75rem; }
  .qt-hint { font-size: 0.82rem; color: #6a7482; margin: 0.35rem 0 0; line-height: 1.4; }
  .qt-muted { color: #8a94a6; font-weight: 400; }

  .qt-checks { display: grid; grid-template-columns: 1fr 1fr; gap: 0.5rem; }
  .qt-check { display: flex; align-items: center; gap: 0.5rem; font-size: 0.9rem; font-weight: 400; color: #404954; cursor: pointer; }
  .qt-check input[type="checkbox"] { width: auto; margin: 0; }
  .qt-check-bold { font-weight: 600; color: #131619; }

  /* File input — the native control is ugly, hide it and style a label. */
  .qt-file-input { position: absolute; left: -9999px; width: 1px; height: 1px; opacity: 0; }
  .qt-file-label { display: flex; align-items: center; gap: 1rem; cursor: pointer; }
  .qt-file-btn { display: inline-block; padding: 0.65rem 1rem; background: #131619; color: #fff; border-radius: 6px; font-size: 0.88rem; font-weight: 600; }
  .qt-file-btn:hover { background: #2a2e33; }
  .qt-file-name { color: #6a7482; font-size: 0.88rem; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; flex: 1; min-width: 0; }

  .qt-submit { display: block; width: 100%; padding: 1rem 1.5rem; background: #c5332e; color: #fff; border: 0; border-radius: 6px; font-size: 1rem; font-weight: 700; cursor: pointer; margin-top: 1rem; transition: background 0.15s; }
  .qt-submit:hover:not(:disabled) { background: #a72824; }
  .qt-submit:disabled { opacity: 0.6; cursor: not-allowed; }

  .qt-form-status { margin: 0.75rem 0 0; font-size: 0.9rem; min-height: 1.2rem; }
  .qt-form-status-ok { color: #0b7a2f; font-weight: 600; }
  .qt-form-status-err { color: #c5332e; font-weight: 600; }

  .qt-form-fineprint { font-size: 0.8rem; color: #8a94a6; margin: 1rem 0 0; line-height: 1.5; }

  /* ===== ASIDE ===== */
  .qt-aside { display: flex; flex-direction: column; gap: 1rem; position: sticky; top: 1.5rem; }
  .qt-aside-card { background: #fafbfc; border: 1px solid #eef0f3; border-radius: 8px; padding: 1.25rem; }
  .qt-aside-card-trust { background: #131619; border-color: #131619; color: #e7eaef; }
  .qt-aside-card-trust .qt-aside-eyebrow { color: #8a94a6; }
  .qt-aside-card-cta { background: #fffaf5; border-color: #f4dcca; }

  .qt-aside-title { font-size: 1rem; font-weight: 700; color: #131619; margin: 0 0 0.85rem; }
  .qt-aside-eyebrow { font-size: 0.78rem; font-weight: 600; letter-spacing: 0.06em; text-transform: uppercase; color: #6a7482; margin: 0 0 0.5rem; }
  .qt-aside-copy { font-size: 0.9rem; color: #404954; margin: 0 0 0.85rem; line-height: 1.5; }
  .qt-aside-link { display: block; margin-top: 0.6rem; font-size: 0.85rem; color: #6a7482; text-align: center; text-decoration: none; }
  .qt-aside-link:hover { text-decoration: underline; }

  .qt-steps { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 0.75rem; }
  .qt-steps li { display: flex; flex-direction: column; gap: 0.15rem; }
  .qt-step-k { font-size: 0.88rem; font-weight: 600; color: #131619; }
  .qt-step-v { font-size: 0.85rem; color: #6a7482; line-height: 1.4; }

  .qt-trust-list { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 0.5rem; font-size: 0.9rem; }
  .qt-trust-list li { color: #d2d8e0; }
  .qt-trust-list strong { color: #fff; font-weight: 700; }

  /* ===== MOBILE ===== */
  @media (max-width: 820px) {
    .qt-banner { height: 160px; }
    .qt-banner-title { font-size: 2rem; }
    .qt { padding: 2rem 1rem 3rem; }
    .qt-grid { grid-template-columns: 1fr; gap: 1.5rem; }
    .qt-aside { position: static; order: 2; }
    .qt-form { padding: 1.25rem; order: 1; }
    .qt-field-pair { grid-template-columns: 1fr; }
    .qt-checks { grid-template-columns: 1fr; }
  }
</style>

---
import OperationsLayout from "../../components/operations/OperationsLayout.astro";
---

<OperationsLayout
  active="overview"
  title="Operations overview"
  description="Protected staff overview of Brisbane TVs leads, customer mail and website growth."
>
  <section class="operations-page-header dashboard-header" aria-labelledby="operations-overview-title">
    <div>
      <p class="operations-eyebrow" data-dashboard-date>Brisbane operations</p>
      <h1 id="operations-overview-title" class="operations-title">The useful signals, in one place.</h1>
      <p class="operations-copy">Live lead and website reporting, with an honest view of what is active and what is still staged for customer mail.</p>
    </div>
    <div class="dashboard-actions">
      <p class="operations-status" data-dashboard-status role="status">Checking protected Operations data...</p>
      <button class="operations-button" type="button" data-dashboard-refresh>Refresh</button>
    </div>
  </section>

  <section class="dashboard-metrics" aria-label="Business summary">
    <article class="dashboard-metric"><span>Total leads</span><strong data-total-leads>&mdash;</strong><small>Protected lead register</small></article>
    <article class="dashboard-metric"><span>Leads today</span><strong data-today-leads>&mdash;</strong><small>Brisbane time</small></article>
    <article class="dashboard-metric"><span>Last 7 days</span><strong data-week-leads>&mdash;</strong><small>Saved enquiries</small></article>
    <article class="dashboard-metric"><span>Stored mail</span><strong data-stored-mail>&mdash;</strong><small>Across three staff addresses</small></article>
    <article class="dashboard-metric is-featured is-status"><span>Mail routing</span><strong data-routing-metric>Checking</strong><small>Incoming customer mail</small></article>
  </section>

  <section class="dashboard-grid is-wide" aria-label="Leads and customer mailbox">
    <article class="operations-panel dashboard-panel">
      <div class="dashboard-panel-head">
        <div><h2>Leads</h2><p>Saved enquiries by source</p></div>
        <a href="/operations/leads/">Open leads</a>
      </div>
      <ul class="dashboard-source-list" data-source-mix aria-live="polite"><li>Loading lead sources...</li></ul>
      <p class="dashboard-panel-note" data-lead-note>Checking the protected lead register...</p>
    </article>

    <article class="operations-panel dashboard-panel">
      <div class="dashboard-panel-head">
        <div><h2>Customer mailbox</h2><p>DeAndre, Kody and Tom</p></div>
        <a href="/operations/inbox/">Open mailbox</a>
      </div>
      <ul class="dashboard-mailboxes" aria-label="Customer mail addresses">
        <li>
          <span><strong>DeAndre</strong><small>deandre@brisbanetvs.com</small></span>
          <b data-mailbox-count="deandre">&mdash;</b>
        </li>
        <li>
          <span><strong>Kody</strong><small>kody@brisbanetvs.com</small></span>
          <b data-mailbox-count="kody">&mdash;</b>
        </li>
        <li>
          <span><strong>Tom</strong><small>tom@brisbanetvs.com</small></span>
          <b data-mailbox-count="tom">&mdash;</b>
        </li>
      </ul>
      <div class="dashboard-capabilities" aria-label="Mailbox capabilities">
        <span>Incoming <strong class="dashboard-status-pill is-checking" data-mail-routing-status>Checking</strong></span>
        <span>Drafts <strong class="dashboard-status-pill is-checking" data-draft-status>Checking</strong></span>
        <span>Sending <strong class="dashboard-status-pill is-checking" data-send-status>Checking</strong></span>
      </div>
      <p class="dashboard-panel-note" data-mail-note>Checking whether incoming delivery is active...</p>
    </article>
  </section>

  <section class="dashboard-grid" aria-label="Website growth and Operations status">
    <article class="operations-panel dashboard-panel analytics-overview">
      <div class="dashboard-panel-head">
        <div><h2>Website growth</h2><p>Completed reporting windows, not today's partial totals</p></div>
        <a href="/operations/analytics/">Open analytics</a>
      </div>
      <div class="google-summary">
        <div><span>Consented sessions</span><strong data-ga-sessions>&mdash;</strong><small>Last 28 complete days</small></div>
        <div><span>Engagement rate</span><strong data-ga-engagement>&mdash;</strong><small>GA4 consented visits</small></div>
        <div><span>Search impressions</span><strong data-search-impressions>&mdash;</strong><small>Final Search Console data</small></div>
        <div><span>Search clicks</span><strong data-search-clicks>&mdash;</strong><small>From Google results</small></div>
      </div>
      <div class="dashboard-insight-head"><strong>Pages to improve first</strong><span data-search-window>Waiting for Search Console...</span></div>
      <ol class="dashboard-opportunities" data-opportunities aria-live="polite"><li>Loading page opportunities...</li></ol>
    </article>

    <article class="operations-panel dashboard-panel">
      <div class="dashboard-panel-head">
        <div><h2>Live and staged</h2><p>What staff can rely on today</p></div>
      </div>
      <ul class="dashboard-system-status">
        <li>
          <span><strong>Lead register</strong><small data-lead-status-detail>Checking saved enquiries...</small></span>
          <b class="dashboard-status-pill is-checking" data-lead-system-status>Checking</b>
        </li>
        <li>
          <span><strong>Customer mail</strong><small data-mail-status-detail>Checking incoming delivery...</small></span>
          <b class="dashboard-status-pill is-checking" data-mail-system-status>Checking</b>
        </li>
        <li>
          <span><strong>Website growth</strong><small data-analytics-status-detail>Checking Google reporting...</small></span>
          <b class="dashboard-status-pill is-checking" data-analytics-system-status>Checking</b>
        </li>
        <li>
          <span><strong>Staff access</strong><small>Cloudflare account sign-in for three approved staff identities</small></span>
          <b class="dashboard-status-pill is-live">Live</b>
        </li>
      </ul>
      <div class="dashboard-quick-links">
        <a href="/operations/leads/"><span>Leads</span><strong>Open &rarr;</strong></a>
        <a href="/operations/inbox/"><span>Customer mailbox</span><strong>Open &rarr;</strong></a>
        <a href="/operations/analytics/"><span>Website growth</span><strong>Open &rarr;</strong></a>
      </div>
    </article>
  </section>

  <section class="operations-privacy-note">
    <span aria-hidden="true">&#10003;</span>
    <p>Lead totals come from the protected register. Stored mail counts only messages held by this dashboard; staged routing means new email is not yet being delivered here. GA4 counts only visitors who allowed analytics.</p>
  </section>

  <script>
    const numberFormat = new Intl.NumberFormat("en-AU");
    const percentFormat = new Intl.NumberFormat("en-AU", { style: "percent", maximumFractionDigits: 1 });
    const dateElement = document.querySelector("[data-dashboard-date]");
    const statusElement = document.querySelector("[data-dashboard-status]");
    const refreshButton = document.querySelector("[data-dashboard-refresh]");

    const setText = (selector, value) => {
      const element = document.querySelector(selector);
      if (element) element.textContent = value;
    };

    const setNumber = (selector, value) => {
      const element = document.querySelector(selector);
      if (!element) return;
      if (value === null || value === undefined || value === "") {
        element.textContent = "\u2014";
        return;
      }
      const number = Number(value);
      element.textContent = Number.isFinite(number)
        ? numberFormat.format(Math.max(0, number))
        : "\u2014";
    };

    const setBadge = (selector, text, tone) => {
      const element = document.querySelector(selector);
      if (!element) return;
      element.textContent = text;
      element.className = `dashboard-status-pill is-${tone}`;
    };

    const requestJson = async (path) => {
      const response = await fetch(path, {
        cache: "no-store",
        credentials: "same-origin",
        headers: { accept: "application/json" },
      });
      const payload = await response.json().catch(() => null);
      if (!response.ok || !payload?.ok) {
        const error = new Error(response.status === 403 ? "signin" : "unavailable");
        error.status = response.status;
        throw error;
      }
      return payload;
    };

    function renderSources(entries, unavailable = false) {
      const target = document.querySelector("[data-source-mix]");
      if (!target) return;
      target.replaceChildren();
      if (!entries?.length) {
        const empty = document.createElement("li");
        empty.textContent = unavailable
          ? "Lead sources could not be refreshed."
          : "No saved lead source data yet.";
        target.append(empty);
        return;
      }
      const maximum = Math.max(1, ...entries.map((entry) => Number(entry.count) || 0));
      entries.slice(0, 7).forEach((entry) => {
        const item = document.createElement("li");
        const label = document.createElement("span");
        const track = document.createElement("span");
        const fill = document.createElement("i");
        const count = document.createElement("strong");
        const value = Math.max(0, Number(entry.count) || 0);
        label.textContent = entry.label || "Other";
        fill.style.width = `${Math.max(3, (value / maximum) * 100)}%`;
        track.append(fill);
        count.textContent = numberFormat.format(value);
        item.append(label, track, count);
        target.append(item);
      });
    }

    function leadRecencyCopy(summary) {
      if (!summary || Number(summary.totalLeads) === 0) {
        return "The protected lead register is connected; no leads have been saved yet.";
      }
      if (summary.latestLeadRecency === "today") return "The latest saved lead arrived today.";
      if (summary.latestLeadRecency === "yesterday") return "The latest saved lead arrived yesterday.";
      if (summary.latestLeadRecency === "older") return "The latest saved lead is older than yesterday.";
      return "The protected lead register is connected.";
    }

    function renderLeadSummary(summary) {
      setNumber("[data-total-leads]", summary?.totalLeads);
      setNumber("[data-today-leads]", summary?.leadsToday);
      setNumber("[data-week-leads]", summary?.leadsLast7Days);
      renderSources(summary?.byPlatform);
      const detail = leadRecencyCopy(summary);
      setText("[data-lead-note]", detail);
      setText("[data-lead-status-detail]", detail);
      setBadge("[data-lead-system-status]", "Live", "live");
    }

    function renderMailbox(inbox) {
      setNumber("[data-stored-mail]", inbox?.total);
      const counts = new Map((inbox?.mailboxes || []).map((mailbox) => [mailbox.id, mailbox.count]));
      ["deandre", "kody", "tom"].forEach((id) => {
        setNumber(`[data-mailbox-count="${id}"]`, counts.get(id) ?? 0);
      });

      const inboundEnabled = inbox?.inboundEnabled === true;
      const draftsEnabled = inbox?.capabilities?.createDrafts === true;
      const sendingEnabled = inbox?.outboundEnabled === true && inbox?.capabilities?.send === true;

      setText("[data-routing-metric]", inboundEnabled ? "Live" : "Staged");
      setBadge("[data-mail-routing-status]", inboundEnabled ? "Live" : "Staged", inboundEnabled ? "live" : "staged");
      setBadge("[data-draft-status]", draftsEnabled ? "Available" : "Unavailable", draftsEnabled ? "live" : "warning");
      setBadge("[data-send-status]", sendingEnabled ? "Live" : "Disabled", sendingEnabled ? "live" : "off");
      setBadge("[data-mail-system-status]", inboundEnabled ? "Live" : "Staged", inboundEnabled ? "live" : "staged");

      const detail = inboundEnabled
        ? "Protected inbox ingestion reports active for the three staff addresses."
        : "The mailbox and drafts are ready; incoming delivery is still staged.";
      setText("[data-mail-note]", detail);
      setText("[data-mail-status-detail]", detail);
    }

    function renderAnalytics(analytics) {
      const stable = analytics?.last28Days;
      const search = analytics?.searchConsole;
      setNumber("[data-ga-sessions]", stable?.sessions);
      setText(
        "[data-ga-engagement]",
        stable ? percentFormat.format(Number(stable.engagementRate) || 0) : "\u2014",
      );
      setNumber("[data-search-impressions]", search?.status === "ready" ? search?.totals?.impressions : null);
      setNumber("[data-search-clicks]", search?.status === "ready" ? search?.totals?.clicks : null);

      setText(
        "[data-search-window]",
        search?.status === "ready"
          ? `${search.window.startDate} to ${search.window.endDate}`
          : "Search Console is not available",
      );

      const target = document.querySelector("[data-opportunities]");
      if (target) {
        target.replaceChildren();
        if (search?.status !== "ready" || !search.opportunities?.length) {
          const empty = document.createElement("li");
          empty.textContent = search?.status === "not_configured"
            ? "Connect Search Console to see impression pages and queries."
            : "No page opportunities are available yet.";
          target.append(empty);
        } else {
          search.opportunities.slice(0, 4).forEach((page) => {
            const item = document.createElement("li");
            const text = document.createElement("div");
            const path = document.createElement("a");
            const reason = document.createElement("span");
            const metrics = document.createElement("strong");
            path.href = `/operations/analytics/#${encodeURIComponent(page.path)}`;
            path.textContent = page.path;
            reason.textContent = page.opportunity?.label || "Monitor";
            metrics.textContent = `${numberFormat.format(Number(page.impressions) || 0)} impressions \u00b7 ${numberFormat.format(Number(page.clicks) || 0)} clicks`;
            text.append(path, reason);
            item.append(text, metrics);
            target.append(item);
          });
        }
      }

      if (analytics?.gaStatus === "ready") {
        const complete = search?.status === "ready";
        setBadge("[data-analytics-system-status]", complete ? "Live" : "Partial", complete ? "live" : "warning");
        setText(
          "[data-analytics-status-detail]",
          complete
            ? "GA4 and Search Console reporting are available."
            : "GA4 is live; Search Console is not available.",
        );
      } else if (analytics?.gaStatus === "not_configured") {
        setBadge("[data-analytics-system-status]", "Setup needed", "staged");
        setText("[data-analytics-status-detail]", "Google Analytics reporting has not been connected.");
      } else {
        setBadge("[data-analytics-system-status]", "Unavailable", "warning");
        setText("[data-analytics-status-detail]", "Google reporting could not be refreshed.");
      }
    }

    function markLeadUnavailable() {
      setNumber("[data-total-leads]", null);
      setNumber("[data-today-leads]", null);
      setNumber("[data-week-leads]", null);
      renderSources(null, true);
      setText("[data-lead-note]", "The protected lead register could not be refreshed.");
      setText("[data-lead-status-detail]", "The protected lead register could not be refreshed.");
      setBadge("[data-lead-system-status]", "Unavailable", "warning");
    }

    function markMailboxUnavailable() {
      setNumber("[data-stored-mail]", null);
      setText("[data-routing-metric]", "Unavailable");
      setBadge("[data-mail-routing-status]", "Unavailable", "warning");
      setBadge("[data-draft-status]", "Unavailable", "warning");
      setBadge("[data-send-status]", "Unavailable", "warning");
      setBadge("[data-mail-system-status]", "Unavailable", "warning");
      setText("[data-mail-note]", "The protected customer mailbox could not be checked.");
      setText("[data-mail-status-detail]", "The protected customer mailbox could not be checked.");
    }

    function markAnalyticsUnavailable() {
      setNumber("[data-ga-sessions]", null);
      setText("[data-ga-engagement]", "\u2014");
      setNumber("[data-search-impressions]", null);
      setNumber("[data-search-clicks]", null);
      setText("[data-search-window]", "Google reporting is unavailable");
      const target = document.querySelector("[data-opportunities]");
      if (target) {
        target.replaceChildren();
        const empty = document.createElement("li");
        empty.textContent = "Website growth data could not be refreshed.";
        target.append(empty);
      }
      setBadge("[data-analytics-system-status]", "Unavailable", "warning");
      setText("[data-analytics-status-detail]", "Google reporting could not be refreshed.");
    }

    async function loadDashboard() {
      refreshButton.disabled = true;
      statusElement.textContent = "Refreshing protected Operations data...";
      statusElement.classList.remove("is-ready", "is-warning");

      const results = await Promise.allSettled([
        requestJson("/operations/api/summary"),
        requestJson("/operations/api/inbox?status=stored&limit=1"),
        requestJson("/operations/api/analytics"),
      ]);
      const [summaryResult, inboxResult, analyticsResult] = results;

      if (summaryResult.status === "fulfilled") renderLeadSummary(summaryResult.value.summary);
      else markLeadUnavailable();

      if (inboxResult.status === "fulfilled") renderMailbox(inboxResult.value);
      else markMailboxUnavailable();

      if (analyticsResult.status === "fulfilled") renderAnalytics(analyticsResult.value.analytics);
      else markAnalyticsUnavailable();

      const fulfilled = results.filter((result) => result.status === "fulfilled").length;
      const needsSignIn = results.some((result) => result.status === "rejected" && result.reason?.status === 403);
      statusElement.textContent = needsSignIn
        ? "Your secure session has expired. Sign in again to view Operations."
        : fulfilled === results.length
          ? "Overview is up to date."
          : fulfilled > 0
            ? "Some live panels could not be refreshed."
            : "The protected dashboard is temporarily unavailable.";
      statusElement.classList.toggle("is-ready", fulfilled === results.length);
      statusElement.classList.toggle("is-warning", fulfilled > 0 && fulfilled < results.length);
      refreshButton.disabled = false;
    }

    dateElement.textContent = new Intl.DateTimeFormat("en-AU", {
      timeZone: "Australia/Brisbane",
      weekday: "long",
      day: "numeric",
      month: "long",
    }).format(new Date()).toUpperCase();
    refreshButton.addEventListener("click", loadDashboard);
    loadDashboard();
  </script>

  <style>
    .dashboard-header { padding-bottom: 1.5rem; border-bottom: 1px solid #e7e5e0; }
    .dashboard-actions { display: flex; align-items: center; gap: .6rem; }
    .dashboard-metrics { display: grid; grid-template-columns: repeat(5, minmax(0, 1fr)); gap: .7rem; margin-bottom: 1.15rem; }
    .dashboard-metric { display: flex; min-width: 0; min-height: 8.4rem; flex-direction: column; border: 1px solid #e7e5e0; border-radius: .8rem; padding: 1.05rem; background: #fff; }
    .dashboard-metric span { color: #83847f; font-size: .58rem; font-weight: 750; letter-spacing: .1em; text-transform: uppercase; }
    .dashboard-metric > strong { margin: .75rem 0 .45rem; font-family: Georgia, "Times New Roman", serif; font-size: 1.8rem; font-weight: 400; }
    .dashboard-metric small { margin-top: auto; color: #888b88; font-size: .62rem; }
    .dashboard-metric.is-featured { border-color: #131619; color: #fff; background: #131619; }
    .dashboard-metric.is-featured span, .dashboard-metric.is-featured small { color: #aeb3b5; }
    .dashboard-metric.is-status > strong { font-size: 1.35rem; }
    .dashboard-grid { display: grid; grid-template-columns: minmax(0, 1.5fr) minmax(19rem, .85fr); gap: 1.1rem; margin-top: 1.1rem; }
    .dashboard-grid.is-wide { grid-template-columns: minmax(0, 1.15fr) minmax(24rem, .85fr); }
    .dashboard-panel { padding: 0; overflow: hidden; }
    .dashboard-panel-head { display: flex; align-items: flex-end; justify-content: space-between; gap: 1rem; border-bottom: 1px solid #e7e5e0; padding: 1.1rem 1.2rem; }
    .dashboard-panel-head h2 { margin: 0; font-family: Georgia, "Times New Roman", serif; font-size: 1.3rem; font-weight: 400; }
    .dashboard-panel-head p { margin: .3rem 0 0; color: #7c838c; font-size: .68rem; }
    .dashboard-panel-head a { color: #131619; font-size: .68rem; font-weight: 700; text-decoration: none; border-bottom: 1px solid #aaa; }
    .dashboard-panel-note { margin: .35rem 1.2rem 1rem; border-top: 1px solid #efede8; padding-top: .85rem; color: #737b80; font-size: .68rem; line-height: 1.5; }
    .dashboard-source-list { min-height: 10rem; margin: 0; padding: .8rem 1.2rem .4rem; list-style: none; }
    .dashboard-source-list li { display: grid; grid-template-columns: 7rem 1fr 2rem; gap: .6rem; align-items: center; padding: .48rem 0; color: #6b7073; font-size: .65rem; }
    .dashboard-source-list li > span:nth-child(2) { height: .38rem; overflow: hidden; border-radius: 999px; background: #efede8; }
    .dashboard-source-list i { display: block; height: 100%; border-radius: inherit; background: #63796b; }
    .dashboard-source-list strong { color: #131619; font-size: .65rem; text-align: right; }
    .dashboard-mailboxes, .dashboard-system-status { margin: 0; padding: .45rem 1.2rem; list-style: none; }
    .dashboard-mailboxes li, .dashboard-system-status li { display: flex; align-items: center; justify-content: space-between; gap: 1rem; border-bottom: 1px solid #efede8; padding: .72rem 0; }
    .dashboard-mailboxes li:last-child, .dashboard-system-status li:last-child { border: 0; }
    .dashboard-mailboxes li > span, .dashboard-system-status li > span { display: grid; min-width: 0; gap: .16rem; }
    .dashboard-mailboxes li > span > strong, .dashboard-system-status li > span > strong { font-size: .72rem; }
    .dashboard-mailboxes small, .dashboard-system-status small { overflow-wrap: anywhere; color: #7c838c; font-size: .61rem; font-weight: 500; line-height: 1.4; }
    .dashboard-mailboxes li > b { display: grid; flex: 0 0 auto; width: 1.75rem; height: 1.75rem; place-items: center; border-radius: 999px; color: #315544; background: #e4eee8; font-size: .66rem; }
    .dashboard-capabilities { display: grid; grid-template-columns: repeat(3, minmax(0, 1fr)); gap: .45rem; border-top: 1px solid #e7e5e0; padding: .8rem 1.2rem .55rem; }
    .dashboard-capabilities > span { display: grid; gap: .35rem; color: #7c838c; font-size: .57rem; font-weight: 700; letter-spacing: .06em; text-transform: uppercase; }
    .dashboard-status-pill { display: inline-flex; width: max-content; max-width: 100%; align-items: center; border-radius: 999px; padding: .27rem .48rem; font-size: .56rem; font-weight: 800; line-height: 1.1; text-transform: none; white-space: nowrap; }
    .dashboard-status-pill.is-live { color: #176444; background: #dceee5; }
    .dashboard-status-pill.is-staged { color: #765924; background: #f6ebd2; }
    .dashboard-status-pill.is-warning { color: #8a433d; background: #f4e4e2; }
    .dashboard-status-pill.is-off, .dashboard-status-pill.is-checking { color: #5f6d77; background: #ece9e1; }
    .google-summary { display: grid; grid-template-columns: repeat(4, minmax(0, 1fr)); border-bottom: 1px solid #e7e5e0; }
    .google-summary > div { display: flex; min-height: 7rem; flex-direction: column; border-right: 1px solid #e7e5e0; padding: 1rem; }
    .google-summary > div:last-child { border: 0; }
    .google-summary span { color: #83847f; font-size: .58rem; text-transform: uppercase; }
    .google-summary strong { margin: .55rem 0 .3rem; font-family: Georgia, "Times New Roman", serif; font-size: 1.55rem; font-weight: 400; }
    .google-summary small { margin-top: auto; color: #8b8e8c; font-size: .57rem; }
    .dashboard-insight-head { display: flex; justify-content: space-between; gap: 1rem; padding: 1rem 1.2rem .35rem; font-size: .67rem; }
    .dashboard-insight-head span { color: #8b8e8c; font-size: .58rem; }
    .dashboard-opportunities { margin: 0; padding: .35rem 1.2rem 1rem; list-style: none; }
    .dashboard-opportunities li { display: grid; grid-template-columns: minmax(0, 1fr) auto; gap: 1rem; align-items: center; border-bottom: 1px solid #efede8; padding: .65rem 0; }
    .dashboard-opportunities li:last-child { border: 0; }
    .dashboard-opportunities div { display: grid; min-width: 0; gap: .15rem; }
    .dashboard-opportunities a { overflow: hidden; color: #131619; font-size: .7rem; font-weight: 700; text-overflow: ellipsis; white-space: nowrap; }
    .dashboard-opportunities span { color: #a66b16; font-size: .59rem; }
    .dashboard-opportunities > li > strong { color: #696f72; font-size: .61rem; font-weight: 600; text-align: right; }
    .dashboard-system-status { padding-top: .55rem; padding-bottom: .55rem; }
    .dashboard-system-status li > b { flex: 0 0 auto; }
    .dashboard-quick-links { display: grid; border-top: 1px solid #e7e5e0; }
    .dashboard-quick-links a { display: flex; justify-content: space-between; gap: 1rem; border-bottom: 1px solid #efede8; padding: .78rem 1.2rem; color: #131619; font-size: .68rem; text-decoration: none; }
    .dashboard-quick-links a:last-child { border: 0; }
    .dashboard-quick-links strong { font-size: .62rem; }
    :global(:root[data-theme="dark"]) .dashboard-panel-note,

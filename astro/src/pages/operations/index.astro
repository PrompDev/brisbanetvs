<!doctype html>
<html lang="en-AU">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex,nofollow" />
    <title>Operations | Brisbane TVs</title>
    <meta name="description" content="Protected Brisbane TVs lead operations dashboard." />
  </head>
  <body>
    <main class="dashboard-shell">
      <header class="dashboard-header">
        <a class="brand" href="/" aria-label="Brisbane TVs home">BRISBANE <span>TVS</span></a>
        <p><span class="secure-dot" aria-hidden="true"></span> Secure staff workspace</p>
      </header>

      <section class="intro" aria-labelledby="dashboard-title">
        <div>
          <p class="eyebrow">Operations</p>
          <h1 id="dashboard-title">Leads at a glance.</h1>
          <p class="intro-copy">A private, aggregate-only view of incoming lead activity. Individual contact details stay in the restricted lead register.</p>
        </div>
        <p class="summary-state" data-summary-state role="status">Loading protected lead summary…</p>
      </section>

      <section class="metrics" aria-label="Lead summary">
        <article class="metric-card">
          <p>Total leads</p>
          <strong data-summary-total>—</strong>
          <span>Lead register total</span>
        </article>
        <article class="metric-card">
          <p>New today</p>
          <strong data-summary-today>—</strong>
          <span>Brisbane time</span>
        </article>
        <article class="metric-card">
          <p>Last 7 days</p>
          <strong data-summary-week>—</strong>
          <span>Recent incoming leads</span>
        </article>
        <article class="metric-card status-card">
          <p>Intake health</p>
          <strong data-summary-health>Checking</strong>
          <span data-summary-run>Checking latest lead run</span>
        </article>
      </section>

      <section class="breakdown-grid" aria-label="Lead mix">
        <article class="breakdown-card">
          <div class="card-heading">
            <div>
              <p class="eyebrow">Source mix</p>
              <h2>By platform</h2>
            </div>
            <span class="recency" data-summary-recency>Latest: checking</span>
          </div>
          <ul class="breakdown-list" data-summary-platform aria-live="polite">
            <li class="loading">Loading aggregate counts…</li>
          </ul>
        </article>
        <article class="breakdown-card">
          <div class="card-heading">
            <div>
              <p class="eyebrow">Demand signal</p>
              <h2>TV size</h2>
            </div>
          </div>
          <ul class="breakdown-list" data-summary-size aria-live="polite">
            <li class="loading">Loading aggregate counts…</li>
          </ul>
        </article>
      </section>

      <section class="privacy-note">
        <span aria-hidden="true">⌁</span>
        <p>This workspace intentionally excludes names, phone numbers, emails, lead IDs, raw answers and exact timestamps.</p>
      </section>
    </main>

    <script>
      const numberFormat = new Intl.NumberFormat("en-AU");
      const state = document.querySelector("[data-summary-state]");
      const total = document.querySelector("[data-summary-total]");
      const today = document.querySelector("[data-summary-today]");
      const week = document.querySelector("[data-summary-week]");
      const health = document.querySelector("[data-summary-health]");
      const run = document.querySelector("[data-summary-run]");
      const recency = document.querySelector("[data-summary-recency]");
      const platform = document.querySelector("[data-summary-platform]");
      const size = document.querySelector("[data-summary-size]");

      const recencyCopy = {
        today: "today",
        yesterday: "yesterday",
        older: "earlier",
        none: "none yet",
        unknown: "unknown",
      };
      const healthCopy = {
        healthy: "Healthy",
        attention: "Needs attention",
        never: "No successful run yet",
        unknown: "Checking",
      };

      function showBuckets(target, items) {
        target.replaceChildren();
        if (!items.length) {
          const empty = document.createElement("li");
          empty.className = "loading";
          empty.textContent = "No aggregate data yet.";
          target.append(empty);
          return;
        }

        items.forEach((item) => {
          const row = document.createElement("li");
          const label = document.createElement("span");
          const value = document.createElement("strong");
          label.textContent = item.label;
          value.textContent = numberFormat.format(item.count);
          row.append(label, value);
          target.append(row);
        });
      }

      function render(summary) {
        total.textContent = numberFormat.format(summary.totalLeads);
        today.textContent = numberFormat.format(summary.leadsToday);
        week.textContent = numberFormat.format(summary.leadsLast7Days);
        health.textContent = healthCopy[summary.syncHealth] || healthCopy.unknown;
        run.textContent = `Latest run: ${recencyCopy[summary.lastRunRecency] || "unknown"}`;
        recency.textContent = `Latest lead: ${recencyCopy[summary.latestLeadRecency] || "unknown"}`;
        showBuckets(platform, summary.byPlatform || []);
        showBuckets(size, summary.byTvSize || []);
        state.textContent = "Lead summary is up to date.";
        state.classList.add("ready");
      }

      async function loadSummary() {
        try {
          const response = await fetch("/operations/api/summary", {
            cache: "no-store",
            credentials: "same-origin",
            headers: { accept: "application/json" },
          });
          const payload = await response.json().catch(() => null);

          if (!response.ok || !payload?.ok || !payload.summary) {
            if (response.status === 401 || response.status === 403) {
              state.textContent = "Your secure session has expired. Sign in again to view the lead summary.";
            } else if (response.status === 503) {
              state.textContent = "The protected lead summary is being connected. Please try again shortly.";
            } else {
              state.textContent = "The lead summary is temporarily unavailable. Please try again shortly.";
            }
            return;
          }

          render(payload.summary);
        } catch {
          state.textContent = "The lead summary is temporarily unavailable. Please try again shortly.";
        }
      }

      loadSummary();
    </script>
  </body>
</html>

<style>
  :global(*) { box-sizing: border-box; }
  :global(body) { margin: 0; min-width: 320px; background: #f5f3ee; color: #162330; font-family: Inter, ui-sans-serif, system-ui, sans-serif; }
  .dashboard-shell { width: min(1160px, calc(100% - 2rem)); margin: 0 auto; padding: 1.4rem 0 4rem; }
  .dashboard-header { display: flex; align-items: center; justify-content: space-between; gap: 1rem; padding: .95rem 0 3rem; }
  .brand { color: #162330; font-size: 1.02rem; font-weight: 850; letter-spacing: .12em; text-decoration: none; }
  .brand span { color: #a98245; }
  .dashboard-header p { display: flex; align-items: center; gap: .55rem; margin: 0; color: #536270; font-size: .84rem; font-weight: 650; }
  .secure-dot { width: .55rem; height: .55rem; border-radius: 50%; background: #29875d; box-shadow: 0 0 0 4px rgba(41,135,93,.12); }
  .intro { display: flex; justify-content: space-between; align-items: end; gap: 2rem; margin-bottom: 2rem; }
  .eyebrow { margin: 0 0 .5rem; color: #9c773f; font-size: .72rem; font-weight: 850; letter-spacing: .13em; text-transform: uppercase; }
  h1, h2 { margin: 0; font-family: Georgia, "Times New Roman", serif; }
  h1 { font-size: clamp(2.6rem, 7vw, 5rem); line-height: .94; letter-spacing: -.045em; }
  h2 { font-size: 1.55rem; }
  .intro-copy { max-width: 42rem; margin: 1rem 0 0; color: #586572; line-height: 1.65; }
  .summary-state { max-width: 21rem; margin: 0; border: 1px solid #ddd9cf; border-radius: .6rem; padding: .8rem .9rem; color: #596674; background: #fffdf8; font-size: .86rem; line-height: 1.45; }
  .summary-state.ready { color: #176444; border-color: #b7d8c7; background: #f0faf4; }
  .metrics { display: grid; grid-template-columns: repeat(4, minmax(0, 1fr)); gap: 1rem; }
  .metric-card, .breakdown-card { border: 1px solid #dedbd4; border-radius: .9rem; background: #fffdf9; box-shadow: 0 14px 35px rgba(25,33,43,.045); }
  .metric-card { min-height: 10.3rem; padding: 1.3rem; }
  .metric-card p { margin: 0; color: #61707d; font-size: .88rem; font-weight: 680; }
  .metric-card strong { display: block; margin: .75rem 0 .45rem; font-family: Georgia, "Times New Roman", serif; font-size: clamp(2rem, 4vw, 3rem); line-height: 1; }
  .metric-card span { color: #79848d; font-size: .78rem; }
  .status-card { background: #172e40; border-color: #172e40; color: #fff; }
  .status-card p, .status-card span { color: #c5d0d7; }
  .breakdown-grid { display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 1rem; margin-top: 1rem; }
  .breakdown-card { padding: 1.45rem; }
  .card-heading { display: flex; align-items: flex-start; justify-content: space-between; gap: 1rem; }
  .recency { border-radius: 999px; padding: .4rem .6rem; background: #f0ece4; color: #68737d; font-size: .75rem; white-space: nowrap; }
  .breakdown-list { display: grid; gap: .75rem; margin: 1.65rem 0 0; padding: 0; list-style: none; }
  .breakdown-list li { display: flex; align-items: center; justify-content: space-between; gap: 1rem; border-top: 1px solid #ece8e1; padding-top: .75rem; color: #4b5966; }
  .breakdown-list li strong { color: #172e40; }
  .breakdown-list .loading { justify-content: flex-start; color: #7a858f; font-size: .9rem; }
  .privacy-note { display: flex; align-items: flex-start; gap: .75rem; margin-top: 1rem; border-radius: .8rem; padding: 1rem 1.1rem; background: #e9eff0; color: #50616c; }
  .privacy-note span { color: #277a59; font-size: 1.5rem; line-height: 1; }
  .privacy-note p { margin: 0; font-size: .88rem; line-height: 1.55; }
  @media (max-width: 800px) { .intro { align-items: flex-start; flex-direction: column; } .summary-state { max-width: none; } .metrics { grid-template-columns: repeat(2, minmax(0, 1fr)); } }
  @media (max-width: 560px) { .dashboard-shell { width: min(100% - 1.2rem, 1160px); } .dashboard-header { padding-bottom: 2.2rem; } .dashboard-header p { font-size: .74rem; } .metrics, .breakdown-grid { grid-template-columns: 1fr; } .metric-card { min-height: auto; } .card-heading { align-items: flex-start; flex-direction: column; } }
</style>

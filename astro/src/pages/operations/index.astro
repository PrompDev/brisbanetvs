---
import OperationsLayout from "../../components/operations/OperationsLayout.astro";
---

<OperationsLayout
  active="overview"
  title="Operations overview"
  description="Protected Brisbane TVs operations overview for staff."
>
  <section class="operations-page-header" aria-labelledby="operations-overview-title">
    <div>
      <p class="operations-eyebrow">Operations</p>
      <h1 id="operations-overview-title" class="operations-title">Know what needs attention.</h1>
      <p class="operations-copy">Use the workspace sections below for the customer register, team inbox and consent-aware website reporting. This page stays aggregate-only so the daily workflow is easy to scan.</p>
    </div>
    <p class="operations-status" data-summary-state role="status">Connecting to the protected lead register...</p>
  </section>

  <section class="operations-grid operations-metrics" aria-label="Lead summary">
    <article class="operations-metric">
      <p class="operations-metric-label">Total leads</p>
      <strong class="operations-metric-value" data-summary-total>—</strong>
      <span class="operations-metric-copy">Protected master register</span>
    </article>
    <article class="operations-metric">
      <p class="operations-metric-label">Received today</p>
      <strong class="operations-metric-value" data-summary-today>—</strong>
      <span class="operations-metric-copy">Brisbane time</span>
    </article>
    <article class="operations-metric">
      <p class="operations-metric-label">Last 7 days</p>
      <strong class="operations-metric-value" data-summary-week>—</strong>
      <span class="operations-metric-copy">New customer enquiries</span>
    </article>
    <article class="operations-metric is-dark">
      <p class="operations-metric-label">Intake health</p>
      <strong class="operations-metric-value" data-summary-health>Checking</strong>
      <span class="operations-metric-copy" data-summary-recency>Checking latest intake</span>
    </article>
  </section>

  <section class="operations-grid operations-action-grid" aria-label="Operations sections">
    <article class="operations-panel operations-action-card is-leads">
      <p class="operations-eyebrow">Lead register</p>
      <h2 class="operations-section-title">Every customer contact in one place.</h2>
      <p class="operations-panel-copy" data-lead-register-copy>Loading the protected register status...</p>
      <a class="operations-link" href="/operations/leads/">Open master lead list</a>
    </article>
    <article class="operations-panel operations-action-card is-inbox">
      <div class="operations-panel-heading">
        <div>
          <p class="operations-eyebrow">Team inbox</p>
          <h2 class="operations-section-title">Mail, without sending.</h2>
        </div>
        <span class="operations-pill is-muted" data-inbox-state>Checking</span>
      </div>
      <p class="operations-panel-copy" data-inbox-copy>Checking the team inbox connection...</p>
      <a class="operations-link is-quiet" href="/operations/inbox/">Open inbox and drafts</a>
    </article>
    <article class="operations-panel operations-action-card is-analytics">
      <div class="operations-panel-heading">
        <div>
          <p class="operations-eyebrow">Google Analytics</p>
          <h2 class="operations-section-title">Website activity, separately.</h2>
        </div>
        <span class="operations-pill is-muted" data-analytics-state>Checking</span>
      </div>
      <p class="operations-panel-copy" data-analytics-copy>Checking consent-aware reporting access...</p>
      <a class="operations-link is-quiet" href="/operations/analytics/">Open analytics</a>
    </article>
  </section>

  <section class="operations-grid operations-breakdown-grid" aria-label="Lead mix">
    <article class="operations-panel">
      <p class="operations-eyebrow">Source mix</p>
      <h2 class="operations-section-title">By platform</h2>
      <ul class="operations-list" data-summary-platform aria-live="polite">
        <li class="operations-list-loading">Loading lead sources...</li>
      </ul>
    </article>
    <article class="operations-panel">
      <p class="operations-eyebrow">Demand signal</p>
      <h2 class="operations-section-title">TV size</h2>
      <ul class="operations-list" data-summary-size aria-live="polite">
        <li class="operations-list-loading">Loading TV preferences...</li>
      </ul>
    </article>
  </section>

  <section class="operations-privacy-note">
    <span aria-hidden="true">✓</span>
    <p>This overview deliberately excludes customer names, phone numbers, emails and lead IDs. Open <a href="/operations/leads/">Leads</a> only when you need to work with the restricted customer register.</p>
  </section>

  <script>
    const numberFormat = new Intl.NumberFormat("en-AU");
    const summaryState = document.querySelector("[data-summary-state]");
    const total = document.querySelector("[data-summary-total]");
    const today = document.querySelector("[data-summary-today]");
    const week = document.querySelector("[data-summary-week]");
    const health = document.querySelector("[data-summary-health]");
    const recency = document.querySelector("[data-summary-recency]");
    const platform = document.querySelector("[data-summary-platform]");
    const size = document.querySelector("[data-summary-size]");
    const leadRegisterCopy = document.querySelector("[data-lead-register-copy]");
    const inboxState = document.querySelector("[data-inbox-state]");
    const inboxCopy = document.querySelector("[data-inbox-copy]");
    const analyticsState = document.querySelector("[data-analytics-state]");
    const analyticsCopy = document.querySelector("[data-analytics-copy]");

    const recencyCopy = {
      today: "Latest contact arrived today",
      yesterday: "Latest contact arrived yesterday",
      older: "Latest contact is older",
      none: "No contacts yet",
      unknown: "Latest intake time is unavailable",
    };
    const healthCopy = { ready: "Ready", attention: "Needs attention", empty: "No leads yet" };

    async function requestJson(path) {
      const response = await fetch(path, {
        cache: "no-store",
        credentials: "same-origin",
        headers: { accept: "application/json" },
      });
      const payload = await response.json().catch(() => null);
      return { response, payload };
    }

    function renderBuckets(target, items) {
      target.replaceChildren();
      if (!items?.length) {
        const item = document.createElement("li");
        item.className = "operations-list-loading";
        item.textContent = "No lead data yet.";
        target.append(item);
        return;
      }
      items.forEach((entry) => {
        const row = document.createElement("li");
        const label = document.createElement("span");
        const value = document.createElement("strong");
        label.textContent = entry.label;
        value.textContent = numberFormat.format(entry.count);
        row.append(label, value);
        target.append(row);
      });
    }

    async function loadSummary() {
      try {
        const { response, payload } = await requestJson("/operations/api/summary");
        if (!response.ok || !payload?.ok || !payload.summary) {
          summaryState.textContent = response.status === 403
            ? "Your secure session has expired. Sign in again to view Operations."
            : "The protected lead register is temporarily unavailable. Please refresh shortly.";
          return;
        }

        const summary = payload.summary;
        total.textContent = numberFormat.format(summary.totalLeads);
        today.textContent = numberFormat.format(summary.leadsToday);
        week.textContent = numberFormat.format(summary.leadsLast7Days);
        health.textContent = healthCopy[summary.syncHealth] || "Checking";
        recency.textContent = recencyCopy[summary.latestLeadRecency] || recencyCopy.unknown;
        leadRegisterCopy.textContent = summary.totalLeads
          ? `${numberFormat.format(summary.totalLeads)} protected customer contact${summary.totalLeads === 1 ? "" : "s"} ready for staff follow-up.`
          : "No customer contacts have been imported yet.";
        renderBuckets(platform, summary.byPlatform);
        renderBuckets(size, summary.byTvSize);
        summaryState.textContent = "The protected lead register is up to date.";
        summaryState.classList.add("is-ready");
      } catch {
        summaryState.textContent = "The protected lead register is temporarily unavailable. Please refresh shortly.";
      }
    }

    async function loadInboxState() {
      try {
        const { response, payload } = await requestJson("/operations/api/inbox");
        if (!response.ok || !payload?.ok) throw new Error("inbox unavailable");
        const enabled = payload.inboundEnabled === true;
        inboxState.textContent = enabled ? "Receiving" : "Staged";
        inboxState.classList.toggle("is-muted", !enabled);
        inboxCopy.textContent = enabled
          ? "Incoming mail is stored in the protected team inbox. Outbound sending remains disabled."
          : "Inbound delivery has not been moved here. The current business mail service remains unchanged.";
      } catch {
        inboxState.textContent = "Unavailable";
        inboxCopy.textContent = "The team inbox status could not be checked.";
      }
    }

    async function loadAnalyticsState() {
      try {
        const { response, payload } = await requestJson("/operations/api/analytics");
        if (response.ok && payload?.ok && payload.analytics) {
          const analytics = payload.analytics;
          const gaStatus = analytics.gaStatus || "unavailable";
          if (gaStatus !== "ready") {
            analyticsState.textContent = gaStatus === "not_configured" ? "Setup needed" : "Unavailable";
            analyticsState.classList.add("is-muted");
            analyticsCopy.textContent = gaStatus === "not_configured"
              ? "GA4 collection may be active, but secure reporting still needs its server-side connection."
              : "GA4 reporting is temporarily unavailable; saved lead reporting is unaffected.";
            return;
          }

          const sessions = Number(analytics.today?.sessions) || 0;
          const realtime = analytics.realtime || {};
          const activeUsers = realtime.status === "ready"
            ? Math.max(0, Number(realtime.activeUsersLast30Minutes) || 0)
            : null;
          analyticsState.textContent = activeUsers > 0
            ? "Receiving"
            : activeUsers === 0
              ? "Connected"
              : "Reports live";
          analyticsState.classList.toggle("is-muted", activeUsers === 0);
          analyticsCopy.textContent = activeUsers > 0
            ? `${numberFormat.format(activeUsers)} consented active visitor${activeUsers === 1 ? "" : "s"} in the last 30 minutes; ${numberFormat.format(sessions)} consented session${sessions === 1 ? "" : "s"} recorded today.`
            : activeUsers === 0
              ? `No consented active visitors in the last 30 minutes; ${numberFormat.format(sessions)} consented session${sessions === 1 ? "" : "s"} recorded today.`
              : `${numberFormat.format(sessions)} consented session${sessions === 1 ? "" : "s"} recorded today. Realtime is temporarily unavailable.`;
          return;
        }
        analyticsState.textContent = "Unavailable";
        analyticsState.classList.add("is-muted");
        analyticsCopy.textContent = "Analytics reporting is temporarily unavailable.";
      } catch {
        analyticsState.textContent = "Unavailable";
        analyticsCopy.textContent = "Analytics reporting is temporarily unavailable.";
      }
    }

    loadSummary();
    loadInboxState();
    loadAnalyticsState();
  </script>
</OperationsLayout>

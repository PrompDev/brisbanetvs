---
import OperationsLayout from "../../../components/operations/OperationsLayout.astro";
---

<OperationsLayout
  active="analytics"
  title="Website analytics"
  description="Protected consent-aware website reporting for Brisbane TVs staff."
>
  <section class="operations-page-header" aria-labelledby="analytics-title">
    <div>
      <p class="operations-eyebrow">Website insights</p>
      <h1 id="analytics-title" class="operations-title">What is working.</h1>
      <p class="operations-copy">A practical, aggregate-only view of consented website activity: the pages attracting attention, time spent on site, traffic sources and the Google searches that lead to Brisbane TVs.</p>
    </div>
    <p class="operations-status" data-analytics-status role="status">Connecting to secure reporting...</p>
  </section>

  <section class="operations-grid operations-breakdown-grid" aria-label="Website activity periods">
    <article class="operations-panel">
      <div class="operations-panel-heading">
        <div>
          <p class="operations-eyebrow">Consented GA4: Today</p>
          <h2 class="operations-section-title">Current activity</h2>
        </div>
        <span class="operations-pill is-muted" data-realtime-pill>Checking</span>
      </div>
      <p class="operations-panel-copy" data-realtime-copy>Checking whether consented visits are reaching Google Analytics...</p>
      <div class="operations-grid operations-analytics-metrics" style="margin-top: 1.2rem;">
        <div class="operations-metric"><p class="operations-metric-label">Sessions</p><strong class="operations-metric-value" data-today-sessions>—</strong><span class="operations-metric-copy">Consent-aware visits</span></div>
        <div class="operations-metric"><p class="operations-metric-label">Avg. session</p><strong class="operations-metric-value" data-today-duration>—</strong><span class="operations-metric-copy">Time on site</span></div>
        <div class="operations-metric"><p class="operations-metric-label">Page views</p><strong class="operations-metric-value" data-today-views>—</strong><span class="operations-metric-copy">Viewed pages</span></div>
        <div class="operations-metric"><p class="operations-metric-label">Lead events</p><strong class="operations-metric-value" data-today-leads>—</strong><span class="operations-metric-copy">Successful form events</span></div>
      </div>
    </article>

    <article class="operations-panel">
      <p class="operations-eyebrow">Consented GA4: Last 7 days</p>
      <h2 class="operations-section-title">Recent direction</h2>
      <div class="operations-grid operations-analytics-metrics" style="margin-top: 1.2rem;">
        <div class="operations-metric"><p class="operations-metric-label">Sessions</p><strong class="operations-metric-value" data-week-sessions>—</strong><span class="operations-metric-copy">Consent-aware visits</span></div>
        <div class="operations-metric"><p class="operations-metric-label">Avg. session</p><strong class="operations-metric-value" data-week-duration>—</strong><span class="operations-metric-copy">Time on site</span></div>
        <div class="operations-metric"><p class="operations-metric-label">Page views</p><strong class="operations-metric-value" data-week-views>—</strong><span class="operations-metric-copy">Viewed pages</span></div>
        <div class="operations-metric"><p class="operations-metric-label">Lead events</p><strong class="operations-metric-value" data-week-leads>—</strong><span class="operations-metric-copy">Successful form events</span></div>
      </div>
    </article>
  </section>

  <section class="operations-grid operations-breakdown-grid" aria-label="Saved lead signals" style="margin-top: 1rem;">
    <article class="operations-panel">
      <div class="operations-panel-heading">
        <div>
          <p class="operations-eyebrow">Actual enquiries</p>
          <h2 class="operations-section-title">Leads saved, not just clicks</h2>
        </div>
        <span class="operations-pill is-muted" data-lead-signal-pill>Checking</span>
      </div>
      <p class="operations-panel-copy" data-lead-signal-copy>Loading the protected Operations lead register. Saved leads include every successful submission, regardless of analytics consent.</p>
      <div class="operations-grid operations-analytics-metrics" style="margin-top: 1.2rem;">
        <div class="operations-metric"><p class="operations-metric-label">Saved today</p><strong class="operations-metric-value" data-saved-today>—</strong><span class="operations-metric-copy">All lead sources</span></div>
        <div class="operations-metric"><p class="operations-metric-label">Saved in 7 days</p><strong class="operations-metric-value" data-saved-week>—</strong><span class="operations-metric-copy">Real enquiries</span></div>
        <div class="operations-metric"><p class="operations-metric-label">Website forms</p><strong class="operations-metric-value" data-saved-website>—</strong><span class="operations-metric-copy">Last 7 days</span></div>
        <div class="operations-metric"><p class="operations-metric-label">Sheet waiting</p><strong class="operations-metric-value" data-sheet-waiting>—</strong><span class="operations-metric-copy">0 means healthy</span></div>
      </div>
    </article>

    <article class="operations-panel">
      <p class="operations-eyebrow">Decision signals</p>
      <h2 class="operations-section-title">What is producing enquiries</h2>
      <p class="operations-panel-copy">Actual saved leads by source, campaign and website landing page for the last seven days.</p>
      <p class="operations-metric-label" style="margin-top: 1rem;">Lead sources</p>
      <ul class="operations-list" data-lead-sources aria-live="polite">
        <li class="operations-list-loading">Loading lead sources...</li>
      </ul>
      <p class="operations-metric-label" style="margin-top: 1rem;">Campaigns</p>
      <ul class="operations-list" data-lead-campaigns aria-live="polite">
        <li class="operations-list-loading">Loading campaigns...</li>
      </ul>
      <p class="operations-metric-label" style="margin-top: 1rem;">Website lead pages</p>
      <ul class="operations-list" data-lead-pages aria-live="polite">
        <li class="operations-list-loading">Loading lead pages...</li>
      </ul>
    </article>
  </section>

  <section class="operations-grid operations-breakdown-grid" aria-label="Traffic detail" style="margin-top: 1rem;">
    <article class="operations-panel">
      <div class="operations-panel-heading">
        <div>
          <p class="operations-eyebrow">Acquisition</p>
          <h2 class="operations-section-title">Top traffic sources</h2>
        </div>
        <span class="operations-pill is-muted" data-analytics-pill>Checking</span>
      </div>
      <p class="operations-panel-copy" data-analytics-copy>Only controlled GA4 channel groups from consented sessions are shown here.</p>
      <ul class="operations-list" data-analytics-sources aria-live="polite">
        <li class="operations-list-loading">Loading traffic sources...</li>
      </ul>
    </article>

    <article class="operations-panel">
      <div class="operations-panel-heading">
        <div>
          <p class="operations-eyebrow">Popular pages</p>
          <h2 class="operations-section-title">Top and trending pages</h2>
        </div>
        <span class="operations-pill is-muted">7 days</span>
      </div>
      <p class="operations-panel-copy">Consented GA4 page views, average engagement time and movement against the previous seven days.</p>
      <ul class="operations-list" data-analytics-pages aria-live="polite">
        <li class="operations-list-loading">Loading page trends...</li>
      </ul>
    </article>
  </section>

  <section class="operations-grid operations-breakdown-grid" aria-label="Organic search and reporting connection" style="margin-top: 1rem;">
    <article class="operations-panel">
      <div class="operations-panel-heading">
        <div>
          <p class="operations-eyebrow">Google Search</p>
          <h2 class="operations-section-title">Searches bringing people in</h2>
        </div>
        <span class="operations-pill is-muted" data-search-pill>Checking</span>
      </div>
      <p class="operations-panel-copy" data-search-copy>Loading aggregated Google Search queries and landing pages...</p>
      <ul class="operations-list" data-analytics-queries aria-live="polite">
        <li class="operations-list-loading">Loading search terms...</li>
      </ul>
    </article>

    <article class="operations-panel" data-analytics-setup>
      <p class="operations-eyebrow">Reporting connection</p>
      <h2 class="operations-section-title">Private by design</h2>
      <p class="operations-panel-copy" data-analytics-setup-copy>Checking the server-side reporting connection...</p>
      <ul class="operations-setup-list">
        <li>GA4 tracking remains consent-aware on the public website.</li>
        <li>A restricted service-account credential is kept only in Cloudflare's encrypted environment settings.</li>
        <li>Google Search queries require a verified Search Console property and read-only access for that reporting account.</li>
      </ul>
    </article>
  </section>

  <section class="operations-privacy-note">
    <span aria-hidden="true">✓</span>
    <p>Analytics stays aggregate-only: no visitor names, emails, phone numbers or free-text form answers are requested or displayed. Campaign labels and Brisbane TVs landing-page paths are privacy-filtered and shown only as grouped lead counts.</p>
  </section>

  <script>
    const numberFormat = new Intl.NumberFormat("en-AU");
    const status = document.querySelector("[data-analytics-status]");
    const pill = document.querySelector("[data-analytics-pill]");
    const copy = document.querySelector("[data-analytics-copy]");
    const setupCopy = document.querySelector("[data-analytics-setup-copy]");
    const sourceList = document.querySelector("[data-analytics-sources]");
    const pageList = document.querySelector("[data-analytics-pages]");
    const queryList = document.querySelector("[data-analytics-queries]");
    const searchPill = document.querySelector("[data-search-pill]");
    const searchCopy = document.querySelector("[data-search-copy]");
    const leadSignalPill = document.querySelector("[data-lead-signal-pill]");
    const leadSignalCopy = document.querySelector("[data-lead-signal-copy]");
    const leadSourceList = document.querySelector("[data-lead-sources]");
    const leadCampaignList = document.querySelector("[data-lead-campaigns]");
    const leadPageList = document.querySelector("[data-lead-pages]");
    const realtimePill = document.querySelector("[data-realtime-pill]");
    const realtimeCopy = document.querySelector("[data-realtime-copy]");
    const values = {
      todaySessions: document.querySelector("[data-today-sessions]"),
      todayDuration: document.querySelector("[data-today-duration]"),
      todayViews: document.querySelector("[data-today-views]"),
      todayLeads: document.querySelector("[data-today-leads]"),
      weekSessions: document.querySelector("[data-week-sessions]"),
      weekDuration: document.querySelector("[data-week-duration]"),
      weekViews: document.querySelector("[data-week-views]"),
      weekLeads: document.querySelector("[data-week-leads]"),
      savedToday: document.querySelector("[data-saved-today]"),
      savedWeek: document.querySelector("[data-saved-week]"),
      savedWebsite: document.querySelector("[data-saved-website]"),
      sheetWaiting: document.querySelector("[data-sheet-waiting]"),
    };

    async function requestJson(path) {
      const response = await fetch(path, {
        cache: "no-store",
        credentials: "same-origin",
        headers: { accept: "application/json" },
      });
      const payload = await response.json().catch(() => null);
      return { response, payload };
    }

    function formatDuration(value) {
      const seconds = Math.max(0, Math.round(Number(value) || 0));
      const minutes = Math.floor(seconds / 60);
      return minutes ? `${minutes}m ${seconds % 60}s` : `${seconds}s`;
    }

    function emptyList(list, message) {
      list.replaceChildren();
      const item = document.createElement("li");
      item.className = "operations-list-loading";
      item.textContent = message;
      list.append(item);
    }

    function renderSources(sources) {
      if (!sources?.length) {
        emptyList(sourceList, "No traffic sources recorded in this period.");
        return;
      }

      sourceList.replaceChildren();
      sources.forEach((source) => {
        const item = document.createElement("li");
        const label = document.createElement("span");
        const value = document.createElement("strong");
        label.textContent = source.label;
        value.textContent = `${numberFormat.format(Number(source.sessions) || 0)} sessions`;
        item.append(label, value);
        sourceList.append(item);
      });
    }

    function renderPages(pages) {
      if (!pages?.length) {
        emptyList(pageList, "No page activity recorded in this period.");
        return;
      }

      pageList.replaceChildren();
      pages.forEach((page) => {
        const item = document.createElement("li");
        const path = document.createElement("span");
        const value = document.createElement("strong");
        const views = numberFormat.format(Number(page.pageViews) || 0);
        const change = Number(page.changeFromPreviousWeek) || 0;
        const trend = change > 0 ? `↑ ${numberFormat.format(change)}` : change < 0 ? `↓ ${numberFormat.format(Math.abs(change))}` : "No change";
        path.textContent = page.path;
        value.textContent = `${views} views · ${formatDuration(page.averageEngagementSeconds)} avg. engagement · ${trend}`;
        item.append(path, value);
        pageList.append(item);
      });
    }

    function renderSearch(searchConsole) {
      const search = searchConsole || { status: "not_configured", queries: [] };
      const statusName = search.status;
      const isReady = statusName === "ready";
      searchPill.classList.toggle("is-muted", !isReady);
      searchPill.textContent = isReady ? "Live" : statusName === "not_configured" ? "Setup needed" : "Unavailable";
      searchCopy.textContent = isReady
        ? "Top Google Search queries and landing pages from the last 28 completed days. Search data normally arrives a few days behind."
        : statusName === "not_configured"
          ? "Connect a verified Google Search Console property to see the searches and pages that bring visitors in."
          : "Google Search data is temporarily unavailable. GA4 website activity remains available above.";

      if (!isReady || !search.queries?.length) {
        emptyList(queryList, isReady ? "No Google Search queries recorded in this period." : "Search terms will appear here once connected.");
        return;
      }

      queryList.replaceChildren();
      search.queries.forEach((result) => {
        const item = document.createElement("li");
        const label = document.createElement("span");
        const value = document.createElement("strong");
        label.textContent = `${result.query} · ${result.page}`;
        value.textContent = `${numberFormat.format(Number(result.clicks) || 0)} clicks · ${numberFormat.format(Number(result.impressions) || 0)} impressions`;
        item.append(label, value);
        queryList.append(item);
      });
    }

    function renderLeadList(list, entries, emptyMessage) {
      if (!entries?.length) {
        emptyList(list, emptyMessage);
        return;
      }

      list.replaceChildren();
      entries.forEach((entry) => {
        const item = document.createElement("li");
        const label = document.createElement("span");
        const value = document.createElement("strong");
        label.textContent = entry.label;
        value.textContent = `${numberFormat.format(Number(entry.leads) || 0)} leads`;
        item.append(label, value);
        list.append(item);
      });
    }

    function renderLeadSignals(signals) {
      const ready = signals?.status === "ready";
      const delivery = signals?.sheetDelivery || {};
      const waiting = (Number(delivery.pending) || 0)
        + (Number(delivery.failed) || 0)
        + (Number(delivery.missing) || 0);
      setValue(values.savedToday, signals?.today);
      setValue(values.savedWeek, signals?.last7Days);
      setValue(values.savedWebsite, signals?.websiteLast7Days);
      setValue(values.sheetWaiting, waiting);

      leadSignalPill.classList.toggle("is-muted", !ready || waiting > 0);
      leadSignalPill.textContent = !ready ? "Unavailable" : waiting > 0 ? "Check delivery" : "Live";
      leadSignalCopy.textContent = ready
        ? `${numberFormat.format(Number(delivery.delivered) || 0)} website lead copies confirmed in the private Sheet. Saved leads include every successful submission, regardless of analytics consent. ${waiting ? `${numberFormat.format(waiting)} still need attention.` : "Nothing is waiting to sync."}`
        : "The protected lead signal summary is temporarily unavailable.";
      renderLeadList(leadSourceList, signals?.bySource, "No saved leads in this period.");
      renderLeadList(leadCampaignList, signals?.topCampaigns, "No tagged campaigns have produced a saved lead yet.");
      renderLeadList(leadPageList, signals?.topLandingPages, "No website form leads have been saved in this period.");
    }

    function renderRealtime(realtime) {
      const realtimeStatus = realtime?.status || "unavailable";
      const activeUsers = realtimeStatus === "ready"
        ? Math.max(0, Number(realtime.activeUsersLast30Minutes) || 0)
        : null;
      const ready = realtimeStatus === "ready";
      realtimePill.classList.toggle("is-muted", !ready || activeUsers === 0);

      if (!ready) {
        realtimePill.textContent = realtimeStatus === "not_configured" ? "Setup needed" : "Realtime unavailable";
        realtimeCopy.textContent = realtimeStatus === "not_configured"
          ? "Realtime collection will appear after the secure GA4 reporting connection is completed."
          : "Realtime is temporarily unavailable; the standard consented GA4 reports below remain separate.";
        return;
      }

      realtimePill.textContent = activeUsers > 0 ? `Receiving: ${numberFormat.format(activeUsers)} active` : "Connected";
      realtimeCopy.textContent = activeUsers > 0
        ? `${numberFormat.format(activeUsers)} consented active visitor${activeUsers === 1 ? "" : "s"} in the last 30 minutes.`
        : "Connected, with no consented active visitors in the last 30 minutes.";
    }

    function setValue(target, value) {
      target.textContent = numberFormat.format(Number(value) || 0);
    }

    function setDuration(target, value) {
      target.textContent = formatDuration(value);
    }

    function clearGaMetrics() {
      [
        values.todaySessions,
        values.todayDuration,
        values.todayViews,
        values.todayLeads,
        values.weekSessions,
        values.weekDuration,
        values.weekViews,
        values.weekLeads,
      ].forEach((target) => { target.textContent = "—"; });
    }

    function renderAnalytics(analytics) {
      const gaStatus = analytics.gaStatus || "ready";
      const gaReady = gaStatus === "ready";
      renderLeadSignals(analytics.leadSignals);
      renderSearch(analytics.searchConsole);
      renderRealtime(analytics.realtime);

      if (!gaReady) {
        clearGaMetrics();
        emptyList(sourceList, gaStatus === "not_configured"
          ? "Traffic sources will appear after the secure GA4 reporting connection is completed."
          : "Traffic sources are temporarily unavailable.");
        emptyList(pageList, gaStatus === "not_configured"
          ? "Page trends will appear after the secure GA4 reporting connection is completed."
          : "Page trends are temporarily unavailable.");
        status.textContent = gaStatus === "not_configured"
          ? "Saved enquiries and Sheet delivery are live. GA4 traffic reporting still needs its secure connection."
          : "Saved enquiries and Sheet delivery are live. GA4 traffic reporting is temporarily unavailable.";
        status.classList.remove("is-ready");
        status.classList.toggle("is-warning", gaStatus === "not_configured");
        pill.textContent = gaStatus === "not_configured" ? "Leads live · GA setup" : "Leads live · GA unavailable";
        pill.classList.add("is-muted");
        copy.textContent = "Lead totals, campaigns, landing pages and Sheet health remain available below.";
        setupCopy.textContent = gaStatus === "not_configured"
          ? "Complete the read-only GA4 reporting credential to add sessions, engagement and page trends."
          : "The GA4 connection can be retried without affecting lead capture or Sheet delivery.";
        return;
      }

      setValue(values.todaySessions, analytics.today?.sessions);
      setDuration(values.todayDuration, analytics.today?.averageSessionDuration);
      setValue(values.todayViews, analytics.today?.pageViews);
      setValue(values.todayLeads, analytics.today?.generateLeads);
      setValue(values.weekSessions, analytics.last7Days?.sessions);
      setDuration(values.weekDuration, analytics.last7Days?.averageSessionDuration);
      setValue(values.weekViews, analytics.last7Days?.pageViews);
      setValue(values.weekLeads, analytics.last7Days?.generateLeads);
      renderSources(analytics.topSources);
      renderPages(analytics.topPages);
      status.textContent = "Secure consented website reporting is live.";
      status.classList.add("is-ready");
      status.classList.remove("is-warning");
      pill.textContent = "Live";
      pill.classList.remove("is-muted");
      copy.textContent = "Fixed aggregate reports for visitors who allowed analytics, refreshed when this page opens.";
      setupCopy.textContent = "Connected. The reporting credential stays server-side and is never exposed to this page.";
    }

    function renderUnavailable(needsSetup) {
      status.textContent = needsSetup
        ? "GA4 is collecting consented website activity; secure reporting access still needs its server-side credential."
        : "Analytics reporting is temporarily unavailable. Please refresh shortly.";
      status.classList.toggle("is-warning", needsSetup);
      pill.textContent = needsSetup ? "Setup needed" : "Unavailable";
      copy.textContent = needsSetup
        ? "Tracking is separate from reporting. Once the restricted GA4 service credential is stored in Cloudflare, figures will populate here."
        : "No traffic sources are available while reporting is unavailable.";
      setupCopy.textContent = needsSetup
        ? "One read-only reporting credential remains to be stored securely in Cloudflare; it is not committed to the website or sent to staff browsers."
        : "Check the restricted reporting connection and refresh this page.";
      renderSources([]);
      renderPages([]);
      renderSearch({ status: needsSetup ? "not_configured" : "unavailable", queries: [] });
      renderRealtime({ status: needsSetup ? "not_configured" : "unavailable" });
      renderLeadSignals({ status: "unavailable" });
    }

    async function loadAnalytics() {
      try {
        const { response, payload } = await requestJson("/operations/api/analytics");
        if (response.ok && payload?.ok && payload.analytics) {
          renderAnalytics(payload.analytics);
          return;
        }

        if (response.status === 403) {
          status.textContent = "Your secure session has expired. Sign in again to view Analytics.";
          pill.textContent = "Sign in needed";
          renderSources([]);
          renderPages([]);
          renderSearch({ status: "unavailable", queries: [] });
          renderRealtime({ status: "unavailable" });
          renderLeadSignals({ status: "unavailable" });
          return;
        }

        renderUnavailable(payload?.error === "analytics_not_configured");
      } catch {
        renderUnavailable(false);
      }
    }

    loadAnalytics();
  </script>
</OperationsLayout>

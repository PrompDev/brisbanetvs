---
import OperationsLayout from "../../../components/operations/OperationsLayout.astro";
---

<OperationsLayout
  active="analytics"
  title="Website growth"
  description="A protected feedback loop joining Google Search, consented website behaviour and saved enquiries for Brisbane TVs staff."
>
  <div class="analytics-page">
    <section class="operations-page-header analytics-header" aria-labelledby="analytics-title">
      <div>
        <p class="operations-eyebrow">Website feedback loop</p>
        <h1 id="analytics-title" class="operations-title">What should we improve next?</h1>
        <p class="operations-copy">Read the recorded facts first. The page then separates what is unknown from the hypotheses you may choose to test.</p>
      </div>
      <div class="analytics-actions">
        <p class="operations-status" data-analytics-status role="status">Connecting to secure reporting...</p>
        <button class="operations-button" type="button" data-analytics-refresh>Refresh data</button>
      </div>
    </section>

    <section class="analytics-journey" aria-labelledby="journey-title">
      <div class="analytics-section-head">
        <div><p class="operations-eyebrow">Site pulse</p><h2 id="journey-title">Find → Visit → Engage → Enquire</h2></div>
        <span>Google: final 28 days · GA4: 28 complete days · enquiries: live 28 days</span>
      </div>
      <div class="journey-grid">
        <article><span class="journey-step">01 · Find</span><strong data-search-impressions>—</strong><h3>Google appearances</h3><p>Times a Brisbane TVs result appeared in Google. This is not a visit.</p></article>
        <article><span class="journey-step">02 · Visit</span><strong data-stable-sessions>—</strong><h3>Consented sessions</h3><p>Visits measured after somebody allowed analytics.</p></article>
        <article><span class="journey-step">03 · Engage</span><strong data-stable-rate>—</strong><h3>Engagement rate</h3><p data-engage-detail>Engaged sessions divided by consented sessions.</p></article>
        <article class="is-outcome"><span class="journey-step">04 · Enquire</span><strong data-saved-web-28>—</strong><h3>Saved website enquiries</h3><p data-enquiry-detail>Accepted website forms, independent of analytics consent.</p></article>
      </div>
      <p class="analytics-period-note"><strong>Why the numbers differ:</strong> Google appearances, consented GA4 sessions and saved enquiries use different collection rules. They are directional stages, not a person-by-person funnel.</p>
    </section>

    <section class="measured-evidence" aria-labelledby="measured-title">
      <div class="analytics-section-head">
        <div><p class="operations-eyebrow">Recorded facts</p><h2 id="measured-title">What customers actually did</h2><p>These are direct aggregate counts from the website and Operations. No reason or intent is inferred here.</p></div>
        <span>Last 28 days · public website only</span>
      </div>
      <div class="measured-grid">
        <article class="operations-panel analytics-panel measured-panel">
          <div class="analytics-panel-head"><div><h3>Consented website actions</h3><p>Recorded GA4 events · actions, not unique people</p></div><span class="operations-pill is-muted" data-actions-pill>Checking</span></div>
          <dl class="measured-list">
            <div><dt>Quote CTA clicks</dt><dd data-action-quote>—</dd></div>
            <div><dt>Phone-link clicks</dt><dd data-action-call>—</dd></div>
            <div><dt>Pricing calculator uses</dt><dd data-action-pricing>—</dd></div>
            <div><dt>Form starts</dt><dd data-action-form-start>—</dd></div>
            <div><dt>Forms with a validation error</dt><dd data-action-form-error>—</dd></div>
            <div><dt>GA lead events</dt><dd data-action-lead>—</dd></div>
          </dl>
          <p class="measured-note" data-actions-note>Loading recorded action events...</p>
        </article>
        <article class="operations-panel analytics-panel measured-panel is-outcome">
          <div class="analytics-panel-head"><div><h3>Saved business outcomes</h3><p>Direct Operations records for website leads</p></div><span class="operations-pill is-muted" data-outcomes-pill>Checking</span></div>
          <dl class="measured-list">
            <div><dt>Saved website enquiries</dt><dd data-outcome-leads>—</dd></div>
            <div><dt>Quotes created</dt><dd data-outcome-quotes>—</dd></div>
            <div><dt>Quotes accepted</dt><dd data-outcome-accepted>—</dd></div>
            <div><dt>Jobs completed</dt><dd data-outcome-jobs>—</dd></div>
            <div><dt>Job revenue recorded</dt><dd data-outcome-revenue>—</dd></div>
            <div><dt>Invoice payments recorded</dt><dd data-outcome-paid>—</dd></div>
          </dl>
          <p class="measured-note" data-outcomes-note>Loading saved business outcomes...</p>
        </article>
      </div>
      <p class="fact-boundary"><strong>Evidence boundary:</strong> a zero means the connected source recorded zero. A dash means the source is unavailable. Motivation remains unknown unless a customer tells us.</p>
    </section>

    <section class="improvement-loop" aria-labelledby="loop-title">
      <div class="analytics-section-head">
        <div>
          <p class="operations-eyebrow">Improvement loop</p>
          <h2 id="loop-title">One page. One change. One measured decision.</h2>
          <p>Use the queue as a repeatable SEO workflow, not a list of interesting numbers.</p>
        </div>
        <span>You approve every task and release</span>
      </div>
      <ol class="loop-steps">
        <li><span>01</span><strong>Detect</strong><p>Choose the highest-ranked page with enough final evidence.</p></li>
        <li><span>02</span><strong>Task</strong><p>Copy its complete brief into Codex. The brief points to the page and likely source file.</p></li>
        <li><span>03</span><strong>Publish</strong><p>Make one coherent SEO change, verify it, push it to main and record the release date.</p></li>
        <li><span>04</span><strong>Measure</strong><p>Wait for 28 complete post-release days plus Search Console's reporting delay.</p></li>
        <li><span>05</span><strong>Decide</strong><p>Keep a winner. Improve or undo a loser. Feed the result into the next task.</p></li>
      </ol>
      <p class="loop-control"><strong>Nothing changes automatically.</strong> “Copy agent task” prepares the handoff; you choose when to send it to an agent.</p>
    </section>

    <section class="analytics-actions-section" aria-labelledby="actions-title">
      <div class="analytics-section-head is-action-head">
        <div><p class="operations-eyebrow">Do next</p><h2 id="actions-title">Page improvement queue</h2><p>Each card turns the evidence into a source-aware agent task, a single change and a measurable success rule.</p></div>
        <div class="analytics-filters">
          <label><span>Find a page or query</span><input type="search" data-page-search placeholder="e.g. mount or repair" /></label>
          <label><span>Problem type</span><select data-opportunity-filter><option value="all">All pages</option><option value="snippet_gap">Shown, not clicked</option><option value="near_page_one">Within reach</option><option value="low_ctr">Low click rate</option><option value="growing_visibility">Growing visibility</option><option value="monitor">Monitor</option></select></label>
        </div>
      </div>
      <ol class="opportunity-list" data-opportunity-list aria-live="polite"><li class="analytics-empty">Loading page and query details...</li></ol>
      <p class="copy-status" data-copy-status role="status" aria-live="polite"></p>
      <p class="analytics-footnote" data-search-note>Search Console data is finalised with a short delay.</p>
    </section>

    <section aria-labelledby="attention-title">
      <div class="analytics-section-head">
        <div><p class="operations-eyebrow">Attention</p><h2 id="attention-title">Which landing pages hold attention?</h2></div>
        <span data-ga-window>27 days ago to yesterday · completed days</span>
      </div>
      <div class="attention-layout">
        <article class="operations-panel analytics-panel attention-panel">
          <div class="attention-table-head" aria-hidden="true"><span>Landing page</span><span>Avg. engaged</span><span>Engaged</span><span>Depth</span></div>
          <ul class="attention-list" data-landing-pages><li class="analytics-empty">Loading landing pages...</li></ul>
        </article>
        <aside class="attention-review" aria-labelledby="review-title">
          <p class="operations-eyebrow">Review signal</p>
          <h3 id="review-title">Where attention may be dropping</h3>
          <p data-attention-insight>Waiting for enough consented landing-page data.</p>
          <small>This does not prove why somebody left. It identifies a page worth reviewing for clarity, relevance, speed and the next action.</small>
        </aside>
      </div>
    </section>

    <section aria-labelledby="acquisition-title">
      <div class="analytics-section-head">
        <div><p class="operations-eyebrow">Acquisition</p><h2 id="acquisition-title">How people found us</h2></div>
        <span data-search-window>Final Google data ends three days ago</span>
      </div>
      <div class="acquisition-grid">
        <article class="operations-panel analytics-panel search-quality">
          <div class="analytics-panel-head"><div><h3>Google search quality</h3><p>Whether appearances are turning into visits</p></div></div>
          <div class="search-quality-grid">
            <div><span>Search clicks</span><strong data-search-clicks>—</strong><small data-click-change>vs previous 28 days</small></div>
            <div><span>Click-through rate</span><strong data-search-ctr>—</strong><small data-ctr-change>vs previous period</small></div>
            <div><span>Average position</span><strong data-search-position>—</strong><small data-position-change>Smaller is better</small></div>
          </div>
        </article>
        <article class="operations-panel analytics-panel">
          <div class="analytics-panel-head"><div><h3>Consented traffic channels</h3><p>Where GA4 sessions came from</p></div><span class="operations-pill is-muted" data-ga-pill>Checking</span></div>
          <ul class="analytics-list" data-traffic-sources><li>Loading channels...</li></ul>
        </article>
        <article class="operations-panel analytics-panel">
          <div class="analytics-panel-head"><div><h3>Saved enquiry sources</h3><p>All accepted enquiries · last 7 days</p></div><span class="operations-pill is-muted" data-leads-pill>Checking</span></div>
          <div class="enquiry-summary"><div><span>All sources</span><strong data-saved-week>—</strong></div><div><span>Website forms</span><strong data-saved-web>—</strong></div></div>
          <ul class="analytics-list" data-lead-sources><li>Loading saved lead sources...</li></ul>
        </article>
        <article class="operations-panel analytics-panel">
          <div class="analytics-panel-head"><div><h3>Google search by device</h3><p>Direct Search Console clicks and appearances</p></div></div>
          <ul class="analytics-list search-breakdown" data-search-devices><li>Loading device evidence...</li></ul>
        </article>
        <article class="operations-panel analytics-panel">
          <div class="analytics-panel-head"><div><h3>Local search audience</h3><p>Australia compared with all other countries</p></div></div>
          <ul class="analytics-list search-breakdown" data-search-geography><li>Loading location evidence...</li></ul>
        </article>
      </div>
    </section>

    <details class="analytics-health">
      <summary><span><strong>Reporting health</strong><small>Open this when the numbers look wrong or reporting shows a warning.</small></span><span aria-hidden="true">+</span></summary>
      <div class="analytics-grid" aria-label="Session reporting health">
        <article class="operations-panel analytics-panel">
          <div class="analytics-panel-head"><div><h2>Daily consented sessions</h2><p>Completed days plus a separate provisional view of today</p></div><span class="operations-pill is-muted" data-realtime-pill>Checking realtime</span></div>
          <div class="session-chart" data-session-chart aria-hidden="true"><p>Loading daily sessions...</p></div>
          <p class="analytics-visually-hidden" data-session-chart-summary>Loading the daily consented-session summary.</p>
          <div class="today-strip">
            <div><span>Today · provisional</span><strong data-today-sessions>—</strong><small>sessions</small></div>
            <div><span>Today</span><strong data-today-views>—</strong><small>page views</small></div>
            <p data-realtime-copy>Checking visitors active in the last 30 minutes...</p>
          </div>
        </article>
        <article class="operations-panel analytics-panel session-health">
          <div class="analytics-panel-head"><div><h2>Collection check</h2><p>GA4 sessions compared with its session_start event</p></div><span class="operations-pill is-muted" data-session-health-pill>Checking</span></div>
          <div class="session-compare">
            <div><span>Sessions</span><strong data-diagnostic-sessions>—</strong></div>
            <div><span>session_start</span><strong data-diagnostic-starts>—</strong></div>
            <div><span>Difference</span><strong data-diagnostic-difference>—</strong></div>
            <div><span>Days with visits</span><strong data-diagnostic-days>—</strong></div>
            <div><span>GA lead events · 28 days</span><strong data-stable-leads>—</strong></div>
            <div><span>Sheet delivery waiting</span><strong data-sheet-waiting>—</strong></div>
          </div>
          <p class="analytics-explanation"><span data-session-health-copy>Loading the session diagnostic...</span> GA lead events are a consented collection check; saved Operations enquiries are authoritative.</p>
        </article>
      </div>
    </details>

    <section class="analytics-definitions" aria-labelledby="definitions-title">
      <div class="analytics-section-head"><div><p class="operations-eyebrow">Definitions</p><h2 id="definitions-title">What these numbers mean</h2></div></div>
      <dl>
        <div><dt>Search impression</dt><dd>A Brisbane TVs result appeared in Google. Nobody needed to open it.</dd></div>
        <div><dt>Search click</dt><dd>A person opened Brisbane TVs from a Google result.</dd></div>
        <div><dt>Click-through rate</dt><dd>Search clicks divided by search impressions.</dd></div>
        <div><dt>Session</dt><dd>A GA4 visit from someone who allowed analytics.</dd></div>
        <div><dt>Engaged session</dt><dd>GA4's engaged-session count for consented visits.</dd></div>
        <div><dt>Engagement rate</dt><dd>Engaged sessions divided by consented sessions.</dd></div>
        <div><dt>Average engaged time</dt><dd>Active engagement seconds per landing session, not total time a tab stayed open.</dd></div>
        <div><dt>Views per session</dt><dd>Page views divided by consented sessions; a browsing-depth signal.</dd></div>
        <div><dt>Page path</dt><dd>The location inside the public website. <strong>Homepage (/)</strong> means brisbanetvs.com itself.</dd></div>
        <div><dt>Saved enquiry</dt><dd>An accepted enquiry in Operations, whether or not analytics was allowed.</dd></div>
        <div><dt>GA lead event</dt><dd>A consented generate_lead event used as a collection check, not the authoritative enquiry total.</dd></div>
        <div><dt>Website action</dt><dd>A recorded consented event such as a quote click or form start. One person can create more than one action.</dd></div>
        <div><dt>Business outcome</dt><dd>A quote, job, revenue or payment explicitly saved in Operations. Missing records are never estimated.</dd></div>
        <div><dt>Hypothesis</dt><dd>A possible explanation to verify against the page. It is not a measured fact or proof of why somebody left.</dd></div>
        <div><dt>Average position</dt><dd>The average Google result position across appearances. A smaller number is better.</dd></div>
      </dl>
    </section>

    <section class="operations-privacy-note">
      <span aria-hidden="true">✓</span>
      <p>This page requests fixed, aggregate reports only. The private <strong>/operations/*</strong> workspace is excluded from analytics collection and these reports. Search queries and public page paths are privacy-filtered; visitor identities, contact details and free-text form answers are not requested from Google or displayed here.</p>
    </section>
  </div>

  <script>
    const numberFormat = new Intl.NumberFormat("en-AU");
    const decimalFormat = new Intl.NumberFormat("en-AU", { maximumFractionDigits: 1 });
    const percentFormat = new Intl.NumberFormat("en-AU", { style: "percent", maximumFractionDigits: 1 });
    const currencyFormat = new Intl.NumberFormat("en-AU", { style: "currency", currency: "AUD", maximumFractionDigits: 0 });
    const statusElement = document.querySelector("[data-analytics-status]");
    const refreshButton = document.querySelector("[data-analytics-refresh]");
    const pageSearch = document.querySelector("[data-page-search]");
    const opportunityFilter = document.querySelector("[data-opportunity-filter]");
    let currentAnalytics = null;

    const numeric = (value) => Math.max(0, Number(value) || 0);
    const setText = (selector, value) => { const element = document.querySelector(selector); if (element) element.textContent = value; };
    const setNumber = (selector, value) => setText(selector, numberFormat.format(numeric(value)));
    const pageLabel = (path) => path === "/" ? "Homepage (/)" : path;

    function signed(value, suffix = "") {
      const amount = Number(value) || 0;
      if (amount === 0) return `No change${suffix}`;
      return `${amount > 0 ? "+" : "−"}${decimalFormat.format(Math.abs(amount))}${suffix}`;
    }

    function positionMovement(value) {
      const amount = Number(value) || 0;
      if (amount === 0) return "No movement · smaller is better";
      return `${amount > 0 ? "Improved" : "Worsened"} ${decimalFormat.format(Math.abs(amount))} positions`;
    }

    function formatDuration(value) {
      const seconds = Math.max(0, Math.round(Number(value) || 0));
      if (seconds < 60) return `${seconds}s`;
      const minutes = Math.floor(seconds / 60);
      const remainder = seconds % 60;
      return remainder ? `${minutes}m ${remainder}s` : `${minutes}m`;
    }

    async function requestAnalytics() {
      const response = await fetch("/operations/api/analytics", {
        cache: "no-store",
        credentials: "same-origin",
        headers: { accept: "application/json" },
      });
      const payload = await response.json().catch(() => null);
      if (!response.ok || !payload?.ok || !payload.analytics) {
        throw Object.assign(new Error("analytics unavailable"), { status: response.status });
      }
      return payload.analytics;
    }

    function replaceWithMessage(target, message) {
      target.replaceChildren();
      const element = document.createElement(["UL", "OL"].includes(target.tagName) ? "li" : "p");
      element.className = "analytics-empty";
      element.textContent = message;
      target.append(element);
    }

    function renderDailySessions(days) {
      const target = document.querySelector("[data-session-chart]");
      target.replaceChildren();
      if (!days?.length) {
        replaceWithMessage(target, "No consented sessions were reported in the completed-day window.");
        setText("[data-session-chart-summary]", "No consented sessions were reported in the completed-day window.");
        return;
      }
      const maximum = Math.max(1, ...days.map((day) => numeric(day.sessions)));
      const total = days.reduce((sum, day) => sum + numeric(day.sessions), 0);
      setText("[data-session-chart-summary]", `${numberFormat.format(total)} consented sessions were reported across ${numberFormat.format(days.length)} completed days; the busiest day had ${numberFormat.format(maximum)} sessions.`);
      days.forEach((day, index) => {
        const column = document.createElement("div");
        const bar = document.createElement("span");
        const label = document.createElement("small");
        const sessions = numeric(day.sessions);
        const date = new Date(`${day.date}T00:00:00+10:00`);
        column.title = `${day.date}: ${numberFormat.format(sessions)} sessions, ${numberFormat.format(numeric(day.pageViews))} page views`;
        column.setAttribute("aria-label", column.title);
        bar.style.height = `${Math.max(sessions > 0 ? 6 : 1, Math.round((sessions / maximum) * 100))}%`;
        label.textContent = index % 7 === 0 ? new Intl.DateTimeFormat("en-AU", { day: "numeric", month: "short" }).format(date) : "";
        column.append(bar, label);
        target.append(column);
      });
    }

    function renderRealtime(realtime) {
      const pill = document.querySelector("[data-realtime-pill]");
      const ready = realtime?.status === "ready";
      const active = ready ? numeric(realtime.activeUsersLast30Minutes) : null;
      pill.classList.toggle("is-muted", !ready || active === 0);
      pill.textContent = ready ? `${numberFormat.format(active)} active now` : "Realtime unavailable";
      setText("[data-realtime-copy]", ready
        ? active > 0
          ? `${numberFormat.format(active)} consented visitor${active === 1 ? "" : "s"} active in the last 30 minutes.`
          : "Connected, with no consented visitors active in the last 30 minutes."
        : "Realtime is unavailable; the completed-day report remains the reliable view.");
    }

    function renderSessionHealth(diagnostic) {
      const pill = document.querySelector("[data-session-health-pill]");
      if (!diagnostic) {
        pill.textContent = "Unavailable";
        setText("[data-session-health-copy]", "The session comparison could not be loaded.");
        return;
      }
      setNumber("[data-diagnostic-sessions]", diagnostic.sessions);
      setNumber("[data-diagnostic-starts]", diagnostic.sessionStartEvents);
      setText("[data-diagnostic-difference]", signed(diagnostic.difference));
      setText("[data-diagnostic-days]", `${numberFormat.format(numeric(diagnostic.daysWithSessions))}/${numberFormat.format(numeric(diagnostic.daysReported))}`);
      pill.classList.toggle("is-muted", diagnostic.status !== "aligned");
      pill.classList.toggle("is-warning", diagnostic.status === "processing_difference");
      if (diagnostic.status === "aligned") {
        pill.textContent = "Aligned";
        setText("[data-session-health-copy]", "Sessions and session_start events agree. Collection is working for visitors who allow analytics.");
      } else if (diagnostic.status === "no_consent_data") {
        pill.textContent = "No consented visits";
        setText("[data-session-health-copy]", "GA4 received no consented sessions in this window. Search impressions can still exist because appearing in Google does not mean someone opened the site or allowed analytics.");
      } else {
        pill.textContent = "Processing difference";
        setText("[data-session-health-copy]", "The two GA4 counts differ. Standard reports can continue processing for 24–48 hours; this completed-day window avoids today's largest delay, but the newest days can still settle.");
      }
    }

    function renderSearchMetrics(search) {
      const ready = search?.status === "ready";
      if (!ready) {
        ["[data-search-clicks]", "[data-search-impressions]", "[data-search-ctr]", "[data-search-position]"].forEach((selector) => setText(selector, "—"));
        setText("[data-search-window]", search?.status === "not_configured" ? "Search Console setup needed" : "Search Console unavailable");
        return;
      }
      setNumber("[data-search-clicks]", search.totals?.clicks);
      setNumber("[data-search-impressions]", search.totals?.impressions);
      setText("[data-search-ctr]", percentFormat.format(numeric(search.totals?.ctr)));
      setText("[data-search-position]", decimalFormat.format(numeric(search.totals?.position)));
      setText("[data-click-change]", `${signed(search.changes?.clicks)} clicks vs previous 28 days`);
      setText("[data-impression-change]", `${signed(search.changes?.impressions)} impressions vs previous 28 days`);
      setText("[data-ctr-change]", `${signed((Number(search.changes?.ctr) || 0) * 100, " points")} vs previous period`);
      setText("[data-position-change]", `${positionMovement(search.changes?.position)} vs previous period`);
      setText("[data-search-window]", `${search.window.startDate} to ${search.window.endDate} · final data`);
      setText("[data-search-note]", `Showing privacy-filtered page rows for ${search.window.startDate} to ${search.window.endDate}. Search Console dates use Pacific Time and finish ${search.window.lagDays} days behind today.`);
    }

    function landingPageMap(landingPages) {
      return new Map((landingPages || []).map((page) => [page.path, page]));
    }

    function buildAgentBrief(page, gaPage, actionPage, outcomePage, search) {
      const source = page.opportunity?.source || {};
      const sourceInstruction = source.file
        ? `Start with the likely source file: ${source.file}`
        : `Source needs tracing: ${source.hint || "Find the route under astro/src/pages, astro/src/content or astro/public before editing."}`;
      const queryLines = (page.topQueries || []).slice(0, 3).map((query) =>
        `- ${query.query}: ${numberFormat.format(numeric(query.impressions))} appearances, ${numberFormat.format(numeric(query.clicks))} clicks, ${percentFormat.format(numeric(query.ctr))} CTR, average position ${decimalFormat.format(numeric(query.position))}`
      );
      const gaEvidence = gaPage
        ? `${numberFormat.format(numeric(gaPage.sessions))} consented landings; ${percentFormat.format(numeric(gaPage.engagementRate))} engaged; ${formatDuration(gaPage.averageEngagementSeconds)} average engaged time; ${decimalFormat.format(numeric(gaPage.viewsPerSession))} views per session.`
        : "No consented GA4 landing-page match was available. Treat this as missing consented evidence, not zero traffic.";
      const actionEvidence = actionPage
        ? `${numberFormat.format(numeric(actionPage.quoteCtaClicks))} quote CTA clicks; ${numberFormat.format(numeric(actionPage.callClicks))} phone-link clicks; ${numberFormat.format(numeric(actionPage.formStarts))} form starts; ${numberFormat.format(numeric(actionPage.formErrors))} forms with a validation error; ${numberFormat.format(numeric(actionPage.generateLeads))} GA lead events.`
        : "No consented action-event row matched this landing page. Treat this as missing consented evidence, not proof that nobody acted.";
      const outcomeEvidence = outcomePage
        ? `${numberFormat.format(numeric(outcomePage.leads))} saved website enquiries; ${numberFormat.format(numeric(outcomePage.quotes))} quotes; ${numberFormat.format(numeric(outcomePage.acceptedQuotes))} accepted quotes; ${numberFormat.format(numeric(outcomePage.completedJobs))} completed jobs; ${currencyFormat.format(numeric(outcomePage.revenueCents) / 100)} recorded job revenue.`
        : "No saved business-outcome row matched this landing page in the 28-day window. Treat this as no attribution match, not zero outcomes.";
      const searchWindow = search?.window
        ? `${search.window.startDate} to ${search.window.endDate} (final Search Console data)`
        : "the current final Search Console window";

      return [
        "Brisbane TVs SEO improvement task",
        "",
        "OUTCOME",
        `Improve ${pageLabel(page.path)} at https://brisbanetvs.com${page.path} using one focused, evidence-led change. Do not make broad site-wide edits unless the evidence proves they are required.`,
        "",
        "WHERE TO START",
        sourceInstruction,
        "Inspect both the live page and its actual source before editing. If the source hint is wrong, trace the route and report the correct file.",
        "",
        `BASELINE — ${searchWindow}`,
        `- Search appearances: ${numberFormat.format(numeric(page.impressions))} (${signed(page.impressionChange)} vs previous window)`,
        `- Search clicks: ${numberFormat.format(numeric(page.clicks))} (${signed(page.clickChange)} vs previous window)`,
        `- Click-through rate: ${percentFormat.format(numeric(page.ctr))}`,
        `- Average position: ${decimalFormat.format(numeric(page.position))} (${positionMovement(page.positionChange)})`,
        `- Consented behaviour: ${gaEvidence}`,
        `- Recorded website actions: ${actionEvidence}`,
        `- Saved business outcomes: ${outcomeEvidence}`,
        "",
        "TOP VISIBLE QUERIES",
        ...(queryLines.length ? queryLines : ["- No privacy-safe query rows were returned. Do not invent target queries."]),
        "",
        "HYPOTHESIS TO VERIFY",
        page.opportunity?.hypothesis || "The current evidence needs to be checked against the live page before choosing a change.",
        "This is an inference, not a measured reason for visitor behaviour. Keep the cause marked unknown unless direct customer feedback proves it.",
        "",
        "FOCUSED CHANGE",
        page.opportunity?.recommendation || "Review the page against its visible search demand and choose one defensible improvement.",
        "",
        "WORKING RULES",
        "1. Verify the search intent and current page before accepting the hypothesis.",
        "2. Change one coherent SEO variable or closely related set: search snippet, query coverage, internal linking, page clarity or next action.",
        "3. Keep every claim truthful and specific to Brisbane TVs. Do not keyword-stuff or invent prices, credentials, reviews, service areas or customer facts.",
        "4. Preserve the Analytics Design Certificate and the exclusion of /operations/* from public analytics.",
        "5. Run the relevant tests, production build and SEO/link checks. Commit and push the finished work to main only after they pass.",
        "6. In the handoff, record the files changed, exact change, release date and this baseline so the result can be measured.",
        "7. If the evidence is too weak or the proposed change would be misleading, make no change and explain what data is needed.",
        "",
        "SUCCESS DECISION",
        page.opportunity?.successCheck || "Compare the next complete 28-day window with this baseline.",
        page.opportunity?.reviewRule || "Review after 28 complete post-release days once Search Console data is final.",
        "Keep a clear winner. Iterate or undo a loser, and record what was learned for the next dashboard cycle.",
      ].join("\n");
    }

    async function copyText(value) {
      if (navigator.clipboard?.writeText && window.isSecureContext) {
        await navigator.clipboard.writeText(value);
        return;
      }
      const textarea = document.createElement("textarea");
      textarea.value = value;
      textarea.setAttribute("readonly", "");
      textarea.style.position = "fixed";
      textarea.style.opacity = "0";
      document.body.append(textarea);
      textarea.select();
      const copied = document.execCommand("copy");
      textarea.remove();
      if (!copied) throw new Error("copy unavailable");
    }

    function renderOpportunities() {
      const target = document.querySelector("[data-opportunity-list]");
      const search = currentAnalytics?.searchConsole;
      if (search?.status !== "ready") {
        replaceWithMessage(target, search?.status === "not_configured" ? "Search Console needs its read-only connection before page opportunities can appear." : "Search Console is temporarily unavailable.");
        return;
      }
      const term = String(pageSearch.value || "").trim().toLowerCase();
      const filter = opportunityFilter.value;
      const gaPages = landingPageMap(currentAnalytics?.landingPages);
      const actionPages = landingPageMap(currentAnalytics?.publicActions?.pages);
      const outcomePages = landingPageMap(currentAnalytics?.leadSignals?.pageOutcomes);
      const pages = (search.opportunities || []).filter((page) => {
        const matchesTerm = !term || pageLabel(page.path).toLowerCase().includes(term) || (page.topQueries || []).some((query) => String(query.query).toLowerCase().includes(term));
        const matchesFilter = filter === "all" || page.opportunity?.type === filter;
        return matchesTerm && matchesFilter;
      }).slice(0, 5);
      target.replaceChildren();
      if (!pages.length) {
        replaceWithMessage(target, "No page opportunities match that filter.");
        return;
      }
      pages.forEach((page, index) => {
        const card = document.createElement("li");
        card.className = `opportunity-card${index === 0 ? " is-priority" : ""}`;
        card.id = encodeURIComponent(page.path);
        const rank = document.createElement("span");
        rank.className = "opportunity-rank";
        rank.textContent = index === 0 ? "Best next move" : `Priority ${String(index + 1).padStart(2, "0")}`;
        const body = document.createElement("div");
        body.className = "opportunity-body";
        const heading = document.createElement("div");
        heading.className = "opportunity-title";
        const path = document.createElement("a");
        path.href = `https://brisbanetvs.com${page.path}`;
        path.target = "_blank";
        path.rel = "noreferrer";
        path.textContent = pageLabel(page.path);
        const pageHeading = document.createElement("h3");
        pageHeading.append(path);
        const badge = document.createElement("span");
        badge.className = `opportunity-badge is-${page.opportunity?.type || "monitor"}`;
        badge.textContent = page.opportunity?.label || "Monitor";
        heading.append(pageHeading, badge);
        const recommendation = document.createElement("p");
        recommendation.className = "opportunity-summary";
        recommendation.textContent = `Why it is ranked: ${page.opportunity?.label || "Monitor"}. The figures on the right are the measurement baseline.`;

        const plan = document.createElement("dl");
        plan.className = "opportunity-plan";
        const gaPage = gaPages.get(page.path);
        const actionPage = actionPages.get(page.path);
        const outcomePage = outcomePages.get(page.path);
        const observedFact = `${numberFormat.format(numeric(page.impressions))} Google appearances produced ${numberFormat.format(numeric(page.clicks))} search clicks in the final window.${gaPage ? ` GA4 recorded ${numberFormat.format(numeric(gaPage.sessions))} consented landings.` : " No matching consented landing row was available."}${outcomePage ? ` Operations matched ${numberFormat.format(numeric(outcomePage.leads))} saved website enquiries.` : " No matching saved-enquiry row was available."}`;
        [
          ["Observed facts", observedFact],
          ["Still unknown", "The reports do not reveal why a visitor clicked, continued or left. Verify the live page and preserve that uncertainty."],
          ["Hypothesis to verify", page.opportunity?.hypothesis || "Review the live page before deciding why this signal exists."],
          ["Focused change", page.opportunity?.recommendation || "Keep watching this page as more search data arrives."],
          ["Winning result", page.opportunity?.successCheck || "Compare the next complete 28-day window with this baseline."],
        ].forEach(([labelText, valueText]) => {
          const wrapper = document.createElement("div");
          const label = document.createElement("dt");
          const value = document.createElement("dd");
          label.textContent = labelText;
          value.textContent = valueText;
          wrapper.append(label, value);
          plan.append(wrapper);
        });

        const evidence = document.createElement("div");
        evidence.className = "opportunity-evidence";
        const evidenceLabel = document.createElement("span");
        evidenceLabel.textContent = "Evidence · top visible queries";
        const queries = document.createElement("ul");
        queries.className = "query-list";
        if (page.topQueries?.length) {
          page.topQueries.slice(0, 3).forEach((query) => {
            const item = document.createElement("li");
            const label = document.createElement("b");
            const detail = document.createElement("small");
            label.textContent = query.query;
            detail.textContent = `${numberFormat.format(numeric(query.impressions))} appearances · ${numberFormat.format(numeric(query.clicks))} clicks · position ${decimalFormat.format(numeric(query.position))}`;
            item.append(label, detail);
            queries.append(item);
          });
        } else {
          const unavailable = document.createElement("small");
          unavailable.textContent = "No privacy-safe query rows were returned for this page.";
          queries.append(unavailable);
        }
        evidence.append(evidenceLabel, queries);

        const source = document.createElement("p");
        source.className = "opportunity-source";
        const sourceLabel = document.createElement("strong");
        const sourceValue = document.createElement(page.opportunity?.source?.file ? "code" : "span");
        sourceLabel.textContent = "Likely source: ";
        sourceValue.textContent = page.opportunity?.source?.file || page.opportunity?.source?.hint || "Trace the public route before editing.";
        source.append(sourceLabel, sourceValue);

        const controls = document.createElement("div");
        controls.className = "opportunity-controls";
        const openPage = document.createElement("a");
        openPage.className = "opportunity-open";
        openPage.href = `https://brisbanetvs.com${page.path}`;
        openPage.target = "_blank";
        openPage.rel = "noreferrer";
        openPage.textContent = "Open live page";
        const copyTask = document.createElement("button");
        copyTask.className = "opportunity-copy";
        copyTask.type = "button";
        copyTask.textContent = "Copy agent task";
        copyTask.addEventListener("click", async () => {
          const originalLabel = copyTask.textContent;
          copyTask.disabled = true;
          try {
            await copyText(buildAgentBrief(page, gaPage, actionPage, outcomePage, search));
            copyTask.textContent = "Task copied";
            setText("[data-copy-status]", `Agent task for ${pageLabel(page.path)} copied. Paste it into Codex when you are ready.`);
          } catch {
            copyTask.textContent = "Copy failed";
            setText("[data-copy-status]", "The browser blocked clipboard access. Open the page in a secure browser session and try again.");
          } finally {
            window.setTimeout(() => {
              copyTask.disabled = false;
              copyTask.textContent = originalLabel;
            }, 2400);
          }
        });
        controls.append(openPage, copyTask);
        body.append(heading, recommendation, plan, evidence, source, controls);

        const metrics = document.createElement("dl");
        metrics.className = "opportunity-metrics";
        const values = [
          ["Search appearances", numberFormat.format(numeric(page.impressions)), `${signed(page.impressionChange)} vs previous`],
          ["Search clicks / CTR", `${numberFormat.format(numeric(page.clicks))} / ${percentFormat.format(numeric(page.ctr))}`, `${signed(page.clickChange)} clicks vs previous`],
          ["Average position", decimalFormat.format(numeric(page.position)), positionMovement(page.positionChange)],
          ["Consented landings", gaPage ? numberFormat.format(numeric(gaPage.sessions)) : "—", gaPage ? `${percentFormat.format(numeric(gaPage.engagementRate))} engaged` : "No consented GA4 match"],
          ["Quote CTA / phone clicks", actionPage ? `${numberFormat.format(numeric(actionPage.quoteCtaClicks))} / ${numberFormat.format(numeric(actionPage.callClicks))}` : "—", actionPage ? "Consented actions · 28 complete days" : "No consented action match"],
          ["Form starts / errors", actionPage ? `${numberFormat.format(numeric(actionPage.formStarts))} / ${numberFormat.format(numeric(actionPage.formErrors))}` : "—", actionPage ? "Recorded events, not unique people" : "No consented action match"],
          ["Saved website enquiries", outcomePage ? numberFormat.format(numeric(outcomePage.leads)) : "—", outcomePage ? "Matched landing page · 28 days" : "No 28-day attribution match"],
          ["Completed jobs / revenue", outcomePage ? `${numberFormat.format(numeric(outcomePage.completedJobs))} / ${currencyFormat.format(numeric(outcomePage.revenueCents) / 100)}` : "—", outcomePage ? "Explicit Operations records" : "No attributed outcome record"],
        ];
        values.forEach(([labelText, valueText, detailText]) => {
          const wrapper = document.createElement("div");
          const termElement = document.createElement("dt");
          const valueElement = document.createElement("dd");
          const detailElement = document.createElement("small");
          termElement.textContent = labelText;
          valueElement.textContent = valueText;
          detailElement.textContent = detailText;
          wrapper.append(termElement, valueElement, detailElement);
          metrics.append(wrapper);
        });
        card.append(rank, body, metrics);
        target.append(card);
      });
    }

    function renderLandingPages(pages) {
      const target = document.querySelector("[data-landing-pages]");
      target.replaceChildren();
      if (!pages?.length) {
        replaceWithMessage(target, "No consented landing-page sessions were reported.");
        setText("[data-attention-insight]", "There is not enough consented landing-page data to choose a review candidate yet.");
        return;
      }
      pages.slice(0, 10).forEach((page) => {
        const item = document.createElement("li");
        item.className = "attention-row";
        const pageCell = document.createElement("div");
        pageCell.className = "attention-page";
        const link = document.createElement("a");
        link.href = `https://brisbanetvs.com${page.path}`;
        link.target = "_blank";
        link.rel = "noreferrer";
        link.textContent = pageLabel(page.path);
        const sessionCount = document.createElement("small");
        sessionCount.textContent = `${numberFormat.format(numeric(page.sessions))} consented session${numeric(page.sessions) === 1 ? "" : "s"}`;
        pageCell.append(link, sessionCount);
        const values = [
          ["Avg. engaged", formatDuration(page.averageEngagementSeconds)],
          ["Engaged", percentFormat.format(numeric(page.engagementRate))],
          ["Depth", `${decimalFormat.format(numeric(page.viewsPerSession))} views`],
        ];
        const cells = values.map(([labelText, valueText]) => {
          const cell = document.createElement("div");
          cell.className = "attention-stat";
          const label = document.createElement("span");
          const value = document.createElement("strong");
          label.textContent = labelText;
          value.textContent = valueText;
          cell.append(label, value);
          return cell;
        });
        item.append(pageCell, ...cells);
        target.append(item);
      });

      const reviewCandidates = pages
        .filter((page) => numeric(page.sessions) >= 3)
        .sort((left, right) => numeric(left.engagementRate) - numeric(right.engagementRate) || numeric(left.averageEngagementSeconds) - numeric(right.averageEngagementSeconds));
      const candidate = reviewCandidates[0];
      setText("[data-attention-insight]", candidate
        ? `${pageLabel(candidate.path)} is the clearest review candidate among pages with at least three consented sessions: ${percentFormat.format(numeric(candidate.engagementRate))} engaged, ${formatDuration(candidate.averageEngagementSeconds)} average engaged time and ${decimalFormat.format(numeric(candidate.viewsPerSession))} views per session.`
        : "There is not enough consented volume on any one landing page to identify a reliable review candidate yet.");
    }

    function renderSimpleList(selector, entries, valueKey, suffix, emptyMessage) {
      const target = document.querySelector(selector);
      target.replaceChildren();
      if (!entries?.length) {
        replaceWithMessage(target, emptyMessage);
        return;
      }
      entries.slice(0, 10).forEach((entry) => {
        const item = document.createElement("li");
        const label = document.createElement("span");
        const value = document.createElement("strong");
        label.textContent = entry.label || "Other";
        value.textContent = `${numberFormat.format(numeric(entry[valueKey]))} ${suffix}`;
        item.append(label, value);
        target.append(item);
      });
    }

    function renderSearchBreakdown(selector, entries, emptyMessage) {
      const target = document.querySelector(selector);
      target.replaceChildren();
      if (!entries?.length) {
        replaceWithMessage(target, emptyMessage);
        return;
      }
      entries.forEach((entry) => {
        const item = document.createElement("li");
        const label = document.createElement("span");
        const values = document.createElement("span");
        const primary = document.createElement("strong");
        const detail = document.createElement("small");
        label.textContent = entry.label || "Other";
        primary.textContent = `${numberFormat.format(numeric(entry.clicks))} clicks`;
        detail.textContent = `${numberFormat.format(numeric(entry.impressions))} appearances · ${percentFormat.format(numeric(entry.ctr))} CTR`;
        values.className = "search-breakdown-values";
        values.append(primary, detail);
        item.append(label, values);
        target.append(item);
      });
    }

    function renderPublicActions(actions) {
      const ready = actions?.status === "ready";
      const pill = document.querySelector("[data-actions-pill]");
      const selectors = ["[data-action-quote]", "[data-action-call]", "[data-action-pricing]", "[data-action-form-start]", "[data-action-form-error]", "[data-action-lead]"];
      if (!ready) {
        selectors.forEach((selector) => setText(selector, "—"));
        pill.textContent = "Unavailable";
        pill.classList.add("is-muted");
        setText("[data-actions-note]", "The action-event report is unavailable. Dashes are not zeroes.");
        return;
      }
      const totals = actions.totals || {};
      setNumber("[data-action-quote]", totals.quoteCtaClicks);
      setNumber("[data-action-call]", totals.callClicks);
      setNumber("[data-action-pricing]", totals.pricingCalculatorUses);
      setNumber("[data-action-form-start]", totals.formStarts);
      setNumber("[data-action-form-error]", totals.formErrors);
      setNumber("[data-action-lead]", totals.generateLeads);
      pill.textContent = "Connected";
      pill.classList.remove("is-muted", "is-warning");
      const recorded = numeric(totals.quoteCtaClicks) + numeric(totals.callClicks) + numeric(totals.emailClicks)
        + numeric(totals.pricingCalculatorUses) + numeric(totals.chatOpens) + numeric(totals.chatMessages)
        + numeric(totals.formStarts) + numeric(totals.formErrors) + numeric(totals.generateLeads);
      setText("[data-actions-note]", recorded
        ? `${numberFormat.format(recorded)} tracked actions were recorded across consenting visits. Repeated actions by one visitor are counted separately.`
        : "Connected, with zero tracked public actions in this completed 28-day window.");
    }

    function renderBusinessOutcomes(outcomes) {
      const ready = outcomes?.status === "ready";
      const pill = document.querySelector("[data-outcomes-pill]");
      const selectors = ["[data-outcome-leads]", "[data-outcome-quotes]", "[data-outcome-accepted]", "[data-outcome-jobs]", "[data-outcome-revenue]", "[data-outcome-paid]"];
      if (!ready) {
        selectors.forEach((selector) => setText(selector, "—"));
        pill.textContent = "Unavailable";
        pill.classList.add("is-muted");
        setText("[data-outcomes-note]", "Operations outcome reporting is unavailable. Dashes are not zeroes.");
        return;
      }
      setNumber("[data-outcome-leads]", outcomes.websiteLeads);
      setNumber("[data-outcome-quotes]", outcomes.quotes);
      setNumber("[data-outcome-accepted]", outcomes.acceptedQuotes);
      setNumber("[data-outcome-jobs]", outcomes.completedJobs);
      setText("[data-outcome-revenue]", currencyFormat.format(numeric(outcomes.revenueCents) / 100));
      setText("[data-outcome-paid]", currencyFormat.format(numeric(outcomes.paidCents) / 100));
      pill.textContent = "Connected";
      pill.classList.remove("is-muted", "is-warning");
      const downstream = numeric(outcomes.quotes) + numeric(outcomes.jobs) + numeric(outcomes.invoices);
      setText("[data-outcomes-note]", downstream
        ? "These outcomes are linked to website leads received during the same 28-day cohort."
        : "No quotes, jobs or invoices are recorded for this website-lead cohort yet. Those stages remain zero rather than being estimated.");
    }

    function renderLeadSignals(signals) {
      const pill = document.querySelector("[data-leads-pill]");
      const delivery = signals?.sheetDelivery || {};
      const waiting = numeric(delivery.pending) + numeric(delivery.failed) + numeric(delivery.missing);
      const ready = signals?.status === "ready";
      if (!ready) {
        ["[data-saved-today]", "[data-saved-week]", "[data-saved-web]", "[data-saved-web-28]", "[data-sheet-waiting]"].forEach((selector) => setText(selector, "—"));
        setText("[data-enquiry-detail]", "Operations enquiry reporting is unavailable; this is not a zero.");
        pill.textContent = "Unavailable";
        pill.classList.add("is-muted");
        renderSimpleList("[data-lead-sources]", [], "leads", "leads", "Saved enquiry sources are unavailable.");
        return;
      }
      setNumber("[data-saved-today]", signals?.today);
      setNumber("[data-saved-week]", signals?.last7Days);
      setNumber("[data-saved-web]", signals?.websiteLast7Days);
      setNumber("[data-saved-web-28]", signals?.websiteLast28Days);
      setNumber("[data-sheet-waiting]", waiting);
      setText("[data-enquiry-detail]", `${numberFormat.format(numeric(signals?.websiteLast28Days))} of ${numberFormat.format(numeric(signals?.last28Days))} saved enquiries came from website forms in the last 28 days.`);
      pill.textContent = waiting ? "Check delivery" : "Live";
      pill.classList.toggle("is-muted", waiting > 0);
      pill.classList.toggle("is-warning", waiting > 0);
      renderSimpleList("[data-lead-sources]", signals?.bySource, "leads", "leads", "No saved leads in this period.");
    }

    function renderAnalytics(analytics) {
      currentAnalytics = analytics;
      const gaReady = analytics.gaStatus === "ready";
      const searchReady = analytics.searchConsole?.status === "ready";
      const leadsReady = analytics.leadSignals?.status === "ready";
      const stable = analytics.last28Days;
      if (gaReady && stable) {
        setNumber("[data-stable-sessions]", stable.sessions);
        setNumber("[data-stable-engaged]", stable.engagedSessions);
        setText("[data-stable-rate]", percentFormat.format(numeric(stable.engagementRate)));
        setNumber("[data-stable-views]", stable.pageViews);
        setText("[data-stable-vps]", decimalFormat.format(numeric(stable.viewsPerSession)));
        setNumber("[data-stable-leads]", stable.generateLeads);
        setText("[data-engage-detail]", `${numberFormat.format(numeric(stable.engagedSessions))} of ${numberFormat.format(numeric(stable.sessions))} consented sessions were engaged.`);
        setNumber("[data-today-sessions]", analytics.today?.sessions);
        setNumber("[data-today-views]", analytics.today?.pageViews);
      } else {
        ["[data-stable-sessions]", "[data-stable-engaged]", "[data-stable-rate]", "[data-stable-views]", "[data-stable-vps]", "[data-stable-leads]", "[data-today-sessions]", "[data-today-views]"].forEach((selector) => setText(selector, "—"));
        setText("[data-engage-detail]", "Consented GA4 reporting is unavailable; this is not a zero.");
      }
      setText("[data-ga-window]", "27 days ago to yesterday · completed days");
      renderRealtime(analytics.realtime);
      renderSessionHealth(analytics.sessionDiagnostics);
      if (analytics.reportHealth?.dailySessions === "ready") renderDailySessions(analytics.dailySessions);
      else {
        replaceWithMessage(document.querySelector("[data-session-chart]"), "Daily session reporting is unavailable.");
        setText("[data-session-chart-summary]", "Daily session reporting is unavailable.");
      }
      renderSearchMetrics(analytics.searchConsole);
      renderSearchBreakdown(
        "[data-search-devices]",
        analytics.searchConsole?.devices,
        analytics.searchConsole?.breakdownHealth?.devices === "ready" ? "No device rows were returned for this final Search Console window." : "The device breakdown is unavailable; the main Search Console totals are still valid.",
      );
      renderSearchBreakdown(
        "[data-search-geography]",
        analytics.searchConsole?.geography,
        analytics.searchConsole?.breakdownHealth?.geography === "ready" ? "No country rows were returned for this final Search Console window." : "The country breakdown is unavailable; the main Search Console totals are still valid.",
      );
      if (analytics.reportHealth?.landingPages === "ready") renderLandingPages(analytics.landingPages);
      else {
        replaceWithMessage(document.querySelector("[data-landing-pages]"), "Landing-page reporting is unavailable; this is not a zero.");
        setText("[data-attention-insight]", "Landing-page attention signals are unavailable until the GA4 report reconnects.");
      }
      renderSimpleList("[data-traffic-sources]", analytics.topSources, "sessions", "sessions", "No consented traffic channels were reported.");
      renderPublicActions(analytics.publicActions);
      renderLeadSignals(analytics.leadSignals);
      renderBusinessOutcomes(analytics.leadSignals?.businessOutcomes);
      renderOpportunities();

      const gaPill = document.querySelector("[data-ga-pill]");
      gaPill.textContent = gaReady ? "Connected" : analytics.gaStatus === "not_configured" ? "Setup needed" : "Unavailable";
      gaPill.classList.toggle("is-muted", !gaReady);
      const leadDelivery = analytics.leadSignals?.sheetDelivery || {};
      const deliveryWaiting = numeric(leadDelivery.pending) + numeric(leadDelivery.failed) + numeric(leadDelivery.missing);
      const actionsReady = analytics.publicActions?.status === "ready";
      const allReady = gaReady && actionsReady && searchReady && leadsReady && deliveryWaiting === 0;
      const statusParts = [
        gaReady && actionsReady ? "GA4 connected" : analytics.gaStatus === "not_configured" ? "GA4 setup needed" : "GA4 partly unavailable",
        searchReady ? "Search Console connected" : analytics.searchConsole?.status === "not_configured" ? "Search Console setup needed" : "Search Console unavailable",
        leadsReady ? "saved enquiries connected" : "saved enquiries unavailable",
      ];
      if (deliveryWaiting > 0) statusParts.push(`${numberFormat.format(deliveryWaiting)} Sheet deliveries need attention`);
      statusElement.textContent = statusParts.join(" · ");
      statusElement.classList.toggle("is-ready", allReady);
      statusElement.classList.toggle("is-warning", !allReady);
      const healthDetails = document.querySelector(".analytics-health");
      if (healthDetails instanceof HTMLDetailsElement) healthDetails.open = !allReady;
    }

    async function loadAnalytics() {
      refreshButton.disabled = true;
      statusElement.textContent = "Refreshing reporting data...";
      try {
        renderAnalytics(await requestAnalytics());
      } catch (error) {
        statusElement.textContent = error?.status === 403
          ? "Your secure session has expired. Sign in again to view Analytics."
          : "Reporting is temporarily unavailable. Please refresh shortly.";
        statusElement.classList.remove("is-ready");
        statusElement.classList.add("is-warning");
        const healthDetails = document.querySelector(".analytics-health");
        if (healthDetails instanceof HTMLDetailsElement) healthDetails.open = true;
        ["[data-search-impressions]", "[data-search-clicks]", "[data-stable-sessions]", "[data-stable-rate]", "[data-saved-web-28]", "[data-stable-leads]", "[data-today-sessions]", "[data-today-views]", "[data-action-quote]", "[data-action-call]", "[data-action-pricing]", "[data-action-form-start]", "[data-action-form-error]", "[data-action-lead]", "[data-outcome-leads]", "[data-outcome-quotes]", "[data-outcome-accepted]", "[data-outcome-jobs]", "[data-outcome-revenue]", "[data-outcome-paid]"].forEach((selector) => setText(selector, "—"));
        replaceWithMessage(document.querySelector("[data-opportunity-list]"), "The improvement queue is unavailable until reporting reconnects.");
        replaceWithMessage(document.querySelector("[data-landing-pages]"), "Landing-page attention is unavailable until reporting reconnects.");

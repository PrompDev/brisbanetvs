---
import OperationsLayout from "../../../components/operations/OperationsLayout.astro";
---

<OperationsLayout
  active="analytics"
  title="Google analytics"
  description="Protected consent-aware Google Analytics and Search Console reporting for Brisbane TVs staff."
>
  <section class="operations-page-header analytics-header" aria-labelledby="analytics-title">
    <div>
      <p class="operations-eyebrow">Marketing · Google</p>
      <h1 id="analytics-title" class="operations-title">See the page, query and next move.</h1>
      <p class="operations-copy">A stable view of consented sessions plus the pages appearing in Google, the queries behind those impressions and the improvements most likely to help.</p>
    </div>
    <div class="analytics-actions">
      <p class="operations-status" data-analytics-status role="status">Connecting to secure Google reporting...</p>
      <button class="operations-button" type="button" data-analytics-refresh>Refresh</button>
    </div>
  </section>

  <section class="analytics-basis" aria-label="How to read these figures">
    <div><strong>Search impressions</strong><span>A Brisbane TVs result appeared in Google. The visitor may never open the site.</span></div>
    <div><strong>GA4 sessions</strong><span>A visit from someone who allowed analytics. Completed days are used below.</span></div>
    <div><strong>Saved enquiries</strong><span>An accepted lead in Operations, regardless of the visitor's analytics choice.</span></div>
  </section>

  <section aria-labelledby="stable-period-title">
    <div class="analytics-section-head">
      <div><p class="operations-eyebrow">Consented GA4</p><h2 id="stable-period-title">Last 28 complete days</h2></div>
      <span data-ga-window>27 days ago to yesterday</span>
    </div>
    <div class="analytics-metrics">
      <article><span>Sessions</span><strong data-stable-sessions>—</strong><small>Consented visits</small></article>
      <article><span>Engaged sessions</span><strong data-stable-engaged>—</strong><small>Meaningful visits</small></article>
      <article><span>Engagement rate</span><strong data-stable-rate>—</strong><small>Engaged ÷ sessions</small></article>
      <article><span>Page views</span><strong data-stable-views>—</strong><small>Across consented visits</small></article>
      <article><span>Views per session</span><strong data-stable-vps>—</strong><small>Browsing depth</small></article>
      <article class="is-featured"><span>GA lead events</span><strong data-stable-leads>—</strong><small>Consented form completions</small></article>
    </div>
  </section>

  <section class="analytics-grid" aria-label="Session reporting health">
    <article class="operations-panel analytics-panel">
      <div class="analytics-panel-head">
        <div><h2>Daily sessions</h2><p>Completed days make gaps and processing delays visible</p></div>
        <span class="operations-pill is-muted" data-realtime-pill>Checking realtime</span>
      </div>
      <div class="session-chart" data-session-chart role="img" aria-label="Daily consented GA4 sessions"><p>Loading daily sessions...</p></div>
      <div class="today-strip">
        <div><span>Today · provisional</span><strong data-today-sessions>—</strong><small>sessions</small></div>
        <div><span>Today</span><strong data-today-views>—</strong><small>page views</small></div>
        <p data-realtime-copy>Checking visitors active in the last 30 minutes...</p>
      </div>
    </article>

    <article class="operations-panel analytics-panel session-health">
      <div class="analytics-panel-head"><div><h2>Session health check</h2><p>GA4 sessions compared with its session_start event</p></div><span class="operations-pill is-muted" data-session-health-pill>Checking</span></div>
      <div class="session-compare">
        <div><span>Sessions</span><strong data-diagnostic-sessions>—</strong></div>
        <div><span>session_start</span><strong data-diagnostic-starts>—</strong></div>
        <div><span>Difference</span><strong data-diagnostic-difference>—</strong></div>
        <div><span>Days with visits</span><strong data-diagnostic-days>—</strong></div>
      </div>
      <p class="analytics-explanation" data-session-health-copy>Loading the session diagnostic...</p>
    </article>
  </section>

  <section class="search-section" aria-labelledby="search-performance-title">
    <div class="analytics-section-head">
      <div><p class="operations-eyebrow">Google Search Console</p><h2 id="search-performance-title">Pages appearing in search</h2></div>
      <span data-search-window>Final data ends three days ago</span>
    </div>
    <div class="search-metrics">
      <article><span>Clicks</span><strong data-search-clicks>—</strong><small data-click-change>vs previous period</small></article>
      <article><span>Impressions</span><strong data-search-impressions>—</strong><small data-impression-change>vs previous period</small></article>
      <article><span>Click-through rate</span><strong data-search-ctr>—</strong><small data-ctr-change>vs previous period</small></article>
      <article><span>Average position</span><strong data-search-position>—</strong><small data-position-change>Higher is better</small></article>
    </div>

    <article class="operations-panel analytics-panel opportunity-panel">
      <div class="analytics-panel-head opportunity-heading">
        <div><h2>Page improvement queue</h2><p>Prioritised from impressions, clicks, rank movement and top queries</p></div>
        <div class="analytics-filters">
          <label><span>Find page</span><input type="search" data-page-search placeholder="e.g. mount or repair" /></label>
          <label><span>Opportunity</span><select data-opportunity-filter><option value="all">All pages</option><option value="snippet_gap">Shown, not clicked</option><option value="near_page_one">Within reach</option><option value="low_ctr">Low click rate</option><option value="growing_visibility">Growing visibility</option><option value="monitor">Monitor</option></select></label>
        </div>
      </div>
      <div class="opportunity-list" data-opportunity-list aria-live="polite"><p class="analytics-empty">Loading page and query details...</p></div>
      <p class="analytics-footnote" data-search-note>Search Console data is finalised with a short delay.</p>
    </article>
  </section>

  <section class="analytics-grid" aria-label="Landing pages and acquisition">
    <article class="operations-panel analytics-panel">
      <div class="analytics-panel-head"><div><h2>GA4 landing pages</h2><p>Where consented sessions began</p></div><span class="operations-pill is-muted">28 complete days</span></div>
      <ul class="analytics-list" data-landing-pages><li>Loading landing pages...</li></ul>
    </article>
    <article class="operations-panel analytics-panel">
      <div class="analytics-panel-head"><div><h2>Traffic channels</h2><p>Controlled GA4 channel groups only</p></div><span class="operations-pill is-muted" data-ga-pill>Checking</span></div>
      <ul class="analytics-list" data-traffic-sources><li>Loading channels...</li></ul>
    </article>
  </section>

  <section class="analytics-grid" aria-label="Saved lead signals">
    <article class="operations-panel analytics-panel saved-leads-panel">
      <div class="analytics-panel-head"><div><h2>Saved enquiries</h2><p>All accepted submissions, independent of analytics consent</p></div><span class="operations-pill is-muted" data-leads-pill>Checking</span></div>
      <div class="saved-lead-metrics">
        <div><span>Today</span><strong data-saved-today>—</strong></div>
        <div><span>Last 7 days</span><strong data-saved-week>—</strong></div>
        <div><span>Website forms</span><strong data-saved-web>—</strong></div>
        <div><span>Sheet waiting</span><strong data-sheet-waiting>—</strong></div>
      </div>
    </article>
    <article class="operations-panel analytics-panel">
      <div class="analytics-panel-head"><div><h2>Enquiry sources</h2><p>Saved lead mix for the last seven days</p></div></div>
      <ul class="analytics-list" data-lead-sources><li>Loading saved lead sources...</li></ul>
    </article>
  </section>

  <section class="operations-privacy-note">
    <span aria-hidden="true">✓</span>
    <p>This page requests fixed, aggregate reports only. Search queries and Brisbane TVs page paths are privacy-filtered; visitor identities, contact details and free-text form answers are not requested from Google or displayed here.</p>
  </section>

  <script>
    const numberFormat = new Intl.NumberFormat("en-AU");
    const decimalFormat = new Intl.NumberFormat("en-AU", { maximumFractionDigits: 1 });
    const percentFormat = new Intl.NumberFormat("en-AU", { style: "percent", maximumFractionDigits: 1 });
    const statusElement = document.querySelector("[data-analytics-status]");
    const refreshButton = document.querySelector("[data-analytics-refresh]");
    const pageSearch = document.querySelector("[data-page-search]");
    const opportunityFilter = document.querySelector("[data-opportunity-filter]");
    let currentAnalytics = null;

    const numeric = (value) => Math.max(0, Number(value) || 0);
    const setText = (selector, value) => { const element = document.querySelector(selector); if (element) element.textContent = value; };
    const setNumber = (selector, value) => setText(selector, numberFormat.format(numeric(value)));

    function signed(value, suffix = "") {
      const amount = Number(value) || 0;
      if (amount === 0) return `No change${suffix}`;
      return `${amount > 0 ? "+" : "−"}${decimalFormat.format(Math.abs(amount))}${suffix}`;
    }

    async function requestAnalytics() {
      const response = await fetch("/operations/api/analytics", {
        cache: "no-store",
        credentials: "same-origin",
        headers: { accept: "application/json" },
      });
      const payload = await response.json().catch(() => null);
      if (!response.ok || !payload?.ok || !payload.analytics) {
        throw Object.assign(new Error("analytics unavailable"), { status: response.status });
      }
      return payload.analytics;
    }

    function replaceWithMessage(target, message) {
      target.replaceChildren();
      const element = document.createElement(target.tagName === "UL" ? "li" : "p");
      element.className = "analytics-empty";
      element.textContent = message;
      target.append(element);
    }

    function renderDailySessions(days) {
      const target = document.querySelector("[data-session-chart]");
      target.replaceChildren();
      if (!days?.length) {
        replaceWithMessage(target, "No consented sessions were reported in the completed-day window.");
        return;
      }
      const maximum = Math.max(1, ...days.map((day) => numeric(day.sessions)));
      days.forEach((day, index) => {
        const column = document.createElement("div");
        const bar = document.createElement("span");
        const label = document.createElement("small");
        const sessions = numeric(day.sessions);
        const date = new Date(`${day.date}T00:00:00+10:00`);
        column.title = `${day.date}: ${numberFormat.format(sessions)} sessions, ${numberFormat.format(numeric(day.pageViews))} page views`;
        column.setAttribute("aria-label", column.title);
        bar.style.height = `${Math.max(sessions > 0 ? 6 : 1, Math.round((sessions / maximum) * 100))}%`;
        label.textContent = index % 7 === 0 ? new Intl.DateTimeFormat("en-AU", { day: "numeric", month: "short" }).format(date) : "";
        column.append(bar, label);
        target.append(column);
      });
    }

    function renderRealtime(realtime) {
      const pill = document.querySelector("[data-realtime-pill]");
      const ready = realtime?.status === "ready";
      const active = ready ? numeric(realtime.activeUsersLast30Minutes) : null;
      pill.classList.toggle("is-muted", !ready || active === 0);
      pill.textContent = ready ? `${numberFormat.format(active)} active now` : "Realtime unavailable";
      setText("[data-realtime-copy]", ready
        ? active > 0
          ? `${numberFormat.format(active)} consented visitor${active === 1 ? "" : "s"} active in the last 30 minutes.`
          : "Connected, with no consented visitors active in the last 30 minutes."
        : "Realtime is unavailable; the completed-day report remains the reliable view.");
    }

    function renderSessionHealth(diagnostic) {
      const pill = document.querySelector("[data-session-health-pill]");
      if (!diagnostic) {
        pill.textContent = "Unavailable";
        setText("[data-session-health-copy]", "The session comparison could not be loaded.");
        return;
      }
      setNumber("[data-diagnostic-sessions]", diagnostic.sessions);
      setNumber("[data-diagnostic-starts]", diagnostic.sessionStartEvents);
      setText("[data-diagnostic-difference]", signed(diagnostic.difference));
      setText("[data-diagnostic-days]", `${numberFormat.format(numeric(diagnostic.daysWithSessions))}/${numberFormat.format(numeric(diagnostic.daysReported))}`);
      pill.classList.toggle("is-muted", diagnostic.status !== "aligned");
      pill.classList.toggle("is-warning", diagnostic.status === "processing_difference");
      if (diagnostic.status === "aligned") {
        pill.textContent = "Aligned";
        setText("[data-session-health-copy]", "Sessions and session_start events agree. Collection is working for visitors who allow analytics.");
      } else if (diagnostic.status === "no_consent_data") {
        pill.textContent = "No consented visits";
        setText("[data-session-health-copy]", "GA4 received no consented sessions in this window. Search impressions can still exist because appearing in Google does not mean someone opened the site or allowed analytics.");
      } else {
        pill.textContent = "Processing difference";
        setText("[data-session-health-copy]", "The two GA4 counts differ. Standard reports can continue processing for 24–48 hours; this completed-day window avoids today's largest delay, but the newest days can still settle.");
      }
    }

    function renderSearchMetrics(search) {
      const ready = search?.status === "ready";
      if (!ready) {
        ["[data-search-clicks]", "[data-search-impressions]", "[data-search-ctr]", "[data-search-position]"].forEach((selector) => setText(selector, "—"));
        setText("[data-search-window]", search?.status === "not_configured" ? "Search Console setup needed" : "Search Console unavailable");
        return;
      }
      setNumber("[data-search-clicks]", search.totals?.clicks);
      setNumber("[data-search-impressions]", search.totals?.impressions);
      setText("[data-search-ctr]", percentFormat.format(numeric(search.totals?.ctr)));
      setText("[data-search-position]", decimalFormat.format(numeric(search.totals?.position)));
      setText("[data-click-change]", `${signed(search.changes?.clicks)} clicks vs previous 28 days`);
      setText("[data-impression-change]", `${signed(search.changes?.impressions)} impressions vs previous 28 days`);
      setText("[data-ctr-change]", `${signed((Number(search.changes?.ctr) || 0) * 100, " points")} vs previous period`);
      setText("[data-position-change]", `${signed(search.changes?.position)} positions vs previous period`);
      setText("[data-search-window]", `${search.window.startDate} to ${search.window.endDate} · final data`);
      setText("[data-search-note]", `Showing privacy-filtered page rows for ${search.window.startDate} to ${search.window.endDate}. Search Console dates use Pacific Time and finish ${search.window.lagDays} days behind today.`);
    }

    function landingPageMap(landingPages) {
      return new Map((landingPages || []).map((page) => [page.path, page]));
    }

    function renderOpportunities() {
      const target = document.querySelector("[data-opportunity-list]");
      const search = currentAnalytics?.searchConsole;
      if (search?.status !== "ready") {
        replaceWithMessage(target, search?.status === "not_configured" ? "Search Console needs its read-only connection before page opportunities can appear." : "Search Console is temporarily unavailable.");
        return;
      }
      const term = String(pageSearch.value || "").trim().toLowerCase();
      const filter = opportunityFilter.value;
      const gaPages = landingPageMap(currentAnalytics?.landingPages);
      const pages = (search.opportunities || []).filter((page) => {
        const matchesTerm = !term || String(page.path).toLowerCase().includes(term) || (page.topQueries || []).some((query) => String(query.query).toLowerCase().includes(term));
        const matchesFilter = filter === "all" || page.opportunity?.type === filter;
        return matchesTerm && matchesFilter;
      });
      target.replaceChildren();
      if (!pages.length) {
        replaceWithMessage(target, "No page opportunities match that filter.");
        return;
      }
      pages.forEach((page, index) => {
        const card = document.createElement("article");
        card.className = "opportunity-card";
        card.id = encodeURIComponent(page.path);
        const rank = document.createElement("span");
        rank.className = "opportunity-rank";
        rank.textContent = String(index + 1).padStart(2, "0");
        const body = document.createElement("div");
        body.className = "opportunity-body";
        const heading = document.createElement("div");
        heading.className = "opportunity-title";
        const path = document.createElement("a");
        path.href = `https://brisbanetvs.com${page.path}`;
        path.target = "_blank";
        path.rel = "noreferrer";
        path.textContent = page.path;
        const badge = document.createElement("span");
        badge.className = `opportunity-badge is-${page.opportunity?.type || "monitor"}`;
        badge.textContent = page.opportunity?.label || "Monitor";
        heading.append(path, badge);
        const recommendation = document.createElement("p");
        recommendation.textContent = page.opportunity?.recommendation || "Keep watching this page as more data arrives.";
        const queries = document.createElement("div");
        queries.className = "query-list";
        if (page.topQueries?.length) {
          page.topQueries.forEach((query) => {
            const item = document.createElement("span");
            const label = document.createElement("b");
            const detail = document.createElement("small");
            label.textContent = query.query;
            detail.textContent = `${numberFormat.format(numeric(query.impressions))} imp · ${numberFormat.format(numeric(query.clicks))} click · pos ${decimalFormat.format(numeric(query.position))}`;
            item.append(label, detail);
            queries.append(item);
          });
        } else {
          const unavailable = document.createElement("small");
          unavailable.textContent = "No privacy-safe query rows were returned for this page.";
          queries.append(unavailable);
        }
        body.append(heading, recommendation, queries);

        const gaPage = gaPages.get(page.path);
        const metrics = document.createElement("dl");
        metrics.className = "opportunity-metrics";
        const values = [
          ["Impressions", numberFormat.format(numeric(page.impressions)), signed(page.impressionChange)],
          ["Clicks / CTR", `${numberFormat.format(numeric(page.clicks))} / ${percentFormat.format(numeric(page.ctr))}`, signed(page.clickChange)],
          ["Avg. position", decimalFormat.format(numeric(page.position)), page.positionChange ? `${signed(page.positionChange)} better` : "No movement"],
          ["GA landing sessions", gaPage ? numberFormat.format(numeric(gaPage.sessions)) : "0", gaPage ? `${percentFormat.format(numeric(gaPage.engagementRate))} engaged` : "No consented session match"],
        ];
        values.forEach(([labelText, valueText, detailText]) => {
          const wrapper = document.createElement("div");
          const termElement = document.createElement("dt");
          const valueElement = document.createElement("dd");
          const detailElement = document.createElement("small");
          termElement.textContent = labelText;
          valueElement.textContent = valueText;
          detailElement.textContent = detailText;
          wrapper.append(termElement, valueElement, detailElement);
          metrics.append(wrapper);
        });
        card.append(rank, body, metrics);
        target.append(card);
      });
    }

    function renderLandingPages(pages) {
      const target = document.querySelector("[data-landing-pages]");
      target.replaceChildren();
      if (!pages?.length) {
        replaceWithMessage(target, "No consented landing-page sessions were reported.");
        return;
      }
      pages.slice(0, 10).forEach((page) => {
        const item = document.createElement("li");
        const label = document.createElement("span");
        const metrics = document.createElement("strong");
        label.textContent = page.path;
        metrics.textContent = `${numberFormat.format(numeric(page.sessions))} sessions · ${percentFormat.format(numeric(page.engagementRate))} engaged`;
        item.append(label, metrics);
        target.append(item);
      });
    }

    function renderSimpleList(selector, entries, valueKey, suffix, emptyMessage) {
      const target = document.querySelector(selector);
      target.replaceChildren();
      if (!entries?.length) {
        replaceWithMessage(target, emptyMessage);
        return;
      }
      entries.slice(0, 10).forEach((entry) => {
        const item = document.createElement("li");
        const label = document.createElement("span");
        const value = document.createElement("strong");
        label.textContent = entry.label || "Other";
        value.textContent = `${numberFormat.format(numeric(entry[valueKey]))} ${suffix}`;
        item.append(label, value);
        target.append(item);
      });
    }

    function renderLeadSignals(signals) {
      const pill = document.querySelector("[data-leads-pill]");
      const delivery = signals?.sheetDelivery || {};
      const waiting = numeric(delivery.pending) + numeric(delivery.failed) + numeric(delivery.missing);
      setNumber("[data-saved-today]", signals?.today);
      setNumber("[data-saved-week]", signals?.last7Days);
      setNumber("[data-saved-web]", signals?.websiteLast7Days);
      setNumber("[data-sheet-waiting]", waiting);
      pill.textContent = signals?.status === "ready" ? waiting ? "Check delivery" : "Live" : "Unavailable";
      pill.classList.toggle("is-muted", signals?.status !== "ready" || waiting > 0);
      pill.classList.toggle("is-warning", waiting > 0);
      renderSimpleList("[data-lead-sources]", signals?.bySource, "leads", "leads", "No saved leads in this period.");
    }

    function renderAnalytics(analytics) {
      currentAnalytics = analytics;
      const gaReady = analytics.gaStatus === "ready";
      const stable = analytics.last28Days;
      setNumber("[data-stable-sessions]", stable?.sessions);
      setNumber("[data-stable-engaged]", stable?.engagedSessions);
      setText("[data-stable-rate]", stable ? percentFormat.format(numeric(stable.engagementRate)) : "—");
      setNumber("[data-stable-views]", stable?.pageViews);
      setText("[data-stable-vps]", stable ? decimalFormat.format(numeric(stable.viewsPerSession)) : "—");
      setNumber("[data-stable-leads]", stable?.generateLeads);
      setNumber("[data-today-sessions]", analytics.today?.sessions);
      setNumber("[data-today-views]", analytics.today?.pageViews);
      setText("[data-ga-window]", "27 days ago to yesterday · completed days");
      renderRealtime(analytics.realtime);
      renderSessionHealth(analytics.sessionDiagnostics);
      renderDailySessions(analytics.dailySessions);
      renderSearchMetrics(analytics.searchConsole);
      renderLandingPages(analytics.landingPages);
      renderSimpleList("[data-traffic-sources]", analytics.topSources, "sessions", "sessions", "No consented traffic channels were reported.");
      renderLeadSignals(analytics.leadSignals);
      renderOpportunities();

      const gaPill = document.querySelector("[data-ga-pill]");
      gaPill.textContent = gaReady ? "Connected" : analytics.gaStatus === "not_configured" ? "Setup needed" : "Unavailable";
      gaPill.classList.toggle("is-muted", !gaReady);
      statusElement.textContent = gaReady
        ? "Google reporting is connected. Completed-day session data and final Search Console data are shown."
        : analytics.gaStatus === "not_configured"
          ? "Saved lead data is live; the read-only GA4 reporting connection still needs setup."
          : "Saved lead data is live; GA4 reporting is temporarily unavailable.";
      statusElement.classList.toggle("is-ready", gaReady);
      statusElement.classList.toggle("is-warning", !gaReady);
    }

    async function loadAnalytics() {
      refreshButton.disabled = true;
      statusElement.textContent = "Refreshing Google reporting...";
      try {
        renderAnalytics(await requestAnalytics());
      } catch (error) {
        statusElement.textContent = error?.status === 403
          ? "Your secure session has expired. Sign in again to view Analytics."
          : "Google reporting is temporarily unavailable. Please refresh shortly.";
        statusElement.classList.remove("is-ready");
      } finally {
        refreshButton.disabled = false;
      }
    }

    pageSearch.addEventListener("input", renderOpportunities);
    opportunityFilter.addEventListener("change", renderOpportunities);
    refreshButton.addEventListener("click", loadAnalytics);
    loadAnalytics();
  </script>

  <style>
    .analytics-header { padding-bottom: 1.5rem; border-bottom: 1px solid #e7e5e0; }
    .analytics-actions { display: flex; align-items: center; gap: .6rem; }
    .analytics-basis { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1px; overflow: hidden; margin-bottom: 1.7rem; border: 1px solid #e7e5e0; border-radius: .75rem; background: #e7e5e0; }
    .analytics-basis > div { display: grid; gap: .3rem; padding: 1rem; background: #fff; }
    .analytics-basis strong { font-size: .7rem; }
    .analytics-basis span { color: #71777b; font-size: .64rem; line-height: 1.45; }
    .analytics-section-head { display: flex; align-items: flex-end; justify-content: space-between; gap: 1rem; margin: 1.7rem 0 .85rem; }
    .analytics-section-head h2, .analytics-panel-head h2 { margin: 0; font-family: Georgia, "Times New Roman", serif; font-size: 1.35rem; font-weight: 400; }
    .analytics-section-head > span { color: #7c838c; font-size: .65rem; }
    .analytics-metrics { display: grid; grid-template-columns: repeat(6, 1fr); gap: .7rem; }
    .analytics-metrics article, .search-metrics article { display: flex; min-width: 0; min-height: 8.2rem; flex-direction: column; border: 1px solid #e7e5e0; border-radius: .75rem; padding: 1rem; background: #fff; }
    .analytics-metrics span, .search-metrics span, .session-compare span, .saved-lead-metrics span { color: #83847f; font-size: .57rem; font-weight: 750; letter-spacing: .08em; text-transform: uppercase; }
    .analytics-metrics strong, .search-metrics strong { margin: .7rem 0 .35rem; font-family: Georgia, "Times New Roman", serif; font-size: 1.7rem; font-weight: 400; }
    .analytics-metrics small, .search-metrics small { margin-top: auto; color: #8a8d8a; font-size: .58rem; line-height: 1.35; }
    .analytics-metrics .is-featured { border-color: #131619; color: #fff; background: #131619; }
    .analytics-metrics .is-featured span, .analytics-metrics .is-featured small { color: #aeb3b5; }

        replaceWithMessage(document.querySelector("[data-search-devices]"), "Device evidence is unavailable until reporting reconnects.");
        replaceWithMessage(document.querySelector("[data-search-geography]"), "Location evidence is unavailable until reporting reconnects.");
      } finally {
        refreshButton.disabled = false;
      }
    }

    pageSearch.addEventListener("input", renderOpportunities);
    opportunityFilter.addEventListener("change", renderOpportunities);
    refreshButton.addEventListener("click", loadAnalytics);

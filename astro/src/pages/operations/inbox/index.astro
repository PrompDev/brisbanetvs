---
import OperationsLayout from "../../../components/operations/OperationsLayout.astro";
import "../../../styles/operations-mailbox.css";
---

<OperationsLayout
  active="inbox"
  title="Customer mailbox"
  description="The protected Brisbane TVs customer mailbox for DeAndre, Kody and Tom."
>
  <section class="mail-page" data-inbox-root aria-labelledby="operations-mail-title">
    <header class="mail-hero">
      <div>
        <p class="mail-eyebrow">Customer mailbox</p>
        <h1 id="operations-mail-title">One customer inbox. Three Brisbane TVs addresses.</h1>
        <p class="mail-hero-copy">
          Read customer mail, move between staff addresses and prepare replies without leaving the protected dashboard.
        </p>
      </div>
      <div class="mail-connection is-checking" data-connection-status role="status">
        <span class="mail-connection-dot" aria-hidden="true"></span>
        <span data-connection-copy>Checking the protected mailbox...</span>
      </div>
    </header>

    <div class="mail-readiness" aria-label="Mailbox readiness">
      <div class="mail-readiness-item is-ready">
        <span>Dashboard</span>
        <strong>Ready</strong>
        <small>Protected staff access</small>
      </div>
      <div class="mail-readiness-item is-checking" data-readiness-incoming-card>
        <span>Incoming</span>
        <strong data-readiness-incoming>Checking</strong>
        <small data-readiness-incoming-detail>Confirming routing state</small>
      </div>
      <div class="mail-readiness-item is-ready">
        <span>Drafts</span>
        <strong>Ready</strong>
        <small>Nothing sends automatically</small>
      </div>
      <div class="mail-readiness-item is-locked" data-readiness-sending-card>
        <span>Sending</span>
        <strong data-readiness-sending>Locked</strong>
        <small data-readiness-sending-detail>Onboarding and live test required</small>
      </div>
    </div>

    <div class="mail-client" data-mail-client>
      <aside class="mail-rail" aria-label="Mailbox navigation">
        <div class="mail-rail-brand">
          <span class="mail-rail-mark" aria-hidden="true">
            <svg viewBox="0 0 24 24" role="img">
              <path d="M4 6.75h16v10.5H4z"></path>
              <path d="m4.75 7.5 7.25 5 7.25-5"></path>
            </svg>
          </span>
          <span>
            <strong>Brisbane TVs</strong>
            <small>Customer mail</small>
          </span>
        </div>

        <button class="mail-compose-button" type="button" data-compose-new>
          <svg viewBox="0 0 24 24" aria-hidden="true">
            <path d="M12 5v14M5 12h14"></path>
          </svg>
          Compose
        </button>

        <nav class="mail-nav" aria-label="Mail folders">
          <p class="mail-nav-label">Mail</p>
          <button class="mail-nav-button is-active" type="button" data-folder="inbox" aria-current="page">
            <svg viewBox="0 0 24 24" aria-hidden="true">
              <path d="M4 5h16v14H4z"></path>
              <path d="m5 6 7 6 7-6"></path>
            </svg>
            <span>Inbox</span>
            <strong data-inbox-total>0</strong>
          </button>
          <button class="mail-nav-button" type="button" data-folder="drafts">
            <svg viewBox="0 0 24 24" aria-hidden="true">
              <path d="M5 19h4l10-10-4-4L5 15z"></path>
              <path d="m13.5 6.5 4 4"></path>
            </svg>
            <span>Drafts</span>
            <strong data-draft-total>0</strong>
          </button>
          <button class="mail-nav-button" type="button" data-folder="sent">
            <svg viewBox="0 0 24 24" aria-hidden="true">
              <path d="m3 11 18-8-7 18-3-7z"></path>
              <path d="m11 14 4-4"></path>
            </svg>
            <span>Delivery</span>
            <strong data-sent-total>0</strong>
          </button>
          <button class="mail-nav-button" type="button" data-folder="archived">
            <svg viewBox="0 0 24 24" aria-hidden="true">
              <path d="M4 7h16v13H4zM3 4h18v3H3z"></path>
              <path d="M9 11h6"></path>
            </svg>
            <span>Archived</span>
          </button>
        </nav>

        <nav class="mail-nav mail-address-nav" aria-label="Staff addresses">
          <p class="mail-nav-label">Addresses</p>
          <button class="mail-address-button is-active" type="button" data-mailbox="all" aria-pressed="true">
            <span class="mail-address-avatar is-all">A</span>
            <span>
              <strong>All mail</strong>
              <small>3 addresses</small>
            </span>
            <b data-mailbox-count="all">0</b>
          </button>
          <button class="mail-address-button" type="button" data-mailbox="deandre" aria-pressed="false">
            <span class="mail-address-avatar is-deandre">D</span>
            <span>
              <strong>DeAndre</strong>
              <small>deandre@</small>
            </span>
            <b data-mailbox-count="deandre">0</b>
          </button>
          <button class="mail-address-button" type="button" data-mailbox="kody" aria-pressed="false">
            <span class="mail-address-avatar is-kody">K</span>
            <span>
              <strong>Kody</strong>
              <small>kody@</small>
            </span>
            <b data-mailbox-count="kody">0</b>
          </button>
          <button class="mail-address-button" type="button" data-mailbox="tom" aria-pressed="false">
            <span class="mail-address-avatar is-tom">T</span>
            <span>
              <strong>Tom</strong>
              <small>tom@</small>
            </span>
            <b data-mailbox-count="tom">0</b>
          </button>
        </nav>

        <div class="mail-routing-card">
          <span data-routing-state>Dashboard ready</span>
          <small data-routing-detail>Inbound routing is not connected yet.</small>
        </div>
      </aside>

      <section class="mail-list-pane" aria-labelledby="mail-list-title">
        <header class="mail-list-header">
          <div>
            <p class="mail-list-kicker" data-list-kicker>All addresses</p>
            <h2 id="mail-list-title" data-list-title>Inbox</h2>
          </div>
          <button class="mail-icon-button" type="button" data-refresh-mail aria-label="Refresh mail">
            <svg viewBox="0 0 24 24" aria-hidden="true">
              <path d="M20 11a8 8 0 1 0-2.35 5.65"></path>
              <path d="M20 5v6h-6"></path>
            </svg>
          </button>
        </header>

        <form class="mail-search" data-mail-search role="search">
          <svg viewBox="0 0 24 24" aria-hidden="true">
            <circle cx="11" cy="11" r="6.5"></circle>
            <path d="m16 16 4 4"></path>
          </svg>
          <label class="mail-visually-hidden" for="mail-search-input">Search mail</label>
          <input id="mail-search-input" name="query" type="search" maxlength="120" placeholder="Search sender, subject or message" autocomplete="off" data-search-input />
          <button type="button" data-clear-search hidden>Clear</button>
        </form>

        <div class="mail-list-summary">
          <span data-list-count>Loading messages...</span>
          <span data-list-filter>Newest first</span>
        </div>

        <ul class="mail-message-list" data-message-list aria-live="polite">
          <li class="mail-loading-row">
            <span></span><span></span><span></span>
          </li>
          <li class="mail-loading-row">
            <span></span><span></span><span></span>
          </li>
          <li class="mail-loading-row">
            <span></span><span></span><span></span>
          </li>
        </ul>
      </section>

      <section class="mail-reader-pane" aria-label="Selected conversation">
        <div class="mail-reader-toolbar" data-reader-toolbar hidden>
          <button class="mail-toolbar-button mail-mobile-back" type="button" data-close-reader>
            <svg viewBox="0 0 24 24" aria-hidden="true"><path d="m15 5-7 7 7 7"></path></svg>
            Back
          </button>
          <span></span>
          <button class="mail-toolbar-button" type="button" data-mark-unread>
            <svg viewBox="0 0 24 24" aria-hidden="true">
              <path d="M4 6h16v12H4z"></path>
              <path d="m5 7 7 6 7-6"></path>
            </svg>
            Mark unread
          </button>
          <button class="mail-toolbar-button" type="button" data-archive-thread>
            <svg viewBox="0 0 24 24" aria-hidden="true">
              <path d="M4 7h16v13H4zM3 4h18v3H3z"></path>
              <path d="M9 11h6"></path>
            </svg>
            <span data-archive-label>Archive</span>
          </button>
        </div>

        <div class="mail-reader-empty" data-reader-empty>
          <span class="mail-empty-illustration" aria-hidden="true">
            <svg viewBox="0 0 64 64">
              <path d="M10 18h44v30H10z"></path>
              <path d="m12 20 20 16 20-16"></path>
              <path d="M21 13h22"></path>
            </svg>
          </span>
          <h2>Select a conversation</h2>
          <p>Messages stay private inside Operations. Choose one from the list to read the full thread.</p>
        </div>

        <article class="mail-conversation" data-reader-content hidden>
          <header class="mail-conversation-header">
            <div>
              <span class="mail-mailbox-pill" data-reader-mailbox>Mailbox</span>
              <h2 data-reader-subject>Conversation</h2>
              <p data-reader-summary></p>
            </div>
          </header>
          <div class="mail-thread" data-reader-thread></div>
          <footer class="mail-reply-bar">
            <button class="mail-reply-button" type="button" data-reply-message>
              <svg viewBox="0 0 24 24" aria-hidden="true">
                <path d="m10 7-6 5 6 5v-3c5 0 8 1 10 4-1-6-4-8-10-8z"></path>
              </svg>
              Reply
            </button>
            <p data-reply-note>Replies save as drafts while Cloudflare sending is being enabled.</p>
          </footer>
        </article>
      </section>
    </div>

    <p class="mail-safety-note">
      Incoming HTML is never rendered here. The reader uses safe plain text; raw MIME and attachments stay in private Cloudflare storage.
    </p>
  </section>

  <dialog class="mail-compose-dialog" data-compose-dialog aria-labelledby="mail-compose-title">
    <form class="mail-compose-form" data-compose-form>
      <header class="mail-compose-header">
        <div>
          <p>Customer mailbox</p>
          <h2 id="mail-compose-title" data-compose-title>New message</h2>
        </div>
        <button class="mail-icon-button" type="button" data-close-compose aria-label="Close composer">
          <svg viewBox="0 0 24 24" aria-hidden="true"><path d="m6 6 12 12M18 6 6 18"></path></svg>
        </button>
      </header>

      <div class="mail-compose-fields">
        <label class="mail-compose-row">
          <span>From</span>
          <select name="from" required>
            <option value="deandre@brisbanetvs.com">DeAndre &lt;deandre@brisbanetvs.com&gt;</option>
            <option value="kody@brisbanetvs.com">Kody &lt;kody@brisbanetvs.com&gt;</option>
            <option value="tom@brisbanetvs.com">Tom &lt;tom@brisbanetvs.com&gt;</option>
          </select>
        </label>
        <label class="mail-compose-row">
          <span>To</span>
          <input name="to" type="email" maxlength="320" autocomplete="email" placeholder="customer@example.com" required />
        </label>
        <label class="mail-compose-row">
          <span>Subject</span>
          <input name="subject" type="text" maxlength="180" placeholder="Email subject" required />
        </label>
        <label class="mail-compose-body">
          <span class="mail-visually-hidden">Message</span>
          <textarea name="plainText" maxlength="10000" placeholder="Write your message..." required></textarea>
        </label>
      </div>

      <footer class="mail-compose-footer">
        <div>
          <button class="mail-text-button" type="button" data-discard-compose>Discard</button>
          <span class="mail-compose-status" data-compose-status role="status"></span>
        </div>
        <div class="mail-compose-actions">
          <button class="mail-secondary-button" type="submit" data-save-draft>
            Save draft <span class="mail-keyboard-hint" aria-hidden="true">Ctrl S</span>
          </button>
          <button class="mail-send-button" type="button" data-send-message disabled title="Cloudflare Email Sending is not enabled yet">
            <svg viewBox="0 0 24 24" aria-hidden="true">
              <path d="m3 11 18-8-7 18-3-7z"></path>
              <path d="m11 14 4-4"></path>
            </svg>
            <span data-send-label>Send locked</span>
          </button>
        </div>
      </footer>
    </form>
  </dialog>

  <script>
    import "../../../scripts/operations-inbox.js";
  </script>
</OperationsLayout>

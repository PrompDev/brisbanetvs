---
import BaseLayout from "~/layouts/BaseLayout.astro";
import { getCollection } from "astro:content";

/**
 * /products/ — collection landing page for the TV/AV product silo.
 *
 * Products are grouped by category (tv / soundbar / etc). Each card
 * carries brand, model, screen size, price, and rating so visitors can
 * compare across the grid without opening every detail page.
 */

const products = (
  await getCollection("products", ({ data }) => !data.draft)
).sort((a, b) => b.data.priceAud - a.data.priceAud);

const CATEGORY_LABELS: Record<string, string> = {
  tv: "Televisions",
  soundbar: "Soundbars",
  "media-box": "Media boxes",
  cable: "Cables",
  accessory: "Accessories",
};
const CATEGORY_ORDER = ["tv", "soundbar", "media-box", "cable", "accessory"];

const byCategory = new Map<string, typeof products>();
for (const p of products) {
  const key = p.data.category ?? "tv";
  if (!byCategory.has(key)) byCategory.set(key, []);
  byCategory.get(key)!.push(p);
}
const groupedSorted = [...byCategory.entries()].sort(
  ([a], [b]) => CATEGORY_ORDER.indexOf(a) - CATEGORY_ORDER.indexOf(b)
);

const pageUrl = new URL("/products/", Astro.site).toString();
const businessUrl = new URL("/", Astro.site).toString();

const avgRating =
  products.filter((p) => typeof p.data.rating === "number").length > 0
    ? (
        products.reduce(
          (acc, p) => acc + (typeof p.data.rating === "number" ? p.data.rating : 0),
          0
        ) /
        products.filter((p) => typeof p.data.rating === "number").length
      ).toFixed(1)
    : null;

const breadcrumbLd = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    { "@type": "ListItem", position: 1, name: "Home", item: businessUrl },
    { "@type": "ListItem", position: 2, name: "Products", item: pageUrl },
  ],
};

const collectionLd = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  "@id": pageUrl,
  url: pageUrl,
  name: "TVs & AV Gear for Brisbane Installs",
  description:
    "Curated selection of TVs, soundbars, and AV gear our Brisbane installers recommend. Real specs, real pricing, real field experience.",
  hasPart: products.map((p) => ({
    "@type": "Product",
    name: p.data.title,
    url: new URL(`/products/${p.slug}/`, Astro.site).toString(),
  })),
};
---
<BaseLayout
  title="TVs & AV Gear — Brisbane Installer Picks"
  description="TVs, soundbars, and AV gear our Brisbane installers recommend after mounting them into real houses. Full specs, current pricing, install-ready."
  canonical={pageUrl}
>
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbLd)} />
  <script type="application/ld+json" set:html={JSON.stringify(collectionLd)} />

  <section class="idx-banner">
    <img
      class="idx-banner-img"
      src="/media/product-samsung-s95d-65-hero.jpg"
      alt=""
      aria-hidden="true"
    />
    <div class="idx-banner-inner">
      <p class="idx-banner-title">Products</p>
    </div>
  </section>

  <article class="idx">
    <div class="idx-split">
      <div class="idx-split-left">
        <nav class="idx-crumbs" aria-label="Breadcrumb">
          <a href="/">Home</a>
          <span aria-hidden="true">›</span>
          <span class="idx-crumbs-current">Products</span>
        </nav>
        <header class="idx-hero-copy">
          <p class="idx-eyebrow">Brisbane · Installer picks</p>
          <h1>TVs and AV gear we've actually mounted.</h1>
          <p class="idx-lede">
            Every product here has been installed by our Brisbane team at least once —
            we know what fits which bracket, how heavy it really is off the box, and
            which "smart" features are worth the extra cost.
          </p>
          <div class="idx-stats">
            <div class="idx-stat">
              <span class="idx-stat-k">Products</span>
              <span class="idx-stat-v">{products.length}</span>
            </div>
            <div class="idx-stat">
              <span class="idx-stat-k">Categories</span>
              <span class="idx-stat-v">{groupedSorted.length}</span>
            </div>
            {avgRating && (
              <div class="idx-stat">
                <span class="idx-stat-k">Avg rating</span>
                <span class="idx-stat-v">{avgRating}★</span>
              </div>
            )}
            <div class="idx-stat">
              <span class="idx-stat-k">Advice</span>
              <span class="idx-stat-v">Free</span>
            </div>
          </div>
          <div class="idx-cta-row">
            <a class="idx-btn idx-btn-primary" href="tel:0432145101">Ask about a TV</a>
            <a class="idx-btn idx-btn-ghost" href="/mounts/">Browse mounts</a>
          </div>
        </header>
      </div>
      <div class="idx-split-img-wrap">
        <img
          class="idx-split-img"
          src="/media/product-samsung-s95d-65-hero.jpg"
          alt="A Samsung QD-OLED TV mounted in a contemporary Brisbane living room, showing vibrant colour on a sunset scene"
          loading="eager"
        />
      </div>
    </div>

    <hr class="idx-section-divider" />

    <div class="idx-article-grid">
      <div class="idx-article-main">
        <section class="idx-list-section" aria-labelledby="idx-prod-h">
          <h2 id="idx-prod-h">Pick a product</h2>
          <p class="u-muted">
            Real-world notes from our installers, not spec-sheet regurgitation. Tap any
            card for the full writeup, VESA pattern, and mount recommendations.
          </p>

          {products.length === 0 && (
            <p class="idx-empty">Product pages coming soon. In the meantime, <a href="tel:0432145101">tell us the TV you're looking at</a> and we'll weigh in.</p>
          )}

          {groupedSorted.map(([cat, entries]) => (
            <div class="idx-region-group">
              <h3 class="idx-region-title">{CATEGORY_LABELS[cat] ?? cat}</h3>
              <ul class="idx-card-grid">
                {entries.map((p) => (
                  <li class="idx-card">
                    <a class="idx-card-link" href={`/products/${p.slug}/`}>
                      <div class="idx-card-img-wrap">
                        <img
                          class="idx-card-img"
                          src={p.data.heroImage}
                          alt={p.data.heroAlt}
                          loading="lazy"
                        />
                        {typeof p.data.priceWas === "number" && p.data.priceWas > p.data.priceAud && (
                          <span class="idx-card-badge">Save ${p.data.priceWas - p.data.priceAud}</span>
                        )}
                      </div>
                      <div class="idx-card-body">
                        <p class="idx-card-eyebrow">
                          {p.data.brand}
                          {p.data.screenSizeInches && <span class="idx-card-dot"> · </span>}
                          {p.data.screenSizeInches && <span>{p.data.screenSizeInches}"</span>}
                          {p.data.panelType && <span class="idx-card-dot"> · </span>}
                          {p.data.panelType && <span>{p.data.panelType}</span>}
                        </p>
                        <h3 class="idx-card-title">{p.data.title}</h3>
                        <p class="idx-card-desc">{p.data.description}</p>
                        <div class="idx-card-foot">
                          <span class="idx-card-price">
                            <span class="idx-card-price-k">Price</span>
                            <span class="idx-card-price-v">${p.data.priceAud.toLocaleString()}</span>
                          </span>
                          {typeof p.data.rating === "number" && (
                            <span class="idx-card-rating">★ {p.data.rating.toFixed(1)}</span>
                          )}
                          <span class="idx-card-arrow" aria-hidden="true">→</span>
                        </div>
                      </div>
                    </a>
                  </li>
                ))}
              </ul>
            </div>
          ))}
        </section>

        <section class="idx-why" aria-labelledby="idx-how-h">
          <h2 id="idx-how-h">How we pick products</h2>
          <ul class="idx-why-list">
            <li>
              <span class="idx-why-k">Installed it ourselves</span>
              <span class="idx-why-v">Every product on this list has been mounted by our Brisbane team in an actual customer home.</span>
            </li>
            <li>
              <span class="idx-why-k">Bracket-compatibility verified</span>
              <span class="idx-why-v">We check VESA pattern, weight, and OneConnect-style cable boxes before we recommend a mount.</span>
            </li>
            <li>
              <span class="idx-why-k">No kickback-only listings</span>
              <span class="idx-why-v">If a product has affiliate earnings we disclose it — but we don't list anything we wouldn't install in our own home.</span>
            </li>
            <li>
              <span class="idx-why-k">Kept current</span>
              <span class="idx-why-v">Prices and availability checked quarterly; superseded models get moved to an archive page, not quietly re-priced.</span>
            </li>
          </ul>
        </section>
      </div>

      <aside class="idx-sidebar" aria-label="Booking sidebar">
        <div class="idx-book-card">
          <p class="idx-book-eyebrow">Brisbane TVs · Products</p>
          <h3 class="idx-book-title">Need buying advice on a TV?</h3>
          <p class="idx-book-desc">
            We'll tell you honestly which panel fits your room, which features are
            worth paying up for, and which bracket to pair it with.
          </p>
          <ul class="idx-book-list">
            <li><span class="idx-book-k">Products</span><span>{products.length}</span></li>
            {avgRating && (<li><span class="idx-book-k">Avg rating</span><span>{avgRating}★</span></li>)}
            <li><span class="idx-book-k">Advice</span><span>Free</span></li>
          </ul>
          <a class="idx-book-btn" href="tel:0432145101">Ask about a TV →</a>
          <a class="idx-book-link" href="tel:+61000000000">or call dispatch</a>
        </div>
      </aside>
    </div>

    <aside class="idx-foot-cta">
      <div>
        <h2>Want it mounted the day it arrives?</h2>
        <p>Buy through us and we'll coordinate delivery with the install — one crew, one day, one flat rate.</p>
      </div>
      <a class="idx-btn idx-btn-primary" href="tel:0432145101">Bundle it with an install</a>
    </aside>
  </article>
</BaseLayout>

<style is:global>
  /* Product-specific additions on top of the shared .idx-* styles.
     The save-badge sits over the top-left corner of the card image
     (mirrors how the detail page surfaces discount pricing). */
  .idx-card-badge { position: absolute; top: 0.75rem; left: 0.75rem; z-index: 1; background: #c5332e; color: #fff; font-size: 0.72rem; font-weight: 700; letter-spacing: 0.04em; padding: 0.3rem 0.55rem; border-radius: 4px; text-transform: uppercase; }
  /* Star rating pill in the card footer. Kept subtle so it doesn't
     compete with the price, which is the primary comparison signal. */
  .idx-card-rating { font-size: 0.85rem; color: #131619; font-weight: 600; padding: 0.15rem 0.45rem; background: #fafbfc; border: 1px solid #eef0f3; border-radius: 4px; align-self: flex-end; }
</style>

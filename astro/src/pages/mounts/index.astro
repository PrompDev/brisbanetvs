---
import BaseLayout from "~/layouts/BaseLayout.astro";
import { getCollection } from "astro:content";

/**
 * /mounts/ — collection landing page for the wall-mount / bracket silo.
 *
 * Groups mounts by mountType (fixed / tilt / full-motion / ceiling / outdoor).
 * Each card surfaces the fits range (min–max screen size) and max weight
 * so visitors can filter by their own TV at a glance.
 */

const mounts = (
  await getCollection("mounts", ({ data }) => !data.draft)
).sort((a, b) => b.data.maxWeightKg - a.data.maxWeightKg);

const TYPE_LABELS: Record<string, string> = {
  fixed: "Fixed (flush)",
  tilt: "Tilting",
  "full-motion": "Full-motion",
  ceiling: "Ceiling",
  outdoor: "Outdoor",
};
const TYPE_ORDER = ["full-motion", "tilt", "fixed", "ceiling", "outdoor"];

const byType = new Map<string, typeof mounts>();
for (const m of mounts) {
  const key = m.data.mountType ?? "full-motion";
  if (!byType.has(key)) byType.set(key, []);
  byType.get(key)!.push(m);
}
const groupedSorted = [...byType.entries()].sort(
  ([a], [b]) => TYPE_ORDER.indexOf(a) - TYPE_ORDER.indexOf(b)
);

const pageUrl = new URL("/mounts/", Astro.site).toString();
const businessUrl = new URL("/", Astro.site).toString();

const heaviestMount = mounts.length
  ? Math.max(...mounts.map((m) => m.data.maxWeightKg))
  : null;

const breadcrumbLd = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    { "@type": "ListItem", position: 1, name: "Home", item: businessUrl },
    { "@type": "ListItem", position: 2, name: "Wall mounts", item: pageUrl },
  ],
};

const collectionLd = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  "@id": pageUrl,
  url: pageUrl,
  name: "TV Wall Mounts & Brackets — Brisbane Installer Picks",
  description:
    "Every TV wall mount and bracket our Brisbane installers keep in the van. Real fitment specs, real weight ratings, field-tested.",
  hasPart: mounts.map((m) => ({
    "@type": "Product",
    name: m.data.title,
    url: new URL(`/mounts/${m.slug}/`, Astro.site).toString(),
  })),
};
---
<BaseLayout
  title="TV Wall Mounts & Brackets — Brisbane Installer Picks"
  description="Wall mounts and brackets our Brisbane installers trust. Full-motion, tilt, fixed, ceiling, outdoor — VESA-matched to your TV, weight-rated, warrantied."
  canonical={pageUrl}
>
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbLd)} />
  <script type="application/ld+json" set:html={JSON.stringify(collectionLd)} />

  <section class="idx-banner">
    <img
      class="idx-banner-img"
      src="/media/mount-sanus-vmpl50a-b1-hero.jpg"
      alt=""
      aria-hidden="true"
    />
    <div class="idx-banner-inner">
      <p class="idx-banner-title">Wall Mounts</p>
    </div>
  </section>

  <article class="idx">
    <div class="idx-split">
      <div class="idx-split-left">
        <nav class="idx-crumbs" aria-label="Breadcrumb">
          <a href="/">Home</a>
          <span aria-hidden="true">›</span>
          <span class="idx-crumbs-current">Wall mounts</span>
        </nav>
        <header class="idx-hero-copy">
          <p class="idx-eyebrow">Brisbane · Bracket guide</p>
          <h1>The TV brackets our installers actually trust.</h1>
          <p class="idx-lede">
            Full-motion, tilt, fixed, ceiling, outdoor. Every mount on this list has
            been fitted to customer walls by our Brisbane team — so the fitment specs,
            weight ratings, and motion feel ratings come from the install, not the box.
          </p>
          <div class="idx-stats">
            <div class="idx-stat">
              <span class="idx-stat-k">Mounts</span>
              <span class="idx-stat-v">{mounts.length}</span>
            </div>
            <div class="idx-stat">
              <span class="idx-stat-k">Types</span>
              <span class="idx-stat-v">{groupedSorted.length}</span>
            </div>
            {heaviestMount !== null && (
              <div class="idx-stat">
                <span class="idx-stat-k">Up to</span>
                <span class="idx-stat-v">{heaviestMount}kg</span>
              </div>
            )}
            <div class="idx-stat">
              <span class="idx-stat-k">Warranty</span>
              <span class="idx-stat-v">12 months</span>
            </div>
          </div>
          <div class="idx-cta-row">
            <a class="idx-btn idx-btn-primary" href="tel:0432145101">Ask which mount fits</a>
            <a class="idx-btn idx-btn-ghost" href="/products/">Browse TVs</a>
          </div>
        </header>
      </div>
      <div class="idx-split-img-wrap">
        <img
          class="idx-split-img"
          src="/media/mount-sanus-vmpl50a-b1-hero.jpg"
          alt="A full-motion wall mount extended from a living room wall with a 65-inch TV attached"
          loading="eager"
        />
      </div>
    </div>

    <hr class="idx-section-divider" />

    <div class="idx-article-grid">
      <div class="idx-article-main">
        <section class="idx-list-section" aria-labelledby="idx-mnt-h">
          <h2 id="idx-mnt-h">Pick a mount</h2>
          <p class="u-muted">
            Grouped by mount type — start with the motion you want, then filter by fits
            range and weight. Every page shows compatible TVs we've installed it with.
          </p>

          {mounts.length === 0 && (
            <p class="idx-empty">Mount pages coming soon. In the meantime, <a href="tel:0432145101">tell us your TV size + weight</a> and we'll recommend one.</p>
          )}

          {groupedSorted.map(([type, entries]) => (
            <div class="idx-region-group">
              <h3 class="idx-region-title">{TYPE_LABELS[type] ?? type}</h3>
              <ul class="idx-card-grid">
                {entries.map((m) => (
                  <li class="idx-card">
                    <a class="idx-card-link" href={`/mounts/${m.slug}/`}>
                      <div class="idx-card-img-wrap">
                        <img
                          class="idx-card-img"
                          src={m.data.heroImage}
                          alt={m.data.heroAlt}
                          loading="lazy"
                        />
                        {typeof m.data.priceWas === "number" && m.data.priceWas > m.data.priceAud && (
                          <span class="idx-card-badge">Save ${m.data.priceWas - m.data.priceAud}</span>
                        )}
                      </div>
                      <div class="idx-card-body">
                        <p class="idx-card-eyebrow">
                          {m.data.brand}
                          <span class="idx-card-dot"> · </span>
                          <span>Fits {m.data.minScreenInches}–{m.data.maxScreenInches}"</span>
                          <span class="idx-card-dot"> · </span>
                          <span>{m.data.maxWeightKg}kg max</span>
                        </p>
                        <h3 class="idx-card-title">{m.data.title}</h3>
                        <p class="idx-card-desc">{m.data.description}</p>
                        <div class="idx-card-foot">
                          <span class="idx-card-price">
                            <span class="idx-card-price-k">Price</span>
                            <span class="idx-card-price-v">${m.data.priceAud.toLocaleString()}</span>
                          </span>
                          {typeof m.data.rating === "number" && (
                            <span class="idx-card-rating">★ {m.data.rating.toFixed(1)}</span>
                          )}
                          <span class="idx-card-arrow" aria-hidden="true">→</span>
                        </div>
                      </div>
                    </a>
                  </li>
                ))}
              </ul>
            </div>
          ))}
        </section>

        <section class="idx-why" aria-labelledby="idx-pick-h">
          <h2 id="idx-pick-h">Which mount for which install</h2>
          <ul class="idx-why-list">
            <li>
              <span class="idx-why-k">Full-motion</span>
              <span class="idx-why-v">Open-plan living, corner installs, or when you need to pull the TV out from the wall for cable access.</span>
            </li>
            <li>
              <span class="idx-why-k">Tilt</span>
              <span class="idx-why-v">High-mount installs above a fireplace or bedroom wall — tilts the picture down toward the couch or bed.</span>
            </li>
            <li>
              <span class="idx-why-k">Fixed (flush)</span>
              <span class="idx-why-v">Minimalist feature walls where you want the TV to sit nearly flush with the plaster. The lowest-profile option.</span>
            </li>
            <li>
              <span class="idx-why-k">Ceiling / outdoor</span>
              <span class="idx-why-v">Alfresco areas, commercial fit-outs, and patio installs — weather-rated hardware, structural anchor points.</span>
            </li>
          </ul>
        </section>
      </div>

      <aside class="idx-sidebar" aria-label="Booking sidebar">
        <div class="idx-book-card">
          <p class="idx-book-eyebrow">Brisbane TVs · Mounts</p>
          <h3 class="idx-book-title">Not sure which mount?</h3>
          <p class="idx-book-desc">
            Send us the TV brand, model, and the wall photo. We'll spec the right
            mount, VESA pattern, and anchor type before the install.
          </p>
          <ul class="idx-book-list">
            <li><span class="idx-book-k">Mounts</span><span>{mounts.length}</span></li>
            <li><span class="idx-book-k">Up to</span><span>{heaviestMount !== null ? `${heaviestMount}kg` : "—"}</span></li>
            <li><span class="idx-book-k">Warranty</span><span>12 months</span></li>
          </ul>
          <a class="idx-book-btn" href="tel:0432145101">Ask which mount →</a>
          <a class="idx-book-link" href="tel:+61000000000">or call dispatch</a>
        </div>
      </aside>
    </div>

    <aside class="idx-foot-cta">
      <div>
        <h2>Need a bracket AND an install?</h2>
        <p>We supply + fit brackets at a bundled rate — one job, one crew, warranty from both sides of the bracket.</p>
      </div>
      <a class="idx-btn idx-btn-primary" href="tel:0432145101">Get a supply-and-fit quote</a>
    </aside>
  </article>
</BaseLayout>

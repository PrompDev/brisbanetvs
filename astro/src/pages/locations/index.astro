---
import MarketingLayout from "~/layouts/MarketingLayout.astro";
import { getCollection } from "astro:content";
import { getLocationImage } from "~/data/installationImages";

/**
 * /locations/ — collection landing page for the suburb silo.
 *
 * Groups published suburb entries by region so the hub doubles as a
 * navigable site-map. Reuses the shared `.idx-*` classes from the
 * services/products/mounts index pages for layout consistency.
 */

const locations = (
  await getCollection("locations", ({ data }) => !data.draft)
).sort((a, b) => a.data.suburb.localeCompare(b.data.suburb));

/**
 * Group suburbs by region. Entries without an explicit `region` fall
 * into the "Other Brisbane" bucket — every suburb in Greater Brisbane
 * gets shown, even before we backfill region data.
 */
const GROUP_ORDER = [
  "Brisbane City",
  "Inner Brisbane",
  "Inner North Brisbane",
  "North Brisbane",
  "North-West Brisbane",
  "Bayside North",
  "Southside Brisbane",
  "Eastern Brisbane & Bayside",
  "Western Brisbane",
  "Moreton Bay",
  "Redlands",
  "Logan",
  "Ipswich",
  "Gold Coast",
  "Sunshine Coast",
];
const grouped = new Map<string, typeof locations>();
for (const loc of locations) {
  const key = loc.data.region ?? "Other service areas";
  if (!grouped.has(key)) grouped.set(key, []);
  grouped.get(key)!.push(loc);
}
const groupedSorted = [...grouped.entries()].sort(([a], [b]) => {
  const ai = GROUP_ORDER.indexOf(a);
  const bi = GROUP_ORDER.indexOf(b);
  if (ai === -1 && bi === -1) return a.localeCompare(b);
  if (ai === -1) return 1;
  if (bi === -1) return -1;
  return ai - bi;
});

const pageUrl = new URL("/locations/", Astro.site).toString();
const businessUrl = new URL("/", Astro.site).toString();

const breadcrumbLd = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    { "@type": "ListItem", position: 1, name: "Home", item: businessUrl },
    { "@type": "ListItem", position: 2, name: "Locations", item: pageUrl },
  ],
};

const collectionLd = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  "@id": pageUrl,
  url: pageUrl,
  name: "Brisbane TVs service-area directory",
  description:
    "Listed service areas across Greater Brisbane, Moreton Bay, Redlands, Logan and Ipswich, plus selected Gold Coast and Sunshine Coast suburbs.",
  hasPart: locations.map((l) => ({
    "@type": "Place",
    name: l.data.suburb,
    url: new URL(`/locations/${l.slug}/`, Astro.site).toString(),
    image: getLocationImage(l.slug).url,
  })),
};
---
<MarketingLayout
  title={`TV Mounting Service Areas - ${locations.length} Locations | Brisbane TVs`}
  description={`${locations.length} listed service areas across Greater Brisbane and surrounding South East Queensland, including selected Gold Coast and Sunshine Coast suburbs.`}
  canonical={pageUrl}
  ogImage="https://cdn.brisbanetvs.com/work/v1/installer-large-tv.jpg"
  keywords="TV mounting near me Brisbane, TV installer Brisbane suburbs, TV mounting Gold Coast, TV mounting Sunshine Coast, Brisbane TV install service areas"
  jsonLd={[breadcrumbLd, collectionLd]}
  bodyClass="page-locations-index"
>
  <section class="idx-banner">
    <img
      class="idx-banner-img"
      src="https://cdn.brisbanetvs.com/work/v1/installer-large-tv.jpg"
      width="2880"
      height="2160"
      alt=""
      aria-hidden="true"
    />
    <div class="idx-banner-inner">
      <p class="idx-banner-title">Locations</p>
    </div>
  </section>

  <article class="idx">
    <div class="idx-split">
      <div class="idx-split-left">
        <nav class="idx-crumbs" aria-label="Breadcrumb">
          <a href="/">Home</a>
          <span aria-hidden="true">›</span>
          <span class="idx-crumbs-current">Locations</span>
        </nav>
        <header class="idx-hero-copy">
          <p class="idx-eyebrow">Brisbane and listed SEQ service areas</p>
          <h1>TV mounting across Brisbane and our listed service areas.</h1>
          <p class="idx-lede">
            Browse Greater Brisbane, Moreton Bay, Redlands, Logan and Ipswich, plus the
            Gold Coast and Sunshine Coast suburbs currently listed. Each page covers
            local housing notes, nearby areas and booking details.
          </p>
          <div class="idx-stats">
            <div class="idx-stat">
              <span class="idx-stat-k">Suburbs listed</span>
              <span class="idx-stat-v">{locations.length}</span>
            </div>
            <div class="idx-stat">
              <span class="idx-stat-k">Regions</span>
              <span class="idx-stat-v">{groupedSorted.length}</span>
            </div>
            <div class="idx-stat">
              <span class="idx-stat-k">Response</span>
              <span class="idx-stat-v">At booking</span>
            </div>
            <div class="idx-stat">
              <span class="idx-stat-k">Call-out</span>
              <span class="idx-stat-v">No charge</span>
            </div>
          </div>
          <div class="idx-cta-row">
            <a class="idx-btn idx-btn-primary" href="tel:0432145101">Book in your suburb</a>
            <a class="idx-btn idx-btn-ghost" href="/services/">See all services</a>
          </div>
        </header>
      </div>
      <div class="idx-split-img-wrap">
        <img
          class="idx-split-img"
          src="https://cdn.brisbanetvs.com/work/v1/apartment-wall-mounted-tv.jpg"
          width="1600"
          height="1200"
          alt="Wall-mounted TV above a timber media cabinet in an apartment"
          loading="eager"
          decoding="async"
          fetchpriority="high"
        />
      </div>
    </div>

    <hr class="idx-section-divider" />

    <div class="idx-article-grid">
      <div class="idx-article-main">
        <section class="idx-list-section" aria-labelledby="idx-loc-h">
          <h2 id="idx-loc-h">Pick your suburb</h2>
          <p class="u-muted">
            Suburbs grouped by region — tap a card for suburb-specific housing notes,
            local installer FAQs, and nearby suburbs we also cover.
          </p>

          {locations.length === 0 && (
            <p class="idx-empty">Suburb pages coming soon. In the meantime, <a href="tel:0432145101">tell us where you are</a> and we'll book you in.</p>
          )}

          {groupedSorted.map(([region, entries]) => (
            <div class="idx-region-group">
              <h3 class="idx-region-title">{region}</h3>
              <ul class="idx-card-grid">
                {entries.map((l) => (
                  <li class="idx-card">
                    <a class="idx-card-link" href={`/locations/${l.slug}/`}>
                      <div class="idx-card-img-wrap">
                        <img
                          class="idx-card-img"
                          src={getLocationImage(l.slug).url}
                          width={getLocationImage(l.slug).width}
                          height={getLocationImage(l.slug).height}
                          alt={getLocationImage(l.slug).alt}
                          loading="lazy"
                          decoding="async"
                        />
                      </div>
                      <div class="idx-card-body">
                        <p class="idx-card-eyebrow">
                          {l.data.postcode ?? "Brisbane"}
                          {l.data.travelTimeFromCbd && <span class="idx-card-dot"> · </span>}
                          {l.data.travelTimeFromCbd && <span>{l.data.travelTimeFromCbd} from CBD</span>}
                        </p>
                        <h3 class="idx-card-title">{l.data.suburb}</h3>
                        <p class="idx-card-desc">{l.data.description}</p>
                        <div class="idx-card-foot">
                          <span class="idx-card-price">
                            <span class="idx-card-price-k">Jobs done</span>
                            <span class="idx-card-price-v">{typeof l.data.jobCount === "number" ? `${l.data.jobCount}+` : "—"}</span>
                          </span>
                          <span class="idx-card-arrow" aria-hidden="true">→</span>
                        </div>
                      </div>
                    </a>
                  </li>
                ))}
              </ul>
            </div>
          ))}
        </section>

        <section class="idx-why" aria-labelledby="idx-coverage-h">
          <h2 id="idx-coverage-h">How our coverage works</h2>
          <ul class="idx-why-list">
            <li>
              <span class="idx-why-k">No call-out fees</span>
              <span class="idx-why-v">One flat rate for the whole job, whether you're in the CBD or out on the bay.</span>
            </li>
            <li>
              <span class="idx-why-k">Suburb-aware installers</span>
              <span class="idx-why-v">Our team knows the housing stock by suburb — queenslanders, riverside highrises, post-war fibro cottages.</span>
            </li>
            <li>
              <span class="idx-why-k">Building-manager coordination</span>
              <span class="idx-why-v">We handle the lift booking, loading-bay access, and strata paperwork for apartment installs.</span>
            </li>
            <li>
              <span class="idx-why-k">Full insurance cover</span>
              <span class="idx-why-v">$20M public liability plus workers' comp — body corps and property managers accept us on first contact.</span>
            </li>
          </ul>
        </section>
      </div>

      <aside class="idx-sidebar" aria-label="Booking sidebar">
        <div class="idx-book-card">
          <p class="idx-book-eyebrow">Brisbane TVs · Coverage</p>
          <h3 class="idx-book-title">Don't see your suburb?</h3>
          <p class="idx-book-desc">
            Every current service area is listed on this page. If you are nearby but
            cannot find your suburb, call and Tom will confirm availability before you book.
          </p>
          <ul class="idx-book-list">
            <li><span class="idx-book-k">Suburbs</span><span>{locations.length} listed</span></li>
            <li><span class="idx-book-k">Availability</span><span>Confirmed at booking</span></li>
            <li><span class="idx-book-k">Call-out fee</span><span>$0</span></li>
          </ul>
          <a class="idx-book-btn" href="tel:0432145101">Check your suburb →</a>
          <a class="idx-book-link" href="tel:0432145101">or call 0432 145 101</a>
        </div>
      </aside>
    </div>

    <aside class="idx-foot-cta">
      <div>
        <h2>Greater Brisbane and selected South East Queensland service areas.</h2>
        <p>See the listed suburbs for Moreton Bay, Redlands, Logan, Ipswich, Gold Coast and Sunshine Coast.</p>
      </div>
      <a class="idx-btn idx-btn-primary" href="tel:0432145101">Book an installer</a>
    </aside>
  </article>
</MarketingLayout>

<!--
  All .idx-* styles (including .idx-region-group / .idx-region-title)
  now live in /public/css/marketing.css — loaded by MarketingLayout on
  every hub page so the chrome stays consistent across services /
  locations / products / mounts.
-->

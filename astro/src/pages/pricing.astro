---
import MarketingLayout from "~/layouts/MarketingLayout.astro";
import { BUSINESS, PACKAGES } from "~/data/business";

/**
 * /pricing/ — public pricing page.
 *
 * Rewritten 2026-04-22 to mirror the homepage's `.pricing-section`
 * treatment so the chrome feels continuous: same beige canvas, same
 * interactive calculator, same dark featured card, same serif-headline
 * grid of cards. Data source is `data/business.ts` — Tom's 5 canonical
 * packages (Basic / Living Room / XL Living Room / Cinema / XL Cinema).
 *
 * Two jobs on one page:
 *   1. Show Tom's packages with honest "from" prices.
 *   2. Instant quote calculator: TV size + wall type → matched package +
 *      tentative total, POST'd to BUSINESS.webhooks.quickQuote.
 */

const pageUrl = new URL("/pricing/", Astro.site).toString();
const businessUrl = new URL("/", Astro.site).toString();

const breadcrumbLd = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    { "@type": "ListItem", position: 1, name: "Home", item: businessUrl },
    { "@type": "ListItem", position: 2, name: "Pricing", item: pageUrl },
  ],
};

// Offer JSON-LD: Google loves explicit priced packages.
const offersLd = PACKAGES.filter((p) => p.priceAud !== null).map((p) => ({
  "@context": "https://schema.org",
  "@type": "Offer",
  name: p.name,
  description: p.tagline,
  priceCurrency: "AUD",
  price: p.priceAud,
  url: pageUrl,
  seller: { "@type": "LocalBusiness", name: BUSINESS.name },
  eligibleQuantity: {
    "@type": "QuantitativeValue",
    minValue: p.sizeMin,
    maxValue: p.sizeMax ?? 200,
    unitText: "inch TV",
  },
}));

// Mark the middle tier ("Living Room" / 60–70") as the featured card —
// it's the size bucket Tom books the most of.
const FEATURED_ID = "living-room";
---
<MarketingLayout
  title="TV Mounting Prices Brisbane — Flat-Rate Install Packages | Brisbane TVs"
  description="Flat-rate TV mounting packages across Brisbane. From $289 for small TVs through to custom-quoted oversize cinema installs. Instant quote + same-day booking."
  canonical={pageUrl}
  ogImage="https://cdn.brisbanetvs.com/install-ashgrove1200x1200.webp"
  keywords="TV mounting Brisbane prices, flat-rate TV install Brisbane, TV mount packages Brisbane, instant TV install quote Brisbane"
  jsonLd={[breadcrumbLd, ...offersLd]}
  bodyClass="page-pricing"
>
  {/* ===== BANNER ===== */}
  <section class="pr-banner">
    <img
      class="pr-banner-img"
      src="https://cdn.brisbanetvs.com/install-ashgrove1200x1200.webp"
      alt=""
      aria-hidden="true"
    />
    <div class="pr-banner-inner">
      <p class="pr-banner-title">Pricing</p>
    </div>
  </section>

  {/* ===== PRICING SECTION — homepage style ===== */}
  <section class="pricing-section" id="pricing">
    <div class="pricing-inner">
      <div class="pricing-header">
        <span class="pricing-eyebrow">Flat-Rate Pricing</span>
        <h1 class="pricing-title">TV Wall Mounting Prices Brisbane</h1>
        <p class="pricing-sub">
          Honest, flat-rate packages — sized by the TV, not by the hour.
          GST included, no call-out fees, every job backed by our lifetime
          workmanship guarantee. Use the instant calculator below or pick
          the package that matches your screen.
        </p>
      </div>

      {/* Quick Quote Calculator — matches homepage calculator markup */}
      <div class="pricing-calculator" id="pricingCalculator" data-webhook={BUSINESS.webhooks.quickQuote}>
        <div class="calc-inputs">
          <div class="calc-field">
            <label class="calc-label">Number of TVs</label>
            <div class="calc-stepper" data-stepper>
              <button type="button" data-action="dec" aria-label="Decrease">−</button>
              <span class="calc-stepper-value" id="calcCount">1</span>
              <button type="button" data-action="inc" aria-label="Increase">+</button>
            </div>
          </div>

          <div class="calc-field">
            <label class="calc-label">TV Size</label>
            <div class="calc-segmented" id="calcSize">
              {PACKAGES.map((pkg) => (
                <button
                  type="button"
                  class={pkg.id === FEATURED_ID ? "is-active" : ""}
                  data-tier={pkg.id}
                  data-price={pkg.priceAud ?? 0}
                  data-custom={pkg.priceAud === null ? "true" : "false"}
                  data-label={`${pkg.name} (${pkg.sizeLabel})`}
                >
                  {pkg.sizeLabel}
                </button>
              ))}
            </div>
          </div>

          <div class="calc-field">
            <label class="calc-label">Add-ons (per TV)</label>
            <div class="calc-addons" id="calcAddons">
              <label class="calc-checkbox"><input type="checkbox" data-price="100" data-label="In-wall cable concealment"> <span>Cable concealment <em>+$100</em></span></label>
              <label class="calc-checkbox"><input type="checkbox" data-price="80" data-label="Soundbar mount"> <span>Soundbar mount <em>+$80</em></span></label>
              <label class="calc-checkbox"><input type="checkbox" data-price="50" data-label="Full-motion bracket upgrade"> <span>Full-motion bracket <em>+$50</em></span></label>
            </div>
          </div>
        </div>

        <div class="calc-summary">
          <div class="calc-summary-label">Estimated Total</div>
          <div class="calc-total">
            <span class="currency">$</span><span id="calcTotal">{PACKAGES.find((p) => p.id === FEATURED_ID)?.priceAud ?? "—"}</span>
          </div>
          <div class="calc-breakdown" id="calcBreakdown">
            1 TV · {PACKAGES.find((p) => p.id === FEATURED_ID)?.name}
          </div>
          <a href="/quote/" class="calc-cta" id="calcCta">Book this install <span>›</span></a>
        </div>
      </div>

      {/* Package Grid — matches homepage pricing-card markup */}
      <div class="pricing-grid pricing-grid-five">
        {PACKAGES.map((pkg) => (
          <div
            class={`pricing-card ${pkg.id === FEATURED_ID ? "is-featured" : ""} ${pkg.priceAud === null ? "is-custom" : ""}`}
            data-tier={pkg.id}
          >
            {pkg.id === FEATURED_ID && <span class="pricing-card-tag">Most Booked</span>}
            <div class="pricing-card-name">{pkg.name}</div>
            <div class="pricing-card-meta">TVs {pkg.sizeLabel}</div>
            <div class="pricing-card-price">
              {pkg.priceAud !== null ? (
                <><span class="currency">$</span>{pkg.priceAud}</>
              ) : (
                <span class="pricing-card-price-custom">Custom</span>
              )}
            </div>
            <div class="pricing-card-price-note">
              {pkg.priceAud !== null ? "Flat rate, Brisbane metro" : "Photo of wall speeds this up"}
            </div>
            <ul class="pricing-card-features">
              {pkg.highlights.map((h) => <li>{h}</li>)}
            </ul>
            <a href={`/quote/?package=${pkg.id}`} class="pricing-card-cta">
              {pkg.priceAud !== null ? `Book ${pkg.name.replace(" Package", "")}` : "Request quote"} <span>›</span>
            </a>
          </div>
        ))}
      </div>

      <div class="pricing-footnote">
        <span class="pricing-footnote-icon" aria-hidden="true">!</span>
        <h3 class="pricing-footnote-title">Need something beyond a standard TV wall mount?</h3>
        <p>
          Our Brisbane installers also handle <strong>soundbar mounting</strong>,
          <strong> Starlink dish installation</strong>,
          <strong> digital TV antenna setup</strong>,
          <strong> in-wall cable concealment</strong>, and
          <strong> full home theatre builds</strong> — across every Brisbane suburb,
          from the inner city out to the bay. Every custom job is fixed-price, GST-included, and backed by our lifetime workmanship guarantee.
        </p>
        <p class="pricing-footnote-cta">
          <a href="/quote/">Get a free quote ›</a> &nbsp;·&nbsp; We respond in under 2 hours, Brisbane-wide.
        </p>
      </div>
    </div>
  </section>

  {/* ===== TRUST STRIP ===== */}
  <section class="pr-trust" aria-labelledby="pr-trust-h">
    <div class="pr-trust-inner">
      <h2 id="pr-trust-h">Why the flat rate works</h2>
      <div class="pr-trust-grid">
        <div class="pr-trust-card">
          <h3>No hourly billing</h3>
          <p>
            Your quote is locked before the installer arrives. If a job takes
            longer than expected, that's on us — we eat the time, not you.
          </p>
        </div>
        <div class="pr-trust-card">
          <h3>$20M public liability</h3>
          <p>
            Every job is covered. If we put a hole in the wrong wall, our
            insurer handles it — not a hand-scribbled receipt.
          </p>
        </div>
        <div class="pr-trust-card">
          <h3>Lifetime workmanship</h3>
          <p>
            If the mount loosens, the cable conceal lifts, or anything we
            installed fails — we come back and fix it. Free. Forever.
          </p>
        </div>
        <div class="pr-trust-card">
          <h3>Locally owned</h3>
          <p>
            Every installer lives in Brisbane. No franchise head office,
            no sub-contractor roulette — you talk to the same team that shows up.
          </p>
        </div>
      </div>
    </div>
  </section>

  {/* ===== FOOT CTA ===== */}
  <section class="pr-foot">
    <div class="pr-foot-inner">
      <p class="pr-foot-eyebrow">Prefer to talk it through?</p>
      <h2 class="pr-foot-title">Tom answers the phone, 7 days a week.</h2>
      <p class="pr-foot-lede">7 AM – 7 PM · Same-week bookings · Brisbane-wide</p>
      <div class="pr-foot-cta-row">
        <a class="pr-foot-btn pr-foot-btn-primary" href={BUSINESS.phoneTel}>
          Call {BUSINESS.phoneDisplay}
        </a>
        <a class="pr-foot-btn pr-foot-btn-ghost" href="/quote/">
          Send a photo quote →
        </a>
      </div>
    </div>
  </section>
</MarketingLayout>

{/* ===== JS: price the quote live + submit to n8n ===== */}
<script is:inline define:vars={{ PACKAGES: PACKAGES.map((p) => ({ id: p.id, name: p.name, sizeMin: p.sizeMin, sizeMax: p.sizeMax, priceAud: p.priceAud, sizeLabel: p.sizeLabel })) }}>
  (function () {
    const calc = document.getElementById("pricingCalculator");
    if (!calc) return;

    const stepper = calc.querySelector("[data-stepper]");
    const countEl = document.getElementById("calcCount");
    const segButtons = calc.querySelectorAll("#calcSize button");
    const addons = calc.querySelectorAll("#calcAddons input");
    const totalEl = document.getElementById("calcTotal");
    const breakdownEl = document.getElementById("calcBreakdown");
    const cards = document.querySelectorAll(".pricing-card[data-tier]");

    let count = 1;
    let tier = document.querySelector("#calcSize button.is-active");

    function recompute() {
      const selectedTier = calc.querySelector("#calcSize button.is-active");
      const price = parseFloat(selectedTier?.dataset.price || "0");
      const custom = selectedTier?.dataset.custom === "true";
      const label = selectedTier?.dataset.label || "";
      const tierId = selectedTier?.dataset.tier;

      let total = price;
      let addonSum = 0;
      const addonNames = [];
      addons.forEach((a) => {
        if (a.checked) {
          addonSum += parseFloat(a.dataset.price || "0");
          addonNames.push(a.dataset.label);
        }
      });
      total = (total + addonSum) * count;

      if (custom || !price) {
        totalEl.textContent = "Quote";
        totalEl.style.fontSize = "1.8rem";
        breakdownEl.textContent = count + " × " + label + " — sized on site";
      } else {
        totalEl.textContent = total.toLocaleString();
        totalEl.style.fontSize = "";
        const addonText = addonNames.length ? " + " + addonNames.join(", ") : "";
        breakdownEl.textContent = count + (count === 1 ? " TV · " : " TVs · ") + label + addonText;
      }

      // Sync matched card highlight
      cards.forEach((c) => c.classList.remove("is-matched"));
      if (tierId) {
        const matchedCard = document.querySelector('.pricing-card[data-tier="' + tierId + '"]');
        if (matchedCard) matchedCard.classList.add("is-matched");
      }
    }

    // Stepper
    stepper?.addEventListener("click", (e) => {
      const btn = e.target.closest("button[data-action]");
      if (!btn) return;
      if (btn.dataset.action === "inc") count = Math.min(count + 1, 10);
      else count = Math.max(count - 1, 1);
      countEl.textContent = count;
      recompute();
    });

    // Segmented buttons
    segButtons.forEach((b) => {
      b.addEventListener("click", () => {
        segButtons.forEach((x) => x.classList.remove("is-active"));
        b.classList.add("is-active");
        recompute();
      });
    });

    // Pricing card → clicking a non-featured card also selects it in the segmented control
    cards.forEach((card) => {
      card.addEventListener("click", (e) => {
        // Don't hijack clicks on the CTA link
        if (e.target.closest("a")) return;
        const tierId = card.dataset.tier;
        const match = calc.querySelector('#calcSize button[data-tier="' + tierId + '"]');
        if (match) {
          segButtons.forEach((x) => x.classList.remove("is-active"));
          match.classList.add("is-active");
          card.classList.add("is-selected");
          setTimeout(() => card.classList.remove("is-selected"), 1500);
          recompute();
          document.getElementById("pricingCalculator")?.scrollIntoView({ behavior: "smooth", block: "center" });
        }
      });
    });

    // Checkbox toggles
    addons.forEach((a) => {
      a.addEventListener("change", () => {
        const wrap = a.closest(".calc-checkbox");
        if (wrap) wrap.classList.toggle("is-checked", a.checked);
        recompute();
      });
    });

    recompute();
  })();
</script>

<style is:global>
  /* =====================================================================
     PRICING PAGE — banner + homepage-style pricing block + trust + CTA
     =====================================================================
     The middle "pricing-section" is inherited from /css/marketing.css so it
     renders identically to the homepage. This file only adds the banner,
     the 5-column grid override, the trust strip, and the foot CTA.
  */

  /* ===== Banner ===== */
  .pr-banner {
    position: relative;
    margin-left: calc(50% - 50vw);
    margin-right: calc(50% - 50vw);
    width: 100vw;
    height: clamp(240px, 32vh, 420px);
    overflow: hidden;
    background: #131619;
  }
  .pr-banner-img {
    position: absolute; inset: 0;
    width: 100%; height: 100%;
    object-fit: cover; object-position: center;
  }
  .pr-banner::after {
    content: "";
    position: absolute; inset: 0;
    background: linear-gradient(90deg, rgba(0,0,0,0.55) 0%, rgba(0,0,0,0.35) 35%, rgba(0,0,0,0) 70%);
    pointer-events: none;
  }
  .pr-banner-inner {
    position: relative; z-index: 1;
    width: 100%; max-width: 1200px; height: 100%;
    margin: 0 auto;
    padding: 0 24px;
    display: flex; align-items: center;
  }
  @media (min-width: 1201px) {
    .pr-banner-inner { width: 90%; max-width: 1720px; padding: 0; }
  }
  .pr-banner-title {
    margin: 0;
    color: #fff;
    font-family: "Inter", sans-serif;
    font-weight: 400;
    font-size: clamp(2.5rem, 6vw, 5rem);
    letter-spacing: 0.02em;
    text-transform: uppercase;
    line-height: 1;
    text-shadow: 0 2px 18px rgba(0,0,0,0.35);
  }

  /* ===== 5-column pricing grid override ===== */
  /* Homepage uses `repeat(4, 1fr)` — we ship 5 packages, so override here */
  .pricing-grid.pricing-grid-five {
    grid-template-columns: repeat(5, 1fr);
  }
  @media (max-width: 1280px) {
    .pricing-grid.pricing-grid-five { grid-template-columns: repeat(3, 1fr); }
  }
  @media (max-width: 860px) {
    .pricing-grid.pricing-grid-five { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 560px) {
    .pricing-grid.pricing-grid-five { grid-template-columns: 1fr; }
  }

  /* Custom-quote card's "Custom" label — match the currency/price rhythm */
  .pricing-card.is-custom .pricing-card-price-custom {
    font-family: "Noto Serif", serif;
    font-size: 1.7rem;
    font-weight: 400;
    color: #1a1a1a;
    letter-spacing: -0.4px;
  }
  .pricing-card.is-featured.is-custom .pricing-card-price-custom,
  .pricing-card.is-custom:hover .pricing-card-price-custom,
  .pricing-card.is-custom.is-matched .pricing-card-price-custom,
  .pricing-card.is-custom.is-selected .pricing-card-price-custom {
    color: #fff;
  }

  /* Hide an empty currency span in pricing-card-price when a custom label is rendered */
  .pricing-card.is-custom .pricing-card-price { line-height: 1.2; }

  /* ===== Trust strip ===== */
  .pr-trust {
    background: #fff;
    padding: clamp(48px, 7vw, 96px) 0;
    display: flex;
    justify-content: center;
  }
  .pr-trust-inner {
    width: 85%;
    max-width: 1720px;
  }
  .pr-trust h2 {
    font-family: "Noto Serif", serif;
    font-size: clamp(1.8rem, 2.6vw, 2.4rem);
    font-weight: 500;
    color: #1a1a1a;
    letter-spacing: -0.4px;
    margin: 0 0 28px;
    text-align: center;
  }
  .pr-trust-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 20px;
  }
  .pr-trust-card {
    padding: 24px 26px 22px;
    background: #fafafa;
    border: 1px solid rgba(0,0,0,0.06);
    border-radius: 4px;
  }
  .pr-trust-card h3 {
    font-family: "Noto Serif", serif;
    font-size: 1.15rem;
    font-weight: 600;
    color: #1a1a1a;
    margin: 0 0 8px;
    letter-spacing: -0.2px;
  }
  .pr-trust-card p {
    font-family: "Inter", sans-serif;
    font-size: 13.5px;
    color: #4a4a4a;
    line-height: 1.55;
    margin: 0;
  }
  @media (max-width: 960px) {
    .pr-trust-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 520px) {
    .pr-trust-grid { grid-template-columns: 1fr; }
  }

  /* ===== Foot CTA (dark, full-bleed) ===== */
  .pr-foot {
    background: linear-gradient(152deg, #1c1c1f 0%, #0a0a0c 52%, #000 100%);
    color: #f5f5f5;
    padding: clamp(48px, 7vw, 96px) 0;
    display: flex;
    justify-content: center;
  }
  .pr-foot-inner {
    width: 85%;
    max-width: 1200px;
    text-align: center;
  }
  .pr-foot-eyebrow {
    font-family: "Inter", sans-serif;
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 1.8px;
    text-transform: uppercase;
    color: #7b79f0;
    margin: 0 0 12px;
  }
  .pr-foot-title {
    font-family: "Noto Serif", serif;
    font-size: clamp(1.8rem, 3vw, 2.6rem);
    font-weight: 500;
    letter-spacing: -0.4px;
    margin: 0 0 10px;
    color: #fff;
  }
  .pr-foot-lede {
    font-family: "Inter", sans-serif;
    font-size: 15px;
    color: rgba(255,255,255,0.55);
    margin: 0 0 28px;
  }
  .pr-foot-cta-row {
    display: inline-flex;
    gap: 12px;
    flex-wrap: wrap;
    justify-content: center;
  }
  .pr-foot-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 14px 26px;
    font-family: "Inter", sans-serif;
    font-size: 13px;
    font-weight: 600;
    letter-spacing: 1.2px;
    text-transform: uppercase;
    border-radius: 2px;
    transition: background 0.2s, color 0.2s, border-color 0.2s;
    text-decoration: none;
  }
  .pr-foot-btn-primary {
    background: #fff;
    color: #1a1a1a;
    border: 1px solid #fff;
  }
  .pr-foot-btn-primary:hover { background: #f7f3ec; }
  .pr-foot-btn-ghost {
    background: transparent;
    color: #fff;
    border: 1px solid rgba(255,255,255,0.3);
  }
  .pr-foot-btn-ghost:hover { border-color: #fff; }
</style>

---
import AdminShell from "~/layouts/AdminShell.astro";
import BulkCreateModal from "~/components/admin/BulkCreateModal.astro";
import PublishToggle from "~/components/admin/PublishToggle.astro";
import { getCollection } from "astro:content";

/**
 * /admin-nav/mounts/ — admin list for the mounts collection.
 *
 * First row is the public /mounts/ landing page. Subsequent rows list
 * every mount entry sorted by max weight rating descending (heaviest first).
 *
 * Top-right "+ New mount ▾" dropdown offers both the single-entry CMS
 * flow and the bulk .md uploader (see BulkCreateModal).
 */
const mounts = (await getCollection("mounts")).sort(
  (a, b) => b.data.maxWeightKg - a.data.maxWeightKg
);
const published = mounts.filter((m) => !m.data.draft).length;
const drafts = mounts.filter((m) => m.data.draft).length;
---
<AdminShell title="Mounts" active="mounts" description="TV wall mounts and brackets.">
  <div slot="actions">
    <div class="np-dropdown" data-np-root>
      <button type="button" class="btn btn-primary" data-np-toggle aria-haspopup="true" aria-expanded="false">
        + New mount <span class="np-caret" aria-hidden="true">▾</span>
      </button>
      <div class="np-menu" data-np-menu hidden role="menu">
        <a class="np-item" href="/admin/#/collections/mounts/new" target="_blank" rel="noopener" role="menuitem">
          <span class="np-item-title">Single mount</span>
          <span class="np-item-sub">Open the CMS editor</span>
        </a>
        <button type="button" class="np-item" data-bulk-open role="menuitem">
          <span class="np-item-title">Bulk upload .md files</span>
          <span class="np-item-sub">Drag up to 50 files at once</span>
        </button>
      </div>
    </div>
  </div>

  <div class="content">
    <section class="panel">
      <div class="panel-head">
        <h2>Mounts<span class="counter">({mounts.length} entries · {published} live · {drafts} draft)</span></h2>
        <div class="panel-actions">
          <a class="btn" href="/mounts/" target="_blank" rel="noopener">View hub</a>
          <a class="btn" href="/templates/mount-page-template.md" download>Download .md template</a>
          <a class="btn" href="/admin/#/collections/mounts" target="_blank" rel="noopener">Manage in CMS</a>
        </div>
      </div>

      <div class="table-wrap">
        <table class="table">
          <thead>
            <tr>
              <th>Title</th>
              <th>Slug</th>
              <th>Brand</th>
              <th>Type</th>
              <th>Fits</th>
              <th>Max kg</th>
              <th>Status</th>
              <th style="width: 1%;">Actions</th>
            </tr>
          </thead>
          <tbody>
            <tr class="row-index">
              <td class="cell-title">
                <strong><a href="/mounts/" target="_blank" rel="noopener" style="color: inherit;">Wall mounts landing page</a></strong>
                <span>Public hub grouping mounts by type — <code>/mounts/index.html</code></span>
              </td>
              <td>
                <a href="/mounts/" target="_blank" rel="noopener" style="font-family: ui-monospace, SFMono-Regular, Menlo, monospace; font-size: 0.78rem; color: var(--sidebar-accent); text-decoration: none;">
                  /mounts/
                </a>
              </td>
              <td style="color: var(--muted);">—</td>
              <td style="color: var(--muted);">—</td>
              <td style="color: var(--muted);">—</td>
              <td style="color: var(--muted);">—</td>
              <td><span class="badge badge-ok">Live</span></td>
              <td>
                <div class="actions">
                  <a class="btn" href="/mounts/" target="_blank" rel="noopener">View</a>
                </div>
              </td>
            </tr>

            {mounts.length === 0 ? (
              <tr>
                <td colspan="8" style="text-align: center; padding: 2rem; color: var(--ink-soft);">
                  No mounts yet. Hit <strong>+ New mount</strong> or drop a <code>.md</code> file into <code>src/content/mounts/</code>.
                </td>
              </tr>
            ) : (
              mounts.map((m) => (
                <tr>
                  <td class="cell-title">
                    <strong><a href={`/mounts/${m.slug}/`} target="_blank" rel="noopener" style="color: inherit;">{m.data.title}</a></strong>
                    <span>{m.data.description}</span>
                  </td>
                  <td>
                    <a href={`/mounts/${m.slug}/`} target="_blank" rel="noopener" style="font-family: ui-monospace, SFMono-Regular, Menlo, monospace; font-size: 0.78rem; color: var(--sidebar-accent); text-decoration: none;">
                      /{m.slug}
                    </a>
                  </td>
                  <td>{m.data.brand}</td>
                  <td><span class="badge badge-muted">{m.data.mountType}</span></td>
                  <td>{m.data.minScreenInches}–{m.data.maxScreenInches}"</td>
                  <td>{m.data.maxWeightKg}kg</td>
                  <td>{m.data.draft ? <span class="badge badge-draft">Draft</span> : <span class="badge badge-ok">Live</span>}</td>
                  <td>
                    <div class="actions">
                      <a class="btn" href={`/mounts/${m.slug}/`} target="_blank" rel="noopener">View</a>
                      <a class="btn" href={`/admin/#/collections/mounts/entries/${m.slug}`} target="_blank" rel="noopener">Edit</a>
                      <PublishToggle collection="mounts" slug={m.slug} draft={m.data.draft} />
                    </div>
                  </td>
                </tr>
              ))
            )}
          </tbody>
        </table>
      </div>
    </section>
  </div>

  {/* Bulk-upload overlay (hidden by default, opened by [data-bulk-open]) */}
  <BulkCreateModal collection="mounts" />

  <style is:global>
    .row-index td { background: #fafbff; }
    .row-index td:first-child { border-left: 3px solid var(--sidebar-accent); }
    .row-index .cell-title strong { color: var(--sidebar-accent); }
  </style>
</AdminShell>

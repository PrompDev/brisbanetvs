---
import AdminShell from "~/layouts/AdminShell.astro";
import { getCollection } from "astro:content";

const posts = (await getCollection("blog")).sort(
  (a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf()
);
const published = posts.filter((p) => !p.data.draft).length;
const drafts = posts.filter((p) => p.data.draft).length;
---
<AdminShell title="Blogs" active="blogs" description="All blog posts.">
  <div slot="actions">
    <div class="np-dropdown" data-np-root>
      <button type="button" class="btn btn-primary" data-np-toggle aria-haspopup="true" aria-expanded="false">
        + New blog post <span class="np-caret" aria-hidden="true">▾</span>
      </button>
      <div class="np-menu" data-np-menu hidden role="menu">
        <a class="np-item" href="/admin/#/collections/blog/new" target="_blank" rel="noopener" role="menuitem">
          <span class="np-item-title">Single post</span>
          <span class="np-item-sub">Open the CMS editor</span>
        </a>
        <button type="button" class="np-item" data-bulk-open role="menuitem">
          <span class="np-item-title">Bulk upload .md files</span>
          <span class="np-item-sub">Drag up to 50 files at once</span>
        </button>
      </div>
    </div>
  </div>

  <div class="content">
    <section class="panel">
      <div class="panel-head">
        <h2>Blog posts<span class="counter">({posts.length} total · {published} live · {drafts} draft)</span></h2>
        <div class="panel-actions">
          <a class="btn" href="/templates/blog-post-template.md" download>Download .md template</a>
          <a class="btn" href="/admin/#/collections/blog" target="_blank" rel="noopener">Manage in CMS</a>
        </div>
      </div>
      {posts.length === 0 ? (
        <div class="empty">
          <h3>No posts yet</h3>
          <p>Hit <strong>+ New blog post</strong> above or drop a <code>.md</code> file into <code>src/content/blog/</code>.</p>
        </div>
      ) : (
        <div class="table-wrap">
          <table class="table">
            <thead>
              <tr>
                <th>Title</th>
                <th>Slug</th>
                <th>Published</th>
                <th>Style</th>
                <th>Status</th>
                <th>Tags</th>
                <th style="width: 1%;">Actions</th>
              </tr>
            </thead>
            <tbody>
              {/* Collection landing page row — surfaces the public /blog/ index
                  so the dashboard doubles as a site-map. Sits at the top so
                  it's the first thing the user sees when they open the list. */}
              <tr class="row-index">
                <td class="cell-title">
                  <strong><a href="/blog/" target="_blank" rel="noopener" style="color: inherit;">Blog landing page</a></strong>
                  <span>Public hub listing every post — <code>/blog/index.html</code></span>
                </td>
                <td>
                  <a href="/blog/" target="_blank" rel="noopener" style="font-family: ui-monospace, SFMono-Regular, Menlo, monospace; font-size: 0.78rem; color: var(--sidebar-accent); text-decoration: none;">
                    /blog/
                  </a>
                </td>
                <td style="color: var(--muted);">—</td>
                <td><span class="badge badge-muted">index</span></td>
                <td><span class="badge badge-ok">Live</span></td>
                <td style="color: var(--muted);">—</td>
                <td>
                  <div class="actions">
                    <a class="btn" href="/blog/" target="_blank" rel="noopener">View</a>
                  </div>
                </td>
              </tr>
              {posts.map((post) => (
                <tr>
                  <td class="cell-title">
                    <strong><a href={`/admin-nav/blogs/${post.slug}/`} style="color: inherit;">{post.data.title}</a></strong>
                    <span>{post.data.description}</span>
                  </td>
                  <td>
                    <a href={`/admin-nav/blogs/${post.slug}/`} style="font-family: ui-monospace, SFMono-Regular, Menlo, monospace; font-size: 0.78rem; color: var(--sidebar-accent); text-decoration: none;">
                      /{post.slug}
                    </a>
                  </td>
                  <td>{new Date(post.data.publishDate).toLocaleDateString("en-AU", { day: "numeric", month: "short", year: "numeric" })}</td>
                  <td><span class="badge badge-muted">{post.data.style}</span></td>
                  <td>{post.data.draft ? <span class="badge badge-draft">Draft</span> : <span class="badge badge-ok">Live</span>}</td>
                  <td style="color: var(--ink-soft); font-size: 0.82rem;">
                    {post.data.tags.length > 0 ? post.data.tags.join(", ") : <span style="color: var(--muted);">—</span>}
                  </td>
                  <td>
                    <div class="actions">
                      <a class="btn" href={`/admin-nav/blogs/${post.slug}/`}>Open</a>
                      <a class="btn btn-primary" href={`/admin/#/collections/blog/entries/${post.slug}`} target="_blank" rel="noopener">Edit</a>
                    </div>
                  </td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      )}
    </section>
  </div>

  {/* === BULK UPLOAD MODAL === */}
  <div class="bulk-overlay" data-bulk-overlay hidden>
    <div class="bulk-modal" role="dialog" aria-labelledby="bulk-title" aria-modal="true">
      <header class="bulk-head">
        <div>
          <h3 id="bulk-title">Bulk upload blog posts</h3>
          <p>Drop <code>.md</code> files, then click through each post and pick an image for every <code>IMAGE:</code> slot.</p>
        </div>
        <button type="button" class="bulk-close" data-bulk-close aria-label="Close">×</button>
      </header>

      {/* Connection banner — shows whether we can talk to the CMS proxy */}
      <div class="bulk-conn" data-bulk-conn>
        <span class="bulk-conn-dot" data-bulk-conn-dot></span>
        <span data-bulk-conn-label>Checking CMS connection…</span>
        <button type="button" class="bulk-conn-btn" data-bulk-root hidden>Pick folder manually…</button>
      </div>

      <div class="bulk-drop" data-bulk-drop tabindex="0">
        <p class="bulk-drop-main">Drag <strong>.md</strong> files here or <button type="button" class="bulk-browse" data-bulk-browse>browse…</button></p>
        <input type="file" accept=".md,text/markdown" multiple hidden data-bulk-input />
      </div>

      {/* Dot rail + prev/next stepper — only shows once files are added */}
      <nav class="bulk-strip" data-bulk-strip hidden aria-label="Posts">
        <button type="button" class="bulk-nav" data-bulk-prev aria-label="Previous post (left arrow)">‹</button>
        <span class="bulk-strip-count" data-bulk-strip-count>1 / 1</span>
        <div class="bulk-dots" data-bulk-dots role="tablist"></div>
        <span class="bulk-strip-error" data-bulk-strip-error hidden title="">Invalid template</span>
        <button type="button" class="bulk-nav" data-bulk-next aria-label="Next post (right arrow)">›</button>
      </nav>

      {/* Single-post focus view */}
      <section class="bulk-focus" data-bulk-focus hidden aria-live="polite"></section>

      <footer class="bulk-foot">
        <div class="bulk-summary" data-bulk-summary>No files yet.</div>
        <div class="bulk-actions">
          <button type="button" class="btn" data-bulk-clear disabled>Clear</button>
          <button type="button" class="btn btn-primary" data-bulk-save disabled>Save all</button>
        </div>
      </footer>

      <p class="bulk-hint">
        Tip: use <kbd>←</kbd> <kbd>→</kbd> to jump between posts, <kbd>Enter</kbd> to open the picker on the focused slot.
      </p>
    </div>
  </div>

<style is:global>
  /* ===== Dropdown ===== */
  .np-dropdown { position: relative; display: inline-block; }
  .np-caret { font-size: 0.75rem; margin-left: 0.1rem; transition: transform 0.15s; }
  .np-dropdown[data-open="true"] .np-caret { transform: rotate(180deg); }

  .np-menu {
    position: absolute;
    top: calc(100% + 6px);
    right: 0;
    min-width: 240px;
    background: #fff;
    border: 1px solid var(--panel-line, #e5e7eb);
    border-radius: 8px;
    box-shadow: 0 12px 28px rgba(15, 22, 36, 0.12);
    padding: 0.35rem;
    z-index: 40;
    display: flex;
    flex-direction: column;
  }
  .np-menu[hidden] { display: none; }

  .np-item {
    all: unset;
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
    padding: 0.6rem 0.75rem;
    border-radius: 6px;
    cursor: pointer;
    font-family: inherit;
    color: var(--ink, #131619);
  }
  .np-item:hover,
  .np-item:focus-visible { background: #f1f3f7; outline: none; }
  .np-item-title { font-size: 0.88rem; font-weight: 600; }
  .np-item-sub { font-size: 0.76rem; color: var(--ink-soft, #5a6271); }

  /* ===== Bulk upload modal ===== */
  .bulk-overlay {
    position: fixed;
    inset: 0;
    background: rgba(15, 22, 36, 0.55);
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 1.5rem;
    z-index: 80;
  }
  .bulk-overlay[hidden] { display: none; }
  /* Defensive [hidden] reset — our class rules set display: flex/inline-flex
     which would otherwise override the attribute's default display: none. */
  .bulk-strip[hidden],
  .bulk-focus[hidden],
  .bulk-strip-error[hidden] { display: none !important; }

  .bulk-modal {
    width: min(640px, 100%);
    max-height: calc(100vh - 3rem);
    background: #fff;
    border-radius: 12px;
    box-shadow: 0 24px 60px rgba(0, 0, 0, 0.25);
    display: flex;
    flex-direction: column;
    overflow: hidden;
  }

  .bulk-head {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 1rem;
    padding: 1.1rem 1.25rem 0.9rem;
    border-bottom: 1px solid var(--panel-line, #e5e7eb);
  }
  .bulk-head h3 { margin: 0 0 0.25rem; font-size: 1.02rem; font-weight: 600; }
  .bulk-head p { margin: 0; font-size: 0.82rem; color: var(--ink-soft, #5a6271); line-height: 1.4; }
  .bulk-head code { font-size: 0.78rem; background: #f1f3f7; padding: 0.05rem 0.3rem; border-radius: 4px; }

  .bulk-close {
    border: 0;
    background: transparent;
    color: var(--ink-soft, #5a6271);
    font-size: 1.5rem;
    line-height: 1;
    cursor: pointer;
    padding: 0.1rem 0.35rem;
    border-radius: 4px;
    flex-shrink: 0;
  }
  .bulk-close:hover { background: #f1f3f7; color: var(--ink, #131619); }

  .bulk-drop {
    margin: 1rem 1.25rem;
    padding: 2rem 1rem;
    border: 2px dashed var(--panel-line, #d7dae1);
    border-radius: 10px;
    text-align: center;
    color: var(--ink-soft, #5a6271);
    transition: background 0.12s, border-color 0.12s;
    cursor: pointer;
  }
  .bulk-drop.is-dragover { background: #f5f3eb; border-color: #c5a14a; color: var(--ink, #131619); }
  .bulk-drop svg { color: var(--ink-soft, #5a6271); margin-bottom: 0.5rem; }
  .bulk-drop-main { margin: 0 0 0.25rem; font-size: 0.95rem; color: var(--ink, #131619); }
  .bulk-drop-sub { margin: 0; font-size: 0.82rem; }

  .bulk-browse {
    border: 0; background: transparent; padding: 0;
    color: var(--sidebar-accent, #4f46e5);
    text-decoration: underline;
    font: inherit; cursor: pointer;
  }

  /* ===== Connection banner (full-width, flush to modal edges) ===== */
  .bulk-conn {
    display: flex;
    align-items: center;
    gap: 0.55rem;
    margin: 0;
    padding: 0.55rem 1.25rem;
    border-radius: 0;
    background: #f6f7fa;
    border: 0;
    border-bottom: 1px solid var(--panel-line, #e5e7eb);
    font-size: 0.8rem;
    color: var(--ink-soft, #5a6271);
  }
  .bulk-conn.is-online  { background: #ecfaf1; border-bottom-color: #b9e6ce; color: #17633a; }
  .bulk-conn.is-offline { background: #fff7e8; border-bottom-color: #f1d99b; color: #7a5507; }
  .bulk-conn.is-folder  { background: #edf1fd; border-bottom-color: #c2cef0; color: #1e40af; }
  .bulk-conn-dot {
    width: 0.5rem; height: 0.5rem; border-radius: 50%;
    background: #b6bdc9; flex-shrink: 0;
  }
  .bulk-conn.is-online  .bulk-conn-dot { background: #1e9a58; box-shadow: 0 0 0 3px #1e9a5830; }
  .bulk-conn.is-offline .bulk-conn-dot { background: #c88b22; }
  .bulk-conn.is-folder  .bulk-conn-dot { background: #1e40af; }
  .bulk-conn-btn {
    margin-left: auto;
    border: 1px solid currentColor;
    background: transparent;
    color: inherit;
    font: inherit;
    font-size: 0.74rem;
    padding: 0.2rem 0.55rem;
    border-radius: 4px;
    cursor: pointer;
    opacity: 0.85;
  }
  .bulk-conn-btn:hover { opacity: 1; background: rgba(0,0,0,0.05); }

  /* ===== Dot rail + stepper (clear card, never looks empty) ===== */
  .bulk-strip {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin: 1rem 1.25rem 0;
    padding: 0.45rem 0.55rem;
    background: #fafbfc;
    border: 1px solid var(--panel-line, #e5e7eb);
    border-radius: 8px;
  }
  .bulk-strip-count {
    flex-shrink: 0;
    font-size: 0.74rem;
    font-weight: 600;
    color: var(--ink-soft, #5a6271);
    padding: 0 0.4rem;
    min-width: 3.5rem;
    text-align: center;
  }
  .bulk-nav {
    border: 1px solid var(--panel-line, #d7dae1);
    background: #fff;
    width: 2rem; height: 2rem;
    border-radius: 50%;
    font-size: 1.1rem; line-height: 1;
    cursor: pointer;
    color: var(--ink, #131619);
    flex-shrink: 0;
    display: flex; align-items: center; justify-content: center;
  }
  .bulk-nav:hover:not(:disabled) { background: #f5f3eb; border-color: #c5a14a; }
  .bulk-nav:disabled { opacity: 0.35; cursor: not-allowed; }
  .bulk-dots {
    flex: 1;
    display: flex;
    align-items: center;
    gap: 6px;
    overflow-x: auto;
    padding: 0.15rem 0.25rem;
    justify-content: flex-start;
    min-height: 1.5rem;
  }
  .bulk-dots::-webkit-scrollbar { height: 4px; }
  .bulk-dots::-webkit-scrollbar-thumb { background: #d7dae1; border-radius: 2px; }
  .bulk-dot {
    width: 0.85rem; height: 0.85rem;
    border-radius: 50%;
    border: 2px solid #fff;
    padding: 0;
    cursor: pointer;
    background: #c9cdd4;
    flex-shrink: 0;
    box-shadow: 0 0 0 1px #c9cdd4;
    transition: transform 0.12s, box-shadow 0.12s;
  }
  .bulk-dot:hover { transform: scale(1.2); }
  .bulk-dot.is-current {
    transform: scale(1.25);
    box-shadow: 0 0 0 2px var(--ink, #131619);
  }
  .bulk-dot.is-ready { background: #1e9a58; box-shadow: 0 0 0 1px #1e9a58; }
  .bulk-dot.is-needs { background: #d4a94a; box-shadow: 0 0 0 1px #d4a94a; }
  .bulk-dot.is-error {
    background: #c62828;
    box-shadow: 0 0 0 1px #c62828;
    /* Inner "!" mark so red dots read as warnings even at a glance */
    position: relative;
  }
  .bulk-dot.is-error::before {
    content: "!";
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #fff;
    font-size: 0.6rem;
    font-weight: 900;
    line-height: 1;
    font-family: ui-sans-serif, system-ui, sans-serif;
  }
  .bulk-dot.is-saved { background: #1e40af; box-shadow: 0 0 0 1px #1e40af; }
  .bulk-dot.is-current.is-ready { box-shadow: 0 0 0 2px var(--ink, #131619); }
  .bulk-dot.is-current.is-needs { box-shadow: 0 0 0 2px var(--ink, #131619); }
  .bulk-dot.is-current.is-error { box-shadow: 0 0 0 2px #c62828; animation: bulk-dot-pulse 1.4s ease-in-out infinite; }
  .bulk-dot.is-current.is-saved { box-shadow: 0 0 0 2px var(--ink, #131619); }
  @keyframes bulk-dot-pulse {
    0%, 100% { box-shadow: 0 0 0 2px #c62828, 0 0 0 4px #c6282800; }
    50%      { box-shadow: 0 0 0 2px #c62828, 0 0 0 5px #c6282855; }
  }

  /* Small red pill shown in the stepper when any entry fails validation */
  .bulk-strip-error {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    flex-shrink: 0;
    font-size: 0.7rem;
    font-weight: 700;
    color: #fff;
    background: #c62828;
    padding: 0.2rem 0.55rem 0.22rem;
    border-radius: 999px;
    line-height: 1;
    white-space: nowrap;
  }
  .bulk-strip-error::before {
    content: "!";
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 0.85rem; height: 0.85rem;
    border-radius: 50%;
    background: #fff;
    color: #c62828;
    font-weight: 900;
    font-size: 0.65rem;
  }

  /* ===== Single-post focus view (card container) ===== */
  .bulk-focus {
    margin: 0.75rem 1.25rem 0;
    padding: 0;
    background: transparent;
    max-height: 54vh;
    overflow-y: auto;
    display: flex;
    flex-direction: column;
    gap: 0.65rem;
  }

  /* Metadata card — slug + core fields at the top */
  .bf-meta-card {
    background: #fff;
    border: 1px solid var(--panel-line, #e5e7eb);
    border-radius: 10px;
    padding: 0.85rem 1rem;
    box-shadow: 0 1px 2px rgba(15, 22, 36, 0.03);
  }
  .bf-meta-top {
    display: flex;
    align-items: flex-start;
    gap: 0.65rem;
    margin-bottom: 0.7rem;
    padding-bottom: 0.65rem;
    border-bottom: 1px solid var(--panel-line, #eef0f4);
  }
  .bf-meta-main { flex: 1; min-width: 0; }
  .bf-pos {
    font-size: 0.7rem;
    color: var(--ink-soft, #5a6271);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    font-weight: 600;
    margin-bottom: 0.2rem;
  }
  .bf-title {
    font-size: 1rem;
    font-weight: 600;
    color: var(--ink, #131619);
    line-height: 1.3;
    margin: 0 0 0.25rem;
    word-break: break-word;
  }
  .bf-slug-row {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
    font-size: 0.75rem;
    background: #f5f3eb;
    border: 1px solid #eadfb8;
    color: #5e4a15;
    padding: 0.15rem 0.45rem;
    border-radius: 4px;
    max-width: 100%;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
  .bf-slug-row .bf-slug-prefix { opacity: 0.6; }
  .bf-file {
    display: block;
    margin-top: 0.35rem;
    font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
    font-size: 0.7rem;
    color: var(--ink-soft, #5a6271);
  }
  .bf-status { font-size: 0.72rem; padding: 0.15rem 0.55rem; border-radius: 999px; font-weight: 600; flex-shrink: 0; align-self: center; }
  .bf-status.ready { background: #dcf5e5; color: #17633a; }
  .bf-status.needs { background: #fff1cf; color: #7a5507; }
  .bf-status.error { background: #fde1e1; color: #8a1c1c; }
  .bf-status.saved { background: #d6e2ff; color: #1e40af; }
  .bf-remove {
    border: 0; background: transparent; cursor: pointer;
    color: var(--ink-soft, #5a6271);
    font-size: 1.1rem; line-height: 1;
    padding: 0.15rem 0.35rem; border-radius: 4px;
    flex-shrink: 0;
    align-self: flex-start;
  }
  .bf-remove:hover { background: #f1f3f7; color: #b33; }

  /* Core info grid — editable author/date/style fields */
  .bf-fields {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 0.85rem 1rem;
    padding-top: 0.35rem;
  }
  @media (max-width: 560px) {
    .bf-fields { grid-template-columns: 1fr 1fr; }
  }
  .bf-field { display: flex; flex-direction: column; gap: 0.35rem; min-width: 0; }
  .bf-field label {
    display: block;
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--ink-soft, #5a6271);
    font-weight: 600;
    line-height: 1;
    margin: 0;
  }
  .bf-field input,
  .bf-field select {
    font: inherit;
    font-size: 0.85rem;
    color: var(--ink, #131619);
    background: #fff;
    border: 1px solid var(--panel-line, #d7dae1);
    border-radius: 6px;
    padding: 0.5rem 0.65rem;
    width: 100%;
    min-width: 0;
    box-sizing: border-box;
    line-height: 1.3;
  }
  .bf-field input:hover,
  .bf-field select:hover { border-color: #b2b7c2; }
  .bf-field input:focus,
  .bf-field select:focus {
    outline: none;
    border-color: #c5a14a;
    box-shadow: 0 0 0 2px #c5a14a33;
  }

  .bf-errors {
    margin: 0;
    padding: 0.55rem 0.7rem;
    background: #fdf4f4;
    border: 1px solid #f3c8c8;
    border-left: 3px solid #b33;
    border-radius: 6px;
    font-size: 0.78rem;
    color: #8a1c1c;
  }

  /* Images card — wraps all slot cards */
  .bf-images-card {
    background: #fff;
    border: 1px solid var(--panel-line, #e5e7eb);
    border-radius: 10px;
    padding: 0.75rem 0.85rem 0.85rem;
    box-shadow: 0 1px 2px rgba(15, 22, 36, 0.03);
  }
  .bf-images-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.5rem;
    margin-bottom: 0.6rem;
    padding-bottom: 0.55rem;
    border-bottom: 1px solid var(--panel-line, #eef0f4);
  }
  .bf-images-title {
    font-size: 0.82rem;
    font-weight: 600;
    color: var(--ink, #131619);

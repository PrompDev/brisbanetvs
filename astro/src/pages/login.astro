<!doctype html>
<html lang="en-AU">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex,nofollow" />
    <title>Staff Login | Brisbane TVs</title>
    <meta name="description" content="Secure Brisbane TVs staff access." />
  </head>
  <body>
    <main class="login-shell">
      <a class="brand" href="/" aria-label="Brisbane TVs home">BRISBANE <span>TVS</span></a>
      <section class="login-card" aria-labelledby="login-title">
        <p class="eyebrow">Staff workspace</p>
        <h1 id="login-title">Secure staff login</h1>
        <p>Use your approved work identity to open the Brisbane TVs leads and operations dashboard.</p>
        <a class="continue" href="/operations/">Continue securely <span aria-hidden="true">→</span></a>
        <p class="reassurance">Access is managed by Cloudflare Access. Brisbane TVs does not store a staff password on this website.</p>
      </section>
      <p class="help">Need access? Contact Brisbane TVs administration.</p>
    </main>
  </body>
</html>

<style>
  :global(*) { box-sizing: border-box; }
  :global(body) { margin: 0; min-width: 320px; background: #111a26; color: #f8f5ef; font-family: Inter, ui-sans-serif, system-ui, sans-serif; }
  .login-shell { min-height: 100vh; display: grid; place-items: center; align-content: center; gap: 2.5rem; padding: 2rem; background: radial-gradient(circle at top right, #305a78 0, transparent 36%), linear-gradient(135deg, #111a26, #172c3d); }
  .brand { color: #fff; font-size: 1.05rem; font-weight: 800; letter-spacing: .12em; text-decoration: none; }
  .brand span { color: #b9985a; }
  .login-card { width: min(100%, 32rem); border: 1px solid rgba(255,255,255,.18); border-radius: 1rem; padding: clamp(2rem, 7vw, 3.5rem); background: rgba(12, 24, 34, .82); box-shadow: 0 24px 70px rgba(0,0,0,.26); }
  .eyebrow { margin: 0 0 .85rem; color: #d3b67c; font-size: .72rem; font-weight: 800; letter-spacing: .15em; text-transform: uppercase; }
  h1 { margin: 0; font-family: Georgia, "Times New Roman", serif; font-size: clamp(2.35rem, 8vw, 3.8rem); line-height: .96; }
  .login-card > p:not(.eyebrow) { margin: 1.35rem 0 0; color: #d5dde2; line-height: 1.7; }
  .continue { display: flex; justify-content: space-between; align-items: center; gap: 1rem; margin-top: 2rem; padding: 1rem 1.15rem; border-radius: .55rem; background: #c7a76b; color: #101820; font-weight: 800; text-decoration: none; }
  .continue:hover, .continue:focus-visible { background: #e1c58d; }
  .continue span { font-size: 1.4rem; }
  .login-card .reassurance { color: #aebbc4; font-size: .85rem; }
  .help { margin: 0; color: #b9c5ce; font-size: .9rem; }
</style>

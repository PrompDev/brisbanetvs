---
import MarketingLayout from "~/layouts/MarketingLayout.astro";
import { getCollection } from "astro:content";

/**
 * /blog/ — blog hub with a featured post, card grid, and a magazine-style
 * sidebar on the right.
 *
 * Layout (desktop):
 *   ┌──────────────── .blog-hub (1720px / 90% from 1201px) ───────────────┐
 *   │ banner, breadcrumb, hero copy                                        │
 *   │ ┌────────────── .blog-split (grid 1fr / 340px) ──────────────────┐   │
 *   │ │ .blog-main                          │  .blog-sidebar (sticky)  │   │
 *   │ │   .blog-featured                    │  newsletter card         │   │
 *   │ │   .blog-section-divider             │  popular posts card      │   │
 *   │ │   .blog-feed                        │  topics card             │   │
 *   │ │                                     │  book an install CTA     │   │
 *   │ └───────────────────────────────────────────────────────────────┘    │
 *   └──────────────────────────────────────────────────────────────────────┘
 *
 * Below 960px the sidebar drops under the feed instead of sitting beside
 * it, so mobile readers still get a banner, featured post, and article
 * feed in the natural reading order.
 */

const posts = (await getCollection("blog", ({ data }) => !data.draft)).sort(
  (a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf()
);

const featured = posts[0];
const rest = posts.slice(1);

// Sidebar "popular" picks — if we had view counts we'd sort by those;
// for now we use the next 3 most recent (behind the featured one) so
// the sidebar always shows something the reader hasn't just seen in
// the big card above.
const popular = rest.slice(0, 3);

// Topic cloud — aggregate tags across every published post, count
// occurrences, and keep the 10 most-used so the sidebar shows a real
// usage-weighted list rather than whatever the most recent post
// happened to be tagged with.
const tagCounts = new Map<string, number>();
for (const p of posts) {
  for (const t of p.data.tags ?? []) {
    tagCounts.set(t, (tagCounts.get(t) ?? 0) + 1);
  }
}
const topTags = [...tagCounts.entries()]
  .sort((a, b) => b[1] - a[1])
  .slice(0, 10)
  .map(([name, count]) => ({ name, count }));

const pageUrl = new URL("/blog/", Astro.site).toString();
const businessUrl = new URL("/", Astro.site).toString();

const breadcrumbLd = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    { "@type": "ListItem", position: 1, name: "Home", item: businessUrl },
    { "@type": "ListItem", position: 2, name: "Blog", item: pageUrl },
  ],
};

const blogLd = {
  "@context": "https://schema.org",
  "@type": "Blog",
  "@id": pageUrl,
  url: pageUrl,
  name: "Brisbane TVs Journal",
  description:
    "Installation guides, suburb-by-suburb notes, and practical TV-mounting advice from our Brisbane installers.",
  blogPost: posts.map((p) => ({
    "@type": "BlogPosting",
    headline: p.data.title,
    url: new URL(`/blog/${p.slug}/`, Astro.site).toString(),
    datePublished: p.data.publishDate.toISOString(),
    image: new URL(p.data.heroImage, Astro.site).toString(),
  })),
};
---
<MarketingLayout
  title="Brisbane TV Installation Blog — Guides, Tips & Suburb Know-How | Brisbane TVs"
  description="Install guides, wall-type tips, and suburb-by-suburb advice from Brisbane's highest-rated TV mounting crew. Written by installers, for homeowners."
  canonical={pageUrl}
  ogImage="https://cdn.brisbanetvs.com/install-hamilton1200x1200.webp"
  keywords="TV mounting blog Brisbane, TV installation guide, Brisbane TV mounting tips, cable concealment guide, wall-mount buying guide"
  jsonLd={[breadcrumbLd, blogLd]}
  bodyClass="page-blog-index"
>
  {/* Full-bleed banner — "Blog" title over a cinematic image so the
      visitor immediately knows which section they've landed in. Same
      100vw escape trick as LocationPage. */}
  <section class="blog-banner">
    <img
      class="blog-banner-img"
      src="https://cdn.brisbanetvs.com/install-hamilton1200x1200.webp"
      alt=""
      aria-hidden="true"
    />
    <div class="blog-banner-inner">
      <p class="blog-banner-title">Blog</p>
    </div>
  </section>

  <article class="blog-hub">
    <nav class="blog-crumbs" aria-label="Breadcrumb">
      <a href="/">Home</a>
      <span aria-hidden="true">›</span>
      <span class="blog-crumbs-current">Blog</span>
    </nav>

    <header class="blog-hero-copy">
      <p class="blog-eyebrow">Journal</p>
      <h1>Guides, stories, and local know-how.</h1>
      <p class="blog-lede">
        Practical advice for Brisbane homes — how to mount a TV safely, which bracket
        fits which wall, and what to expect when we come out to your place.
      </p>
    </header>

    {/* Split grid — main column (featured + feed) plus sticky sidebar.
        Collapses to a single column below 960px. */}
    <div class="blog-split">
      <div class="blog-main">
        {/* Featured post — one compact card taking the most recent post.
            Capped at 900px in the CSS so it doesn't sprawl; the sidebar
            on the right fills the remaining grid width on wide screens. */}
        {featured && (
          <section class="blog-featured" aria-labelledby="blog-featured-h">
            <a class="blog-featured-link" href={`/blog/${featured.slug}/`}>
              <div class="blog-featured-img-wrap">
                <img
                  class="blog-featured-img"
                  src={featured.data.heroImage}
                  alt={featured.data.heroAlt}
                  loading="eager"
                />
                <span class="blog-featured-flag">Featured</span>
              </div>
              <div class="blog-featured-body">
                {featured.data.tags.length > 0 && (
                  <div class="blog-featured-tags">
                    {featured.data.tags.slice(0, 3).map((t) => (
                      <span class="blog-featured-tag">{t}</span>
                    ))}
                  </div>
                )}

                <h2 id="blog-featured-h" class="blog-featured-title">{featured.data.title}</h2>
                <p class="blog-featured-desc">{featured.data.description}</p>

                <div class="blog-featured-meta">
                  <span class="blog-featured-meta-item">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                      <circle cx="12" cy="8" r="4"/>
                      <path d="M4 21c0-4.4 3.6-8 8-8s8 3.6 8 8"/>
                    </svg>
                    <span>By <strong>{featured.data.author}</strong></span>
                  </span>
                  <span class="blog-featured-meta-sep" aria-hidden="true">·</span>
                  <span class="blog-featured-meta-item">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                      <rect x="3" y="4" width="18" height="17" rx="2"/>
                      <path d="M16 2v4M8 2v4M3 10h18"/>
                    </svg>
                    <span>{new Date(featured.data.publishDate).toLocaleDateString("en-AU", { day: "numeric", month: "short", year: "numeric" })}</span>
                  </span>
                  {featured.data.readTime && (
                    <>
                      <span class="blog-featured-meta-sep" aria-hidden="true">·</span>
                      <span class="blog-featured-meta-item">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                          <circle cx="12" cy="12" r="9"/>
                          <path d="M12 7v5l3 2"/>
                        </svg>
                        <span>{featured.data.readTime} min read</span>
                      </span>
                    </>
                  )}
                </div>

                <span class="blog-featured-cta">Read the post →</span>
              </div>
            </a>
          </section>
        )}

        {rest.length > 0 && <hr class="blog-section-divider" />}

        {rest.length > 0 && (
          <section class="blog-feed" aria-labelledby="blog-feed-h">
            <h2 id="blog-feed-h" class="blog-feed-title">More from the journal</h2>
            <div class="blog-grid">
              {rest.map((post) => (
                <article class="blog-card">
                  <a href={`/blog/${post.slug}/`}>
                    <div class="blog-card-img-wrap">
                      <img
                        class="blog-card-img"
                        src={post.data.heroImage}
                        alt={post.data.heroAlt}
                        loading="lazy"
                      />
                    </div>
                    <div class="blog-card-body">
                      <p class="blog-card-meta">
                        {new Date(post.data.publishDate).toLocaleDateString("en-AU", {
                          day: "numeric", month: "short", year: "numeric",
                        })}
                      </p>
                      <h3 class="blog-card-title">{post.data.title}</h3>
                      <p class="blog-card-desc">{post.data.description}</p>
                    </div>
                  </a>
                </article>
              ))}
            </div>
          </section>
        )}

        {posts.length === 0 && (
          <p class="blog-empty">No posts yet — check back soon.</p>
        )}
      </div>

      {/* Sidebar — newsletter, popular picks, topics, and an install CTA.
          Sits sticky below the header on desktop so it stays in view as
          the visitor scrolls the feed. On mobile it stacks below the
          main column (still useful, just non-sticky). */}
      <aside class="blog-sidebar" aria-label="Blog sidebar">
        {/* Newsletter — editorial hook, single-field form. The form is
            a mailto fallback so this still works on a static host; the
            real integration (Buttondown, Mailchimp, etc.) can be wired
            into the same markup later. */}
        <section class="blog-side-card blog-side-newsletter" aria-labelledby="blog-news-h">
          <p class="blog-side-eyebrow">Newsletter</p>
          <h3 id="blog-news-h" class="blog-side-title">Install notes in your inbox.</h3>
          <p class="blog-side-desc">
            One short email a month. New posts, buying tips, and the real-world gotchas
            our Brisbane crew hit on install days — no spam, unsubscribe anytime.
          </p>
          <form
            class="blog-side-form"
            action="mailto:hello@brisbanetvs.com"
            method="post"
            enctype="text/plain"
          >
            <label class="blog-side-form-label" for="blog-newsletter-email">Your email</label>
            <div class="blog-side-form-row">
              <input
                id="blog-newsletter-email"
                class="blog-side-form-input"
                type="email"
                name="email"
                placeholder="you@example.com"
                autocomplete="email"
                required
              />
              <button type="submit" class="blog-side-form-btn">Subscribe</button>
            </div>
            <p class="blog-side-form-fineprint">By subscribing you agree to our privacy policy.</p>
          </form>
        </section>

        {/* Popular posts — three compact rows with thumbnail + title. A
            visitor who isn't interested in the featured post can still
            find something to click on without scrolling the feed. */}
        {popular.length > 0 && (
          <section class="blog-side-card" aria-labelledby="blog-pop-h">
            <div class="blog-side-heading">
              <p class="blog-side-eyebrow">Popular</p>
              <h3 id="blog-pop-h" class="blog-side-title">Most-read right now</h3>
            </div>
            <ol class="blog-side-list">
              {popular.map((p, i) => (
                <li class="blog-side-list-item">
                  <a class="blog-side-list-link" href={`/blog/${p.slug}/`}>
                    <span class="blog-side-list-num">{String(i + 1).padStart(2, "0")}</span>
                    <div class="blog-side-list-body">
                      <p class="blog-side-list-title">{p.data.title}</p>
                      <p class="blog-side-list-meta">
                        {new Date(p.data.publishDate).toLocaleDateString("en-AU", {
                          day: "numeric", month: "short", year: "numeric",
                        })}
                        {p.data.readTime && (
                          <>
                            <span aria-hidden="true"> · </span>
                            <span>{p.data.readTime} min read</span>
                          </>
                        )}
                      </p>
                    </div>
                  </a>
                </li>
              ))}
            </ol>
          </section>
        )}

        {/* Topic pills — aggregated from tags so readers can jump into
            a specific vein of posts. Click goes back to the feed (no
            per-tag page yet); the href is a fragment link that scrolls
            the feed section into view so it still reads as an action. */}
        {topTags.length > 0 && (
          <section class="blog-side-card" aria-labelledby="blog-topics-h">
            <div class="blog-side-heading">
              <p class="blog-side-eyebrow">Topics</p>
              <h3 id="blog-topics-h" class="blog-side-title">Browse by subject</h3>
            </div>
            <ul class="blog-side-topics">
              {topTags.map((t) => (
                <li>
                  <a class="blog-side-topic" href="#blog-feed-h">
                    <span>{t.name}</span>
                    <span class="blog-side-topic-count">{t.count}</span>
                  </a>
                </li>
              ))}
            </ul>
          </section>
        )}

        {/* Install CTA — dark card, mirrors the .idx-book-card pattern
            on the hub pages so the sidebar closes with a strong action
            rather than tapering off into whitespace. */}
        <section class="blog-side-cta" aria-labelledby="blog-cta-h">
          <p class="blog-side-cta-eyebrow">Ready to mount?</p>
          <h3 id="blog-cta-h" class="blog-side-cta-title">Book a Brisbane install crew.</h3>
          <p class="blog-side-cta-desc">
            Same-day quotes, 5-year warranty, fully insured. We'll confirm bracket
            compatibility before we knock.
          </p>
          <a class="blog-side-cta-btn" href="/quote/">Get a quote →</a>
          <a class="blog-side-cta-link" href="tel:0432145101">or call 0432 145 101</a>
        </section>
      </aside>
    </div>
  </article>
</MarketingLayout>

<style is:global>
  /* ========== Banner ========== */
  .blog-banner { position: relative; margin-left: calc(50% - 50vw); margin-right: calc(50% - 50vw); width: 100vw; height: clamp(240px, 32vh, 420px); overflow: hidden; background: #131619; }
  .blog-banner-img { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; object-position: center; }
  .blog-banner::after { content: ""; position: absolute; inset: 0; background: linear-gradient(90deg, rgba(0,0,0,0.55) 0%, rgba(0,0,0,0.35) 35%, rgba(0,0,0,0) 70%); pointer-events: none; }
  .blog-banner-inner { position: relative; z-index: 1; width: 100%; max-width: 1200px; height: 100%; margin: 0 auto; padding: 0 24px; display: flex; align-items: center; }
  @media (min-width: 1201px) { .blog-banner-inner { width: 90%; max-width: 1720px; padding: 0; } }
  .blog-banner-title { margin: 0; color: #fff; font-weight: 400; font-size: clamp(2.5rem, 6vw, 5rem); letter-spacing: 0.02em; text-transform: uppercase; line-height: 1; text-shadow: 0 2px 18px rgba(0,0,0,0.35); }

  /* ========== Hub container — aligns with the header edges ========== */
  /* 1720px / 90% mirrors the site header rule. Below 1201px we default
     to the 1200px container with 24px gutter so the blog hub stays
     flush with the narrower header on smaller screens. */
  .blog-hub { width: 100%; max-width: 1200px; margin: 0 auto; padding: 2rem 24px 4rem; }
  @media (min-width: 1201px) { .blog-hub { width: 90%; max-width: 1720px; padding: 2rem 0 4rem; } }

  .blog-crumbs { font-size: 0.85rem; color: #5a6271; display: flex; gap: 0.4rem; flex-wrap: wrap; margin: 0 0 2.5rem; }
  .blog-crumbs a { color: #5a6271; text-decoration: none; }
  .blog-crumbs a:hover { color: #131619; text-decoration: underline; }
  .blog-crumbs-current { color: #131619; font-weight: 500; }

  /* Hero copy — eyebrow + h1 + lede. Kept above the split grid so the
     heading still takes the full hub width without being squeezed by
     the sidebar column. */
  .blog-hero-copy { margin-bottom: 2.5rem; }
  .blog-eyebrow { text-transform: uppercase; letter-spacing: 0.08em; font-size: 0.75rem; color: #8a94a6; margin: 0 0 0.5rem; font-weight: 600; }
  .blog-hero-copy h1 { font-size: clamp(1.8rem, 3vw, 2.4rem); line-height: 1.15; margin: 0 0 0.75rem; }
  @media (min-width: 961px) { .blog-hero-copy h1 { white-space: nowrap; } }
  .blog-lede { font-size: 1.05rem; color: #3d4656; line-height: 1.55; margin: 0; max-width: 720px; }

  /* ========== Split grid: main column + sidebar ========== */
  /* 340px sidebar on the right at 961px+, collapses to a single column
     below. minmax(0, 1fr) on the main column prevents overflowing
     images/titles from pushing the sidebar off-grid. The column-gap
     sets the white-space between main and sidebar. */
  .blog-split { display: grid; grid-template-columns: 1fr; gap: 2.5rem; align-items: start; }
  @media (min-width: 961px) {
    .blog-split { grid-template-columns: minmax(0, 1fr) 340px; column-gap: 3rem; row-gap: 2.5rem; }
  }
  @media (min-width: 1201px) {
    .blog-split { grid-template-columns: minmax(0, 1fr) 360px; column-gap: 4rem; }
  }

  /* ========== Featured card ========== */
  /* Card now fills its grid column instead of being capped at 900px —
     the sidebar is what holds the visual balance on wide screens. */
  .blog-featured { margin: 0 0 2.5rem; }
  .blog-featured-link { display: flex; flex-direction: column; text-decoration: none; color: inherit; border-radius: 12px; overflow: hidden; background: #fff; border: 1px solid #eef0f3; transition: border-color 0.15s, box-shadow 0.15s; }
  .blog-featured-link:hover { border-color: #131619; box-shadow: 0 6px 28px rgba(15, 22, 36, 0.08); }
  .blog-featured-img-wrap { position: relative; width: 100%; aspect-ratio: 21/9; overflow: hidden; background: #eef0f3; }
  .blog-featured-img { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; display: block; }
  .blog-featured-flag { position: absolute; top: 5px; left: 5px; background: #131619; color: #fff; font-size: 0.7rem; font-weight: 700; letter-spacing: 0.08em; padding: 0.45rem 0.8rem; border-radius: 12px; text-transform: uppercase; }
  .blog-featured-body { display: flex; flex-direction: column; padding: 1.5rem 1.85rem 1.75rem; gap: 0.75rem; }
  .blog-featured-tags { display: flex; flex-wrap: wrap; gap: 0.4rem; }
  .blog-featured-tag { display: inline-block; padding: 0.22rem 0.6rem; font-size: 0.68rem; text-transform: uppercase; letter-spacing: 0.08em; font-weight: 700; color: #131619; background: #eef0f3; border-radius: 999px; }
  .blog-featured-title { margin: 0; font-size: clamp(1.35rem, 2.2vw, 1.85rem); line-height: 1.2; color: #131619; font-family: 'Noto Serif', serif; font-weight: 700; }
  .blog-featured-desc { margin: 0; font-size: 1rem; color: #3d4656; line-height: 1.5; }
  .blog-featured-meta { display: flex; flex-wrap: wrap; align-items: center; gap: 0.55rem; margin-top: 0.2rem; padding-top: 0.8rem; border-top: 1px solid #eef0f3; font-size: 0.82rem; color: #5a6271; }
  .blog-featured-meta-item { display: inline-flex; align-items: center; gap: 0.4rem; }
  .blog-featured-meta-item svg { width: 14px; height: 14px; color: #8a94a6; flex-shrink: 0; }
  .blog-featured-meta-item strong { color: #131619; font-weight: 600; }
  .blog-featured-meta-sep { color: #d7dbe2; font-weight: 700; }
  .blog-featured-cta { margin-top: 0.2rem; font-size: 0.9rem; font-weight: 600; color: #131619; }

  @media (max-width: 860px) {
    .blog-featured-img-wrap { aspect-ratio: 16/10; }
    .blog-featured-body { padding: 1.15rem 1.25rem 1.3rem; }
    .blog-featured-meta { font-size: 0.78rem; }
  }

  /* ========== Divider ========== */
  .blog-section-divider { width: 100%; border: 0; border-top: 1px solid #e5e7eb; margin: 0 0 2.5rem; }

  /* ========== Feed — the rest of the posts ========== */
  .blog-feed-title { margin: 0 0 1.25rem; font-size: 1.3rem; color: #131619; }
  /* Grid sizing accounts for the narrower column when the sidebar is
     visible — minmax(260px, 1fr) gives us a dense 2-up / 3-up feed in
     the main column rather than the wide 3-up that looked sparse. */
  .blog-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(260px, 1fr)); gap: 1.5rem; align-items: stretch; }
  .blog-card { display: flex; height: 100%; }
  .blog-card a { display: flex; flex-direction: column; width: 100%; height: 100%; background: #eef0f3; border-radius: 10px; text-decoration: none; color: inherit; box-shadow: 0 0 0 1px #eef0f3; transition: box-shadow 0.15s, transform 0.15s; }
  .blog-card a:hover { box-shadow: 0 0 0 1px #131619, 0 4px 14px rgba(15, 22, 36, 0.06); transform: translateY(-2px); }
  .blog-card-img-wrap { position: relative; width: 100%; aspect-ratio: 16/10; overflow: hidden; background: #eef0f3; }
  .blog-card-img { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; display: block; }
  .blog-card-body { display: flex; flex-direction: column; gap: 0.5rem; padding: 1rem 1.1rem 1.2rem; flex: 1 1 auto; background: #fff; }
  .blog-card-meta { margin: 0; font-size: 0.78rem; text-transform: uppercase; letter-spacing: 0.06em; color: #8a94a6; font-weight: 600; }
  .blog-card-title { margin: 0; font-size: 1.05rem; line-height: 1.3; color: #131619; font-weight: 600; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; min-height: calc(1.05rem * 1.3 * 2); }
  .blog-card-desc { margin: 0; color: #3d4656; font-size: 0.92rem; line-height: 1.5; display: -webkit-box; -webkit-line-clamp: 3; -webkit-box-orient: vertical; overflow: hidden; }

  .blog-empty { padding: 3rem; background: #fafbfc; border: 1px dashed #d7dbe2; border-radius: 8px; text-align: center; color: #5a6271; }

  /* ========== Sidebar ========== */
  /* Sticky on desktop so it stays visible as the reader scrolls the
     feed. top: 6rem clears the opaque page-subpage header. Below 960px
     it becomes static (stacked below the main column). */
  .blog-sidebar { display: flex; flex-direction: column; gap: 1.25rem; }
  @media (min-width: 961px) {
    .blog-sidebar { position: sticky; top: 6rem; align-self: start; max-height: calc(100vh - 7rem); overflow-y: auto; padding-right: 4px; }
    /* Hide the scrollbar on the sidebar (still scrollable) so the card
       edges stay clean on tall sidebar content. */
    .blog-sidebar::-webkit-scrollbar { width: 6px; }
    .blog-sidebar::-webkit-scrollbar-thumb { background: #d7dbe2; border-radius: 3px; }
  }

  /* Base card — the common wrapper for newsletter / popular / topics. */
  .blog-side-card { background: #fff; border: 1px solid #eef0f3; border-radius: 12px; padding: 1.4rem 1.4rem 1.5rem; display: flex; flex-direction: column; gap: 0.85rem; }
  .blog-side-heading { display: flex; flex-direction: column; gap: 0.25rem; }
  .blog-side-eyebrow { text-transform: uppercase; letter-spacing: 0.1em; font-size: 0.7rem; font-weight: 700; color: #8a94a6; margin: 0; }
  .blog-side-title { margin: 0; font-size: 1.1rem; line-height: 1.25; color: #131619; font-family: 'Noto Serif', serif; font-weight: 700; }
  .blog-side-desc { margin: 0; font-size: 0.9rem; line-height: 1.55; color: #3d4656; }

  /* Newsletter specifics — soft tint so it reads as a distinct pane
     from the plainer popular/topics cards below it. */
  .blog-side-newsletter { background: linear-gradient(145deg, #f4f7fb 0%, #eef0f3 100%); border-color: #e1e6ee; }
  .blog-side-form { display: flex; flex-direction: column; gap: 0.5rem; margin-top: 0.25rem; }

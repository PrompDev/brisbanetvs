---
import MarketingLayout from "~/layouts/MarketingLayout.astro";
import { getCollection } from "astro:content";

/**
 * /services/ — collection landing page for the services silo.
 *
 * Mirrors the approved LocationPage banner + 1720px split + sticky-sidebar
 * pattern so the hub feels consistent with the deeper silo pages. Emits
 * schema.org/CollectionPage + BreadcrumbList JSON-LD so Google understands
 * this is the canonical index for the service-landing silo.
 */

const services = (
  await getCollection("services", ({ data }) => !data.draft)
).sort((a, b) => a.data.priceFrom - b.data.priceFrom);

const pageUrl = new URL("/services/", Astro.site).toString();
const businessUrl = new URL("/", Astro.site).toString();

const ACRONYMS = new Set(["tv", "av", "hdmi", "uhd", "4k", "8k"]);
function formatSlugLabel(slug: string): string {
  return slug
    .split("-")
    .map((w) =>
      ACRONYMS.has(w.toLowerCase())
        ? w.toUpperCase()
        : w.charAt(0).toUpperCase() + w.slice(1)
    )
    .join(" ");
}

const fromPrices = services.map((s) => s.data.priceFrom);
const lowestFrom = fromPrices.length ? Math.min(...fromPrices) : null;

const breadcrumbLd = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    { "@type": "ListItem", position: 1, name: "Home", item: businessUrl },
    { "@type": "ListItem", position: 2, name: "Services", item: pageUrl },
  ],
};

const collectionLd = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  "@id": pageUrl,
  url: pageUrl,
  name: "Brisbane TV Installation Services",
  description:
    "Full list of TV installation services offered across Brisbane — wall mounting, cable concealment, soundbar installs, antenna work, and more.",
  hasPart: services.map((s) => ({
    "@type": "Service",
    name: s.data.title,
    url: new URL(`/services/${s.slug}/`, Astro.site).toString(),
  })),
};
---
<MarketingLayout
  title="TV Installation Services Brisbane — Wall Mounting, Cable Concealment, Soundbar & Starlink | Brisbane TVs"
  description="Every TV install service we offer across Brisbane: wall mounting from $179, in-wall cable concealment, soundbar pairing, Starlink, outdoor, fireplace, commercial fit-out. Flat-rate, insured, same-day."
  canonical={pageUrl}
  ogImage="https://cdn.brisbanetvs.com/install-newstead1200x1200.webp"
  keywords="TV installation Brisbane, TV wall mounting Brisbane services, cable concealment Brisbane, soundbar installation, Starlink installer Brisbane, outdoor TV mount"
  jsonLd={[breadcrumbLd, collectionLd]}
  bodyClass="page-services-index"
>
  <section class="idx-banner">
    <img
      class="idx-banner-img"
      src="https://cdn.brisbanetvs.com/install-newstead1200x1200.webp"
      alt=""
      aria-hidden="true"
    />
    <div class="idx-banner-inner">
      <p class="idx-banner-title">Services</p>
    </div>
  </section>

  <article class="idx">
    <div class="idx-split">
      <div class="idx-split-left">
        <nav class="idx-crumbs" aria-label="Breadcrumb">
          <a href="/">Home</a>
          <span aria-hidden="true">›</span>
          <span class="idx-crumbs-current">Services</span>
        </nav>
        <header class="idx-hero-copy">
          <p class="idx-eyebrow">Brisbane · Full service menu</p>
          <h1>Every TV installation service we offer in Brisbane.</h1>
          <p class="idx-lede">
            Flat-rate pricing, fully insured installers, same-week bookings. Pick the
            service you need — we handle everything from single TV wall-mounts to
            whole-home AV fit-outs across Brisbane and the bayside.
          </p>
          <div class="idx-stats">
            <div class="idx-stat">
              <span class="idx-stat-k">Services</span>
              <span class="idx-stat-v">{services.length}</span>
            </div>
            {lowestFrom !== null && (
              <div class="idx-stat">
                <span class="idx-stat-k">From</span>
                <span class="idx-stat-v">${lowestFrom}</span>
              </div>
            )}
            <div class="idx-stat">
              <span class="idx-stat-k">Insurance</span>
              <span class="idx-stat-v">$20M PL</span>
            </div>
            <div class="idx-stat">
              <span class="idx-stat-k">Warranty</span>
              <span class="idx-stat-v">12 months</span>
            </div>
          </div>
          <div class="idx-cta-row">
            <a class="idx-btn idx-btn-primary" href="tel:0432145101">Get a free quote</a>
            <a class="idx-btn idx-btn-ghost" href="/locations/">Browse by suburb</a>
          </div>
        </header>
      </div>
      <div class="idx-split-img-wrap">
        <img
          class="idx-split-img"
          src="https://cdn.brisbanetvs.com/foreplacemount1200x1200.webp"
          alt="A Brisbane TVs installer mounting a TV above a gas fireplace in a feature-wall install"
          loading="eager"
        />
      </div>
    </div>

    <hr class="idx-section-divider" />

    <div class="idx-article-grid">
      <div class="idx-article-main">
        <section class="idx-list-section" aria-labelledby="idx-services-h">
          <h2 id="idx-services-h">Pick a service</h2>
          <p class="u-muted">
            Every service below is a flat-rate job — we quote before we arrive, and the
            number is locked. No hourly billing, no nasty surprises after the drill comes out.
          </p>

          {services.length === 0 && (
            <p class="idx-empty">Service pages coming soon. In the meantime, <a href="tel:0432145101">ask us for a quote</a>.</p>
          )}

          <ul class="idx-card-grid">
            {services.map((s) => (
              <li class="idx-card">
                <a class="idx-card-link" href={`/services/${s.slug}/`}>
                  <div class="idx-card-img-wrap">
                    <img
                      class="idx-card-img"
                      src={s.data.heroImage}
                      alt={s.data.heroAlt}
                      loading="lazy"
                    />
                  </div>
                  <div class="idx-card-body">
                    <p class="idx-card-eyebrow">
                      {formatSlugLabel(s.slug)}
                      {s.data.duration && <span class="idx-card-dot"> · </span>}
                      {s.data.duration && <span>{s.data.duration}</span>}
                    </p>
                    <h3 class="idx-card-title">{s.data.title}</h3>
                    <p class="idx-card-desc">{s.data.description}</p>
                    <div class="idx-card-foot">
                      <span class="idx-card-price">
                        <span class="idx-card-price-k">From</span>
                        <span class="idx-card-price-v">${s.data.priceFrom}</span>
                      </span>
                      <span class="idx-card-arrow" aria-hidden="true">→</span>
                    </div>
                  </div>
                </a>
              </li>
            ))}
          </ul>
        </section>

        <section class="idx-why" aria-labelledby="idx-why-h">
          <h2 id="idx-why-h">Why Brisbane homes book us</h2>
          <ul class="idx-why-list">
            <li>
              <span class="idx-why-k">Flat-rate quotes</span>
              <span class="idx-why-v">Locked-in pricing before we arrive. No hourly clocks, no post-install invoice shock.</span>
            </li>
            <li>
              <span class="idx-why-k">Every wall type</span>
              <span class="idx-why-v">Plasterboard, timber, fibro, rendered concrete, Queenslander VJ, exposed brick — we carry anchors for all of it.</span>
            </li>
            <li>
              <span class="idx-why-k">Same-week bookings</span>
              <span class="idx-why-v">Most Brisbane suburbs get a slot inside 5 business days. Inner-city same-day is often possible.</span>
            </li>
            <li>
              <span class="idx-why-k">Written warranty</span>
              <span class="idx-why-v">12-month workmanship warranty on every bracket and cable run. We come back if it moves.</span>
            </li>
          </ul>
        </section>
      </div>

      <aside class="idx-sidebar" aria-label="Booking sidebar">
        <div class="idx-book-card">
          <p class="idx-book-eyebrow">Brisbane TVs · Services</p>
          <h3 class="idx-book-title">Not sure which service you need?</h3>
          <p class="idx-book-desc">
            Send us a photo of the wall and the TV model. We'll tell you which service
            fits and give you a flat-rate quote the same day.
          </p>
          <ul class="idx-book-list">
            <li><span class="idx-book-k">Services</span><span>{services.length}</span></li>
            <li><span class="idx-book-k">From</span><span>{lowestFrom !== null ? `$${lowestFrom}` : "—"}</span></li>
            <li><span class="idx-book-k">Warranty</span><span>12 months</span></li>
          </ul>
          <a class="idx-book-btn" href="tel:0432145101">Get a quote →</a>
          <a class="idx-book-link" href="tel:+61000000000">or call dispatch</a>
        </div>
      </aside>
    </div>

    <aside class="idx-foot-cta">
      <div>
        <h2>Can't find the service you need?</h2>
        <p>We do custom AV work too — multi-room, outdoor, commercial. Tell us what you're building.</p>
      </div>
      <a class="idx-btn idx-btn-primary" href="tel:0432145101">Get a free quote</a>
    </aside>
  </article>
</MarketingLayout>
